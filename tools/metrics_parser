# ================================================================================
# Pattern Configuration - Metric Extraction Rules
# ================================================================================

declare -A EXTRACT_PATTERNS

init_patterns() {
    # CPU test patterns
    EXTRACT_PATTERNS["CPU_EPS"]='events per second:\s*([\d.]+)'
    EXTRACT_PATTERNS["CPU_AVG_LAT"]='Latency.*avg:\s*([\d.]+)'
    EXTRACT_PATTERNS["CPU_P95_LAT"]='95th percentile:\s*([\d.]+)'
    EXTRACT_PATTERNS["CPU_MIN_LAT"]='min:\s*([\d.]+)'
    EXTRACT_PATTERNS["CPU_MAX_LAT"]='max:\s*([\d.]+)'
    EXTRACT_PATTERNS["CPU_SUM_LAT"]='sum:\s*([\d.]+)'
    EXTRACT_PATTERNS["CPU_FAIRNESS"]='events \(avg/stddev\):\s*([\d.]+)'

    # Memory test patterns
    EXTRACT_PATTERNS["MEM_OPS_SEC"]='Total operations:\s*[\d.]+\s*\(([\d.]+)'
    EXTRACT_PATTERNS["MEM_MIB_SEC"]='MiB transferred\s*[\d.]+\s*\(([\d.]+)'
    EXTRACT_PATTERNS["MEM_AVG_LAT"]='avg:\s*([\d.]+)'
    EXTRACT_PATTERNS["MEM_MIN_LAT"]='min:\s*([\d.]+)'
    EXTRACT_PATTERNS["MEM_MAX_LAT"]='max:\s*([\d.]+)'
    EXTRACT_PATTERNS["MEM_P95_LAT"]='95th percentile:\s*([\d.]+)'
    EXTRACT_PATTERNS["MEM_SUM_LAT"]='sum:\s*([\d.]+)'
    EXTRACT_PATTERNS["MEM_FAIRNESS"]='events \(avg/stddev\):\s*([\d.]+)'

    # Threads test patterns
    EXTRACT_PATTERNS["THREADS_EVENTS"]='total number of events:\s*([\d.]+)'
    EXTRACT_PATTERNS["THREADS_TIME"]='total time:\s*([\d.]+)'
    EXTRACT_PATTERNS["THREADS_AVG_LAT"]='avg:\s*([\d.]+)'
    EXTRACT_PATTERNS["THREADS_MIN_LAT"]='min:\s*([\d.]+)'
    EXTRACT_PATTERNS["THREADS_MAX_LAT"]='max:\s*([\d.]+)'
    EXTRACT_PATTERNS["THREADS_P95_LAT"]='95th percentile:\s*([\d.]+)'
    EXTRACT_PATTERNS["THREADS_SUM_LAT"]='sum:\s*([\d.]+)'
    EXTRACT_PATTERNS["THREADS_FAIRNESS"]='events \(avg/stddev\):\s*([\d.]+)'

    # Mutex test patterns
    EXTRACT_PATTERNS["MUTEX_EVENTS"]='total number of events:\s*([\d.]+)'
    EXTRACT_PATTERNS["MUTEX_TIME"]='total time:\s*([\d.]+)'
    EXTRACT_PATTERNS["MUTEX_AVG_LAT"]='avg:\s*([\d.]+)'
    EXTRACT_PATTERNS["MUTEX_MIN_LAT"]='min:\s*([\d.]+)'
    EXTRACT_PATTERNS["MUTEX_MAX_LAT"]='max:\s*([\d.]+)'
    EXTRACT_PATTERNS["MUTEX_P95_LAT"]='95th percentile:\s*([\d.]+)'
    EXTRACT_PATTERNS["MUTEX_SUM_LAT"]='sum:\s*([\d.]+)'
    EXTRACT_PATTERNS["MUTEX_FAIRNESS"]='events \(avg/stddev\):\s*([\d.]+)'
}

# ================================================================================
# Generic Pattern Extractor
# ================================================================================

parse_extract() {
    local line="$1"
    local test_type="$2"
    local pattern_key
    local pattern
    local metric_name

    for pattern_key in "${!EXTRACT_PATTERNS[@]}"; do
        if [[ "$pattern_key" == "${test_type}_"* ]]; then
            pattern="${EXTRACT_PATTERNS[$pattern_key]}"
            metric_name="${pattern_key#${test_type}_}"

            if [[ "$line" =~ $pattern ]]; then
                metrics_set "$metric_name" "${BASH_REMATCH[1]}"
            fi
        fi
    done
}

