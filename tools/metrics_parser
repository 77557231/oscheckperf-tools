parse_threads_report_new() {
    local input_file="$1"
    local output_file="$2"

    if [ ! -f "$input_file" ]; then
        echo "  Test not executed" >> "$output_file"
        return
    fi

    if ! grep -q -E "Threads test summary:|THREADS TEST RESULTS" "$input_file" 2>/dev/null; then
