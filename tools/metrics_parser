    local combined_file="$1"
    local report_file="$2"
    local tmp_dir="$3"

    if [ ! -f "$combined_file" ]; then
        return
    fi

    if ! grep -q "SYSBENCH FILEIO TEST RESULTS\|FIO TEST RESULTS\|IO TEST RESULTS" "$combined_file" 2>/dev/null; then
        return
    fi

    local io_section_count=$(($(grep -c "^SYSBENCH FILEIO TEST RESULTS\|^FIO TEST RESULTS\|^IO TEST RESULTS" "$combined_file" 2>/dev/null)))

    echo "  IO Test Results" >> "$report_file"
    echo "  IO Tool: ${IO_TOOL:-fio}" >> "$report_file"

    local in_io_section=false
    local current_server_ip=""
    local current_read_iops=""
    local current_write_iops=""
    local current_total_iops=""
    local current_read_bw=""
    local current_write_bw=""
    local current_total_bw=""
    local current_avg_lat=""
    local current_fsync_iops=""
    local current_tool="${IO_TOOL:-fio}"
    local current_io_mode=""
    local expect_avg_lat=false
    local results_temp_file=$(mktemp)
    local fio_extended_file=$(mktemp)

    declare -A fio_p99_lat
    declare -A fio_disk_util
    declare -A fio_cpu_usr
    declare -A fio_cpu_sys
    declare -A fio_bw_min
    declare -A fio_bw_max
    declare -A fio_slat_avg
    declare -A fio_clat_avg
    declare -A fio_iodepth_level
    declare -A fio_ctx
    declare -A fio_aggrios
    declare -A fio_aggrticks
    declare -A fio_aggrin_queue
    declare -A fio_aggrutil

    # Pre-extract fio extended metrics from combined file
    awk 'BEGIN{OFS="|"}
        /RESULTS FROM SERVER:/ {match($0, /RESULTS FROM SERVER: ([0-9.]+)/, arr); current_server=arr[1]}
        /FIO TEST RESULTS/ {match($0, /Server: ([0-9.]+)/, arr); ip=arr[1]; if(ip=="") ip=current_server; match($0, /FIO TEST RESULTS \(([^)]+)\)/, mode_arr); io_mode=mode_arr[1]; p99="N/A"; disk="N/A"; cpu_usr="N/A"; cpu_sys="N/A"; r_slat="0"; w_slat="0"; r_clat="N/A"; w_clat="N/A"; r_bw_min="N/A"; r_bw_max="N/A"; w_bw_min="N/A"; w_bw_max="N/A"; iodepth="N/A"; ctx="N/A"; aggrios="N/A"; aggrticks="N/A"; aggrinque="N/A"; aggrutil="N/A"; in_fio=1; ext_started=0; has_read=0; has_write=0; is_read=0}
        in_fio && !ext_started && /^  read:/ {is_read=1; has_read=1}
        in_fio && !ext_started && /^  write:/ {is_read=0; has_write=1}
        in_fio && !ext_started && /slat \(nsec\)/ {split($0, a, "avg="); split(a[2], b, ","); gsub(/ /, "", b[1]); if(is_read) r_slat=b[1]/1000; else w_slat=b[1]/1000}
        in_fio && !ext_started && /slat \(usec\)/ {split($0, a, "avg="); split(a[2], b, ","); gsub(/ /, "", b[1]); if(is_read) r_slat=b[1]; else w_slat=b[1]}
        in_fio && !ext_started && /clat \(nsec\)/ {split($0, a, "avg="); split(a[2], b, ","); gsub(/ /, "", b[1]); if(is_read) r_clat=b[1]/1000; else w_clat=b[1]/1000}
        in_fio && !ext_started && /clat \(usec\)/ {split($0, a, "avg="); split(a[2], b, ","); gsub(/ /, "", b[1]); if(is_read) r_clat=b[1]; else w_clat=b[1]}
        in_fio && !ext_started && /bw \(.*MiB\/s\)/ {
            if(match($0, /min=[[:space:]]*([0-9.]+)/, m)) {if(is_read) r_bw_min=m[1]; else w_bw_min=m[1]}
            if(match($0, /max=[[:space:]]*([0-9.]+)/, m)) {if(is_read) r_bw_max=m[1]; else w_bw_max=m[1]}
        }
        in_fio && !ext_started && /bw \(.*KiB\/s\)/ {
            if(match($0, /min=([0-9]+)/, m)) {if(is_read) r_bw_min=sprintf("%.2f", m[1]/1024); else w_bw_min=sprintf("%.2f", m[1]/1024)}
            if(match($0, /max=([0-9]+)/, m)) {if(is_read) r_bw_max=sprintf("%.2f", m[1]/1024); else w_bw_max=sprintf("%.2f", m[1]/1024)}
        }
        in_fio && !ext_started && /IO depths/ {
            split($0, depths, ",");
            max_depth="<=8"; max_pct=0;
            for(i in depths) {
                if(depths[i] ~ /[[:space:]]1=[0-9.]+%/) { split(depths[i], a, "="); pct=a[2]; sub(/%/, "", pct); if(pct+0 > max_pct) { max_pct=pct+0; max_depth="1"; } }
                if(depths[i] ~ /[[:space:]]2=[0-9.]+%/) { split(depths[i], a, "="); pct=a[2]; sub(/%/, "", pct); if(pct+0 > max_pct) { max_pct=pct+0; max_depth="2"; } }
                if(depths[i] ~ /[[:space:]]4=[0-9.]+%/) { split(depths[i], a, "="); pct=a[2]; sub(/%/, "", pct); if(pct+0 > max_pct) { max_pct=pct+0; max_depth="4"; } }
                if(depths[i] ~ /[[:space:]]8=[0-9.]+%/) { split(depths[i], a, "="); pct=a[2]; sub(/%/, "", pct); if(pct+0 > max_pct) { max_pct=pct+0; max_depth="8"; } }
                if(depths[i] ~ /[[:space:]]16=[0-9.]+%/) { split(depths[i], a, "="); pct=a[2]; sub(/%/, "", pct); if(pct+0 > max_pct) { max_pct=pct+0; max_depth="16"; } }
                if(depths[i] ~ /[[:space:]]32=[0-9.]+%/) { split(depths[i], a, "="); pct=a[2]; sub(/%/, "", pct); if(pct+0 > max_pct) { max_pct=pct+0; max_depth="32"; } }
                if(depths[i] ~ />=64=[0-9.]+%/) { split(depths[i], a, "="); pct=a[2]; sub(/%/, "", pct); if(pct+0 > max_pct) { max_pct=pct+0; max_depth=">=64"; } }
            }
            iodepth=max_depth;
        }
        in_fio && !ext_started && /cpu/ && /ctx=/ {
            if(match($0, /usr=([0-9.]+)%/, m)) cpu_usr=m[1];
            if(match($0, /sys=([0-9.]+)%/, m)) cpu_sys=m[1];
            if(match($0, /ctx=([0-9]+)/, m)) ctx=m[1];
        }
        in_fio && !ext_started && /aggrios=/ {
            if(match($0, /aggrios=([0-9\/]+)/, m)) aggrios=m[1];
            if(match($0, /aggrticks=([0-9\/]+)/, m)) aggrticks=m[1];
            if(match($0, /aggrin_queue=([0-9]+)/, m)) aggrinque=m[1];
            if(match($0, /aggrutil=([0-9.]+)%/, m)) aggrutil=m[1];
        }
        in_fio && /FIO Extended Metrics:/ {ext_started=1}
        in_fio && ext_started && /P99 Latency:/ {p99=$3}
        in_fio && ext_started && /Disk Utilization:/ {disk=$3; sub(/%/, "", disk)}
        in_fio && ext_started && /CPU \(usr\):/ {cpu_usr=$3; sub(/%/, "", cpu_usr)}
        in_fio && ext_started && /CPU \(sys\):/ {cpu_sys=$3; sub(/%/, "", cpu_sys)}
        in_fio && ext_started && /^$/ && ip!="" {
            if(has_read && has_write) {
                printf "%s|%s|%s|%s|%s|%s|%.2f|%.2f|%s|%s|%s|%s|%s|%s|%s|%s\n", ip, io_mode"_r", p99, disk, cpu_usr, cpu_sys, r_slat, r_clat, iodepth, ctx, aggrios, aggrticks, aggrinque, aggrutil, r_bw_min, r_bw_max;
                printf "%s|%s|%s|%s|%s|%s|%.2f|%.2f|%s|%s|%s|%s|%s|%s|%s|%s\n", ip, io_mode"_w", p99, disk, cpu_usr, cpu_sys, w_slat, w_clat, iodepth, ctx, aggrios, aggrticks, aggrinque, aggrutil, w_bw_min, w_bw_max;
            } else if(has_read) {
                printf "%s|%s|%s|%s|%s|%s|%.2f|%.2f|%s|%s|%s|%s|%s|%s|%s|%s\n", ip, io_mode, p99, disk, cpu_usr, cpu_sys, r_slat, r_clat, iodepth, ctx, aggrios, aggrticks, aggrinque, aggrutil, r_bw_min, r_bw_max;
            } else if(has_write) {
                printf "%s|%s|%s|%s|%s|%s|%.2f|%.2f|%s|%s|%s|%s|%s|%s|%s|%s\n", ip, io_mode, p99, disk, cpu_usr, cpu_sys, w_slat, w_clat, iodepth, ctx, aggrios, aggrticks, aggrinque, aggrutil, w_bw_min, w_bw_max;
            }
            ip=""; in_fio=0}' "$combined_file" > "$fio_extended_file"

    # Populate associative arrays from fio_extended_file
    while IFS='|' read -r ip io_mode p99 disk cpu_usr cpu_sys slat clat iodepth ctx aggrios aggrticks aggrinque aggrutil bw_min bw_max; do
        if [[ "$ip" =~ ^[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}$ ]]; then
            local key="${ip}_${io_mode}"
            fio_p99_lat["$key"]="$p99"
            fio_disk_util["$key"]="$disk"
            fio_cpu_usr["$key"]="$cpu_usr"
            fio_cpu_sys["$key"]="$cpu_sys"
            fio_slat_avg["$key"]="$slat"
            fio_clat_avg["$key"]="$clat"
            fio_iodepth_level["$key"]="$iodepth"
            fio_ctx["$key"]="$ctx"
            fio_aggrios["$key"]="$aggrios"
            fio_aggrticks["$key"]="$aggrticks"
            fio_aggrin_queue["$key"]="$aggrinque"
            fio_aggrutil["$key"]="$aggrutil"
            if [ -n "$bw_min" ] && [ "$bw_min" != "N/A" ]; then
                fio_bw_min["$key"]="$bw_min"
            fi
            if [ -n "$bw_max" ] && [ "$bw_max" != "N/A" ]; then
                fio_bw_max["$key"]="$bw_max"
            fi
        fi
    done < "$fio_extended_file"

    while IFS= read -r line; do
        if [[ "$line" =~ "SYSBENCH FILEIO TEST RESULTS" ]]; then
            if [ "$in_io_section" = true ] && [ -n "$current_server_ip" ]; then
                if [ -n "$current_read_iops" ] && [ -n "$current_write_iops" ]; then
                    current_total_iops=$(awk "BEGIN {printf \"%.2f\", $current_read_iops + $current_write_iops}" 2>/dev/null || echo "N/A")
                fi
                if [ -n "$current_read_bw" ] && [ -n "$current_write_bw" ]; then
                    current_total_bw=$(awk "BEGIN {printf \"%.2f\", $current_read_bw + $current_write_bw}" 2>/dev/null || echo "N/A")
                fi
                printf "%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|sysbench\n" "$current_server_ip" "${current_read_iops:-N/A}" "${current_write_iops:-N/A}" "${current_total_iops:-N/A}" "${current_read_bw:-N/A}" "${current_write_bw:-N/A}" "${current_total_bw:-N/A}" "${current_avg_lat:-N/A}" "${current_p95_lat:-N/A}" "${current_min_lat:-N/A}" "${current_max_lat:-N/A}" "${current_io_mode:-rndrw}" "${current_fsync_iops:-N/A}" >> "$results_temp_file"
            fi
            in_io_section=true
            current_server_ip=$(echo "$line" | grep -oP 'Server: \K[0-9.]+' || echo "N/A")
            current_read_iops=""
            current_write_iops=""
            current_total_iops=""
            current_read_bw=""
            current_write_bw=""
            current_total_bw=""
            current_avg_lat=""
            current_p95_lat=""
            current_min_lat=""
            current_max_lat=""
            current_fsync_iops=""
            current_io_mode=$(echo "$line" | grep -oP 'SYSBENCH FILEIO TEST RESULTS \(([^)]+)\)' | awk -F'[()]' '{print $2}')
            current_tool="sysbench"
            expect_avg_lat=false
        elif [[ "$line" =~ "FIO TEST RESULTS" ]]; then
            local new_io_mode=$(echo "$line" | grep -oP 'FIO TEST RESULTS \(([^)]+)\)' | awk -F'[()]' '{print $2}')

            if [ "$in_io_section" = true ] && [ -n "$current_server_ip" ]; then
                if [ -n "$current_read_iops" ] && [ -n "$current_write_iops" ]; then
                    current_total_iops=$(awk "BEGIN {printf \"%.2f\", $current_read_iops + $current_write_iops}" 2>/dev/null || echo "N/A")
                elif [ -n "$current_read_iops" ]; then
                    current_total_iops=$(awk "BEGIN {printf \"%.2f\", $current_read_iops}" 2>/dev/null || echo "$current_read_iops")
                elif [ -n "$current_write_iops" ]; then
                    current_total_iops=$(awk "BEGIN {printf \"%.2f\", $current_write_iops}" 2>/dev/null || echo "$current_write_iops")
                else
                    current_total_iops="N/A"
                fi
                if [ -n "$current_read_bw" ] && [ -n "$current_write_bw" ]; then
                    current_total_bw=$(awk "BEGIN {printf \"%.2f\", $current_read_bw + $current_write_bw}" 2>/dev/null || echo "N/A")
                elif [ -n "$current_read_bw" ]; then
                    current_total_bw=$(awk "BEGIN {printf \"%.2f\", $current_read_bw}" 2>/dev/null || echo "$current_read_bw")
                elif [ -n "$current_write_bw" ]; then
                    current_total_bw=$(awk "BEGIN {printf \"%.2f\", $current_write_bw}" 2>/dev/null || echo "$current_write_bw")
                else
                    current_total_bw="N/A"
                fi
                printf "%s|%s|%s|%s|%s|%s|%s|%s|N/A|N/A|N/A|%s|N/A|fio\n" "$current_server_ip" "${current_read_iops:-N/A}" "${current_write_iops:-N/A}" "${current_total_iops:-N/A}" "${current_read_bw:-N/A}" "${current_write_bw:-N/A}" "${current_total_bw:-N/A}" "${current_avg_lat:-N/A}" "${current_io_mode:-read}" >> "$results_temp_file"
            fi
            in_io_section=true
            current_server_ip=$(echo "$line" | grep -oP 'Server: \K[0-9.]+' || echo "N/A")
            current_read_iops=""
            current_write_iops=""
            current_total_iops=""
            current_read_bw=""
            current_write_bw=""
            current_total_bw=""
            current_avg_lat=""
            current_io_mode=$(echo "$line" | grep -oP 'FIO TEST RESULTS \(([^)]+)\)' | awk -F'[()]' '{print $2}')
            current_tool="fio"
            expect_avg_lat=false
        elif [[ "$line" =~ "IO TEST RESULTS" ]]; then
            if [ "$in_io_section" = true ] && [ -n "$current_server_ip" ]; then
                if [ -n "$current_read_iops" ] && [ -n "$current_write_iops" ]; then
                    current_total_iops=$(awk "BEGIN {printf \"%.2f\", $current_read_iops + $current_write_iops}" 2>/dev/null || echo "N/A")
                fi
                if [ -n "$current_read_bw" ] && [ -n "$current_write_bw" ]; then
                    current_total_bw=$(awk "BEGIN {printf \"%.2f\", $current_read_bw + $current_write_bw}" 2>/dev/null || echo "N/A")
                fi
                printf "%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|sysbench\n" "$current_server_ip" "${current_read_iops:-N/A}" "${current_write_iops:-N/A}" "${current_total_iops:-N/A}" "${current_read_bw:-N/A}" "${current_write_bw:-N/A}" "${current_total_bw:-N/A}" "${current_avg_lat:-N/A}" "${current_p95_lat:-N/A}" "${current_min_lat:-N/A}" "${current_max_lat:-N/A}" "${current_io_mode:-rndrw}" "${current_fsync_iops:-N/A}" >> "$results_temp_file"
            fi
            in_io_section=true
            current_server_ip=$(echo "$line" | grep -oP 'Server: \K[0-9.]+' || echo "N/A")
            current_read_iops=""
            current_write_iops=""
            current_total_iops=""
            current_read_bw=""
            current_write_bw=""
            current_total_bw=""
            current_avg_lat=""
            current_p95_lat=""
            current_min_lat=""
            current_max_lat=""
            current_fsync_iops=""
            current_io_mode="${SYSBENCH_PROFILES:-seqrd seqwr rndrd rndwr}"
            current_tool="sysbench"
            expect_avg_lat=false
        elif [ "$in_io_section" = true ]; then
            if [ "$current_tool" = "sysbench" ]; then
                if [[ "$line" =~ "reads/s:" ]]; then
                    current_read_iops=$(echo "$line" | awk '{print $NF}')
                    expect_avg_lat=true
                elif [[ "$line" =~ "writes/s:" ]]; then
                    current_write_iops=$(echo "$line" | awk '{print $NF}')
                elif [[ "$line" =~ "fsyncs/s:" ]]; then
                    current_fsync_iops=$(echo "$line" | awk '{print $NF}')
                elif [[ "$line" =~ "total/s:" ]]; then
                    current_total_iops=$(echo "$line" | awk '{print $NF}')
                elif [[ "$line" =~ "read, MiB/s:" ]]; then
                    current_read_bw=$(echo "$line" | awk '{print $NF}')
                elif [[ "$line" =~ "written, MiB/s:" ]]; then
                    current_write_bw=$(echo "$line" | awk '{print $NF}')
                elif $expect_avg_lat && [[ "$line" =~ "avg:" ]]; then
                    current_avg_lat=$(echo "$line" | awk '{print $NF}' | tr -d ',')
                    expect_avg_lat=false
                elif [[ "$line" =~ "min:" ]]; then
                    current_min_lat=$(echo "$line" | awk '{print $NF}' | tr -d ',')
                elif [[ "$line" =~ "max:" ]]; then
                    current_max_lat=$(echo "$line" | awk '{print $NF}' | tr -d ',')
                elif [[ "$line" =~ "95th percentile" ]]; then
                    current_p95_lat=$(echo "$line" | awk '{print $NF}' | tr -d ',')
                fi
            elif [ "$current_tool" = "fio" ]; then
                if echo "$line" | grep -q -i "read:"; then
                    local iops_part=$(echo "$line" | grep -o "IOPS=[0-9.]*[kM]*")
                    local bw_part=$(echo "$line" | grep -o "BW=[0-9.]*MiB/s")
                    local bw_range_mib=$(echo "$line" | grep -o "[0-9.]*MiB/s-[0-9.]*MiB/s")
                    local bw_range_kib=$(echo "$line" | grep -o "[0-9.]*KiB/s-[0-9.]*KiB/s")
                    if [ -n "$iops_part" ]; then
                        local iops_value=$(echo "$iops_part" | sed 's/IOPS=//')
                        if echo "$iops_value" | grep -q "k"; then
                            current_read_iops=$(echo "$iops_value" | sed 's/k//' | awk '{printf "%.2f", $1 * 1000}')
                        elif echo "$iops_value" | grep -q "M"; then
                            current_read_iops=$(echo "$iops_value" | sed 's/M//' | awk '{printf "%.2f", $1 * 1000000}')
                        else
                            current_read_iops="$iops_value"
                        fi
                    fi
                    if [ -n "$bw_part" ]; then
                        current_read_bw=$(echo "$bw_part" | sed 's/BW=//' | sed 's/MiB\/s//')
                    fi
                    local bw_range=""
                    if [ -n "$bw_range_mib" ]; then
                        bw_range="$bw_range_mib"
                    elif [ -n "$bw_range_kib" ]; then
                        bw_range="$bw_range_kib"
                    fi
                    if [ -n "$bw_range" ]; then
                        local is_kib=false
                        if echo "$bw_range" | grep -q "KiB/s"; then
                            is_kib=true
                        fi
                        local b_min=$(echo "$bw_range" | awk -F'-' '{print $1}' | sed 's/MiB\/s//' | sed 's/KiB\/s//')
                        local b_max=$(echo "$bw_range" | awk -F'-' '{print $2}' | sed 's/MiB\/s//' | sed 's/KiB\/s//')
                        if [ "$is_kib" = true ]; then
                            b_min=$(awk "BEGIN {printf \"%.2f\", $b_min / 1024}")
                            b_max=$(awk "BEGIN {printf \"%.2f\", $b_max / 1024}")
                        fi
                        local key="${current_server_ip}_${current_io_mode}"
                        if [ "$current_io_mode" = "randrw" ]; then
                            key="${current_server_ip}_${current_io_mode}_r"
                        fi
                        fio_bw_min["$key"]="$b_min"
                        fio_bw_max["$key"]="$b_max"
                    fi
                elif echo "$line" | grep -q -i "write:"; then
                    local iops_part=$(echo "$line" | grep -o "IOPS=[0-9.]*[kM]*")
                    local bw_part=$(echo "$line" | grep -o "BW=[0-9.]*MiB/s")
                    local bw_range_mib=$(echo "$line" | grep -o "[0-9.]*MiB/s-[0-9.]*MiB/s")
                    local bw_range_kib=$(echo "$line" | grep -o "[0-9.]*KiB/s-[0-9.]*KiB/s")
                    if [ -n "$iops_part" ]; then
                        local iops_value=$(echo "$iops_part" | sed 's/IOPS=//')
                        if echo "$iops_value" | grep -q "k"; then
                            current_write_iops=$(echo "$iops_value" | sed 's/k//' | awk '{printf "%.2f", $1 * 1000}')
                        elif echo "$iops_value" | grep -q "M"; then
                            current_write_iops=$(echo "$iops_value" | sed 's/M//' | awk '{printf "%.2f", $1 * 1000000}')
                        else
                            current_write_iops="$iops_value"
                        fi
                    fi
                    if [ -n "$bw_part" ]; then
                        current_write_bw=$(echo "$bw_part" | sed 's/BW=//' | sed 's/MiB\/s//')
                    fi
                    local bw_range=""
                    if [ -n "$bw_range_mib" ]; then
                        bw_range="$bw_range_mib"
                    elif [ -n "$bw_range_kib" ]; then
                        bw_range="$bw_range_kib"
                    fi
                    if [ -n "$bw_range" ]; then
                        local is_kib=false
                        if echo "$bw_range" | grep -q "KiB/s"; then
                            is_kib=true
                        fi
                        local b_min=$(echo "$bw_range" | awk -F'-' '{print $1}' | sed 's/MiB\/s//' | sed 's/KiB\/s//')
                        local b_max=$(echo "$bw_range" | awk -F'-' '{print $2}' | sed 's/MiB\/s//' | sed 's/KiB\/s//')
                        if [ "$is_kib" = true ]; then
                            b_min=$(awk "BEGIN {printf \"%.2f\", $b_min / 1024}")
                            b_max=$(awk "BEGIN {printf \"%.2f\", $b_max / 1024}")
                        fi
                        local key="${current_server_ip}_${current_io_mode}"
                        if [ "$current_io_mode" = "randrw" ]; then
                            key="${current_server_ip}_${current_io_mode}_w"
                        fi
                        fio_bw_min["$key"]="$b_min"
                        fio_bw_max["$key"]="$b_max"
                    fi
                elif echo "$line" | grep -q "lat (usec)" && echo "$line" | grep -q "avg="; then
                    local avg_lat_us=$(echo "$line" | grep -o "avg=[0-9.]*" | sed 's/avg=//')
                    current_avg_lat=$(awk "BEGIN {printf \"%.6f\", $avg_lat_us / 1000}" 2>/dev/null || echo "N/A")
                fi
            fi
        fi
    done < "$combined_file"

    # Process last server results
    if [ "$in_io_section" = true ] && [ -n "$current_server_ip" ]; then
        if [ -n "$current_read_iops" ] && [ -n "$current_write_iops" ]; then
            current_total_iops=$(awk "BEGIN {printf \"%.2f\", $current_read_iops + $current_write_iops}" 2>/dev/null || echo "N/A")
        elif [ -n "$current_read_iops" ]; then
            current_total_iops=$(awk "BEGIN {printf \"%.2f\", $current_read_iops}" 2>/dev/null || echo "$current_read_iops")
        elif [ -n "$current_write_iops" ]; then
            current_total_iops=$(awk "BEGIN {printf \"%.2f\", $current_write_iops}" 2>/dev/null || echo "$current_write_iops")
        else
            current_total_iops="N/A"
        fi
        if [ -n "$current_read_bw" ] && [ -n "$current_write_bw" ]; then
            current_total_bw=$(awk "BEGIN {printf \"%.2f\", $current_read_bw + $current_write_bw}" 2>/dev/null || echo "N/A")
        elif [ -n "$current_read_bw" ]; then
            current_total_bw=$(awk "BEGIN {printf \"%.2f\", $current_read_bw}" 2>/dev/null || echo "$current_read_bw")
        elif [ -n "$current_write_bw" ]; then
            current_total_bw=$(awk "BEGIN {printf \"%.2f\", $current_write_bw}" 2>/dev/null || echo "$current_write_bw")
        else
            current_total_bw="N/A"
        fi
        if [ "$current_tool" = "sysbench" ]; then
            printf "%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|sysbench\n" "$current_server_ip" "${current_read_iops:-N/A}" "${current_write_iops:-N/A}" "${current_total_iops:-N/A}" "${current_read_bw:-N/A}" "${current_write_bw:-N/A}" "${current_total_bw:-N/A}" "${current_avg_lat:-N/A}" "${current_p95_lat:-N/A}" "${current_min_lat:-N/A}" "${current_max_lat:-N/A}" "${current_io_mode:-rndrw}" "${current_fsync_iops:-N/A}" >> "$results_temp_file"
        else
            printf "%s|%s|%s|%s|%s|%s|%s|%s|N/A|N/A|N/A|%s|N/A|fio\n" "$current_server_ip" "${current_read_iops:-N/A}" "${current_write_iops:-N/A}" "${current_total_iops:-N/A}" "${current_read_bw:-N/A}" "${current_write_bw:-N/A}" "${current_total_bw:-N/A}" "${current_avg_lat:-N/A}" "${current_io_mode:-read}" >> "$results_temp_file"

            local ip_prefix="${current_server_ip//./_}_"
            local key="${current_server_ip}_${current_io_mode}"
            local key_r="${current_server_ip}_${current_io_mode}_r"
            local key_w="${current_server_ip}_${current_io_mode}_w"
            # Only read from JSON if values were not extracted from text output
            if [ "$current_io_mode" = "randrw" ]; then
                if [ -z "${fio_bw_min[$key_r]}" ] || [ -z "${fio_bw_max[$key_r]}" ]; then
                    for json_file in "$tmp_dir"/"${ip_prefix}"fio_*_result_*.json "$tmp_dir"/fio_*_result_*.json; do
                        if [ -f "$json_file" ] && jq_available; then
                            if [[ "$json_file" =~ "_${current_io_mode}_" ]] || [[ "$json_file" =~ "_${current_io_mode}\." ]]; then
                                local r_bw_min=$(jq -r '.jobs[0].read.bw_min // "N/A"' "$json_file" 2>/dev/null)
                                local r_bw_max=$(jq -r '.jobs[0].read.bw_max // "N/A"' "$json_file" 2>/dev/null)
                                if [ "$r_bw_min" != "N/A" ] && [ "$r_bw_min" != "null" ] && [ -z "${fio_bw_min[$key_r]}" ]; then
                                    fio_bw_min["$key_r"]=$(awk "BEGIN {printf \"%.2f\", $r_bw_min / 1024}" 2>/dev/null || echo "N/A")
                                fi
                                if [ "$r_bw_max" != "N/A" ] && [ "$r_bw_max" != "null" ] && [ -z "${fio_bw_max[$key_r]}" ]; then
                                    fio_bw_max["$key_r"]=$(awk "BEGIN {printf \"%.2f\", $r_bw_max / 1024}" 2>/dev/null || echo "N/A")
                                fi
                            fi
                        fi
                    done
                fi
                if [ -z "${fio_bw_min[$key_w]}" ] || [ -z "${fio_bw_max[$key_w]}" ]; then
                    for json_file in "$tmp_dir"/"${ip_prefix}"fio_*_result_*.json "$tmp_dir"/fio_*_result_*.json; do
                        if [ -f "$json_file" ] && jq_available; then
                            if [[ "$json_file" =~ "_${current_io_mode}_" ]] || [[ "$json_file" =~ "_${current_io_mode}\." ]]; then
                                local w_bw_min=$(jq -r '.jobs[0].write.bw_min // "N/A"' "$json_file" 2>/dev/null)
                                local w_bw_max=$(jq -r '.jobs[0].write.bw_max // "N/A"' "$json_file" 2>/dev/null)
                                if [ "$w_bw_min" != "N/A" ] && [ "$w_bw_min" != "null" ] && [ -z "${fio_bw_min[$key_w]}" ]; then
                                    fio_bw_min["$key_w"]=$(awk "BEGIN {printf \"%.2f\", $w_bw_min / 1024}" 2>/dev/null || echo "N/A")
                                fi
                                if [ "$w_bw_max" != "N/A" ] && [ "$w_bw_max" != "null" ] && [ -z "${fio_bw_max[$key_w]}" ]; then
                                    fio_bw_max["$key_w"]=$(awk "BEGIN {printf \"%.2f\", $w_bw_max / 1024}" 2>/dev/null || echo "N/A")
                                fi
                            fi
                        fi
                    done
                fi
            else
                if [ -z "${fio_bw_min[$key]}" ] || [ -z "${fio_bw_max[$key]}" ]; then
                    for json_file in "$tmp_dir"/"${ip_prefix}"fio_*_result_*.json "$tmp_dir"/fio_*_result_*.json; do
                        if [ -f "$json_file" ] && jq_available; then
                            if [[ "$json_file" =~ "_${current_io_mode}_" ]] || [[ "$json_file" =~ "_${current_io_mode}\." ]]; then
                                local b_min=$(jq -r '.jobs[0].read.bw_min // .jobs[0].write.bw_min // "N/A"' "$json_file" 2>/dev/null)
                                local b_max=$(jq -r '.jobs[0].read.bw_max // .jobs[0].write.bw_max // "N/A"' "$json_file" 2>/dev/null)
                                if [ "$b_min" != "N/A" ] && [ "$b_min" != "null" ] && [ -z "${fio_bw_min[$key]}" ]; then
                                    fio_bw_min["$key"]=$(awk "BEGIN {printf \"%.2f\", $b_min / 1024}" 2>/dev/null || echo "N/A")
                                fi
                                if [ "$b_max" != "N/A" ] && [ "$b_max" != "null" ] && [ -z "${fio_bw_max[$key]}" ]; then
                                    fio_bw_max["$key"]=$(awk "BEGIN {printf \"%.2f\", $b_max / 1024}" 2>/dev/null || echo "N/A")
                                fi
                                if [ -n "${fio_bw_min[$key]}" ] || [ -n "${fio_bw_max[$key]}" ]; then
                                    break
                                fi
                            fi
                        fi
                    done
                fi
            fi
        fi
    fi

    # Sort results by IP address and output to report
    local is_sysbench=false
    if [ "${IO_TOOL:-fio}" = "sysbench" ]; then
        is_sysbench=true
    fi

    if [ -s "$results_temp_file" ]; then
        if [ "$is_sysbench" = true ]; then
            echo "  ---------------------------------------------------------------------------------------------------------------" >> "$report_file"
            printf "  %-20s %-11s %-11s %-11s %-11s %-11s %-11s %-13s %-8s\n" "Server IP" "Read IOPS" "Write IOPS" "Total IOPS" "Read BW" "Write BW" "Total BW" "Latency(ms)" "Mode" >> "$report_file"
            echo "  ---------------------------------------------------------------------------------------------------------------" >> "$report_file"
        else
            echo "  ------------------------------------------------------------------------------------------------------------------------" >> "$report_file"
            printf "  %-20s %-11s %-11s %-11s %-11s %-11s %-11s %-13s %-10s %-8s\n" "Server IP" "Read IOPS" "Write IOPS" "Total IOPS" "Read BW" "Write BW" "Total BW" "Latency(ms)" "P99(ms)" "Mode" >> "$report_file"
            echo "  ------------------------------------------------------------------------------------------------------------------------" >> "$report_file"
        fi

        while IFS='|' read -r server_ip read_iops write_iops total_iops read_bw write_bw total_bw avg_lat p95_lat min_lat max_lat io_mode fsync_iops tool; do
            if ! [[ "$server_ip" =~ ^[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}$ ]]; then
                continue
            fi
            local fmt_read_iops=$(if [ "$read_iops" != "N/A" ]; then awk -v val="$read_iops" 'BEGIN {if (val == int(val)) printf "%d", val; else printf "%.2f", val}' 2>/dev/null || echo "$read_iops"; else echo "N/A"; fi)
            local fmt_write_iops=$(if [ "$write_iops" != "N/A" ]; then awk -v val="$write_iops" 'BEGIN {if (val == int(val)) printf "%d", val; else printf "%.2f", val}' 2>/dev/null || echo "$write_iops"; else echo "N/A"; fi)
            local fmt_total_iops=$(if [ "$total_iops" != "N/A" ]; then awk -v val="$total_iops" 'BEGIN {if (val == int(val)) printf "%d", val; else printf "%.2f", val}' 2>/dev/null || echo "$total_iops"; else echo "N/A"; fi)
            local fmt_read_bw=$(if [ "$read_bw" != "N/A" ]; then awk -v val="$read_bw" 'BEGIN {if (val == int(val)) printf "%d", val; else printf "%.2f", val}' 2>/dev/null || echo "$read_bw"; else echo "N/A"; fi)
            local fmt_write_bw=$(if [ "$write_bw" != "N/A" ]; then awk -v val="$write_bw" 'BEGIN {if (val == int(val)) printf "%d", val; else printf "%.2f", val}' 2>/dev/null || echo "$write_bw"; else echo "N/A"; fi)
            local fmt_total_bw=$(if [ "$total_bw" != "N/A" ]; then awk -v val="$total_bw" 'BEGIN {if (val == int(val)) printf "%d", val; else printf "%.2f", val}' 2>/dev/null || echo "$total_bw"; else echo "N/A"; fi)
            local fmt_avg_lat=$(if [ "$avg_lat" != "N/A" ]; then awk "BEGIN {printf \"%.2f\", $avg_lat}" 2>/dev/null || echo "$avg_lat"; else echo "N/A"; fi)

            if [ "$is_sysbench" = true ]; then
                printf "  %-20s %-11s %-11s %-11s %-11s %-11s %-11s %-13s %-8s\n" "$server_ip" "$fmt_read_iops" "$fmt_write_iops" "$fmt_total_iops" "$fmt_read_bw" "$fmt_write_bw" "$fmt_total_bw" "$fmt_avg_lat" "$io_mode" >> "$report_file"
            else
                local key="${server_ip}_${io_mode}"
                local p99="${fio_p99_lat[$key]:-N/A}"
                local fmt_p99=$(if [ "$p99" != "N/A" ]; then awk -v val="$p99" 'BEGIN {if (val == int(val)) printf "%d", val; else printf "%.2f", val}' 2>/dev/null || echo "$p99"; else echo "N/A"; fi)
                printf "  %-20s %-11s %-11s %-11s %-11s %-11s %-11s %-13s %-10s %-8s\n" "$server_ip" "$fmt_read_iops" "$fmt_write_iops" "$fmt_total_iops" "$fmt_read_bw" "$fmt_write_bw" "$fmt_total_bw" "$fmt_avg_lat" "$fmt_p99" "$io_mode" >> "$report_file"
            fi
        done < <(sort -t'|' -k1,1 "$results_temp_file")

        if [ "$is_sysbench" = true ]; then
            echo "" >> "$report_file"
            echo "  # Sysbench Extended Metrics" >> "$report_file"
            echo "  ---------------------------------------------------------------------------" >> "$report_file"
            printf "  %-20s %-10s %-10s %-10s %-12s %-8s\n" "Server IP" "P95(ms)" "Min(ms)" "Max(ms)" "fsyncs/s" "Mode" >> "$report_file"
            echo "  ---------------------------------------------------------------------------" >> "$report_file"

            while IFS='|' read -r server_ip read_iops write_iops total_iops read_bw write_bw total_bw avg_lat p95_lat min_lat max_lat io_mode fsync_iops tool; do
                if ! [[ "$server_ip" =~ ^[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}$ ]]; then
                    continue
                fi
                local fmt_p95=$(if [ "$p95_lat" != "N/A" ]; then awk "BEGIN {printf \"%.2f\", $p95_lat}" 2>/dev/null || echo "$p95_lat"; else echo "N/A"; fi)
                local fmt_min=$(if [ "$min_lat" != "N/A" ]; then awk "BEGIN {printf \"%.2f\", $min_lat}" 2>/dev/null || echo "$min_lat"; else echo "N/A"; fi)
                local fmt_max=$(if [ "$max_lat" != "N/A" ]; then awk "BEGIN {printf \"%.2f\", $max_lat}" 2>/dev/null || echo "$max_lat"; else echo "N/A"; fi)
                local fmt_fsync=$(if [ "$fsync_iops" != "N/A" ]; then awk "BEGIN {printf \"%.2f\", $fsync_iops}" 2>/dev/null || echo "$fsync_iops"; else echo "N/A"; fi)

                printf "  %-20s %-10s %-10s %-10s %-12s %-8s\n" "$server_ip" "$fmt_p95" "$fmt_min" "$fmt_max" "$fmt_fsync" "$io_mode" >> "$report_file"
            done < <(sort -t'|' -k1,1 "$results_temp_file")
        fi

        if [ "$is_sysbench" = false ]; then
            echo "" >> "$report_file"
            echo "  # FIO Extended Metrics" >> "$report_file"
            echo "  -----------------------------------------------------------------------------------------------------------------------------------------" >> "$report_file"
            printf "  %-15s %-9s %-9s %-6s %-9s %-9s %-8s %-8s %-7s %-13s %-13s %-6s %-6s %-6s\n" "Server IP" "slat(us)" "clat(us)" "Depth" "CPU(usr)" "CPU(sys)" "bw_min" "bw_max" "ctx" "aggrios" "aggrticks" "util" "aggrutil" "Mode" >> "$report_file"
            echo "  -----------------------------------------------------------------------------------------------------------------------------------------" >> "$report_file"

            while IFS='|' read -r ext_ip ext_mode ext_p99 ext_disk ext_cpu_usr ext_cpu_sys ext_slat ext_clat ext_iodepth ext_ctx ext_aggrios ext_aggrticks ext_aggrinque ext_aggrutil; do
                if ! [[ "$ext_ip" =~ ^[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}$ ]]; then
                    continue
                fi

                local slat="$ext_slat"
                local clat="$ext_clat"
                local iodepth="${ext_iodepth:-N/A}"
                local util="$ext_disk"
                local cpu_usr="$ext_cpu_usr"
                local cpu_sys="$ext_cpu_sys"
                local ctx="${ext_ctx:-N/A}"
                local aggrios="${ext_aggrios:-N/A}"
                local aggrticks="${ext_aggrticks:-N/A}"
                local aggrutil="${ext_aggrutil:-N/A}"
                local b_min="${fio_bw_min[${ext_ip}_${ext_mode}]:-N/A}"
                local b_max="${fio_bw_max[${ext_ip}_${ext_mode}]:-N/A}"

                printf "  %-15s %-9s %-9s %-6s %-9s %-9s %-8s %-8s %-7s %-13s %-13s %-6s %-6s %-6s\n" \
                    "$ext_ip" "$slat" "$clat" "$iodepth" "$cpu_usr" "$cpu_sys" "$b_min" "$b_max" "$ctx" "$aggrios" "$aggrticks" "$util" "$aggrutil" "$ext_mode" >> "$report_file"
            done < <(sort -t'|' -k1,1 "$fio_extended_file")
        fi
    else
        echo "  Test not executed" >> "$report_file"
    fi

    rm -f "$results_temp_file" "$fio_extended_file"
}

