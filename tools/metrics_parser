                metrics_set "EPS" "$eps"
                metrics_flush "THREADS" "$output_file"
            fi
            in_section=false
            metrics_reset "THREADS"
        elif [ "$in_section" = true ]; then
            if [[ "$line" =~ "total number of events:" ]]; then
                current_events=$(echo "$line" | awk '{print $NF}')
            elif [[ "$line" =~ "total time:" ]]; then
                current_time=$(echo "$line" | awk '{print $NF}' | tr -d 's')
            elif [[ "$line" =~ "avg:" ]] && [[ ! "$line" =~ "events" ]]; then
                metrics_set "AVG_LAT" "$(echo "$line" | awk '{print $NF}' | tr -d ',')"
            elif [[ "$line" =~ "min:" ]] && [[ ! "$line" =~ "execution time" ]]; then
                metrics_set "MIN_LAT" "$(echo "$line" | awk '{print $NF}' | tr -d ',')"
            elif [[ "$line" =~ "max:" ]] && [[ ! "$line" =~ "execution time" ]]; then
                metrics_set "MAX_LAT" "$(echo "$line" | awk '{print $NF}' | tr -d ',')"
            elif [[ "$line" =~ "95th percentile" ]]; then
                metrics_set "P95_LAT" "$(echo "$line" | awk '{print $NF}')"
            elif [[ "$line" =~ "sum:" ]]; then
                metrics_set "SUM_LAT" "$(echo "$line" | awk '{print $NF}' | tr -d ',')"
