            metrics_init "THREADS"
            CURRENT_SERVER_IP="${last_testing_ip:-N/A}"
            metrics_set "SERVER_IP" "$CURRENT_SERVER_IP"
            current_events=""
            current_time=""
        elif [ "$in_section" = true ] && [[ "$line" =~ "TEST RESULTS" ]] && [[ ! "$line" =~ "THREADS TEST RESULTS" ]] && [[ ! "$line" =~ "Threads test summary:" ]]; then
