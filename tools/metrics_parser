    metrics_init "THREADS"

    local in_section=false
    local current_events=""
    local current_time=""
    local last_testing_ip=""

    while IFS= read -r line; do
        if [[ "$line" =~ "THREADS TEST RESULTS" ]]; then
            if [ "$in_section" = true ] && metrics_has_data "THREADS"; then
                local eps=$(calc_eps "$current_events" "$current_time")
                metrics_set "EPS" "$eps"
                metrics_flush "THREADS" "$output_file"
            fi
            in_section=true
            metrics_init "THREADS"
            CURRENT_SERVER_IP=$(echo "$line" | grep -oP 'Server: \K[0-9.]+' || echo "N/A")
            last_testing_ip="$CURRENT_SERVER_IP"
            metrics_set "SERVER_IP" "$CURRENT_SERVER_IP"
            current_events=""
            current_time=""
        elif [[ "$line" =~ CPU.*TEST.*RESULTS || "$line" =~ MEMORY.*TEST.*RESULTS || "$line" =~ IO.*TEST.*RESULTS || "$line" =~ FIO.*TEST.*RESULTS || "$line" =~ MUTEX.*TEST.*RESULTS || "$line" =~ NETWORK.*TEST.*RESULTS || "$line" =~ "Testing server" ]]; then
