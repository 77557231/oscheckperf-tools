# ================================================================================
# CPU Report Parsing
# ================================================================================

parse_cpu_report_new() {
    local input_file="$1"
    local output_file="$2"

    if [ ! -f "$input_file" ]; then
        echo "  Test not executed" >> "$output_file"
        return
    fi

    if ! grep -q "CPU TEST RESULTS" "$input_file" 2>/dev/null; then
        echo "  Test not executed" >> "$output_file"
        return
    fi

    echo "  CPU Test Results" >> "$output_file"
    echo "  ---------------------------------------------------------------------------------------------------------------" >> "$output_file"
    printf "  %-18s %-12s %-12s %-12s %-12s %-12s %-14s %-10s\n" "Server IP" "Events/sec" "Avg Lat(ms)" "P95 Lat(ms)" "Max Lat(ms)" "Min Lat(ms)" "Sum Lat(ms)" "Fairness(avg)" >> "$output_file"
    echo "  ---------------------------------------------------------------------------------------------------------------" >> "$output_file"

    metrics_init "CPU"

    local in_section=false
    while IFS= read -r line; do
        if [[ "$line" =~ "CPU TEST RESULTS" ]]; then
            if [ "$in_section" = true ] && metrics_has_data "CPU"; then
                metrics_flush "CPU" "$output_file"
            fi
            in_section=true
            metrics_init "CPU"
            CURRENT_SERVER_IP=$(echo "$line" | grep -oP 'Server: \K[0-9.]+' || echo "N/A")
            metrics_set "SERVER_IP" "$CURRENT_SERVER_IP"
        elif [[ "$line" =~ MEMORY.*TEST.*RESULTS || "$line" =~ "SYSBENCH FILEIO TEST RESULTS" || "$line" =~ "THREADS TEST RESULTS" || "$line" =~ "MUTEX TEST RESULTS" || "$line" =~ "NETWORK TEST RESULTS" ]]; then
            if [ "$in_section" = true ] && metrics_has_data "CPU"; then
                metrics_flush "CPU" "$output_file"
            fi
            in_section=false
            metrics_reset "CPU"
        elif [ "$in_section" = true ]; then
            if [[ "$line" =~ "events per second:" ]]; then
                metrics_set "EPS" "$(echo "$line" | awk '{print $NF}')"
            elif [[ "$line" =~ "avg:" ]] && [[ "$line" =~ [0-9] ]] && [[ ! "$line" =~ "events \(avg/stddev\):" ]] && [[ ! "$line" =~ "execution time" ]]; then
                metrics_set "AVG_LAT" "$(echo "$line" | awk '{print $NF}')"
            elif [[ "$line" =~ "95th percentile:" ]]; then
                metrics_set "P95_LAT" "$(echo "$line" | awk '{print $NF}')"
            elif [[ "$line" =~ "min:" ]] && [[ "$line" =~ [0-9] ]] && [[ ! "$line" =~ "execution time" ]]; then
                metrics_set "MIN_LAT" "$(echo "$line" | awk '{print $NF}' | tr -d ',')"
            elif [[ "$line" =~ "max:" ]] && [[ "$line" =~ [0-9] ]] && [[ ! "$line" =~ "execution time" ]]; then
                metrics_set "MAX_LAT" "$(echo "$line" | awk '{print $NF}' | tr -d ',')"
            elif [[ "$line" =~ "sum:" ]]; then
                metrics_set "SUM_LAT" "$(echo "$line" | awk '{print $NF}' | tr -d ',')"
            elif echo "$line" | grep -q "events.*avg/stddev"; then
                metrics_set "FAIRNESS" "$(echo "$line" | awk '{print $NF}')"
            fi
        fi
    done < "$input_file"

    if [ "$in_section" = true ] && metrics_has_data "CPU"; then
        metrics_flush "CPU" "$output_file"
    fi
}

# ================================================================================
# Memory Report Parsing
# ================================================================================

parse_memory_report_new() {
    local input_file="$1"
    local output_file="$2"

    if [ ! -f "$input_file" ]; then
        echo "  Test not executed" >> "$output_file"
        return
    fi

    if ! grep -q "MEMORY.*TEST RESULTS" "$input_file" 2>/dev/null; then
        echo "  Test not executed" >> "$output_file"
        return
    fi

    echo "  Memory Test Results" >> "$output_file"
    echo "  ---------------------------------------------------------------------------------------------------------------------------------" >> "$output_file"
    printf "  %-18s %-12s %-12s %-12s %-10s %-10s %-10s %-12s %-17s %-8s\n" "Server IP" "Ops/sec" "MiB/sec" "Avg Lat(ms)" "Min Lat(ms)" "Max Lat(ms)" "P95 Lat(ms)" "Sum Lat(ms)" "Fairness(avg)" "Mode" >> "$output_file"
    echo "  ---------------------------------------------------------------------------------------------------------------------------------" >> "$output_file"

    metrics_init "MEMORY"

    local in_section=false
    local in_latency_section=false
    local current_mode=""

    while IFS= read -r line; do
        if [[ "$line" =~ MEMORY\ ([A-Z]+)\ TEST\ RESULTS ]]; then
            if [ "$in_section" = true ] && metrics_has_data "MEMORY"; then
                metrics_set "MODE" "$current_mode"
                metrics_flush "MEMORY" "$output_file"
            fi
            in_section=true
            in_latency_section=false
            metrics_init "MEMORY"
            CURRENT_SERVER_IP=$(echo "$line" | grep -oP 'Server: \K[0-9.]+' || echo "N/A")
            metrics_set "SERVER_IP" "$CURRENT_SERVER_IP"
            current_mode=$(echo "$line" | awk '{print $2}' | tr '[:upper:]' '[:lower:]')
        elif [[ "$line" =~ CPU.*TEST.*RESULTS || "$line" =~ SYSBENCH\ FILEIO.*TEST.*RESULTS || "$line" =~ THREADS.*TEST.*RESULTS || "$line" =~ MUTEX.*TEST.*RESULTS || "$line" =~ NETWORK.*TEST.*RESULTS ]]; then
            if [ "$in_section" = true ] && metrics_has_data "MEMORY"; then
                metrics_set "MODE" "$current_mode"
                metrics_flush "MEMORY" "$output_file"
            fi
            in_section=false
            in_latency_section=false
            metrics_reset "MEMORY"
            current_mode=""
        elif [ "$in_section" = true ]; then
            if [[ "$line" == *"Total operations:"* ]]; then
                metrics_set "OPS_SEC" "$(echo "$line" | awk -F'[()]' '{print $2}' | awk '{print $1}')"
            elif [[ "$line" == *"MiB transferred"* ]]; then
                metrics_set "MIB_SEC" "$(echo "$line" | awk -F'[()]' '{print $2}' | awk '{print $1}')"
            elif [[ "$line" == *"Latency (ms):"* ]]; then
                in_latency_section=true
            elif [[ "$line" == *"Threads fairness:"* ]]; then
                in_latency_section=false
            elif [ "$in_latency_section" = true ] && [[ "$line" == *"avg:"* ]]; then
                metrics_set "AVG_LAT" "$(echo "$line" | awk '{print $NF}' | tr -d ',')"
            elif [ "$in_latency_section" = true ] && [[ "$line" == *"min:"* ]]; then
                metrics_set "MIN_LAT" "$(echo "$line" | awk '{print $NF}' | tr -d ',')"
            elif [ "$in_latency_section" = true ] && [[ "$line" == *"max:"* ]]; then
                metrics_set "MAX_LAT" "$(echo "$line" | awk '{print $NF}' | tr -d ',')"
            elif [ "$in_latency_section" = true ] && [[ "$line" == *"95th percentile:"* ]]; then
                metrics_set "P95_LAT" "$(echo "$line" | awk '{print $NF}')"
            elif [ "$in_latency_section" = true ] && [[ "$line" == *"sum:"* ]]; then
                metrics_set "SUM_LAT" "$(echo "$line" | awk '{print $NF}' | tr -d ',')"
            elif [[ "$line" == *"events"* && "$line" == *"avg/stddev"* ]]; then
                metrics_set "FAIRNESS" "$(echo "$line" | awk '{print $NF}')"
            fi
        fi
    done < "$input_file"

    if [ "$in_section" = true ] && metrics_has_data "MEMORY"; then
        metrics_set "MODE" "$current_mode"
        metrics_flush "MEMORY" "$output_file"
    fi
}

# ================================================================================
# Threads Report Parsing
