    local disk_read_ahead="N/A"
    local disk_trim="N/A"
    local disk_max_sectors="N/A"
    # Mount Options
    local mount_options=""
    
    while IFS= read -r line; do
        if [ "$line" = "--- Disk Info ---" ]; then
            in_disk="true"; in_network="false"; in_slots="false"; in_inode="false"
            in_disk_usage="false"; in_cpu_advanced="false"; in_numa="false"
            in_memory_advanced="false"; in_io_advanced="false"; in_mount_options="false"
            in_network_advanced="false"
        elif [ "$line" = "--- Disk Usage ---" ]; then
            in_disk="false"; in_network="false"; in_slots="false"; in_inode="false"
            in_disk_usage="true"; in_cpu_advanced="false"; in_numa="false"
            in_memory_advanced="false"; in_io_advanced="false"; in_mount_options="false"
            in_network_advanced="false"
        elif [ "$line" = "--- Inode Info ---" ]; then
            in_disk="false"; in_network="false"; in_slots="false"; in_inode="true"
            in_disk_usage="false"; in_cpu_advanced="false"; in_numa="false"
            in_memory_advanced="false"; in_io_advanced="false"; in_mount_options="false"
            in_network_advanced="false"
        elif [ "$line" = "--- Network Info ---" ]; then
            in_disk="false"; in_network="true"; in_slots="false"; in_inode="false"
            in_disk_usage="false"; in_cpu_advanced="false"; in_numa="false"
            in_memory_advanced="false"; in_io_advanced="false"; in_mount_options="false"
            in_network_advanced="false"
        elif [ "$line" = "--- Memory Slots Detail ---" ]; then
            in_disk="false"; in_network="false"; in_slots="true"; in_inode="false"
            in_disk_usage="false"; in_cpu_advanced="false"; in_numa="false"
            in_memory_advanced="false"; in_io_advanced="false"; in_mount_options="false"
            in_network_advanced="false"
        elif [ "$line" = "--- CPU Advanced Info ---" ]; then
            in_disk="false"; in_network="false"; in_slots="false"; in_inode="false"
            in_disk_usage="false"; in_cpu_advanced="true"; in_numa="false"
            in_memory_advanced="false"; in_io_advanced="false"; in_mount_options="false"
            in_network_advanced="false"
        elif [ "$line" = "--- NUMA Topology ---" ]; then
            in_disk="false"; in_network="false"; in_slots="false"; in_inode="false"
            in_disk_usage="false"; in_cpu_advanced="false"; in_numa="true"
            in_memory_advanced="false"; in_io_advanced="false"; in_mount_options="false"
            in_network_advanced="false"
        elif [ "$line" = "--- Memory Advanced Info ---" ]; then
            in_disk="false"; in_network="false"; in_slots="false"; in_inode="false"
            in_disk_usage="false"; in_cpu_advanced="false"; in_numa="false"
            in_memory_advanced="true"; in_io_advanced="false"; in_mount_options="false"
            in_network_advanced="false"
        elif [ "$line" = "--- IO Advanced Info (Benchmark Disk Only) ---" ]; then
            in_disk="false"; in_network="false"; in_slots="false"; in_inode="false"
            in_disk_usage="false"; in_cpu_advanced="false"; in_numa="false"
            in_memory_advanced="false"; in_io_advanced="true"; in_mount_options="false"
            in_network_advanced="false"
        elif [ "$line" = "--- Mount Options (Benchmark FS Only) ---" ]; then
            in_disk="false"; in_network="false"; in_slots="false"; in_inode="false"
            in_disk_usage="false"; in_cpu_advanced="false"; in_numa="false"
            in_memory_advanced="false"; in_io_advanced="false"; in_mount_options="true"
            in_network_advanced="false"
        elif [ "$line" = "--- Network Advanced Info ---" ]; then
            in_disk="false"; in_network="false"; in_slots="false"; in_inode="false"
            in_disk_usage="false"; in_cpu_advanced="false"; in_numa="false"
            in_memory_advanced="false"; in_io_advanced="false"; in_mount_options="false"
            in_network_advanced="true"
        elif [ "$in_disk" = "true" ] && [ -n "$line" ]; then
            disk_lines+=("$line")
        elif [ "$in_disk_usage" = "true" ] && [ -n "$line" ]; then
            disk_usage_lines+=("$line")
        elif [ "$in_inode" = "true" ] && [ -n "$line" ]; then
            inode_lines+=("$line")
        elif [ "$in_network" = "true" ] && [ -n "$line" ]; then
            network_lines+=("$line")
        elif [ "$in_slots" = "true" ] && [ -n "$line" ]; then
            mem_slots_detail="$mem_slots_detail$line"$'\n'
        elif [ "$in_cpu_advanced" = "true" ] && [ -n "$line" ]; then
            if [[ "$line" == CPU_L1D_CACHE:* ]]; then cpu_l1d_cache="${line#CPU_L1D_CACHE: }"
            elif [[ "$line" == CPU_L2_CACHE:* ]]; then cpu_l2_cache="${line#CPU_L2_CACHE: }"
            elif [[ "$line" == CPU_L3_CACHE:* ]]; then cpu_l3_cache="${line#CPU_L3_CACHE: }"
            elif [[ "$line" == CPU_FEATURES:* ]]; then cpu_features="${line#CPU_FEATURES: }"
            elif [[ "$line" == CPU_FREQ_MIN:* ]]; then cpu_freq_min="${line#CPU_FREQ_MIN: }"
            elif [[ "$line" == CPU_FREQ_MAX:* ]]; then cpu_freq_max="${line#CPU_FREQ_MAX: }"
            elif [[ "$line" == CPU_GOVERNOR:* ]]; then cpu_governor="${line#CPU_GOVERNOR: }"
            fi
        elif [ "$in_numa" = "true" ] && [ -n "$line" ]; then
            if [[ "$line" == NUMA_NODE_COUNT:* ]]; then numa_node_count="${line#NUMA_NODE_COUNT: }"
            else numa_detail_lines="$numa_detail_lines$line"$'\n'
            fi
        elif [ "$in_memory_advanced" = "true" ] && [ -n "$line" ]; then
            if [[ "$line" == MEM_USAGE_RATE:* ]]; then mem_usage_rate="${line#MEM_USAGE_RATE: }"
            elif [[ "$line" == THP_STATUS:* ]]; then thp_status="${line#THP_STATUS: }"
            elif [[ "$line" == HUGEPAGES_COUNT:* ]]; then hugepages_count="${line#HUGEPAGES_COUNT: }"
            fi
        elif [ "$in_io_advanced" = "true" ] && [ -n "$line" ]; then
            if [[ "$line" == DISK_QUEUE_DEPTH:* ]]; then disk_queue_depth="${line#DISK_QUEUE_DEPTH: }"
            elif [[ "$line" == DISK_READ_AHEAD:* ]]; then disk_read_ahead="${line#DISK_READ_AHEAD: }"
            elif [[ "$line" == DISK_TRIM:* ]]; then disk_trim="${line#DISK_TRIM: }"
            elif [[ "$line" == DISK_MAX_SECTORS:* ]]; then disk_max_sectors="${line#DISK_MAX_SECTORS: }"
            fi
        elif [ "$in_mount_options" = "true" ] && [ -n "$line" ]; then
            if [[ "$line" == MOUNT_OPTIONS:* ]]; then mount_options="${line#MOUNT_OPTIONS: }"
            fi
        elif [ "$in_network_advanced" = "true" ] && [ -n "$line" ]; then
            network_advanced_lines+=("$line")
        elif [[ "$line" == CPU_ARCH:* ]]; then
            cpu_arch="${line#CPU_ARCH: }"
        elif [[ "$line" == MACHINE_TYPE:* ]]; then
            machine_type="${line#MACHINE_TYPE: }"
        elif [[ "$line" == OS_INFO:* ]]; then
            os_info="${line#OS_INFO: }"
        elif [[ "$line" == KERNEL_VERSION:* ]]; then
            kernel_version="${line#KERNEL_VERSION: }"
        elif [[ "$line" == UPTIME:* ]]; then
            uptime="${line#UPTIME: }"
        elif [[ "$line" == CPU_MODEL:* ]]; then
            cpu_model="${line#CPU_MODEL: }"
        elif [[ "$line" == CPU_PHYSICAL_CORES:* ]]; then
            cpu_physical_cores="${line#CPU_PHYSICAL_CORES: }"
        elif [[ "$line" == CPU_LOGICAL_CORES:* ]]; then
            cpu_logical_cores="${line#CPU_LOGICAL_CORES: }"
        elif [[ "$line" == CPU_FREQ:* ]]; then
            cpu_freq="${line#CPU_FREQ: }"
        elif [[ "$line" == MEM_TOTAL:* ]]; then
            mem_total="${line#MEM_TOTAL: }"
        elif [[ "$line" == MEM_AVAILABLE:* ]]; then
            mem_available="${line#MEM_AVAILABLE: }"
        elif [[ "$line" == MEM_TYPE:* ]]; then
            mem_type="${line#MEM_TYPE: }"
        elif [[ "$line" == MEM_FREQ:* ]]; then
            mem_freq="${line#MEM_FREQ: }"
        elif [[ "$line" == MEM_CHANNELS:* ]]; then
            mem_channels="${line#MEM_CHANNELS: }"
        elif [[ "$line" == NET_BOND:* ]]; then
            net_bond="${line#NET_BOND: }"
        elif [[ "$line" == NET_INTERFACE_COUNT:* ]]; then
            net_count="${line#NET_INTERFACE_COUNT: }"
        fi
    done <<< "$node_info"
    
    # Build combined network lines (basic + advanced)
    local all_network_lines=()
    for nl in "${network_lines[@]}"; do
        [ -n "$nl" ] && all_network_lines+=("$nl")
    done
    for nal in "${network_advanced_lines[@]}"; do
        [ -n "$nal" ] && all_network_lines+=("$nal")
    done
    
    print_system_info "$report_file" "$prefix" "$os_info" "$kernel_version" "$uptime"
    print_cpu_info "$report_file" "$prefix" \
        "$cpu_arch" "$machine_type" "$cpu_model" "$cpu_physical_cores" "$cpu_logical_cores" "$cpu_freq" \
        "$cpu_l1d_cache" "$cpu_l2_cache" "$cpu_l3_cache" "$cpu_features" "$cpu_freq_min" "$cpu_freq_max" "$cpu_governor"
    print_memory_info "$report_file" "$prefix" \
        "$mem_total" "$mem_available" "$mem_type" "$mem_freq" "$mem_channels" \
        "$mem_slots_detail" "$numa_node_count" "$numa_detail_lines" \
        "$mem_usage_rate" "$thp_status" "$hugepages_count"
    local resolved_io_path="$IO_PATH"
    print_mount_options "$report_file" "$prefix" "$mount_options"
    print_disk_info_section "$report_file" "$prefix" "$resolved_io_path" "${disk_lines[@]}"
    print_disk_usage_section "$report_file" "$prefix" "${disk_usage_lines[@]}"
    print_inode_section "$report_file" "$prefix" "${inode_lines[@]}"
    print_disk_io_settings "$report_file" "$prefix" "$disk_queue_depth" "$disk_read_ahead" "$disk_trim" "$disk_max_sectors"
    print_network_info "$report_file" "$prefix" "$net_count" "$net_bond" "${all_network_lines[@]}"
}

# Unified hardware report function - supports both single and multi-node modes
# Usage: generate_hardware_report_unified <report_file> [server1 server2 ...]
generate_hardware_report_unified() {
    local report_file="$1"
    shift
    local servers=("$@")
    
    printf -- "================================================================================\n" > "$report_file"
    printf -- "                    Hardware Information Report\n" >> "$report_file"
    printf -- "================================================================================\n" >> "$report_file"
    printf -- "\n" >> "$report_file"
    
    if [ ${#servers[@]} -gt 0 ]; then
        local node_idx=1
        local local_ip=$(get_machine_ip)
        for ip in "${servers[@]}"; do
            printf -- "  Node %d: %s\n" "$node_idx" "$ip" >> "$report_file"

            printf -- "\n" >> "$report_file"
            
            local is_local="false"
            if [ "$ip" = "$local_ip" ]; then
                is_local="true"
            fi
            
            local node_info=$(get_node_hardware_info "$ip" "$is_local")
            print_node_hardware_info "$report_file" "$node_info" "  "
            
            node_idx=$((node_idx + 1))
            printf -- "\n" >> "$report_file"
        done
    else
        printf -- "Hostname: ${HOSTNAME:-N/A}\n" >> "$report_file"
        printf -- "\n" >> "$report_file"
        
        local cpu_arch=$(get_cpu_arch 2>/dev/null || echo "N/A")
