# Parse and print single node hardware information
print_node_hardware_info() {
    local report_file="$1"
    local node_info="$2"
    local prefix="$3"
    
    local cpu_arch="N/A"
    local machine_type="N/A"
    local os_info="N/A"
    local kernel_version="N/A"
    local uptime="N/A"
    local cpu_model="N/A"
    local cpu_physical_cores="N/A"
    local cpu_logical_cores="N/A"
    local cpu_freq="N/A"
    local mem_total="N/A"
    local mem_available="N/A"
    local mem_type="N/A"
    local mem_freq="N/A"
    local mem_channels="N/A"
    local mem_slots_detail=""
    local net_bond="N/A"
    local net_count="N/A"
    local in_disk="false"
    local in_network="false"
    local in_slots="false"
    local in_inode="false"
    local in_disk_usage="false"
