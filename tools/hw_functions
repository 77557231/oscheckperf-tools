# Print disk information section (filtered: only IO_PATH related device)
print_disk_info_section() {
    local report_file="$1"
    local prefix="$2"
    local io_path="$3"
    shift 3
    local disk_lines=("$@")
    
    # Get IO_PATH mount point for filtering
    local io_mount=""
    if [ -n "$io_path" ] && command -v df &>/dev/null; then
        io_mount=$(df "$io_path" 2>/dev/null | tail -1 | awk '{print $6}')
    fi
    if [ -z "$io_mount" ] && command -v df &>/dev/null; then
        io_mount="/"
    fi
    
    # Collect all disk information (preserve original name with hierarchy)
    declare -A disk_by_name
    declare -A disk_type_by_name
    declare -A disk_display_name
    for disk_line in "${disk_lines[@]}"; do
        if [ -n "$disk_line" ] && [ "$disk_line" != "N/A" ]; then
            IFS='|' read -r name size type fstype mountpoint disk_type vendor model scheduler wcache <<< "$disk_line"
            local clean_name=$(echo "$name" | sed 's/^[├└─ ]*//; s/^[│ ]*//')
            disk_by_name["$clean_name"]="$disk_line"
            disk_type_by_name["$clean_name"]="$type"
            disk_display_name["$clean_name"]="$name"  # Store original name with hierarchy
        fi
    done
    
    # Find relevant devices using universal logic
    local relevant_names=()
    local seen=()
    local main_device=""
    local main_device_found=false
    
    add_device() {
        local dev_name="$1"
        local found=false
        for s in "${seen[@]}"; do [ "$s" = "$dev_name" ] && found=true && break; done
        if [ "$found" = false ] && [ -n "${disk_by_name["$dev_name"]}" ]; then
            seen+=("$dev_name")
            relevant_names+=("$dev_name")
        fi
    }
    
    # Step 1: Find the device that mounts our IO_PATH (universal approach)
    for disk_line in "${disk_lines[@]}"; do
        if [ -n "$disk_line" ] && [ "$disk_line" != "N/A" ]; then
            IFS='|' read -r name size type fstype mountpoint disk_type vendor model scheduler wcache <<< "$disk_line"
            local clean_name=$(echo "$name" | sed 's/^[├└─ ]*//; s/^[│ ]*//')
            
            if [ "$mountpoint" = "$io_mount" ]; then
                main_device="$clean_name"
                add_device "$clean_name"
                main_device_found=true
            fi
        fi
    done
    
    # Step 2: Build device hierarchy based on actual mount relationship
    if [ "$main_device_found" = true ]; then
        # Universal logic: Find all related devices through parent-child relationships
        if [[ "$main_device" == *"-"* ]]; then
            # LVM device: find the specific VG and its physical disks
            local vg_name=$(echo "$main_device" | cut -d'-' -f1)
            
            # Find all LVM devices belonging to the same VG
            for lvm_name in "${!disk_type_by_name[@]}"; do
                local lvm_type="${disk_type_by_name["$lvm_name"]}"
                if [ "$lvm_type" = "lvm" ] && [[ "$lvm_name" == "$vg_name"* ]]; then
                    add_device "$lvm_name"
                fi
            done
            
            # Find the boot disk first (has /boot or /boot/efi and LVM)
            local boot_disk_found=false
            local boot_disk=""
            for disk_name in "${!disk_type_by_name[@]}"; do
                local type="${disk_type_by_name["$disk_name"]}"
                if [ "$type" = "disk" ]; then
                    local is_boot_disk=false
                    local has_lvm=false
                    for part_name in "${!disk_type_by_name[@]}"; do
                        local part_type="${disk_type_by_name["$part_name"]}"
                        if [ "$part_type" = "part" ] && [[ "$part_name" == "$disk_name"* ]]; then
                            local part_line="${disk_by_name["$part_name"]}"
                            if [[ "$part_line" == *"/boot"* ]]; then
                                is_boot_disk=true
                            fi
                            if [[ "$part_line" == *"LVM2_member"* ]]; then
                                has_lvm=true
                            fi
                        fi
                    done
                    if [ "$is_boot_disk" = true ] && [ "$has_lvm" = true ]; then
                        boot_disk="$disk_name"
                        boot_disk_found=true
                        break
                    fi
                fi
            done
            
            # Use boot disk if found, otherwise find any disk with LVM
            local vg_disks=()
            if [ "$boot_disk_found" = true ]; then
                vg_disks=("$boot_disk")
            else
                # Fallback: find the first disk with LVM partition
                for disk_name in "${!disk_type_by_name[@]}"; do
                    local type="${disk_type_by_name["$disk_name"]}"
                    if [ "$type" = "disk" ]; then
                        for part_name in "${!disk_type_by_name[@]}"; do
                            local part_type="${disk_type_by_name["$part_name"]}"
                            if [ "$part_type" = "part" ] && [[ "$part_name" == "$disk_name"* ]]; then
                                local part_line="${disk_by_name["$part_name"]}"
                                if [[ "$part_line" == *"LVM2_member"* ]]; then
                                    vg_disks=("$disk_name")
                                    break 2
                                fi
                            fi
                        done
                    fi
                done
            fi
            
            # Add the disks and their partitions
            for disk_name in "${vg_disks[@]}"; do
                add_device "$disk_name"
                for part_name in "${!disk_type_by_name[@]}"; do
                    local part_type="${disk_type_by_name["$part_name"]}"
                    if [ "$part_type" = "part" ] && [[ "$part_name" == "$disk_name"* ]]; then
                        add_device "$part_name"
                    fi
                done
            done
        else
            # Non-LVM: find parent disk and its partitions
            local main_prefix=$(echo "$main_device" | sed 's/[0-9]*$//; s/p[0-9]*$//')
            
            for disk_name in "${!disk_type_by_name[@]}"; do
                local type="${disk_type_by_name["$disk_name"]}"
                if [ "$type" = "disk" ] && [[ "$main_prefix" == "$disk_name" ]]; then
                    add_device "$disk_name"
                    for part_name in "${!disk_type_by_name[@]}"; do
                        local part_type="${disk_type_by_name["$part_name"]}"
                        if [ "$part_type" = "part" ] && [[ "$part_name" == "$disk_name"* ]]; then
                            add_device "$part_name"
                        fi
                    done
                fi
            done
        fi
    fi
    
    # Sort by hierarchy (disks first, then partitions, then LVM)
    local sorted_names=()
    local disk_names=()
    local part_names=()
    local lvm_names=()
    
    for name in "${relevant_names[@]}"; do
        local type="${disk_type_by_name["$name"]}"
        if [ "$type" = "disk" ]; then
            disk_names+=("$name")
        elif [ "$type" = "part" ]; then
            part_names+=("$name")
        elif [ "$type" = "lvm" ]; then
            lvm_names+=("$name")
        else
            sorted_names+=("$name")
        fi
    done
    
    # Sort partitions by their disk prefix
    IFS=$'\n' part_names=($(sort <<<"${part_names[*]}")); unset IFS
    IFS=$'\n' lvm_names=($(sort <<<"${lvm_names[*]}")); unset IFS
    
    # Build final sorted list
    sorted_names=("${disk_names[@]}" "${part_names[@]}" "${lvm_names[@]}")
    
    # Build and display the filtered list with hierarchy (using spaces for indentation)
    if [ ${#sorted_names[@]} -gt 0 ]; then
        printf -- "%s[Disk Information (IO Benchmark Only)]\n" "$prefix" >> "$report_file"
        printf -- "%s------------------------------------------------------------------------------------------------------------------\n" "$prefix" >> "$report_file"
        printf -- "%s%-28s %-12s %-6s %-8s %-14s %-5s %-8s %-12s %-8s %-8s\n" "$prefix" "NAME" "SIZE" "TYPE" "FS" "MOUNTPOINT" "TYPE" "VENDOR" "MODEL" "SCHEDULER" "WCACHE" >> "$report_file"
        printf -- "%s------------------------------------------------------------------------------------------------------------------\n" "$prefix" >> "$report_file"
        for name in "${sorted_names[@]}"; do
            local disk_line="${disk_by_name["$name"]}"
            if [ -n "$disk_line" ]; then
                IFS='|' read -r name size type fstype mountpoint disk_type vendor model scheduler wcache <<< "$disk_line"
                local clean_name=$(echo "$name" | sed 's/^[├└─ ]*//; s/^[│ ]*//')
                
                local indent=""
                if [ "$type" = "part" ]; then
                    indent="  "
                elif [ "$type" = "lvm" ]; then
                    indent="    "
                fi
                
                local combined_name="$indent$clean_name"
                [ "$disk_type" = "Unknown" ] && disk_type="-"
                printf -- "%s%-28s %-12s %-6s %-8s %-14s %-5s %-8s %-12s %-8s %-8s\n" "$prefix" "$combined_name" "$size" "$type" "$fstype" "$mountpoint" "$disk_type" "$vendor" "$model" "$scheduler" "$wcache" >> "$report_file"
            fi
        done
        printf -- "\n" >> "$report_file"
    fi
}

# Print disk usage section (show all)
print_disk_usage_section() {
    local report_file="$1"
    local prefix="$2"
    shift 2
    local disk_usage_lines=("$@")
    
    # Show all disk usage information
    local all_lines=()
    for disk_usage_line in "${disk_usage_lines[@]}"; do
        if [ -n "$disk_usage_line" ] && [ "$disk_usage_line" != "N/A" ]; then
            all_lines+=("$disk_usage_line")
        fi
    done
    
    if [ ${#all_lines[@]} -gt 0 ]; then
        printf -- "%s[Disk Usage Information]\n" "$prefix" >> "$report_file"
        printf -- "%s--------------------------------------------------------------------------------\n" "$prefix" >> "$report_file"
        printf -- "%s%-30s %-14s %-8s %-8s %-6s %-14s\n" "$prefix" "FILESYSTEM" "SIZE" "USED" "AVAIL" "USE%" "MOUNTED ON" >> "$report_file"
        printf -- "%s--------------------------------------------------------------------------------\n" "$prefix" >> "$report_file"
        for disk_usage_line in "${all_lines[@]}"; do
            IFS='|' read -r fs size used avail pct mount <<< "$disk_usage_line"
            printf -- "%s%-30s %-14s %-8s %-8s %-6s %-14s\n" "$prefix" "$fs" "$size" "$used" "$avail" "$pct" "$mount" >> "$report_file"
        done
        printf -- "\n" >> "$report_file"
    fi
}

# Print inode information section (show all)
print_inode_section() {
