# Get network interface information
get_network_info() {
    local result=""
    local up_count=0
    for iface in $(ls /sys/class/net/ 2>/dev/null | grep -v "^lo$"); do
        local state=$(cat "/sys/class/net/$iface/operstate" 2>/dev/null || echo "N/A")
        if [ "$state" != "up" ]; then
            continue
        fi
        local mac=$(cat "/sys/class/net/$iface/address" 2>/dev/null || echo "N/A")
        local speed=$(cat "/sys/class/net/$iface/speed" 2>/dev/null || echo "N/A")
        local mtu=$(cat "/sys/class/net/$iface/mtu" 2>/dev/null || echo "N/A")
        local ip=$(ip addr show "$iface" 2>/dev/null | grep 'inet ' | awk '{print $2}' | cut -d'/' -f1 | head -1 || echo "N/A")

        local speed_str=""
        if [ "$speed" != "N/A" ] && [ "$speed" -gt 0 ] 2>/dev/null; then
            speed_str="${speed}Mbps"
        elif [ "$speed" = "N/A" ]; then
            speed_str="N/A"
        else
            speed_str="Unknown"
        fi

        result="${result}${iface}: IP=${ip}, MAC=${mac}, Speed=${speed_str}, MTU=${mtu}, State=${state}\n"
        up_count=$((up_count + 1))
    done
    if [ $up_count -eq 0 ]; then
        echo "No active interfaces found"
    else
        echo -e "$result"
    fi
}

# Get CPU L1 data cache size
get_cpu_l1_cache() {
    local cache_val="N/A"

    if command -v lscpu &>/dev/null; then
        cache_val=$(lscpu 2>/dev/null | grep -i 'L1d.*cache' | awk -F: '{print $2}' | awk '{print $1, $2}' | sed 's/^ *//')
        if [ -n "$cache_val" ] && [ "$cache_val" != "N/A" ] && [ "$cache_val" != " " ]; then
            echo "$cache_val"
            return
        fi

        cache_val=$(lscpu -C 2>/dev/null | grep 'L1d' | head -1 | awk '{print $3}')
        if [ -n "$cache_val" ] && [ "$cache_val" != "N/A" ]; then
            echo "$cache_val"
            return
        fi
    fi

    if [ -f /sys/devices/system/cpu/cpu0/cache/index0/size ]; then
        local single_core=$(cat /sys/devices/system/cpu/cpu0/cache/index0/size 2>/dev/null)
        if [ -n "$single_core" ]; then
            local core_count=$(nproc 2>/dev/null || echo 1)
            local single_num=$(echo "$single_core" | sed 's/[KkMmGgTt].*//')
            if [[ "$single_core" == *K* ]] || [[ "$single_core" == *k* ]]; then
                cache_val=$(awk "BEGIN {printf \"%.0f\", $single_num * $core_count / 1024}")"M"
            elif [[ "$single_core" == *M* ]] || [[ "$single_core" == *m* ]]; then
                cache_val=$(awk "BEGIN {printf \"%.0f\", $single_num * $core_count}")"M"
            else
                cache_val="$single_core"
            fi
            echo "$cache_val"
            return
        fi
    fi
    echo "N/A"
}

