        local numa_detail=$(get_numa_topology 2>/dev/null || echo "N/A")
        local mem_usage_rate=$(get_memory_usage_rate 2>/dev/null || echo "N/A")
        local thp_status=$(get_thp_status 2>/dev/null || echo "N/A")
        local hugepages=$(get_hugepages_count 2>/dev/null || echo "N/A")
        local net_bond=$(get_network_bond 2>/dev/null || echo "N/A")
        local net_count=$(get_network_interface_count 2>/dev/null || echo "N/A")
        local disk_queue=$(get_benchmark_disk_queue_depth 2>/dev/null || echo "N/A")
        local disk_ra=$(get_benchmark_disk_read_ahead 2>/dev/null || echo "N/A")
        local disk_trim_val=$(get_benchmark_disk_trim 2>/dev/null || echo "N/A")
        local disk_ms=$(get_benchmark_disk_max_sectors 2>/dev/null || echo "N/A")
        local mount_opts=$(get_benchmark_mount_options 2>/dev/null || echo "N/A")
        
        # Collect network basic lines
        local network_lines=()
        while IFS= read -r line; do
            if [ -n "$line" ]; then
                network_lines+=("$line")
            fi
        done < <(get_network_info 2>/dev/null | grep -v "^$")
        
        # Collect network advanced lines
        local net_adv_lines=()
        while IFS= read -r line; do
            [ -n "$line" ] && net_adv_lines+=("$line")
        done < <(get_network_advanced_info 2>/dev/null | grep -v "^$")
        
        # Build combined network lines
        local all_network_lines=()
        for nl in "${network_lines[@]}"; do
            all_network_lines+=("$nl")
        done
        for nal in "${net_adv_lines[@]}"; do
            all_network_lines+=("$nal")
        done

        print_system_info "$report_file" "" "$os_info" "$kernel_version" "$uptime"
        print_cpu_info "$report_file" "" \
            "$cpu_arch" "$machine_type" "$cpu_model" "$cpu_physical_cores" "$cpu_logical_cores" "$cpu_freq" \
            "$cpu_l1d_cache" "$cpu_l2_cache" "$cpu_l3_cache" "$cpu_features" "$cpu_freq_min" "$cpu_freq_max" "$cpu_governor"
        print_memory_info "$report_file" "" \
            "$mem_total" "$mem_available" "$mem_type" "$mem_freq" "$mem_channels" \
            "$mem_slots_detail" "$numa_count" "$numa_detail" \
            "$mem_usage_rate" "$thp_status" "$hugepages"
        
        local resolved_io_path="$IO_PATH"
        
        # Print mount options before disk information
        print_mount_options "$report_file" "" "$mount_opts"
        
        local disk_lines=()
        while IFS= read -r line; do
            disk_lines+=("$line")
        done < <(get_disk_info_detailed 2>/dev/null)
        print_disk_info_section "$report_file" "" "$resolved_io_path" "${disk_lines[@]}"
        
        local disk_usage_lines=()
        while IFS= read -r line; do
            disk_usage_lines+=("$line")
        done < <(get_disk_usage_info 2>/dev/null)
        print_disk_usage_section "$report_file" "" "${disk_usage_lines[@]}"
        
        local inode_lines=()
        while IFS= read -r line; do
            inode_lines+=("$line")
        done < <(get_inode_info 2>/dev/null)
        print_inode_section "$report_file" "" "${inode_lines[@]}"
        print_disk_io_settings "$report_file" "" "$disk_queue" "$disk_ra" "$disk_trim_val" "$disk_ms"
        print_network_info "$report_file" "" "$net_count" "$net_bond" "${all_network_lines[@]}"
    fi
    
    echo "$report_file"
}

