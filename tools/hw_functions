# Print memory information section (merged basic + slots + NUMA + THP/hugepages at end)
print_memory_info() {
    local report_file="$1"
    local prefix="$2"
    local mem_total="$3"
    local mem_available="$4"
    local mem_type="$5"
    local mem_freq="$6"
    local mem_channels="$7"
    local mem_slots_detail="$8"
    local numa_node_count="$9"
    local numa_detail_lines="${10}"
    local usage_rate="${11}"
    local thp_status="${12}"
    local hugepages_count="${13}"

    printf -- "%s[Memory Information]\n" "$prefix" >> "$report_file"
    printf -- "%s--------------------------------------------------------------------------------\n" "$prefix" >> "$report_file"
    printf -- "%s%-20s %s MB\n" "$prefix" "Total:" "$mem_total" >> "$report_file"
    printf -- "%s%-20s %s MB\n" "$prefix" "Available:" "$mem_available" >> "$report_file"
    printf -- "%s%-20s %s\n" "$prefix" "Type:" "$mem_type" >> "$report_file"
    printf -- "%s%-20s %s\n" "$prefix" "Frequency:" "$mem_freq" >> "$report_file"
    printf -- "%s%-20s %s\n" "$prefix" "Channels:" "$mem_channels" >> "$report_file"
    if [ -n "$usage_rate" ] && [ "$usage_rate" != "N/A" ]; then
        printf -- "%s%-20s %s\n" "$prefix" "Usage Rate:" "$usage_rate" >> "$report_file"
    fi
    # Memory settings at end of Memory Information
    if [ -n "$thp_status" ] && [ "$thp_status" != "N/A" ]; then
        printf -- "%s%-20s %s\n" "$prefix" "THP Status:" "$thp_status" >> "$report_file"
    fi
    if [ -n "$hugepages_count" ] && [ "$hugepages_count" != "N/A" ]; then
        printf -- "%s%-20s %s\n" "$prefix" "Hugepages:" "$hugepages_count" >> "$report_file"
    fi
    printf -- "\n" >> "$report_file"

    # Memory slots detail
    if [ -n "$mem_slots_detail" ]; then
        printf -- "%s[Memory Slots Detail]\n" "$prefix" >> "$report_file"
        printf -- "%s--------------------------------------------------------------------------------\n" "$prefix" >> "$report_file"
        printf -- "%s" "$mem_slots_detail" >> "$report_file"
        printf -- "\n" >> "$report_file"
    fi

    # NUMA topology
    if [ "$numa_node_count" != "N/A" ] || [ -n "$numa_detail_lines" ]; then
        printf -- "%s[NUMA Topology]\n" "$prefix" >> "$report_file"
        printf -- "%s--------------------------------------------------------------------------------\n" "$prefix" >> "$report_file"
        printf -- "%s%-20s %s\n" "$prefix" "Node Count:" "$numa_node_count" >> "$report_file"
        if [ -n "$numa_detail_lines" ]; then
            printf -- "%s%-20s\n" "$prefix" "Topology Detail:" >> "$report_file"
            while IFS= read -r line; do
                [ -n "$line" ] && printf -- "%s  %s\n" "$prefix" "$line" >> "$report_file"
            done <<< "$numa_detail_lines"
        fi
        printf -- "\n" >> "$report_file"
    fi
}

