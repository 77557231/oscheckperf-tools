        local cpu_l3_cache=$(get_cpu_l3_cache 2>/dev/null || echo "N/A")
        local cpu_features=$(get_cpu_features 2>/dev/null || echo "N/A")
        local cpu_freq_min=$(get_cpu_freq_min 2>/dev/null || echo "N/A")
        local cpu_freq_max=$(get_cpu_freq_max 2>/dev/null || echo "N/A")
        local cpu_governor=$(get_cpu_governor 2>/dev/null || echo "N/A")
        local mem_total=$(get_memory_size_mb 2>/dev/null || echo "N/A")
        local mem_available=$(get_memory_available_mb 2>/dev/null || echo "N/A")
        local mem_type=$(get_memory_type 2>/dev/null || echo "N/A")
        local mem_freq=$(get_memory_freq 2>/dev/null || echo "N/A")
        local mem_channels=$(get_memory_channels 2>/dev/null || echo "N/A")
        local mem_slots_detail=$(get_memory_slots_detail 2>/dev/null)
