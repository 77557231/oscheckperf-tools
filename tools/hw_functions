# Get benchmark disk device name from IO_PATH
get_benchmark_disk_device() {
    local io_path="${IO_PATH:-.}"
    local device=$(df "$io_path" 2>/dev/null | tail -1 | awk '{print $1}')
    if [ -n "$device" ]; then
        local basename_dev=$(basename "$device")
        if [ -d "/sys/block/$basename_dev" ]; then
            echo "$basename_dev"
            return
        fi
        if command -v lsblk &>/dev/null; then
            local disk=$(lsblk -ndo pkname "$device" 2>/dev/null | grep -v "^$" | head -1)
            if [ -n "$disk" ]; then
                echo "$disk"
                return
            fi
        fi
        for dm_dir in /sys/block/dm-*; do
            if [ -d "$dm_dir/slaves" ]; then
                local dev_name=$(cat "$dm_dir/dm/name" 2>/dev/null)
                if [ -n "$dev_name" ] && echo "$basename_dev" | grep -q "$dev_name"; then
                    local slave=$(ls "$dm_dir/slaves/" 2>/dev/null | head -1)
                    if [ -n "$slave" ]; then
                        echo "$slave" | sed 's/[0-9]*$//; s/p[0-9]*$//'
                        return
                    fi
                fi
            fi
        done
        echo "$basename_dev" | sed 's/[0-9]*$//; s/p[0-9]*$//; s/-[0-9]*$//'
    else
        echo ""
    fi
}

