    local cpu_l2_cache="N/A"
    local cpu_l3_cache="N/A"
    local cpu_features=""
    local cpu_freq_min="N/A"
    local cpu_freq_max="N/A"
    local cpu_governor="N/A"
    # NUMA
    local numa_node_count="N/A"
    # Memory Advanced
    local mem_usage_rate="N/A"
    local thp_status=""
    local hugepages_count="N/A"
    # IO Advanced
