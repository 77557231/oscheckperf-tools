#!/bin/bash
# Hardware information collection functions
# This file contains all hardware info functions used by oscheckperf
# Both local and remote execution use the same source

# Get CPU architecture
get_cpu_arch() {
    uname -m 2>/dev/null || echo "unknown"
}

# Get machine type (using systemd-detect-virt or fallback)
get_machine_type() {
    local machine_type="Physical Machine"
    
    if command -v systemd-detect-virt &>/dev/null; then
        local virt_output=$(systemd-detect-virt 2>/dev/null)
        case "$virt_output" in
            "kvm") machine_type="Virtual Machine (KVM)" ;;
            "qemu") machine_type="Virtual Machine (QEMU)" ;;
            "vmware") machine_type="Virtual Machine (VMware)" ;;
            "virtualbox") machine_type="Virtual Machine (VirtualBox)" ;;
            "hyperv") machine_type="Virtual Machine (Hyper-V)" ;;
            "xen") machine_type="Virtual Machine (Xen)" ;;
            "none") machine_type="Physical Machine" ;;
            *) machine_type="Unknown" ;;
        esac
    else
        if grep -qi 'kvm' /proc/cpuinfo 2>/dev/null || grep -qi 'qemu' /sys/devices/virtual/dmi/id/product_name 2>/dev/null; then
            machine_type="Virtual Machine (KVM/QEMU)"
        elif grep -qi 'vmware' /sys/devices/virtual/dmi/id/product_name 2>/dev/null; then
            machine_type="Virtual Machine (VMware)"
        elif grep -qi 'hypervisor' /proc/cpuinfo 2>/dev/null; then
            machine_type="Virtual Machine (Unknown)"
        fi
    fi
    
    echo "$machine_type"
}

# Get operating system information
get_os_info() {
    if [ -f /etc/redhat-release ]; then
        cat /etc/redhat-release
        return
    fi
    
    if [ -f /etc/euleros-release ]; then
        echo "EulerOS $(cat /etc/euleros-release | awk '{print $3}')"
        return
    fi
    
    if [ -f /etc/openEuler-release ]; then
        cat /etc/openEuler-release | awk '{print $1, $3}'
        return
    fi
    
    if [ -f /etc/os-release ]; then
        local pretty_name=$(grep -oP 'PRETTY_NAME="?\K[^"]+' /etc/os-release 2>/dev/null)
        if [ -n "$pretty_name" ]; then
            echo "$pretty_name"
            return
        fi
    fi
    
    if [ -f /etc/lsb-release ]; then
        local os_name=$(grep -oP 'DISTRIB_ID=\K.*' /etc/lsb-release 2>/dev/null)
        local os_version=$(grep -oP 'DISTRIB_RELEASE=\K.*' /etc/lsb-release 2>/dev/null)
        echo "$os_name $os_version"
        return
    fi
    
    echo "Unknown"
}

# Get kernel version
get_kernel_version() {
    uname -r 2>/dev/null || echo "unknown"
}

# Get system uptime information
get_uptime_info() {
    if command -v uptime &>/dev/null; then
        uptime | sed -n 's/.* up \(.*\) load.*/\1/p' | sed 's/^[[:space:]]*//' | sed 's/[[:space:]]*$//' | sed 's/, *[0-9]* *user[s]*,* *$//'
    else
        echo "N/A"
    fi
}

# Get CPU model
get_cpu_model() {
    local cpu_model="unknown"

    if command -v lscpu &>/dev/null; then
        cpu_model=$(lscpu 2>/dev/null | grep -i "BIOS Model name" | awk -F: '{print $2}' | sed 's/^ *//' | sed 's/ *$//')
    fi

    if [ -z "$cpu_model" ] || [ "$cpu_model" = "unknown" ]; then
        if command -v lscpu &>/dev/null; then
            cpu_model=$(lscpu 2>/dev/null | grep -i "Model name" | grep -v "BIOS" | awk -F: '{print $2}' | sed 's/^ *//' | sed 's/ *$//')
        fi
    fi

    if [ -z "$cpu_model" ] || [ "$cpu_model" = "unknown" ]; then
        if [ -f /proc/cpuinfo ]; then
            cpu_model=$(grep -m 1 'model name' /proc/cpuinfo | sed 's/model name\s*: //' 2>/dev/null)
        fi
    fi

    if [ -z "$cpu_model" ] || [ "$cpu_model" = "unknown" ]; then
        if command -v lscpu &>/dev/null; then
            local cpu_part=$(lscpu 2>/dev/null | grep -i "CPU part" | awk '{print $NF}')
            local cpu_vendor=$(lscpu 2>/dev/null | grep -i "Vendor ID:" | awk '{print $NF}')
            if [ -n "$cpu_part" ] && [ -n "$cpu_vendor" ]; then
                if [ "$cpu_vendor" = "HiSilicon" ] || [ "$cpu_vendor" = "hisilicon" ]; then
                    cpu_model="Kunpeng-920"
                else
                    cpu_model="${cpu_vendor} ${cpu_part}"
                fi
            fi
        fi
    fi

    if [ -z "$cpu_model" ] || [ "$cpu_model" = "unknown" ]; then
        cpu_model="unknown"
    fi

    echo "$cpu_model"
}

# Get CPU physical cores count
get_cpu_physical_cores() {
    if command -v lscpu &>/dev/null; then
        local sockets=$(lscpu 2>/dev/null | grep -i 'Socket(s)' | awk '{print $NF}')
        local cores_per_socket=$(lscpu 2>/dev/null | grep -i 'Core(s) per socket' | awk '{print $NF}')
        if [ -n "$sockets" ] && [ -n "$cores_per_socket" ] && [ "$sockets" -gt 0 ] 2>/dev/null && [ "$cores_per_socket" -gt 0 ] 2>/dev/null; then
            echo $((sockets * cores_per_socket))
            return
        fi
    fi

    if [ -f /proc/cpuinfo ]; then
        local cores=$(grep -c 'physical id' /proc/cpuinfo 2>/dev/null)
        if [ -n "$cores" ] && [ "$cores" -gt 0 ] 2>/dev/null; then
            echo "$cores"
            return
        fi
    fi

    nproc 2>/dev/null || echo "unknown"
}
# Get CPU logical cores count
get_cpu_logical_cores() {
    nproc 2>/dev/null || grep -c ^processor /proc/cpuinfo 2>/dev/null || echo "unknown"
}

# Get CPU frequency (GHz)
get_cpu_freq() {
    if [ -f /proc/cpuinfo ]; then
        local freq=$(grep -m 1 'cpu MHz' /proc/cpuinfo | awk '{print $4}')
        if [ -n "$freq" ]; then
            awk "BEGIN {printf \"%.2f\", $freq / 1000}"
            return
        fi
    fi
    local freq=$(cat /sys/devices/system/cpu/cpu0/cpufreq/cpuinfo_max_freq 2>/dev/null)
    if [ -n "$freq" ] && [ "$freq" != "0" ]; then
        awk "BEGIN {printf \"%.2f\", $freq / 1000000}"
        return
    fi
    if command -v lscpu &>/dev/null; then
        freq=$(lscpu 2>/dev/null | grep -i 'CPU max MHz' | awk '{print $NF}')
        if [ -n "$freq" ] && [ "$freq" != "0" ]; then
            awk "BEGIN {printf \"%.2f\", $freq / 1000}"
            return
        fi
    fi
    if command -v dmidecode &>/dev/null; then
        freq=$(dmidecode -t processor 2>/dev/null | grep -i 'Current Speed' | head -1 | awk '{print $3}')
        if [ -n "$freq" ] && [ "$freq" != "0" ]; then
            awk "BEGIN {printf \"%.2f\", $freq / 1000}"
            return
        fi
    fi
    if [ -f /proc/cpuinfo ]; then
        freq=$(grep -m 1 'BogoMIPS' /proc/cpuinfo | awk '{print $3}')
        if [ -n "$freq" ] && [ "$freq" -gt 1000 ] 2>/dev/null; then
            awk "BEGIN {printf \"%.2f\", $freq / 1000}"
            return
        fi
    fi
    echo "unknown"
}

# Get memory size (MB)
get_memory_size_mb() {
    if [ -f /proc/meminfo ]; then
        awk '/MemTotal/ {printf "%.0f", $2/1024}' /proc/meminfo 2>/dev/null || echo "unknown"
    else
        echo "unknown"
    fi
}

# Get available memory (MB)
get_memory_available_mb() {
    if [ -f /proc/meminfo ]; then
        awk '/MemAvailable/ {printf "%.0f", $2/1024}' /proc/meminfo 2>/dev/null || echo "unknown"
    else
        echo "unknown"
    fi
}

# Get memory type (DDR4/DDR5 etc.)
get_memory_type() {
    local machine_type=$(get_machine_type 2>/dev/null)
    if echo "$machine_type" | grep -qi "virtual"; then
        echo "N/A (virtual machine)"
        return
    fi
    
    if command -v dmidecode &>/dev/null; then
        local mem_type=$(dmidecode -t memory 2>/dev/null | awk '/Memory Device/{in_device=1;next} in_device && /^[ \t]*Type:/{print $2;exit}')
        if [ -n "$mem_type" ] && [ "$mem_type" != "Unknown" ]; then
            echo "$mem_type"
            return
        fi
        mem_type=$(dmidecode -t memory 2>/dev/null | grep -A5 'Memory Device' | grep -m 1 'Type:' | sed 's/Type:\s*//' | sed 's/^[ \t]*//' | sed 's/[ \t]*$//' 2>/dev/null)
        if [ -n "$mem_type" ] && [ "$mem_type" != "Unknown" ] && [ "$mem_type" != "Error" ]; then
            echo "$mem_type"
            return
        fi
    fi
    
    local dmesg_type=$(dmesg 2>/dev/null | grep -i 'DDR' | head -1 | grep -o 'DDR[0-9]*' | head -1)
    if [ -n "$dmesg_type" ]; then
        echo "$dmesg_type"
        return
    fi
    
    echo "unknown (requires root for dmidecode)"
}

# Get memory frequency (MHz)
get_memory_freq() {
    local machine_type=$(get_machine_type 2>/dev/null)
    if echo "$machine_type" | grep -qi "virtual"; then
        echo "N/A (virtual machine)"
        return
    fi
    
    if ! command -v dmidecode &>/dev/null; then
        echo "unknown (dmidecode not installed)"
        return
    fi
    
    local dmidecode_output=""
    
    if [ "$(whoami)" = "root" ]; then
        dmidecode_output=$(dmidecode -t memory 2>/dev/null)
    elif sudo -n true 2>/dev/null; then
        dmidecode_output=$(sudo -n dmidecode -t memory 2>/dev/null)
    else
        echo "unknown (requires root)"
        return
    fi
    
    local freq=$(echo "$dmidecode_output" | grep -m 1 'Configured Clock Speed' | awk '{print $4}' 2>/dev/null)
    if [ -n "$freq" ] && [ "$freq" -gt 0 ] 2>/dev/null; then
        echo "${freq} MHz"
        return
    fi
    
    freq=$(echo "$dmidecode_output" | grep -m 1 'Speed' | awk '{print $2}' 2>/dev/null)
    if [ -n "$freq" ] && [ "$freq" != "Unknown" ] && [ "$freq" -gt 0 ] 2>/dev/null; then
        echo "${freq} MHz"
        return
    fi
    
    echo "unknown (requires root)"
}

# Get memory channels count
get_memory_channels() {
    if command -v dmidecode &>/dev/null; then
        local channels=$(dmidecode -t memory 2>/dev/null | grep -i 'Bank Locator:' | grep -o 'SOCKET [0-9]* CHANNEL [0-9]*' | sort -u | wc -l)
        if [ "$channels" -gt 0 ] && [ "$channels" -lt 100 ]; then
            echo "$channels"
            return
        fi
        channels=$(dmidecode -t memory 2>/dev/null | grep -i 'Bank Locator:' | grep -o 'CHANNEL [0-9]*' | sort -u | wc -l)
        if [ "$channels" -gt 0 ] && [ "$channels" -lt 100 ]; then
            echo "$channels"
            return
        fi
    fi
    if command -v numactl &>/dev/null; then
        local nodes=$(numactl --hardware 2>/dev/null | grep -c '^node ' 2>/dev/null)
        if [ "$nodes" -gt 0 ] && [ "$nodes" -lt 100 ]; then
            echo "$nodes"
            return
        fi
    fi
    if [ -d /sys/devices/system/node/ ]; then
        local node_count=$(ls /sys/devices/system/node/ | grep -c '^node[0-9]*$')
        if [ "$node_count" -gt 0 ] && [ "$node_count" -lt 100 ]; then
            echo "$node_count"
            return
        fi
    fi
    echo "unknown (requires root for dmidecode)"
}

# Get memory slots detailed information
get_memory_slots_detail() {
    if ! command -v dmidecode &>/dev/null; then
        if [ -x "/usr/sbin/dmidecode" ]; then
            local slots_output=$(/usr/sbin/dmidecode -t memory 2>&1)
            if echo "$slots_output" | grep -qi "permission denied"; then
                echo "N/A (requires root privileges for dmidecode)"
                return
            fi
            echo "N/A (dmidecode execution failed)"
            return
        fi
        echo "N/A (dmidecode not installed)"
        return
    fi
    
    local slots_output=""
    local success=0
    
    if [ "$(whoami)" = "root" ]; then
        slots_output=$(/usr/sbin/dmidecode -t memory 2>&1)
        if echo "$slots_output" | grep -q "Memory Device\|Physical Memory Array"; then
            success=1
        fi
    elif sudo -n true 2>/dev/null; then
        slots_output=$(sudo -n /usr/sbin/dmidecode -t memory 2>&1)
        if echo "$slots_output" | grep -q "Memory Device\|Physical Memory Array"; then
            success=1
        fi
    fi
    
    if [ $success -eq 0 ]; then
        if echo "$slots_output" | grep -qi "permission denied\|password is required"; then
            echo "N/A (requires root privileges for dmidecode)"
        else
            echo "N/A (dmidecode execution failed)"
        fi
        return
    fi
    
    local total_slots=$(echo "$slots_output" | grep -A10 'Physical Memory Array' | grep -i 'Number Of Devices' | awk '{print $NF}')
    if [ -z "$total_slots" ] || [ "$total_slots" = "0" ]; then
        total_slots=$(echo "$slots_output" | grep -c 'Memory Device')
    fi
    
    if [ -z "$total_slots" ] || [ "$total_slots" = "0" ]; then
        local machine_type=$(get_machine_type 2>/dev/null)
        if echo "$machine_type" | grep -qi "virtual"; then
            echo "N/A (virtual machine)"
        else
            echo "N/A (no memory slots detected)"
        fi
        return
    fi
    
    local slot_results=$(echo "$slots_output" | awk '
        BEGIN { slot_count=0; in_device=0; used_count=0; found_size=0 }
        /Memory Device/ {
            if (in_device) {
                print "Slot " slot_count ":"
                if (bank_locator != "") print "  Locator: " bank_locator
                else if (locator != "") print "  Locator: " locator
                if (found_size == 1) {
                    print "  Size: " size
                } else {
                    print "  Size: None"
                }
                if (mem_type != "" && mem_type != "Unknown") print "  Type: " mem_type
                if (manufacturer != "" && manufacturer != "Unknown") print "  Manufacturer: " manufacturer
                else if (size ~ /No Module Installed/) print "  Manufacturer: NO DIMM"
                if (part_num != "" && part_num != "Unknown") print "  Part Number: " part_num
                else if (size ~ /No Module Installed/) print "  Part Number: NO DIMM"
                if (size !~ /^(No Module Installed|Unknown)$/ && found_size == 1 && size !~ /^0+\s*(MB|GB|bytes)$/) {
                    used_count++
                }
            }
            slot_count++
            in_device=1
            bank_locator=""
            locator=""
            size=""
            mem_type=""
            manufacturer=""
            part_num=""
            found_size=0
            next
        }
        in_device && /^[ \t]*Bank Locator:/ { bank_locator=substr($0, index($0,$3)); gsub(/^[ \t]+|[ \t]+$/, "", bank_locator); next }
        in_device && /^[ \t]*Locator:/ { locator=substr($0, index($0,$2)); gsub(/^[ \t]+|[ \t]+$/, "", locator); next }
        in_device && /^[ \t]*Size:/ { 
            size=substr($0, index($0,$2)); 
            gsub(/^[ \t]+|[ \t]+$/, "", size); 
            if (size !~ /^(No Module Installed|Unknown)$/) found_size=1;
            next 
        }
        in_device && /^[ \t]*Type:/ { mem_type=substr($0, index($0,$2)); gsub(/^[ \t]+|[ \t]+$/, "", mem_type); next }
        in_device && /^[ \t]*Manufacturer:/ { manufacturer=substr($0, index($0,$2)); gsub(/^[ \t]+|[ \t]+$/, "", manufacturer); next }
        in_device && /^[ \t]*Part Number:/ { part_num=substr($0, index($0,$3)); gsub(/^[ \t]+|[ \t]+$/, "", part_num); next }
        END {
            if (in_device) {
                print "Slot " slot_count ":"
                if (bank_locator != "") print "  Locator: " bank_locator
                else if (locator != "") print "  Locator: " locator
                if (found_size == 1) {
                    print "  Size: " size
                } else {
                    print "  Size: None"
                }
                if (mem_type != "" && mem_type != "Unknown") print "  Type: " mem_type
                if (manufacturer != "" && manufacturer != "Unknown") print "  Manufacturer: " manufacturer
                else if (size ~ /No Module Installed/) print "  Manufacturer: NO DIMM"
                if (part_num != "" && part_num != "Unknown") print "  Part Number: " part_num
                else if (size ~ /No Module Installed/) print "  Part Number: NO DIMM"
                if (size !~ /^(No Module Installed|Unknown)$/ && found_size == 1 && size !~ /^0+\s*(MB|GB|bytes)$/) {
                    used_count++
                }
            }
            print "USED_COUNT=" used_count
        }
    ')
    
    local used_slots=$(echo "$slot_results" | grep 'USED_COUNT=' | awk -F'=' '{print $2}')
    slot_results=$(echo "$slot_results" | grep -v 'USED_COUNT=')
    
    echo "Total Slots: $total_slots"
    echo "Used Slots: $used_slots"
    echo "$slot_results"
}

# Get network bond info
get_network_bond() {
    if [ -d /proc/net/bonding/ ]; then
        local bonds=$(ls /proc/net/bonding/ 2>/dev/null | tr '\n' ', ')
        if [ -n "$bonds" ]; then
            echo "$bonds"
            return
        fi
    fi
    echo "None"
}

# Get network interface count
get_network_interface_count() {
    ls /sys/class/net/ 2>/dev/null | grep -v "^lo$" | wc -l 2>/dev/null || echo "0"
}

# Get detailed disk info
get_disk_info_detailed() {
    if command -v lsblk &>/dev/null; then
        while read -r line; do
            name=$(echo "$line" | awk '{print $1}' | sed 's/^[├└─ ]*//')
            size=$(echo "$line" | awk '{print $2}')
            type=$(echo "$line" | awk '{print $3}')
            fstype=$(echo "$line" | awk '{print $4}')
            mountpoint=$(echo "$line" | awk '{print $5}')
            
            local vendor="-"
            local model="-"
            local scheduler="-"
            local disk_type="-"
            local wcache="-"
            
            if [ "$type" = "disk" ] || [ "$type" = "rom" ]; then
                if [ -d "/sys/block/$name/device" ]; then
                    if [ -f "/sys/block/$name/device/vendor" ]; then
                        vendor=$(cat "/sys/block/$name/device/vendor" 2>/dev/null | tr -d ' ')
                    fi
                    if [ -f "/sys/block/$name/device/model" ]; then
                        model=$(cat "/sys/block/$name/device/model" 2>/dev/null | sed 's/^[ \t]*//;s/[ \t]*$//')
                    fi
                    if [ -f "/sys/block/$name/queue/scheduler" ]; then
                        scheduler=$(cat "/sys/block/$name/queue/scheduler" 2>/dev/null | grep -o '\[.*\]' | tr -d '[]')
                        [ -z "$scheduler" ] && scheduler=$(cat "/sys/block/$name/queue/scheduler" 2>/dev/null | awk '{print $1}')
                    fi
                    if [ -f "/sys/block/$name/queue/rotational" ]; then
                        rotational=$(cat "/sys/block/$name/queue/rotational" 2>/dev/null)
                        if [ "$rotational" = "0" ]; then
                            disk_type="SSD"
                        elif [ "$rotational" = "1" ]; then
                            disk_type="HDD"
                        fi
                    fi
                    if [ -f "/sys/block/$name/queue/write_cache" ]; then
                        wcache=$(cat "/sys/block/$name/queue/write_cache" 2>/dev/null)
                        if [ "$wcache" = "write back" ] || [ "$wcache" = "1" ]; then
                            wcache="WriteBack"
                        elif [ "$wcache" = "write through" ] || [ "$wcache" = "0" ]; then
                            wcache="WriteThrough"
                        else
                            wcache="Unknown"
                        fi
                    fi
                fi
            fi
            
            [ -z "$fstype" ] && fstype="-"
            [ -z "$mountpoint" ] && mountpoint="-"
            [ -z "$vendor" ] && vendor="-"
            [ -z "$model" ] && model="-"
            [ -z "$scheduler" ] && scheduler="-"
            [ -z "$wcache" ] && wcache="-"
            
            echo "$name|$size|$type|$fstype|$mountpoint|$disk_type|$vendor|$model|$scheduler|$wcache"
        done < <(lsblk -no NAME,SIZE,TYPE,FSTYPE,MOUNTPOINT 2>/dev/null | grep -v "^loop" | grep -v "^NAME" | grep -v "^sr")
    else
        echo "N/A"
    fi
}

# Get disk usage information
get_disk_usage_info() {
    if command -v df &>/dev/null; then
        df -h 2>/dev/null | grep -v "^Filesystem" | while read -r line; do
            fs=$(echo "$line" | awk '{print $1}')
            size=$(echo "$line" | awk '{print $2}')
            used=$(echo "$line" | awk '{print $3}')
            avail=$(echo "$line" | awk '{print $4}')
            pct=$(echo "$line" | awk '{print $5}')
            mount=$(echo "$line" | awk '{print $6}')
            
            [ -z "$fs" ] && fs="-"
            [ -z "$size" ] && size="-"
            [ -z "$used" ] && used="-"
            [ -z "$avail" ] && avail="-"
            [ -z "$pct" ] && pct="-"
            [ -z "$mount" ] && mount="-"
            
            echo "$fs|$size|$used|$avail|$pct|$mount"
        done
    else
        echo "N/A"
    fi
}

