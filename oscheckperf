# Main installation function
install_components() {
    local target="$1"
    local local_ip=$(get_machine_ip)
    local install_dir="$BASE_DIR"
    
    echo "=== Oscheckperf Installation and Distribution ==="
    
    # Determine what to install
    local install_all=false
    local install_script=false
    
    case "$target" in
        oscheckperf)
            install_script=true
            ;;
        all)
            install_all=true
            install_script=true
            # Delete existing directory for clean install
            if [ -d "$install_dir" ]; then
                echo "  Removing existing installation directory: $install_dir"
                rm -rf "$install_dir"
            fi
            ;;
        *)
            echo "Error: Invalid installation target '$target'"
            echo "Valid targets: oscheckperf, all"
            exit 1
            ;;
    esac
    
    # Check build dependencies if installing all
    if [ "$install_all" = "true" ]; then
        check_build_dependencies || exit 1
    fi
    
    # Local installation
    if [ "$install_all" = "true" ]; then
        install_sysbench || exit 1
        install_sshpass || exit 1
        install_fio || exit 1
        install_iperf3 || exit 1
        install_numactl || exit 1
        install_ethtool || exit 1
        install_jq || exit 1
        install_oscheckperf_script || exit 1
    elif [ "$install_script" = "true" ]; then
        install_oscheckperf_script || exit 1
    fi
    
    # Distribute to remote servers
    if [ ${#target_servers[@]} -gt 0 ]; then
        echo "[Step 2/2] Distributing to target servers..."
        echo "  Server list: ${target_servers[*]}"
        
        # Arrays to track skipped servers
        local -a skipped_arch=()
        local -a skipped_os=()
        local -a skipped_distro=()
        local -a failed=()
        
        for ip in "${target_servers[@]}"; do
            distribute_to_server "$ip" "$local_ip" "$target"
            local ret=$?
            case $ret in
                2)
                    skipped_arch+=("$ip")
                    ;;
                3)
                    skipped_os+=("$ip")
                    ;;
                4)
                    skipped_distro+=("$ip")
                    ;;
                1)
                    failed+=("$ip")
                    ;;
            esac
        done
        
        # Display skipped servers summary
        if [ ${#skipped_arch[@]} -gt 0 ] || [ ${#skipped_os[@]} -gt 0 ] || [ ${#skipped_distro[@]} -gt 0 ] || [ ${#failed[@]} -gt 0 ]; then
            echo ""
            echo "=== Skipped/Failed Servers ==="
            if [ ${#skipped_arch[@]} -gt 0 ]; then
                echo "  Architecture mismatch (skipped):"
                for ip in "${skipped_arch[@]}"; do
                    echo "    - $ip"
                done
            fi
            if [ ${#skipped_os[@]} -gt 0 ]; then
                echo "  OS mismatch (skipped):"
                for ip in "${skipped_os[@]}"; do
                    echo "    - $ip"
                done
            fi
            if [ ${#skipped_distro[@]} -gt 0 ]; then
                echo "  Distribution mismatch (skipped):"
                for ip in "${skipped_distro[@]}"; do
                    echo "    - $ip"
                done
                echo "  Note: Servers with distribution mismatch require manual installation"
            fi
            if [ ${#failed[@]} -gt 0 ]; then
                echo "  Distribution failed:"
                for ip in "${failed[@]}"; do
                    echo "    - $ip"
                done
            fi
        fi
    fi
    
    echo ""
    echo "=== Installation Summary ==="
    echo "  Installation directory: $install_dir"
    if [ "$install_all" = "true" ]; then
        if command -v sysbench &> /dev/null; then
            echo "  - sysbench: installed ($(sysbench --version))"
        fi
        if command -v sshpass &> /dev/null; then
            echo "  - sshpass: installed ($(sshpass -V 2>&1 | head -1))"
        fi
        if command -v fio &> /dev/null; then
            echo "  - fio: installed ($(fio --version | head -1))"
        fi
        if command -v iperf3 &> /dev/null; then
            echo "  - iperf3: installed ($(iperf3 --version | head -1))"
        fi
        if command -v numactl &> /dev/null; then
            echo "  - numactl: installed ($(numactl --version 2>&1 | head -1))"
        fi
        if command -v ethtool &> /dev/null; then
            echo "  - ethtool: installed ($(ethtool --version 2>&1 | head -1))"
        fi
        if command -v jq &> /dev/null; then
            echo "  - jq: installed ($(jq --version))"
        fi
        echo "  - oscheckperf: installed"
    elif [ "$install_script" = "true" ]; then
        echo "  - oscheckperf: installed"
    fi
}

