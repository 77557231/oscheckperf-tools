            if [[ "$line" == NUMA_NODE_COUNT:* ]]; then numa_node_count="${line#NUMA_NODE_COUNT: }"
            else numa_detail_lines="$numa_detail_lines$line"$'\n'
            fi
        elif [ "$in_memory_advanced" = "true" ] && [ -n "$line" ]; then
            if [[ "$line" == MEM_USAGE_RATE:* ]]; then mem_usage_rate="${line#MEM_USAGE_RATE: }"
            elif [[ "$line" == THP_STATUS:* ]]; then thp_status="${line#THP_STATUS: }"
            elif [[ "$line" == HUGEPAGES_COUNT:* ]]; then hugepages_count="${line#HUGEPAGES_COUNT: }"
            fi
        elif [ "$in_io_advanced" = "true" ] && [ -n "$line" ]; then
            if [[ "$line" == DISK_QUEUE_DEPTH:* ]]; then disk_queue_depth="${line#DISK_QUEUE_DEPTH: }"
            elif [[ "$line" == DISK_READ_AHEAD:* ]]; then disk_read_ahead="${line#DISK_READ_AHEAD: }"
            elif [[ "$line" == DISK_TRIM:* ]]; then disk_trim="${line#DISK_TRIM: }"
