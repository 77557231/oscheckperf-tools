# sysbench fileio test
run_sysbench_fileio() {
    # Use a real disk directory instead of /tmp (which may be tmpfs)
    local test_dir="$IO_PATH"

    # Support SYSBENCH_PROFILES parameter
    local test_modes="${SYSBENCH_PROFILES:-rndrw}"

    # Only display test info in non-remote mode
    if [ "$REMOTE" != "true" ]; then
        echo "[sysbench] Starting fileio test..."
        echo "  File size: ${IO_TOTAL_SIZE:-1G}, Test modes: $test_modes"
        echo "  Test directory: $test_dir"
    fi

    # Ensure test directory exists
    mkdir -p "$test_dir"

    # Save current directory
    local current_dir="$(pwd)"

    # Validate test modes
    local valid_modes="seqwr seqrewr seqrd rndrd rndwr rndrw"

    # Change to test directory
    cd "$test_dir" || {
        echo "Error: Failed to change to test directory: $test_dir"
        return 1
    }

    # Loop through all test modes (space-separated)
    for test_mode in $test_modes; do
        if [[ ! " $valid_modes " =~ " $test_mode " ]]; then
            echo "Error: Invalid SYSBENCH_PROFILES mode: $test_mode"
            echo "  Valid modes: $valid_modes"
            continue
        fi

        # Generate unique temp file for each test mode
        local temp_output_file="$TMP_DIR/vb_fileio_${test_mode}_${TIMESTAMP}.log"

        # Build full sysbench command
        local sysbench_prepare_cmd="sysbench fileio \
            --file-total-size=${IO_TOTAL_SIZE:-1G} \
            --file-test-mode=$test_mode \
            --file-num=${SYSBENCH_FILE_NUM:-4} \
            --file-block-size=${SYSBENCH_BLOCK_SIZE:-16K} \
            prepare"
        
        local sysbench_run_cmd="sysbench fileio \
            --file-total-size=${IO_TOTAL_SIZE:-1G} \
            --file-test-mode=$test_mode \
            --time=${SYSBENCH_DURATION:-$DURATION} \
            --file-num=${SYSBENCH_FILE_NUM:-4} \
            --file-block-size=${SYSBENCH_BLOCK_SIZE:-16K} \
            --file-io-mode=${SYSBENCH_IO_MODE:-sync} \
            --file-extra-flags=${SYSBENCH_EXTRA_FLAGS:-direct} \
            --threads=${SYSBENCH_THREADS:-4} \
            run"
        
        local sysbench_cleanup_cmd="sysbench fileio \
            --file-total-size=${IO_TOTAL_SIZE:-1G} \
            --file-test-mode=$test_mode \
            --file-num=${SYSBENCH_FILE_NUM:-4} \
            --file-block-size=${SYSBENCH_BLOCK_SIZE:-16K} \
            cleanup"

        if [ "$DRY_RUN" = true ]; then
            echo "  [DRY RUN] Prepare: $sysbench_prepare_cmd"
            echo "  [DRY RUN] Run: $sysbench_run_cmd"
            echo "  [DRY RUN] Cleanup: $sysbench_cleanup_cmd"
            continue
        fi

        # Prepare test files first
        $sysbench_prepare_cmd > "/dev/null" 2>&1
        local prepare_exit=$?
        if [ "$prepare_exit" -ne 0 ]; then
            echo "Error: Prepare command failed for mode: $test_mode"
            continue
        fi

        # Run test
        $sysbench_run_cmd > "$temp_output_file" 2>&1
        local run_exit=$?
        if [ "$run_exit" -ne 0 ]; then
            echo "Error: Run command failed for mode: $test_mode"
            cat "$temp_output_file"
            continue
        fi

        # Cleanup test files
        $sysbench_cleanup_cmd > "/dev/null" 2>&1

        # Parse result and display detailed output
        if [ -f "$temp_output_file" ]; then
            # Display parsed output
            parse_sysbench_fileio_result "$temp_output_file"

            # Append to combined results file
            append_to_original "SYSBENCH FILEIO TEST RESULTS ($test_mode)" "$temp_output_file"
        fi

        # Cleanup temp file
        rm -f "$temp_output_file"
    done

    # Change back to original directory
    cd "$current_dir" || true

    # Only display completion message in non-remote mode
    if [ "$REMOTE" != "true" ]; then
        echo "✓ IO test completed"
    fi
}

# fio test
run_fio_test() {
    echo "[fio] Starting test..."
    
    # Check if fio is installed
    if ! command -v fio &> /dev/null; then
        echo "Error: fio not installed, please run: sudo yum install -y fio"
        return 1
    fi
    
    # Iterate through all profiles
    local profiles="${FIO_PROFILES:-randrw}"
    
    for profile in $profiles; do
        echo "  Executing profile: $profile"
        
        # Generate fio configuration
        local fio_conf="$TMP_DIR/fio_${profile}.fio"
        local rw_type="${profile}"
        local bs="${FIO_BS:-16K}"
        local iodepth="${FIO_IODEPTH:-32}"
        local numjobs="${FIO_NUMJOBS:-4}"
        local direct="${FIO_DIRECT:-1}"
        local ioengine="${FIO_IOENGINE:-libaio}"
        local file_num="${FIO_FILE_NUM:-4}"
        local total_size="${IO_TOTAL_SIZE:-1G}"
        
        # Calculate file size per file: total_size / (file_num * numjobs)
        # Important: fio size is per job, each job can write multiple files
        # e.g., IO_TOTAL_SIZE=1G, FIO_FILE_NUM=4, FIO_NUMJOBS=4 → each file is 64M
        # Total = 64M * 4 files * 4 jobs = 1G (expected)
        local per_file_size="auto"
        local size_value=$(echo "$total_size" | sed -E 's/([0-9]+)([GMK])/\1/')
        
        if [ "$file_num" -gt 0 ] && [ "$size_value" -gt 0 ]; then
            local per_size=$((size_value * 1024 / file_num))
            if [ "$numjobs" -gt 1 ]; then
                per_size=$((per_size / numjobs))
            fi
            per_file_size="${per_size}M"
        else
            per_file_size="${total_size}"
        fi
        
        cat > "$fio_conf" << EOF
[global]
ioengine=${ioengine}
direct=${direct}
size=${per_file_size}
runtime=${FIO_DURATION:-$DURATION}
time_based
group_reporting
thread

[${profile}]
rw=${rw_type}
bs=${bs}
iodepth=${iodepth}
numjobs=${numjobs}
nrfiles=${file_num}
filename="$IO_PATH/fio_test_${profile}_"
EOF
        
        # Show configuration file content (also shown in dry run mode)
        echo "  Configuration file: $fio_conf"
        echo "  Config content:"
        echo "  ----------------"
        cat "$fio_conf"
        echo "  ----------------"
        echo
        
        # Run fio test
        local mixed_output="$TMP_DIR/fio_${profile}_mixed_${TIMESTAMP}.log"
        local json_output="$TMP_DIR/fio_${profile}_result_${TIMESTAMP}.json"
        local normal_output="$TMP_DIR/fio_${profile}_normal_${TIMESTAMP}.log"
        
        if [ "$DRY_RUN" = true ]; then
            echo "[DRY RUN] Would execute: fio \"$fio_conf\" --output=\"$mixed_output\" --output-format=json,normal"
        else
            # Run fio once with both json and normal output
            fio "$fio_conf" --output="$mixed_output" --output-format=json,normal > /dev/null 2>&1
            
            # Extract JSON section (everything from first { to last })
            awk 'BEGIN{found=0}{if($0~/^[{]/)found=1;if(found)print;if($0~/^[}]/)exit}' "$mixed_output" > "$json_output" 2>/dev/null
            
            # Extract normal section (everything before first { and everything after last })
            {
                awk 'BEGIN{found=0}{if($0~/^[{]/)found=1;if(!found)print}' "$mixed_output"
                # Find the line number of last } and extract everything after it
                local last_brace=$(grep -n '^}' "$mixed_output" | tail -n1 | cut -d: -f1)
                if [ -n "$last_brace" ]; then
                    tail -n +$((last_brace + 1)) "$mixed_output"
                fi
            } > "$normal_output" 2>/dev/null
        fi
        
        # Cleanup temporary files (also cleanup in dry run mode)
        rm -f "$fio_conf"
        
        # Cleanup fio test files (support multiple files)
        rm -f "$IO_PATH/fio_test_${profile}_"* 2>/dev/null || true
        
        # Parse result
        if [ "$DRY_RUN" != true ] && [ -f "$json_output" ] && jq_available; then
            # Extract basic metrics (IOPS, BW, Latency)
            local read_iops=$(jq -r '.jobs[0].read.iops // 0' "$json_output")
            local write_iops=$(jq -r '.jobs[0].write.iops // 0' "$json_output")
            local read_bw=$(jq -r '.jobs[0].read.bw // 0' "$json_output")
            local write_bw=$(jq -r '.jobs[0].write.bw // 0' "$json_output")
            local read_avg_lat=$(jq -r '.jobs[0].read.lat_ns.mean // 0' "$json_output")
            local write_avg_lat=$(jq -r '.jobs[0].write.lat_ns.mean // 0' "$json_output")
            
            # Convert BW from KB/s to MB/s
            local read_bw_mb=$(awk "BEGIN {printf \"%.2f\", $read_bw / 1024}" 2>/dev/null || echo "0")
            local write_bw_mb=$(awk "BEGIN {printf \"%.2f\", $write_bw / 1024}" 2>/dev/null || echo "0")
            
            # Convert latency from ns to ms
            local read_avg_lat_ms=$(awk "BEGIN {printf \"%.2f\", $read_avg_lat / 1000000}" 2>/dev/null || echo "0")
            local write_avg_lat_ms=$(awk "BEGIN {printf \"%.2f\", $write_avg_lat / 1000000}" 2>/dev/null || echo "0")
            
            # Display basic results
            echo ""
            echo "  fio [$profile] test results:"
            echo "    Read IOPS: ${read_iops}"
            echo "    Write IOPS: ${write_iops}"
            echo "    Read BW: ${read_bw_mb}MB/s"
            echo "    Write BW: ${write_bw_mb}MB/s"
            echo "    Read Latency: ${read_avg_lat_ms}ms"
            echo "    Write Latency: ${write_avg_lat_ms}ms"
            
            # Extract and display extended metrics
            local fio_metrics=$(parse_fio_json_to_metrics "$json_output" "$normal_output")
            if [ -n "$fio_metrics" ]; then
                echo ""
                echo "  fio [$profile] extended metrics:"
                local lat_p99=$(echo "$fio_metrics" | grep -oP 'lat_p99=\K[^|]+')
                local disk_util=$(echo "$fio_metrics" | grep -oP 'disk_util=\K[^|]+')
                local cpu_usr=$(echo "$fio_metrics" | grep -oP 'cpu_usr=\K[^|]+')
                local cpu_sys=$(echo "$fio_metrics" | grep -oP 'cpu_sys=\K[^|]+')
                [ "$lat_p99" != "N/A" ] && echo "    P99 Latency: ${lat_p99} ms"
                [ "$disk_util" != "N/A" ] && echo "    Disk Utilization: ${disk_util}%"
                [ "$cpu_usr" != "N/A" ] && echo "    CPU (usr): ${cpu_usr}%"
                [ "$cpu_sys" != "N/A" ] && echo "    CPU (sys): ${cpu_sys}%"
                
                # Append extended metrics to normal output file for report generation
                echo "" >> "$normal_output"
                echo "FIO Extended Metrics:" >> "$normal_output"
                [ "$lat_p99" != "N/A" ] && echo "P99 Latency: ${lat_p99} ms" >> "$normal_output"
                [ "$disk_util" != "N/A" ] && echo "Disk Utilization: ${disk_util}%" >> "$normal_output"
                [ "$cpu_usr" != "N/A" ] && echo "CPU (usr): ${cpu_usr}%" >> "$normal_output"
                [ "$cpu_sys" != "N/A" ] && echo "CPU (sys): ${cpu_sys}%" >> "$normal_output"
            fi
            
            # Append normal output to original data file
            append_to_original "FIO TEST RESULTS ($profile)" "$normal_output"
        fi
        
        # Cleanup output files
        rm -f "$mixed_output" "$normal_output"
    done
    
    echo "✓ fio test completed"
}

# Generate text format output from fio JSON output
generate_fio_text_from_json() {
    local json_file="$1"
    local output_file="$2"
    
    if [ ! -f "$json_file" ]; then
        echo "Error: JSON file not found: $json_file" > "$output_file"
        return
    fi
    
    if ! jq_available; then
        echo "Error: jq not installed" > "$output_file"
        return
    fi
    
    local jobname=$(jq -r '.jobs[0].jobname // "unknown"' "$json_file")
    local rw=$(jq -r '.jobs[0]."job options".rw // "unknown"' "$json_file")
    local bs=$(jq -r '.jobs[0]."job options".bs // "unknown"' "$json_file")
    local iodepth=$(jq -r '.jobs[0]."job options".iodepth // "unknown"' "$json_file")
    local numjobs=$(jq -r '.jobs[0]."job options".numjobs // "unknown"' "$json_file")
    local runtime=$(jq -r '.jobs[0].elapsed // "unknown"' "$json_file")
    
    # Read metrics (keep original values for bw in KB/s)
    local read_iops=$(jq -r '.jobs[0].read.iops // 0' "$json_file")
    local read_bw_kb=$(jq -r '.jobs[0].read.bw // 0' "$json_file")
    local read_clat_min=$(jq -r '.jobs[0].read.clat_ns.min // 0' "$json_file")
    local read_clat_max=$(jq -r '.jobs[0].read.clat_ns.max // 0' "$json_file")
    local read_clat_avg=$(jq -r '.jobs[0].read.clat_ns.mean // 0' "$json_file")
    local read_clat_p50=$(jq -r '.jobs[0].read.clat_ns.percentile."50.000000" // 0' "$json_file")
    local read_clat_p95=$(jq -r '.jobs[0].read.clat_ns.percentile."95.000000" // 0' "$json_file")
    local read_clat_p99=$(jq -r '.jobs[0].read.clat_ns.percentile."99.000000" // 0' "$json_file")
    local read_util=$(jq -r '.jobs[0].read.utilization // 0' "$json_file")
    
    # Write metrics (keep original values for bw in KB/s)
    local write_iops=$(jq -r '.jobs[0].write.iops // 0' "$json_file")
    local write_bw_kb=$(jq -r '.jobs[0].write.bw // 0' "$json_file")
    local write_clat_min=$(jq -r '.jobs[0].write.clat_ns.min // 0' "$json_file")
    local write_clat_max=$(jq -r '.jobs[0].write.clat_ns.max // 0' "$json_file")
    local write_clat_avg=$(jq -r '.jobs[0].write.clat_ns.mean // 0' "$json_file")
    local write_clat_p50=$(jq -r '.jobs[0].write.clat_ns.percentile."50.000000" // 0' "$json_file")
    local write_clat_p95=$(jq -r '.jobs[0].write.clat_ns.percentile."95.000000" // 0' "$json_file")
    local write_clat_p99=$(jq -r '.jobs[0].write.clat_ns.percentile."99.000000" // 0' "$json_file")
    local write_util=$(jq -r '.jobs[0].write.utilization // 0' "$json_file")
    
    # Convert nanoseconds to microseconds for display
    read_clat_min=$((read_clat_min / 1000))
    read_clat_max=$((read_clat_max / 1000))
    read_clat_avg=$(awk "BEGIN {printf \"%.2f\", $read_clat_avg / 1000}" 2>/dev/null || echo "0")
    read_clat_p50=$((read_clat_p50 / 1000))
    read_clat_p95=$((read_clat_p95 / 1000))
    read_clat_p99=$((read_clat_p99 / 1000))
    
