# Timer functions for performance tracking
declare -A TIMER_START_TIMES
declare -A TIMER_ACCUMULATED

# Start timer for a named phase
# Usage: start_timer "phase_name"
start_timer() {
    if [ "$DEBUG" != "true" ]; then
        return
    fi
    local phase_name="$1"
    TIMER_START_TIMES["$phase_name"]=$(date +%s%3N)
    echo "[DEBUG] $(date '+%Y-%m-%d %H:%M:%S') - ⏱️ Starting phase: $phase_name"
}

# End timer for a named phase and print elapsed time
# Usage: end_timer "phase_name"
end_timer() {
    if [ "$DEBUG" != "true" ]; then
        return
    fi
    local phase_name="$1"
    local start_time="${TIMER_START_TIMES[$phase_name]}"
    
    if [ -z "$start_time" ]; then
        echo "[DEBUG] $(date '+%Y-%m-%d %H:%M:%S') - ⏱️ Timer not started for phase: $phase_name"
        return
    fi
    
    local end_time=$(date +%s%3N)
    local elapsed_ms=$((end_time - start_time))
    local elapsed_sec=$(awk "BEGIN {printf \"%.2f\", $elapsed_ms / 1000}")
    
    # Accumulate time
    if [ -z "${TIMER_ACCUMULATED[$phase_name]}" ]; then
        TIMER_ACCUMULATED["$phase_name"]=0
    fi
    TIMER_ACCUMULATED["$phase_name"]=$((TIMER_ACCUMULATED["$phase_name"] + elapsed_ms))
    
    # Calculate accumulated seconds using awk with proper quoting
    local accumulated_sec=$(awk "BEGIN {printf \"%.2f\", ${TIMER_ACCUMULATED[$phase_name]} / 1000}")
    echo "[DEBUG] $(date '+%Y-%m-%d %H:%M:%S') - ⏱️ Completed phase: $phase_name (elapsed: ${elapsed_sec}s, accumulated: ${accumulated_sec}s)"
}

# Print timer summary
# Usage: print_timer_summary
print_timer_summary() {
    if [ "$DEBUG" != "true" ]; then
        return
    fi
    
    echo ""
    echo "[DEBUG] $(date '+%Y-%m-%d %H:%M:%S') - ===== TIMER SUMMARY ====="
    
    local total_ms=0
    for phase in "${!TIMER_ACCUMULATED[@]}"; do
        local elapsed_ms="${TIMER_ACCUMULATED[$phase]}"
        local elapsed_sec=$(awk "BEGIN {printf \"%.2f\", $elapsed_ms / 1000}")
        echo "[DEBUG]         $phase: ${elapsed_sec}s"
        total_ms=$((total_ms + elapsed_ms))
    done
    
    local total_sec=$(awk "BEGIN {printf \"%.2f\", $total_ms / 1000}")
    echo "[DEBUG]         Total measured: ${total_sec}s"
    echo "[DEBUG] ======================="
}

