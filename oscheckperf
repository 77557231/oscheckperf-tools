parse_threads_report() {
    local input_file="$1"
    local output_file="$2"
    
    if [ ! -f "$input_file" ]; then
        echo "  Test not executed" >> "$output_file"
        return
    fi
    
    if ! grep -q -E "Threads test summary:|THREADS TEST RESULTS" "$input_file" 2>/dev/null; then
        echo "  Test not executed" >> "$output_file"
        return
    fi
    
    echo "  Threads Test Results" >> "$output_file"
    echo "  -------------------------------------------------------------------------------------------------------------------" >> "$output_file"
    printf "  %-18s %-15s %-18s %-18s %-14s %-14s %-18s\n" "Server IP" "Events/sec" "Avg Latency (ms)" "P95 Latency (ms)" "Min Lat(ms)" "Max Lat(ms)" "Sum Lat(ms)" >> "$output_file"
