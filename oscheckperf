# Generate matrix report
generate_matrix_report() {
    local -n results_arr=$1
    local -n hosts_arr=$2
    local report_file="$TMP_DIR/network_matrix_report_${TIMESTAMP}.log"
    
    echo "Generating matrix network test report..."
    
    # Calculate statistics using common function
    local stats=$(calculate_stats "${results_arr[@]}")
    IFS='|' read -r total_bw avg_bw min_bw max_bw median_bw count <<< "$stats"
    
    # Create report header
    cat > "$report_file" << EOF
================================================================================
                           Matrix Network Test Report
================================================================================

Test Time: $(date '+%Y-%m-%d %H:%M:%S')
Test Duration: $DURATIONs per pair
Parallel Connections: ${NETWORK_PARALLEL:-1}

Hosts: ${hosts_arr[*]}

================================================================================
                              Bandwidth Matrix (MB/s)
================================================================================
EOF
    
    # Create matrix header
    echo -n "FROM\\TO" >> "$report_file"
    for host in "${hosts_arr[@]}"; do
        printf "\t%15s" "$host" >> "$report_file"
    done
    echo >> "$report_file"
    
    # Create matrix rows
    for src in "${hosts_arr[@]}"; do
        printf "%15s" "$src" >> "$report_file"
        for dst in "${hosts_arr[@]}"; do
            if [ "$src" = "$dst" ]; then
                printf "\t%15s" "-" >> "$report_file"
            else
                # Find result for this pair
                local bandwidth="0"
                for result in "${results_arr[@]}"; do
                    IFS='|' read -r r_src r_dst r_bw <<< "$result"
                    if [ "$r_src" = "$src" ] && [ "$r_dst" = "$dst" ]; then
                        bandwidth="$r_bw"
                        break
                    fi
                done
                printf "\t%15s" "$bandwidth" >> "$report_file"
            fi
        done
        echo >> "$report_file"
    done
    
    # Add statistics to report
    cat >> "$report_file" << EOF

================================================================================
                                Statistics
================================================================================
Total bandwidth: $(printf "%.2f" $total_bw) MB/s
Average bandwidth: $(printf "%.2f" $avg_bw) MB/s
Minimum bandwidth: $(printf "%.2f" $min_bw) MB/s
Maximum bandwidth: $(printf "%.2f" $max_bw) MB/s
Median bandwidth: $(printf "%.2f" $median_bw) MB/s
Total test pairs: $count

================================================================================
EOF
    
    # Add performance ranking section
    cat >> "$report_file" << EOF
                            Performance Ranking (MB/s)
================================================================================
EOF
    
    # Sort results by bandwidth (descending) and display
    local sorted_results=$(printf "%s\n" "${results_arr[@]}" | sort -t'|' -k3 -rn)
    local rank=1
    echo "$sorted_results" | while IFS='|' read -r src dst bw; do
        printf "%2d. %15s -> %-15s : %8.2f MB/s" "$rank" "$src" "$dst" "$bw" >> "$report_file"
        # Highlight poor performers (below 50% of average)
        if (( $(echo "$bw < $avg_bw * 0.5" | bc -l) )); then
            echo "  ⚠ POOR PERFORMANCE" >> "$report_file"
        else
            echo "" >> "$report_file"
        fi
        rank=$((rank + 1))
    done
    
    cat >> "$report_file" << EOF
================================================================================
EOF
    
    echo "  ✓ Matrix report generated: $report_file"
    
    # Don't append full report to combined results (only raw data needed)
}

# Parse iperf3 JSON result
parse_iperf3_result() {
    local json_file="$1"
    
    if [ ! -f "$json_file" ]; then
        echo "⚠ Result file not found: $json_file"
        return
    fi
    
    if ! jq_available; then
        echo "⚠ jq not installed, skipping detailed parsing"
        return
    fi
    
    # Extract JSON content by removing any leading non-JSON text
    local json_content=$(awk 'BEGIN{found=0} /^\{/{found=1} found{print} /^\}/{if(found) exit}' "$json_file" 2>/dev/null || cat "$json_file")
    
    # Extract metrics
    local bandwidth_bps=$(echo "$json_content" | jq -r '.end.sum_received.bits_per_second // 0' 2>/dev/null)
    # Convert bps to MB/s: 1 MB/s = 8,000,000 bps
    local bandwidth_mbs=$(awk "BEGIN {printf \"%.2f\", $bandwidth_bps / 8000000}" 2>/dev/null || echo "0")
    
    # Extract extended metrics
    local retransmits=$(echo "$json_content" | jq -r '.end.sum_received.retransmits // "N/A"' 2>/dev/null)
    local rtt_avg=$(echo "$json_content" | jq -r '.end.streams[0].sender.mean_rtt // "N/A"' 2>/dev/null)
    local rtt_min=$(echo "$json_content" | jq -r '.end.streams[0].sender.min_rtt // "N/A"' 2>/dev/null)
    local rtt_max=$(echo "$json_content" | jq -r '.end.streams[0].sender.max_rtt // "N/A"' 2>/dev/null)
    local cpu_sender=$(echo "$json_content" | jq -r '.end.cpu_utilization_percent.sender // "N/A"' 2>/dev/null)
    local cpu_receiver=$(echo "$json_content" | jq -r '.end.cpu_utilization_percent.receiver // "N/A"' 2>/dev/null)
    
    # Convert RTT from microseconds to milliseconds if available
    if [ "$rtt_avg" != "N/A" ] && [ "$rtt_avg" != "null" ]; then
        rtt_avg=$(awk "BEGIN {printf \"%.3f\", $rtt_avg / 1000}" 2>/dev/null || echo "$rtt_avg")
    fi
    if [ "$rtt_min" != "N/A" ] && [ "$rtt_min" != "null" ]; then
        rtt_min=$(awk "BEGIN {printf \"%.3f\", $rtt_min / 1000}" 2>/dev/null || echo "$rtt_min")
    fi
    if [ "$rtt_max" != "N/A" ] && [ "$rtt_max" != "null" ]; then
        rtt_max=$(awk "BEGIN {printf \"%.3f\", $rtt_max / 1000}" 2>/dev/null || echo "$rtt_max")
    fi
    
    # Display summary
    echo ""
    echo "Network test results:"
    echo "  Dynamic Average Bandwidth: ${bandwidth_mbs} MB/s"
    
    # Display extended metrics
    if [ "$retransmits" != "N/A" ] && [ "$retransmits" != "null" ]; then
        echo "  Retransmits: ${retransmits}"
    fi
    if [ "$rtt_avg" != "N/A" ] && [ "$rtt_avg" != "null" ]; then
        echo "  RTT (ms): ${rtt_avg} (Min: ${rtt_min}, Max: ${rtt_max})"
    fi
    if [ "$cpu_sender" != "N/A" ] && [ "$cpu_sender" != "null" ]; then
        echo "  CPU: Sender ${cpu_sender}%, Receiver ${cpu_receiver}%"
    fi
    
    # Only show jitter and packet loss for UDP tests (not applicable for TCP)
    if [ "${NETWORK_PROTOCOL:-tcp}" = "udp" ]; then
        local jitter_ms=$(jq -r '.end.sum_received.jitter_ms // 0' "$json_file" 2>/dev/null)
        local lost_packets=$(jq -r '.end.sum_received.lost_packets // 0' "$json_file" 2>/dev/null)
        local total_packets=$(jq -r '.end.sum_received.packets // 0' "$json_file" 2>/dev/null)
        
        # Calculate packet loss rate
        local packet_loss="0"
        if [ "$total_packets" -gt 0 ] 2>/dev/null; then
            packet_loss=$(awk "BEGIN {printf \"%.2f\", $lost_packets * 100 / $total_packets}" 2>/dev/null || echo "0")
        fi
        
        echo "  Jitter: ${jitter_ms} ms"
        echo "  Lost Packets: ${lost_packets}"
        echo "  Packet Loss: ${packet_loss}%"
    fi
}

# Generate text format output from iperf3 JSON output
generate_iperf3_text_from_json() {
    local json_file="$1"
    local output_file="$2"
    
    if [ ! -f "$json_file" ]; then
        touch "$output_file"
        return
    fi
    
    if ! jq_available; then
        touch "$output_file"
        return
    fi
    
    # Extract JSON content
    local json_content=$(awk 'BEGIN{found=0} /^\{/{found=1} found{print} /^\}/{if(found) exit}' "$json_file" 2>/dev/null || cat "$json_file")
    
    # Generate text-like output from JSON
    {
        echo "iperf3 text output (generated from JSON)"
        echo "========================================="
        
        # Extract interval data
        local intervals=$(echo "$json_content" | jq -r '.intervals[]' 2>/dev/null)
        
        if [ -n "$intervals" ]; then
            local interval_idx=0
            echo "$intervals" | while read -r interval; do
                interval_idx=$((interval_idx + 1))
                
                # Extract timestamp and duration
                local start=$(echo "$interval" | jq -r '.streams[0].start // 0' 2>/dev/null)
                local end=$(awk "BEGIN {printf \"%.2f\", $start + 1}" 2>/dev/null)
                
                # Extract received data
                local bytes=$(echo "$interval" | jq -r '.streams[0].sum.bytes // 0' 2>/dev/null)
                local bits_per_second=$(echo "$interval" | jq -r '.streams[0].sum.bits_per_second // 0' 2>/dev/null)
                
                # Convert bytes to MBytes
                local mbytes=$(awk "BEGIN {printf \"%.2f\", $bytes / 1048576}" 2>/dev/null || echo "0")
                
                # Convert bps to Mbits/sec or Gbits/sec
                local bitrate=""
                if [ "$bits_per_second" -gt 1000000000 ] 2>/dev/null; then
                    bitrate=$(awk "BEGIN {printf \"%.2f Gbits/sec\", $bits_per_second / 1000000000}" 2>/dev/null)
                else
                    bitrate=$(awk "BEGIN {printf \"%.2f Mbits/sec\", $bits_per_second / 1000000}" 2>/dev/null)
                fi
                
                if [ -n "$start" ] && [ "$start" != "null" ]; then
                    printf "[%3d] %6.2f-%6.2f sec  %6.2f MBytes  %s\n" "$interval_idx" "$start" "$end" "$mbytes" "$bitrate"
                fi
            done
        fi
        
        # Add summary
        echo ""
        echo "- - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"
        
        local total_bytes=$(echo "$json_content" | jq -r '.end.sum_received.bytes // 0' 2>/dev/null)
        local total_bits_per_second=$(echo "$json_content" | jq -r '.end.sum_received.bits_per_second // 0' 2>/dev/null)
        
        local total_mbytes=$(awk "BEGIN {printf \"%.2f\", $total_bytes / 1048576}" 2>/dev/null || echo "0")
        
        local total_bitrate=""
        if [ "$total_bits_per_second" -gt 1000000000 ] 2>/dev/null; then
            total_bitrate=$(awk "BEGIN {printf \"%.2f Gbits/sec\", $total_bits_per_second / 1000000000}" 2>/dev/null)
        else
            total_bitrate=$(awk "BEGIN {printf \"%.2f Mbits/sec\", $total_bits_per_second / 1000000}" 2>/dev/null)
        fi
        
        printf "[SUM] %6.2f-%6.2f sec  %6.2f MBytes  %s  sender\n" "0.00" "$(echo "$json_content" | jq -r '.end.sum_received.seconds // 0' 2>/dev/null)" "$total_mbytes" "$total_bitrate"
        printf "[SUM] %6.2f-%6.2f sec  %6.2f MBytes  %s  receiver\n" "0.00" "$(echo "$json_content" | jq -r '.end.sum_received.seconds // 0' 2>/dev/null)" "$total_mbytes" "$total_bitrate"
        
    } > "$output_file"
}

