# Get machine type (using systemd-detect-virt or fallback)
get_machine_type() {
    local machine_type="Physical Machine"
    
    if command -v systemd-detect-virt &>/dev/null; then
        local virt_output=$(systemd-detect-virt 2>/dev/null)
        case "$virt_output" in
            "kvm") machine_type="Virtual Machine (KVM)" ;;
            "qemu") machine_type="Virtual Machine (QEMU)" ;;
            "vmware") machine_type="Virtual Machine (VMware)" ;;
            "virtualbox") machine_type="Virtual Machine (VirtualBox)" ;;
            "hyperv") machine_type="Virtual Machine (Hyper-V)" ;;
            "xen") machine_type="Virtual Machine (Xen)" ;;
            "none") machine_type="Physical Machine" ;;
            *) machine_type="Unknown" ;;
        esac
    else
        # Fallback detection
        if grep -qi 'kvm' /proc/cpuinfo 2>/dev/null || grep -qi 'qemu' /sys/devices/virtual/dmi/id/product_name 2>/dev/null; then
            machine_type="Virtual Machine (KVM/QEMU)"
        elif grep -qi 'vmware' /sys/devices/virtual/dmi/id/product_name 2>/dev/null; then
            machine_type="Virtual Machine (VMware)"
        elif grep -qi 'hypervisor' /proc/cpuinfo 2>/dev/null; then
            machine_type="Virtual Machine (Unknown)"
        fi
    fi
    
    echo "$machine_type"
}

# Get memory slots count (with sudo support)
get_memory_slots() {
    if command -v dmidecode &>/dev/null; then
        # Try with sudo first
        local slots=$((sudo dmidecode -t memory 2>/dev/null || dmidecode -t memory 2>/dev/null) | grep -c 'Memory Device' 2>/dev/null)
        if [ "$slots" -gt 0 ]; then
            echo "$slots"
            return
        fi
    fi
    echo "unknown (requires root)"
}

# Get memory frequency (MHz) (with sudo support)
get_memory_freq() {
    local machine_type=$(get_machine_type 2>/dev/null)
    if echo "$machine_type" | grep -qi "virtual"; then
        echo "N/A (virtual machine)"
        return
    fi
    
    if command -v dmidecode &>/dev/null; then
        local freq=$((sudo dmidecode -t memory 2>/dev/null || dmidecode -t memory 2>/dev/null) | grep -m 1 'Configured Clock Speed' | awk '{print $4}' 2>/dev/null)
        if [ -n "$freq" ] && [ "$freq" -gt 0 ] 2>/dev/null; then
            echo "${freq} MHz"
            return
        fi
        freq=$((sudo dmidecode -t memory 2>/dev/null || dmidecode -t memory 2>/dev/null) | grep -m 1 'Speed' | awk '{print $2}' 2>/dev/null)
        if [ -n "$freq" ] && [ "$freq" != "Unknown" ] && [ "$freq" -gt 0 ] 2>/dev/null; then
            echo "${freq} MHz"
            return
        fi
    fi
    echo "unknown (requires root)"
}

# Get detailed disk info - only disk/rom types get vendor/model/scheduler/wcache
get_disk_info_detailed() {
    if command -v lsblk &>/dev/null; then
        while read -r line; do
            name=$(echo "$line" | awk '{print $1}' | sed 's/^[├└─ ]*//')
            size=$(echo "$line" | awk '{print $2}')
            type=$(echo "$line" | awk '{print $3}')
            fstype=$(echo "$line" | awk '{print $4}')
            mountpoint=$(echo "$line" | awk '{print $5}')
            
            local vendor="-"
            local model="-"
            local scheduler="-"
            local disk_type="-"
            local wcache="-"
            
            # Only get hardware info for disk and rom types
            if [ "$type" = "disk" ] || [ "$type" = "rom" ]; then
                if [ -d "/sys/block/$name/device" ]; then
                    if [ -f "/sys/block/$name/device/vendor" ]; then
                        vendor=$(cat "/sys/block/$name/device/vendor" 2>/dev/null | tr -d ' ')
                    fi
                    if [ -f "/sys/block/$name/device/model" ]; then
                        model=$(cat "/sys/block/$name/device/model" 2>/dev/null | tr -d ' ')
                    fi
                    if [ -f "/sys/block/$name/queue/scheduler" ]; then
                        scheduler=$(cat "/sys/block/$name/queue/scheduler" 2>/dev/null | grep -o '\[.*\]' | tr -d '[]')
                        [ -z "$scheduler" ] && scheduler=$(cat "/sys/block/$name/queue/scheduler" 2>/dev/null | awk '{print $1}')
                    fi
                    if [ -f "/sys/block/$name/queue/rotational" ]; then
                        rotational=$(cat "/sys/block/$name/queue/rotational" 2>/dev/null)
                        if [ "$rotational" = "0" ]; then
                            disk_type="SSD"
                        elif [ "$rotational" = "1" ]; then
                            disk_type="HDD"
                        fi
                    fi
                    if [ -f "/sys/block/$name/queue/write_cache" ]; then
                        wcache=$(cat "/sys/block/$name/queue/write_cache" 2>/dev/null)
                        if [ "$wcache" = "write back" ] || [ "$wcache" = "1" ]; then
                            wcache="WriteBack"
                        elif [ "$wcache" = "write through" ] || [ "$wcache" = "0" ]; then
                            wcache="WriteThrough"
                        else
                            wcache="Unknown"
                        fi
                    fi
                fi
            fi
            
            [ -z "$fstype" ] && fstype="-"
            [ -z "$mountpoint" ] && mountpoint="-"
            [ -z "$vendor" ] && vendor="-"
            [ -z "$model" ] && model="-"
            [ -z "$scheduler" ] && scheduler="-"
            [ -z "$wcache" ] && wcache="-"
            
            echo "$name|$size|$type|$fstype|$mountpoint|$disk_type|$vendor|$model|$scheduler|$wcache"
        done < <(lsblk -no NAME,SIZE,TYPE,FSTYPE,MOUNTPOINT 2>/dev/null | grep -v "^loop" | grep -v "^NAME" | grep -v "^sr")
    else
        echo "N/A"
    fi
}

