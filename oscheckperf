# Parse multi-server configuration
# Format: IP:ROLE:description, multiple servers separated by commas
parse_servers() {
    local servers_str="${SERVERS:-}"
    if [ -z "$servers_str" ]; then
        echo ""
        return
    fi
    
    local IFS=','
    for server in $servers_str; do
        local ip=$(echo "$server" | cut -d: -f1)
        local role=$(echo "$server" | cut -d: -f2)
        local desc=$(echo "$server" | cut -d: -f3)
        echo "$ip|$role|$desc"
    done
}

# Parse test scenarios configuration
# Format: CLIENT_IP:SERVER_IP:Duration (Duration is optional)
parse_test_scenarios() {
    local scenarios_str="${TEST_SCENARIOS:-}"
    if [ -z "$scenarios_str" ]; then
        echo ""
        return
    fi
    
    local IFS=','
    for scenario in $scenarios_str; do
        local client_ip=$(echo "$scenario" | cut -d: -f1)
        local server_ip=$(echo "$scenario" | cut -d: -f2)
        local duration=$(echo "$scenario" | cut -d: -f3)
        echo "$client_ip|$server_ip|$duration"
    done
}

# Check all dependencies
check_all() {
    if [ "$NO_CHECKS" = "true" ]; then
        return
    fi
    
    echo "Checking system prerequisites..."
    echo "--------------------------------"
    
    # Check dependencies
    check_dependencies
    
    # Check permissions
    check_permissions
    
    # Check disk space
    check_disk_space
    
    # Check network connectivity
    check_network
    
    # Check SSH passwordless login for remote servers
    check_ssh
    
    echo ""
    echo "Prerequisites check completed successfully!"
    echo "----------------------------------------"
    echo ""
}

# Check dependencies
check_dependencies() {
    local has_error=false
    
    echo "  Checking dependencies..."
    
    # sysbench is required
    if check_command "sysbench" "sysbench will be automatically distributed to remote servers"; then
        echo "  ✓ sysbench: Installed (required for all tests)"
    else
        echo "  ⚠ sysbench: Not installed (will be automatically distributed)"
    fi
    
    # Additional tools (optional, based on test types)
    if check_command "fio" "Please run: sudo yum install -y fio"; then
        echo "  ✓ fio: Installed (required for IO tests)"
    else
        echo "  ⚠ fio: Not installed (required for IO tests)"
    fi
    
    if check_command "iperf3" "Please run: sudo yum install -y iperf3"; then
        echo "  ✓ iperf3: Installed (required for network tests)"
    else
        echo "  ⚠ iperf3: Not installed (required for network tests)"
    fi
    
    if check_command "jq" "Please run: sudo yum install -y jq"; then
        echo "  ✓ jq: Installed (required for parsing fio JSON output)"
    else
        echo "  ⚠ jq: Not installed (required for parsing fio JSON output)"
    fi
    
    echo "  Note: Install optional dependencies based on your testing needs"
    
    return 0
}

# Check permissions
check_permissions() {
    echo "  Checking permissions..."
    
    # Check test directory write permission
    local test_path="${IO_TEST_PATH:-/tmp}"
    if [ -w "$test_path" ]; then
        echo "  ✓ Test directory write permission: $test_path"
    else
        echo "Error: No write permission for test directory: $test_path"
        exit 1
    fi
    
    # Check if running as root
    if [ "$(id -u)" -eq 0 ]; then
        echo "  ✓ Running as root"
    else
        echo "  ⚠ Running as non-root user, some tests may fail"
        echo "    Suggestion: Run with 'sudo oscheckperf ...'"
    fi
}

# Check disk space
check_disk_space() {
    echo "  Checking disk space..."
    
    local test_path="${IO_TEST_PATH:-/tmp}"
    local available_kb=$(get_disk_available_kb "$test_path")
    local available_gb=$((available_kb / 1024 / 1024))
    
    # Calculate required space based on mode
    local required_gb=0
    case $MODE in
        quick)
            required_gb=2
            ;;
        production)
            required_gb=10
            ;;
        deep)
            required_gb=50
            ;;
        *)
            required_gb=0
            ;;
    esac
    
    if [ "$available_gb" -lt "$required_gb" ]; then
        echo "Error: Insufficient disk space"
        echo "  Available: ${available_gb}GB"
        echo "  Required: ${required_gb}GB"
        return 1
    else
        echo "  ✓ Disk space: ${available_gb}GB available, ${required_gb}GB required"
    fi
}

# Check network connectivity
check_network() {
    echo "  Checking network connectivity..."
    
    # If can ping localhost, consider network OK
    if ! ping -c 1 127.0.0.1 &> /dev/null; then
        echo "Error: Network connectivity check failed"
        return 1
    else
        echo "  ✓ Network connectivity: OK"
    fi
}

# Check SSH passwordless login for remote servers
check_ssh() {
    local local_ip=$(get_machine_ip)
    
    if [ ${#target_servers[@]} -gt 0 ]; then
        echo "  Checking SSH passwordless login..."
        local ssh_failed=()
        
        for ip in "${target_servers[@]}"; do
            # Skip local machine
            if [ "$ip" = "$local_ip" ]; then
                continue
            fi
            
            # Test SSH connection with BatchMode=yes to avoid password prompt
            if ! ssh -o BatchMode=yes -o ConnectTimeout=5 "$ip" "echo 2>/dev/null" > /dev/null 2>&1; then
                ssh_failed+=($ip)
            fi
        done
        
        if [ ${#ssh_failed[@]} -gt 0 ]; then
            echo "Error: SSH passwordless login not configured for the following servers:"
            for ip in "${ssh_failed[@]}"; do
                echo "  - $ip"
            done
            echo ""
            echo "Please configure SSH passwordless login for these servers before running the test."
            echo "You can use: ssh-copy-id $USER@<server_ip>"
            exit 1
        else
            echo "  ✓ SSH passwordless login: OK"
        fi
    fi
}

# Parse CPU result
parse_cpu_result() {
    local result_file="$1"
    
    local events_per_sec=$(grep "events per second" "$result_file" 2>/dev/null | awk -F: '{print $2}' | tr -d ' ' || echo "0")
    local avg_latency=$(grep "avg:" "$result_file" 2>/dev/null | head -1 | awk '{print $NF}' | tr -d ',' || echo "0")
    local p95_latency=$(grep "95th percentile" "$result_file" 2>/dev/null | awk '{print $NF}' | head -1 | tr -d ',' || echo "0")
    local p99_latency=$(grep "99th percentile" "$result_file" 2>/dev/null | awk '{print $NF}' | head -1 | tr -d ',' || echo "0")
    
    # Extract Threads fairness metrics
    local threads_fairness_events=$(grep -A2 "Threads fairness:" "$result_file" 2>/dev/null | grep "events" | head -1)
    local threads_fairness_time=$(grep -A2 "Threads fairness:" "$result_file" 2>/dev/null | grep "execution time" | head -1)
    
    # Display detailed summary
    echo ""
    echo "CPU test summary:"
    echo "  CPU speed:"
    echo "    events per second: $events_per_sec"
    echo "  Avg Latency: ${avg_latency}ms"
    echo "  P95 Latency: ${p95_latency}ms"
    if [ -n "$p99_latency" ] && [ "$p99_latency" != "0" ]; then
        echo "  P99 Latency: ${p99_latency}ms"
    fi
    echo "  Threads fairness:"
    if [ -n "$threads_fairness_events" ]; then
        echo "    $threads_fairness_events"
    fi
    if [ -n "$threads_fairness_time" ]; then
        echo "    $threads_fairness_time"
    fi
}

# Parse memory result
parse_memory_result() {
    local result_file="$1"
    
    # Extract Total operations and operations per second
    local total_ops_line=$(grep "Total operations:" "$result_file" 2>/dev/null)
    local total_ops=$(echo "$total_ops_line" | awk '{print $3}' || echo "0")
    local ops_per_sec=$(echo "$total_ops_line" | awk -F'[()]' '{print $2}' | awk '{print $1}' || echo "0")
    
    # Extract transferred data and MiB/sec
    local transferred_line=$(grep "MiB transferred" "$result_file" 2>/dev/null)
    local transferred=$(echo "$transferred_line" | awk '{print $1}' || echo "0")
    local mib_per_sec=$(echo "$transferred_line" | awk -F'[()]' '{print $2}' | awk '{print $1}' || echo "0")
    
    local avg_latency=$(grep "avg:" "$result_file" 2>/dev/null | head -1 | awk '{print $NF}' | tr -d ',' || echo "0")
    
    # Extract p95 latency
    local p95_latency=$(grep "95th percentile" "$result_file" 2>/dev/null | awk '{print $NF}' | head -1 | tr -d ',' || echo "0")
    
    # Display detailed summary
    echo ""
    echo "Memory test summary:"
    echo "  Total operations: ${total_ops} (${ops_per_sec} per second)"
    echo "  Transferred: ${transferred} MiB (${mib_per_sec} MiB/sec)"
    echo "  Avg Latency: ${avg_latency}ms"
    echo "  P95 Latency: ${p95_latency:-0}ms"
}

# Append result to original data file (raw sysbench output for traceability)
append_to_original() {
    local section_title="$1"
    local result_file="$2"
    local original_file="$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
    
    # Get local machine IP
    local local_ip=$(get_machine_ip)
    
    # Append to original data file for traceability (only raw test output)
    echo "" >> "$original_file"
    echo "================================================================================" >> "$original_file"
    echo "$section_title (Server: $local_ip) (ORIGINAL OUTPUT)" >> "$original_file"
    echo "================================================================================" >> "$original_file"
    if [ -f "$result_file" ]; then
        # For sysbench tests, extract only the raw test output
        if echo "$section_title" | grep -E "CPU|MEMORY|IO|THREADS|MUTEX" > /dev/null; then
            # For both local and remote tests, just append the whole file to original data
            # This ensures we capture all raw sysbench output
            cat "$result_file" >> "$original_file"
        # For pgbench tests
        elif echo "$section_title" | grep -E "PGBENCH" > /dev/null; then
            # Extract pgbench raw output
            cat "$result_file" >> "$original_file"
        # For network tests
        elif echo "$section_title" | grep -E "NETWORK" > /dev/null; then
            # Extract network test raw output
            cat "$result_file" >> "$original_file"
        else
            # For other tests, just append the whole file
            cat "$result_file" >> "$original_file"
        fi
    fi
    echo "" >> "$original_file"
}

