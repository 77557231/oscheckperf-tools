# Check all dependencies
# Usage: check_all [server_ip]
# If server_ip is provided, it will be included in dependency check output
check_all() {
    local server_ip="${1:-}"
    
    if [ "$NO_CHECKS" = "true" ]; then
        return
    fi
    
    start_timer "check_all"
    echo "Checking system prerequisites..."
    echo "--------------------------------"
    
    # Validate parameters first - as the first check item
    echo "  Checking parameters..."
    # Use temporary file to capture output and exit code
    local temp_output=$(mktemp)
    validate_all_parameters true >"$temp_output" 2>&1
    local validation_exit_code=$?
    # Indent the output
    sed 's/^/  /' "$temp_output"
    rm -f "$temp_output"
    if [ $validation_exit_code -eq 0 ]; then
        echo "  ✓ Parameters check passed"
    else
        echo "  ✗ Parameters check failed"
        exit 1
    fi
    echo ""
    
    # Check dependencies
    check_dependencies "$server_ip"
    
    # Check permissions
    check_permissions
    
    # Check disk space
    check_disk_space
    
    # Check network connectivity
    check_network
    
    # Check SSH passwordless login for remote servers
    debug_log "Starting check_ssh"
    check_ssh
    
    # Cleanup residual processes on all servers (before test execution)
