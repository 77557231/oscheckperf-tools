# Validate path for security - check for dangerous characters
# Returns 0 if valid, 1 if invalid
# Prints error message with specific dangerous characters found
validate_path() {
    local path="$1"
    local param_name="$2"
    
    # List of dangerous characters that can be used for command injection
    local dangerous_chars=(";" "|" "&" "<" ">" "$" "\`" "\"" "'" "\\")
    local found_dangerous=""
    
    for char in "${dangerous_chars[@]}"; do
        if [[ "$path" == *"$char"* ]]; then
            # Escape special characters for display
            case "$char" in
                ";") found_dangerous="$found_dangerous ;" ;;
                "|") found_dangerous="$found_dangerous |" ;;
                "&") found_dangerous="$found_dangerous &" ;;
                "<") found_dangerous="$found_dangerous <" ;;
                ">") found_dangerous="$found_dangerous >" ;;
                "$") found_dangerous="$found_dangerous \$" ;;
                "\`") found_dangerous="$found_dangerous \`" ;;
                "\"") found_dangerous="$found_dangerous \"" ;;
                "'") found_dangerous="$found_dangerous '" ;;
                "\\") found_dangerous="$found_dangerous \\" ;;
            esac
        fi
    done
    
    if [ -n "$found_dangerous" ]; then
        echo "Error: Invalid $param_name path contains dangerous characters:$found_dangerous"
        echo "       Path: $path"
        return 1
    fi
    
    # Additional check: path traversal attack
    if [[ "$path" == *"../"* ]]; then
        echo "Error: Invalid $param_name path contains directory traversal (../)"
        echo "       Path: $path"
        return 1
    fi
    
    return 0
}

# Validate all path parameters
validate_all_paths() {
    local error_count=0
    
    # Validate IO_PATH
    if [ -n "${IO_PATH:-}" ]; then
        if ! validate_path "$IO_PATH" "IO_PATH"; then
            error_count=$((error_count + 1))
        fi
    fi
    
    # Validate OUTPUT_DIR
    if [ -n "${OUTPUT_DIR:-}" ]; then
        if ! validate_path "$OUTPUT_DIR" "OUTPUT_DIR"; then
            error_count=$((error_count + 1))
        fi
    fi
    
    # Validate TMP_DIR
    if [ -n "${TMP_DIR:-}" ]; then
        if ! validate_path "$TMP_DIR" "TMP_DIR"; then
            error_count=$((error_count + 1))
        fi
    fi
    
    if [ "$error_count" -gt 0 ]; then
        echo "Error: $error_count path validation error(s) found"
        exit 1
    fi
}

