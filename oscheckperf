# IO test function
run_io_test() {
    echo "=== IO Performance Test ==="
    
    local io_tool="${IO_TOOL:-sysbench}"
    local duration="${DURATION:-60}"
    
    if [ "$io_tool" = "fio" ]; then
        FIO_DURATION="${FIO_DURATION:-$duration}" run_fio_test
    else
        IO_DURATION="${IO_DURATION:-$duration}" run_sysbench_fileio
    fi
}

# sysbench fileio test
run_sysbench_fileio() {
    local temp_output_file="/tmp/vb_fileio_${TIMESTAMP}.txt"
    
    # Use a real disk directory instead of /tmp (which may be tmpfs)
    local test_dir="${IO_TEST_PATH:-$HOME/oscheckperf/io_test}"
    
    # Only display test info in non-remote mode
    if [ "$REMOTE" != "true" ]; then
        echo "Starting fileio test..."
        echo "  File size: ${IO_TOTAL_SIZE:-1G}, Test mode: ${IO_TEST_MODE:-rndrw}"
        echo "  Test directory: $test_dir"
    fi
    
    # Ensure test directory exists
    mkdir -p "$test_dir"
    
    # Save current directory
    local current_dir="$(pwd)"
    
    # Change to test directory
    cd "$test_dir" || {
        echo "❌ Failed to change to test directory: $test_dir"
        return 1
    }
    
    # Prepare test files first
    run_command "sysbench fileio \
        --file-total-size=\"${IO_TOTAL_SIZE:-1G}\" \
        --file-test-mode=\"${IO_TEST_MODE:-rndrw}\" \
        --file-num=\"${IO_FILE_NUM:-1}\" \
        prepare" "/dev/null"
    
    # Run test
    run_command "sysbench fileio \
        --file-total-size=\"${IO_TOTAL_SIZE:-1G}\" \
        --file-test-mode=\"${IO_TEST_MODE:-rndrw}\" \
        --time=\"${IO_DURATION:-120}\" \
        --file-num=\"${IO_FILE_NUM:-1}\" \
        run" "$temp_output_file"
    
    # Cleanup test files
    run_command "sysbench fileio \
        --file-total-size=\"${IO_TOTAL_SIZE:-1G}\" \
        --file-test-mode=\"${IO_TEST_MODE:-rndrw}\" \
        --file-num=\"${IO_FILE_NUM:-1}\" \
        cleanup" "/dev/null"
    
    # Change back to original directory
    cd "$current_dir" || true
    
    # Parse result and display detailed output
    if [ "$DRY_RUN" != true ] && [ -f "$temp_output_file" ]; then
        # Display parsed output
        parse_sysbench_fileio_result "$temp_output_file"
        
        # Append to combined results file
        append_to_original "SYSBENCH FILEIO TEST RESULTS" "$temp_output_file"
    fi
    
    # Cleanup temp file
    rm -f "$temp_output_file"
    
    # Only display completion message in non-remote mode
    if [ "$REMOTE" != "true" ]; then
        echo "✓ IO test completed"
    fi
}

# fio test
run_fio_test() {
    echo "[fio] Starting test..."
    
    # Check if fio is installed
    if ! command -v fio &> /dev/null; then
        echo "Error: fio not installed, please run: sudo yum install -y fio"
        return 1
    fi
    
    # Iterate through all profiles
    local profiles="${FIO_PROFILES:-randread}"
    
    for profile in $profiles; do
        echo "  Executing profile: $profile"
        
        # Generate fio configuration
        local fio_conf="/tmp/fio_${profile}.fio"
        local rw_type=$(eval echo "\$FIO_${profile^^}_RW")
        local bs=$(eval echo "\$FIO_${profile^^}_BS")
        local iodepth=$(eval echo "\$FIO_${profile^^}_IODEPTH")
        local numjobs=$(eval echo "\$FIO_${profile^^}_NUMJOBS")
        
        # Set default values
        rw_type="${rw_type:-randread}"
        bs="${bs:-8K}"
        iodepth="${iodepth:-64}"
        numjobs="${numjobs:-4}"
        
        cat > "$fio_conf" << EOF
[global]
ioengine=libaio
direct=1
size=${IO_TOTAL_SIZE:-1G}
runtime=${FIO_DURATION:-300}
time_based
group_reporting

[${profile}]
rw=${rw_type}
bs=${bs}
iodepth=${iodepth}
numjobs=${numjobs}
filename=${IO_TEST_PATH:-$HOME/oscheckperf/io_test}/fio_test_${profile}
EOF
        
        # Show configuration file content (also shown in dry run mode)
        echo "  Configuration file: $fio_conf"
        echo "  Config content:"
        echo "  ----------------"
        cat "$fio_conf"
        echo "  ----------------"
        echo
        
        # Run fio test
        local json_output="$OUTPUT_DIR/fio_${profile}_result.json"
        run_command "fio \"$fio_conf\" --output=\"$json_output\" --output-format=json" "/dev/null"
        
        # Cleanup temporary files (also cleanup in dry run mode)
        rm -f "$fio_conf"
        
        # Cleanup fio test file
        local fio_test_file="${IO_TEST_PATH:-$HOME/oscheckperf/io_test}/fio_test_${profile}"
        rm -f "$fio_test_file"
        
        # Parse result
        if [ "$DRY_RUN" != true ] && [ -f "$json_output" ]; then
            parse_fio_result "$json_output" "$profile"
        fi
    done
    
    echo "✓ fio test completed"
}

# Parse sysbench fileio result
parse_sysbench_fileio_result() {
    local result_file="$1"
    
    # Extract metrics
    local read_iops=$(grep "reads/s:" "$result_file" 2>/dev/null | awk '{print $NF}' || echo "0")
    local write_iops=$(grep "writes/s:" "$result_file" 2>/dev/null | awk '{print $NF}' || echo "0")
    local total_iops=$(awk "BEGIN {printf \"%.2f\", $read_iops + $write_iops}" 2>/dev/null || echo "0")
    local read_bw=$(grep "read, MiB/s:" "$result_file" 2>/dev/null | awk '{print $NF}' || echo "0")
    local write_bw=$(grep "written, MiB/s:" "$result_file" 2>/dev/null | awk '{print $NF}' || echo "0")
    local total_bw=$(awk "BEGIN {printf \"%.2f\", $read_bw + $write_bw}" 2>/dev/null || echo "0")
    local avg_latency=$(grep "avg:" "$result_file" 2>/dev/null | head -1 | awk '{print $NF}' | tr -d ',' || echo "0")
    
    # Display summary
    echo ""
    echo "IO test results:"
    echo "  Read IOPS: $read_iops"
    echo "  Write IOPS: $write_iops"
    echo "  Total IOPS: $total_iops"
    echo "  Read BW: ${read_bw}MB/s"
    echo "  Write BW: ${write_bw}MB/s"
    echo "  Total BW: ${total_bw}MB/s"
    echo "  Avg Latency: ${avg_latency}ms"
}

# Parse fio result
parse_fio_result() {
    local json_file="$1"
    local profile="$2"
    
    # Check if jq is installed
    if ! command -v jq &> /dev/null; then
        echo "  ⚠ jq not installed, skipping detailed parsing"
        return
    fi
    
    if [ ! -f "$json_file" ]; then
        echo "  ⚠ Result file not found: $json_file"
        return
    fi
    
    # Extract metrics
    local read_iops=$(jq -r '.jobs[0].read.iops // 0' "$json_file" 2>/dev/null)
    local write_iops=$(jq -r '.jobs[0].write.iops // 0' "$json_file" 2>/dev/null)
    local read_bw=$(jq -r '.jobs[0].read.bw_bytes // 0' "$json_file" 2>/dev/null)
    local write_bw=$(jq -r '.jobs[0].write.bw_bytes // 0' "$json_file" 2>/dev/null)
    local read_lat_p50=$(jq -r '.jobs[0].read.lat_ns.percentile."50.000000" // 0' "$json_file" 2>/dev/null)
    local read_lat_p95=$(jq -r '.jobs[0].read.lat_ns.percentile."95.000000" // 0' "$json_file" 2>/dev/null)
    local read_lat_p99=$(jq -r '.jobs[0].read.lat_ns.percentile."99.000000" // 0' "$json_file" 2>/dev/null)
    local write_lat_p50=$(jq -r '.jobs[0].write.lat_ns.percentile."50.000000" // 0' "$json_file" 2>/dev/null)
    local write_lat_p95=$(jq -r '.jobs[0].write.lat_ns.percentile."95.000000" // 0' "$json_file" 2>/dev/null)
    local write_lat_p99=$(jq -r '.jobs[0].write.lat_ns.percentile."99.000000" // 0' "$json_file" 2>/dev/null)
    
    # Save metrics (uppercase profile name as prefix)
    local prefix="FIO_${profile^^}"
    echo "${prefix}_READ_IOPS=${read_iops}" >> "$OUTPUT_DIR/metrics.env"
    echo "${prefix}_WRITE_IOPS=${write_iops}" >> "$OUTPUT_DIR/metrics.env"
    echo "${prefix}_READ_BW_BPS=${read_bw}" >> "$OUTPUT_DIR/metrics.env"
    echo "${prefix}_WRITE_BW_BPS=${write_bw}" >> "$OUTPUT_DIR/metrics.env"
    echo "${prefix}_READ_LAT_P50_NS=${read_lat_p50}" >> "$OUTPUT_DIR/metrics.env"
    echo "${prefix}_READ_LAT_P95_NS=${read_lat_p95}" >> "$OUTPUT_DIR/metrics.env"
    echo "${prefix}_READ_LAT_P99_NS=${read_lat_p99}" >> "$OUTPUT_DIR/metrics.env"
    echo "${prefix}_WRITE_LAT_P50_NS=${write_lat_p50}" >> "$OUTPUT_DIR/metrics.env"
    echo "${prefix}_WRITE_LAT_P95_NS=${write_lat_p95}" >> "$OUTPUT_DIR/metrics.env"
    echo "${prefix}_WRITE_LAT_P99_NS=${write_lat_p99}" >> "$OUTPUT_DIR/metrics.env"
    
    # Display summary
    echo ""
    echo "  fio [$profile] test results:"
    echo "    Read IOPS: $read_iops"
    echo "    Write IOPS: $write_iops"
    echo "    Read BW: $((read_bw / 1024 / 1024))MB/s"
    echo "    Write BW: $((write_bw / 1024 / 1024))MB/s"
    echo "    Read P95 Latency: ${read_lat_p95}ns"
    echo "    Write P95 Latency: ${write_lat_p95}ns"
}

# Get machine's real IP address
get_machine_ip() {
    # Try hostname -I first (returns all IPs), take the first one
    local ip=$(hostname -I 2>/dev/null | awk '{print $1}')
    if [ -n "$ip" ]; then
        echo "$ip"
        return 0
    fi
    
    # Fallback: try ip route
    ip=$(ip route get 8.8.8.8 2>/dev/null | grep -oP 'src \K\S+')
    if [ -n "$ip" ]; then
        echo "$ip"
        return 0
    fi
    
    # Last fallback
    echo "127.0.0.1"
}

# Display per-second throughput
display_per_second_throughput() {
    local text_file="$1"
    local server_ip="$2"
    
    if [ ! -f "$text_file" ]; then
        return
    fi
    
    echo ""
    echo "Per-second throughput for $server_ip:"
    # Extract interval lines showing per-second data (format: [  5] 0.00-1.00 sec XXX MBytes X.XX Gbits/sec)
    # Support both Mbits/sec and Gbits/sec
    local lines=$(grep "sec" "$text_file" | grep "MBytes" | grep -E "(M|G)bits/sec" | grep -v "sender\|receiver")
    if [ -n "$lines" ]; then
        echo "$lines" | sed 's/^/  /'
    else
        echo "  No per-second data available"
    fi
}

# Network test function
run_network_test() {
    local network_tool="${NETWORK_TOOL:-iperf3}"
    local network_mode="${NETWORK_MODE:-single}"
    local network_enabled="${NETWORK_ENABLED:-true}"
    local network_client_ip="${NETWORK_CLIENT_IP:-}"
    
    # Check if network test is enabled
    if [ "$network_enabled" != "true" ]; then
        echo "Network test disabled"
        return 0
    fi
    
    # Skip network test if no client IPs are configured (single machine test has no meaning)
    if [ -z "$network_client_ip" ]; then
        echo "=== Network Performance Test ==="
        echo "Skipping network test: No client IPs configured (single machine test has no meaning)"
        return 0
    fi
    
    echo "=== Network Performance Test ==="
    
    
    # Check if iperf3 is installed
    if ! command -v iperf3 &> /dev/null; then
        echo "Error: iperf3 not installed, please run: sudo yum install -y iperf3"
        return 1
    fi
    
    if [ "$network_mode" = "parallel" ]; then
        run_parallel_network_test
    elif [ "$network_mode" = "matrix" ]; then
        run_matrix_network_test
    else
        run_serial_network_test
    fi
}

# Serial network test (sequential testing)
run_serial_network_test() {
    local port="${NETWORK_PORT:-25201}"
    local duration="${DURATION:-60}"
    local parallel="${NETWORK_PARALLEL:-1}"
    
    # Create output directory if it doesn't exist
    local output_dir="./output"
    mkdir -p "$output_dir"
    
    # Auto-detect server IP if not set
    local server_ip="${NETWORK_SERVER_IP}"
    if [ -z "$server_ip" ]; then
        server_ip=$(get_machine_ip)
        echo "  Auto-detected server IP: $server_ip"
    fi
    
    # Use server IP as client IP if client IP not set (localhost test)
    local client_ip="${NETWORK_CLIENT_IP:-$server_ip}"
    
    local temp_output_file="/tmp/vb_network_${TIMESTAMP}.txt"
    local temp_text_output="/tmp/vb_network_text_${TIMESTAMP}.txt"
    local iperf3_pid=""
    local results=()
    
    # Check if multiple client IPs are configured (space-separated)
    local client_ips=($client_ip)
    local num_clients=${#client_ips[@]}
    
    echo "Starting iperf3 test..."
    echo "  Server: $server_ip:$port"
    echo "  Client(s): $client_ip"
    echo "  Duration: ${duration}s, Parallel connections: $parallel"
    echo "  Total test scenarios: $num_clients"
    
    # Start iperf3 server in background
    echo "  Starting iperf3 server on port $port..."
    if [ "$DRY_RUN" = true ]; then
        # Dry run mode: just show the command
        echo "[DRY RUN] iperf3 -s -p \"$port\" -D"
        echo "[DRY RUN] Server would start on $server_ip:$port"
    else
        # Actual run: start the server
        run_command "iperf3 -s -p \"$port\" -D" "/dev/null"
        sleep 2  # Wait for server to start
        
        # Verify server is running using pidof (more reliable than pgrep)
        if ! pidof iperf3 > /dev/null; then
            echo "⚠ Failed to start iperf3 server"
            return 1
        fi
    fi
    
    # Execute tests for each client IP sequentially
    local client_idx=0
    for client in "${client_ips[@]}"; do
        client_idx=$((client_idx + 1))
        
        if [ $num_clients -gt 1 ]; then
            echo ""
            echo "  [Test $client_idx/$num_clients] Testing from client: $client"
        fi
        
        # Skip test if client and server are the same IP (loopback test)
        if [ "$client" = "$server_ip" ]; then
            echo "  ⚠ Skipping loopback test (client and server are the same IP)"
            echo "  Loopback tests do not represent real network performance"
            continue
        fi
        
        # Calculate timeout: duration + 15s buffer for each client
        local client_timeout=$((duration + 15))
        local client_output_file="$output_dir/network/network_scenario_${client_idx}_${TIMESTAMP}.json"
        local client_text_output="$output_dir/network/network_scenario_${client_idx}_${TIMESTAMP}_text.txt"
        
        # Run iperf3 client with timeout and capture both JSON and text output
        if [ "$DRY_RUN" = true ]; then
            # Dry run mode: just show the commands
            echo "[DRY RUN] timeout $client_timeout iperf3 -c \"$server_ip\" -p \"$port\" -t \"$duration\" -P \"$parallel\" -J"
            echo "[DRY RUN] iperf3 -c \"$server_ip\" -p \"$port\" -t \"$duration\" -P \"$parallel\" 2>&1 | grep -v \"^$\""
            echo "  [DRY RUN] Test would complete: $client -> $server_ip"
        else
            # Actual run: execute the client test
            # Check if client is reachable first
            if ! ping -c 1 -W 2 "$client" > /dev/null 2>&1; then
                echo "  ⚠ Client $client is unreachable"
                continue
            fi
            
            # Check if iperf3 is installed on client
            if ! ssh "$client" "command -v iperf3 > /dev/null 2>&1"; then
                echo "  ⚠ iperf3 not installed on client $client"
                echo "  Please run: ssh $client 'sudo yum install -y iperf3'"
                continue
            fi
            
            echo "  Running test: $client -> $server_ip"
            
            if run_command "timeout $client_timeout ssh $client 'iperf3 -c "$server_ip" -p "$port" -t "$duration" -P "$parallel" -J'" "$client_output_file"; then
                
                # Capture text format output for per-second data
                run_command "ssh $client 'iperf3 -c "$server_ip" -p "$port" -t "$duration" -P "$parallel" 2>&1 | grep -v \"^$\"'" "$client_text_output"
                
                # Parse and display result
                local bandwidth=$(parse_iperf3_matrix_result "$client_output_file")
                parse_iperf3_result "$client_output_file"
                
                # Add result to results array
                results+=("$client|$server_ip|$bandwidth")
                
                # Display per-second throughput
                display_per_second_throughput "$client_text_output" "$server_ip (from $client)"
                
                # Append to combined results file
                append_to_original "NETWORK TEST RESULTS ($server_ip from $client)" "$client_text_output"
                
                echo "  ✓ Client $client test completed"
            else
                echo "  ⚠ Client $client test failed or timed out"
                echo "  Possible issues: firewall, iperf3 not running, or network issues"
            fi
        fi
        
        # Keep the files for report generation
    done
    
    # Stop iperf3 server (only log to terminal, not data file)
    echo "  Stopping iperf3 server..." > /dev/tty
    if [ "$DRY_RUN" = true ]; then
        echo "[DRY RUN] pkill -f \"iperf3 -s -p $port\"" > /dev/tty
    else
        pkill -f "iperf3 -s -p $port" 2>/dev/null || true
        sleep 1
    fi
    
    return 0
}

# Multi-server network test
run_multi_server_network_test() {
    echo "Starting multi-server network test..."
    
    # Create output directory if it doesn't exist
    local output_dir="./output"
    mkdir -p "$output_dir"
    
    # Parse server list
    local servers=$(parse_servers)
    local server_ip=""
    
    if [ -z "$servers" ]; then
        # Generate server list from NETWORK_SERVER_IP and NETWORK_CLIENT_IP
        server_ip="${NETWORK_SERVER_IP}"
        local client_ip="${NETWORK_CLIENT_IP}"
        
        if [ -z "$server_ip" ]; then
            server_ip=$(get_machine_ip)
            echo "  Auto-detected server IP: $server_ip"
        fi
        
        if [ -z "$client_ip" ]; then
            client_ip="$server_ip"
            echo "  Auto-detected client IP: $client_ip"
        fi
        
        # Convert client IPs to array
        local client_ips=($client_ip)
        
        # Generate server list
        echo "  Generating server list from NETWORK_SERVER_IP and NETWORK_CLIENT_IP..."
        servers=""
        for client in "${client_ips[@]}"; do
            servers+="$client|client|"
        done
        servers+="$server_ip|server|"
    else
        # Extract server IP from server list
        server_ip=$(echo "$servers" | grep '|server|' | cut -d'|' -f1 | head -1)
        if [ -z "$server_ip" ]; then
            server_ip=$(get_machine_ip)
            echo "  Auto-detected server IP: $server_ip"
        fi
    fi
    
    # Parse test scenarios
    local scenarios=$(parse_test_scenarios)
    local default_duration="${NETWORK_DURATION:-60}"
    
    if [ -z "$scenarios" ]; then
        # Generate test scenarios from server list and NETWORK_DURATION
        local client_ip="${NETWORK_CLIENT_IP}"
        
        if [ -z "$client_ip" ]; then
            client_ip="$server_ip"
        fi
        
        # Convert client IPs to array
        local client_ips=($client_ip)
        
        # Generate test scenarios
        echo "  Generating test scenarios from NETWORK_SERVER_IP, NETWORK_CLIENT_IP, and NETWORK_DURATION..."
        scenarios=""
        for client in "${client_ips[@]}"; do
            scenarios+="$client|$server_ip|$default_duration,"
        done
        # Remove trailing comma
        scenarios=${scenarios%,}
    else
        # Use default duration if not specified in TEST_SCENARIOS
        local updated_scenarios=""
        while IFS='|' read -r client_ip server_ip duration; do
            if [ -z "$duration" ]; then
                duration="$default_duration"
            fi
            updated_scenarios+="$client_ip|$server_ip|$duration,"
        done <<< "$(echo "$scenarios" | tr ',' '\n')"
        # Remove trailing comma
        scenarios=${updated_scenarios%,}
    fi
    
    # Start iperf3 server in background for local tests
    local port="${NETWORK_PORT:-25201}"
    local iperf3_pid=""
    
    # Check if port is already in use
    if lsof -i:$port > /dev/null 2>&1; then
        echo "  Port $port is already in use, killing existing process..."
        pkill -f "iperf3 -s -p $port" 2>/dev/null || true
        pkill iperf3 2>/dev/null || true
        sleep 2
    fi
    
    echo "  Starting iperf3 server on port $port..."
    # Start iperf3 server in a different way
    (iperf3 -s -p "$port" > /tmp/iperf3_server.log 2>&1) &
    iperf3_pid=$!
    sleep 3  # Wait for server to start
    
    # Verify server is running
    if ! ps -p "$iperf3_pid" > /dev/null 2>&1; then
        echo "⚠ Failed to start iperf3 server"
        echo "  Server log:"
        cat /tmp/iperf3_server.log 2>/dev/null
        # Try alternative approach
        echo "  Trying alternative approach..."
        iperf3 -s -p "$port" -D > /tmp/iperf3_server_alt.log 2>&1
        iperf3_pid=$!
        sleep 2
        if ! ps -p "$iperf3_pid" > /dev/null 2>&1; then
            echo "  Alternative approach failed"
            echo "  Alternative log:"
            cat /tmp/iperf3_server_alt.log 2>/dev/null
            return 1
        fi
    fi
    
    echo "  iperf3 server started successfully with PID: $iperf3_pid"
    
    # Execute each test scenario sequentially
    local scenario_idx=0
    
    while IFS='|' read -r client_ip server_ip duration; do
        scenario_idx=$((scenario_idx + 1))
        echo ""
        echo "Executing scenario $scenario_idx: $client_ip -> $server_ip (${duration}s)"
        
        # Run iperf3 locally
        # Note: For remote testing, SSH passwordless login is required
        echo "  Running network test..."
        echo "  Command: iperf3 -c $server_ip -p $port -t $duration -J"
        
        # Create output directory if it doesn't exist
        local output_dir="./output"
        mkdir -p "$output_dir"
        
        # Update output file path
        local output_file="$output_dir/network_scenario_${scenario_idx}.json"
        
        # Run iperf3 locally
        echo "  Running network test locally..."
        iperf3 -c "$server_ip" -p "$port" -t "$duration" -J > "$output_file" 2>&1
        
        # Check if iperf3 command succeeded
        if [ $? -eq 0 ]; then
            # Capture text format output for per-second data
            local text_output="$output_dir/network_scenario_${scenario_idx}_text.txt"
            iperf3 -c "$server_ip" -p "$port" -t "$duration" 2>&1 | grep -v "^$" > "$text_output"
            
            # Parse and display result
            parse_iperf3_result "$output_file"
            
            # Display per-second throughput
            display_per_second_throughput "$text_output" "$server_ip (from $client_ip)"
            
            # Append to combined results file
            append_to_original "NETWORK TEST RESULTS ($server_ip from $client_ip)" "$text_output"
            
            echo "  ✓ Network test completed locally"
        else
            echo "  ⚠ iperf3 test failed"
            
            # For demonstration, just create an empty file
            touch "$output_file"
        fi
        
    done <<< "$(echo "$scenarios" | tr ',' '\n')"

    
    # Stop iperf3 server
    echo "  Stopping iperf3 server..."
    kill "$iperf3_pid" 2>/dev/null || true
    pkill -f "iperf3 -s -p $port" 2>/dev/null || true
    sleep 1
    
    echo ""
    echo "✓ Multi-server network test completed"
}

# Matrix network test (all-to-all cross testing)
run_matrix_network_test() {
    echo "=== Matrix Network Performance Test (All-to-All) ==="
    
    # Get local IP address
    local LOCAL_IP=$(hostname -I | awk '{print $1}')
    
    local port="${NETWORK_PORT:-25201}"
    local duration="${DURATION:-60}"
    local parallel="${NETWORK_PARALLEL:-1}"
    
    # Create output directory if it doesn't exist
    local output_dir="$OUTPUT_DIR"
    mkdir -p "$output_dir"
    
    # Get all host IPs from server list or NETWORK_CLIENT_IP
    local host_ips=()
    if [ ${#target_servers[@]} -gt 0 ]; then
        host_ips=(${target_servers[@]})
    else
        # Use NETWORK_CLIENT_IP if server list not provided
        local client_ip="${NETWORK_CLIENT_IP:-}"
        if [ -z "$client_ip" ]; then
            echo "Skipping matrix network test: No client IPs configured"
            return 0
        fi
        host_ips=($client_ip)
    fi
    
    local num_hosts=${#host_ips[@]}
    
    if [ $num_hosts -lt 2 ]; then
        echo "Skipping matrix network test: At least 2 hosts required for matrix testing"
        return 0
    fi
    
    echo "Starting matrix network test..."
    echo "  Hosts: ${host_ips[*]}"
    echo "  Test duration: ${duration}s per pair"
    echo "  Parallel connections: $parallel"
    local total_pairs=$((num_hosts * (num_hosts - 1) / 2))
    echo "  Total test pairs: $total_pairs"
    
    # Generate host pairs (A→B only, no B→A duplicates)
    local test_pairs=()
    for ((i=0; i<num_hosts; i++)); do
        for ((j=i+1; j<num_hosts; j++)); do
            test_pairs+=("${host_ips[i]}|${host_ips[j]}")
        done
    done
    
    local num_pairs=${#test_pairs[@]}
    echo "  Total test scenarios: $num_pairs"
    echo "  Test pairs: ${test_pairs[*]}"
    
    # Create results array
    local results=()
    
    # Execute tests for each pair
    local pair_idx=0
    for pair in "${test_pairs[@]}"; do
        pair_idx=$((pair_idx + 1))
        IFS='|' read -r src dst <<< "$pair"
        
        echo ""
        echo "  [Test $pair_idx/$num_pairs] Testing: $src -> $dst"
        
        # Start iperf3 server on destination
        echo "  Starting iperf3 server on $dst..."
        run_command "ssh $dst 'iperf3 -s -p $port -D'" "/dev/null"
        
        if [ "$DRY_RUN" != true ]; then
            sleep 3  # Wait for server to start
        fi
        
        # Run iperf3 client from source
        local client_output_file="$output_dir/network/network_matrix_${pair_idx}_${TIMESTAMP}.json"
        local client_text_output="$output_dir/network/network_matrix_${pair_idx}_${TIMESTAMP}_text.txt"
        
        echo "  Running iperf3 client from $src to $dst..."
        # Check if source is local machine
        if [ "$src" = "$LOCAL_IP" ]; then
            # Run locally
            if run_command "iperf3 -c $dst -p $port -t $duration -P $parallel -J" "$client_output_file"; then
                # Capture text format output
                run_command "iperf3 -c $dst -p $port -t $duration -P $parallel 2>&1 | grep -v ^$" "$client_text_output"
            else
                results+=("$src|$dst|0")
                echo "  ⚠ Test failed: $src -> $dst"
                # Stop iperf3 server on destination
                run_command "ssh $dst 'pkill -f \"iperf3 -s -p $port\"'" "/dev/null"
                continue
            fi
        else
            # Run via SSH
            if run_command "ssh $src \"iperf3 -c $dst -p $port -t $duration -P $parallel -J\"" "$client_output_file"; then
                # Capture text format output
                run_command "ssh $src \"iperf3 -c $dst -p $port -t $duration -P $parallel 2>&1 | grep -v ^$\"" "$client_text_output"
            else
                results+=("$src|$dst|0")
                echo "  ⚠ Test failed: $src -> $dst"
                # Stop iperf3 server on destination
                run_command "ssh $dst 'pkill -f \"iperf3 -s -p $port\"'" "/dev/null"
                continue
            fi
        fi
        
        # Parse result
        if [ "$DRY_RUN" != true ] && [ -f "$client_output_file" ]; then
            local bandwidth=$(parse_iperf3_matrix_result "$client_output_file")
            results+=("$src|$dst|$bandwidth")
            
            # Display per-second throughput
            display_per_second_throughput "$client_text_output" "$dst (from $src)"
            
            # Append to combined results file
            append_to_original "NETWORK MATRIX TEST RESULTS ($src -> $dst)" "$client_text_output"
            
            echo "  ✓ Test completed: $src -> $dst = ${bandwidth} MB/s"
        else
            if [ "$DRY_RUN" = true ]; then
                results+=("$src|$dst|0")
                echo "  [DRY RUN] Test would complete: $src -> $dst"
            else
                results+=("$src|$dst|0")
                echo "  ⚠ Test failed: $src -> $dst"
            fi
        fi
        
        # Stop iperf3 server on destination
        if [ "$DRY_RUN" != true ]; then
            # Use nohup to avoid SSH blocking
            nohup ssh $dst "pkill -f \"iperf3 -s -p $port\" 2>/dev/null" > /dev/null 2>&1 &
            sleep 1
        fi
    done
    
    # Generate matrix report
    generate_matrix_report "${results[@]}" "${host_ips[@]}"
    
    # Output summary of results to terminal
    if [ ${#results[@]} -gt 0 ]; then
        echo ""
        for result in "${results[@]}"; do
            IFS='|' read -r src dst bw <<< "$result"
            echo "- $src -> $dst = ${bw} MB/s"
        done
    fi
    
    echo ""
    echo "✓ Matrix network test completed"
}

# Parallel network test (concurrent testing)
run_parallel_network_test() {
    echo "=== Parallel Network Performance Test ==="
    
    local port="${NETWORK_PORT:-25201}"
    local duration="${DURATION:-60}"
    local parallel="${NETWORK_PARALLEL:-1}"
    
    # Create output directory if it doesn't exist
    local output_dir="$OUTPUT_DIR"
    mkdir -p "$output_dir"
    
    # Get all host IPs from server list or NETWORK_CLIENT_IP
    local host_ips=()
    if [ ${#target_servers[@]} -gt 0 ]; then
        host_ips=(${target_servers[@]})
    else
        # Use NETWORK_CLIENT_IP if server list not provided
        local client_ip="${NETWORK_CLIENT_IP:-}"
        if [ -z "$client_ip" ]; then
            echo "Skipping parallel network test: No client IPs configured"
            return 0
        fi
        host_ips=($client_ip)
    fi
    
    local num_hosts=${#host_ips[@]}
    
    if [ $num_hosts -lt 2 ]; then
        echo "Skipping parallel network test: At least 2 hosts required"
        return 0
    fi
    
    echo "Starting parallel network test..."
    echo "  Hosts: ${host_ips[*]}"
    echo "  Test duration: ${duration}s"
    echo "  Parallel connections: $parallel"
    
    # Use the first host as server
    local server_ip="${host_ips[0]}"
    echo "  Server: $server_ip"
    
    # Start iperf3 server on the first host
    echo "  Starting iperf3 server on $server_ip..."
    run_command "ssh $server_ip 'iperf3 -s -p $port -D'" "/dev/null"
    
    if [ "$DRY_RUN" != true ]; then
        sleep 3  # Wait for server to start
    fi
    
    # Create results array
    local results=()
    local pids=()
    local output_files=()
    
    # Run tests sequentially for all other hosts as clients (more reliable)
    local client_idx=0
    for ((i=1; i<num_hosts; i++)); do
        local client_ip="${host_ips[$i]}"
        client_idx=$((client_idx + 1))
        
        echo "  Starting test $client_idx: $client_ip -> $server_ip"
        
        local client_output_file="$output_dir/network/network_parallel_${client_idx}_${TIMESTAMP}.json"
        local client_text_output="$output_dir/network/network_parallel_${client_idx}_${TIMESTAMP}_text.txt"
        
        if [ "$DRY_RUN" = true ]; then
            echo "[DRY RUN] ssh $client_ip 'iperf3 -c $server_ip -p $port -t $duration -P $parallel -J'"
            echo "[DRY RUN] ssh $client_ip 'iperf3 -c $server_ip -p $port -t $duration -P $parallel 2>&1 | grep -v ^$'"
            results+=("$client_ip|$server_ip|0")
            echo "  [DRY RUN] Test would complete: $client_ip -> $server_ip"
        else
            # Run iperf3 client sequentially with timeout
            timeout 10s ssh $client_ip "iperf3 -c $server_ip -p $port -t $duration -P $parallel -J" > "$client_output_file" 2>&1
            local exit_status=$?
            
            if [ $exit_status -eq 0 ]; then
                # Parse result
                if [ -f "$client_output_file" ]; then
                    local bandwidth=$(parse_iperf3_matrix_result "$client_output_file")
                    results+=("$client_ip|$server_ip|$bandwidth")
                    echo "  ✓ Test completed: $client_ip -> $server_ip = ${bandwidth} MB/s"
                else
                    results+=("$client_ip|$server_ip|0")
                    echo "  ⚠ Test failed: $client_ip -> $server_ip (no output file)"
                fi
            else
                results+=("$client_ip|$server_ip|0")
                echo "  ⚠ Test failed: $client_ip -> $server_ip (timeout or error)"
            fi
        fi
    done
    
    # Stop iperf3 server
    run_command "ssh $server_ip 'pkill -f \"iperf3 -s -p $port\"'" "/dev/null"
    
    if [ "$DRY_RUN" != true ]; then
        sleep 1
    fi
    
    # Generate parallel test report
    generate_parallel_report "${results[@]}" "$server_ip"
    
    # Output summary of results to terminal
    if [ ${#results[@]} -gt 0 ]; then
        echo ""
        for result in "${results[@]}"; do
            IFS='|' read -r src dst bw <<< "$result"
            echo "- $src -> $dst = ${bw} MB/s"
        done
    fi
    
    echo ""
    echo "✓ Parallel network test completed"
}

# Generate parallel test report
generate_parallel_report() {
    local results=($1)
    local server_ip="$2"
    local report_file="$OUTPUT_DIR/network/network_parallel_report_${TIMESTAMP}.txt"
    
    echo "Generating parallel network test report..."
    
    # Create report header
    cat > "$report_file" << EOF
================================================================================
                           Parallel Network Test Report
================================================================================

Test Time: $(date '+%Y-%m-%d %H:%M:%S')
Test Duration: ${DURATION:-60}s
Parallel Connections: ${NETWORK_PARALLEL:-1}
Server: $server_ip

================================================================================
                               Test Results
================================================================================
EOF
    
    # Create results table
    echo -n "Client IP" >> "$report_file"
    printf "\t%15s" "Bandwidth (MB/s)" >> "$report_file"
    echo >> "$report_file"
    
    # Calculate statistics
    local total_bw=0
    local count=0
    local min_bw=999999
    local max_bw=0
    local bw_values=()
    
    for result in "${results[@]}"; do
        IFS='|' read -r client_ip r_server_ip r_bw <<< "$result"
        printf "%15s" "$client_ip" >> "$report_file"
