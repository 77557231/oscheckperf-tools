}

# Unified hardware report function - supports both single and multi-node modes
# Usage: generate_hardware_report_unified <report_file> [server1 server2 ...]
generate_hardware_report_unified() {
    local report_file="$1"
    shift
    local servers=("$@")
    
    printf -- "================================================================================\n" > "$report_file"
    printf -- "                    Hardware Information Report\n" >> "$report_file"
    printf -- "================================================================================\n" >> "$report_file"
    printf -- "\n" >> "$report_file"
    
    if [ ${#servers[@]} -gt 0 ]; then
        local node_idx=1
        local local_ip=$(get_machine_ip)
        for ip in "${servers[@]}"; do
            printf -- "=============================================================================\n" >> "$report_file"
            printf -- "  Node %d: %s\n" "$node_idx" "$ip" >> "$report_file"

            printf -- "\n" >> "$report_file"
            
            local is_local="false"
            if [ "$ip" = "$local_ip" ]; then
                is_local="true"
            fi
            
            local node_info=$(get_node_hardware_info "$ip" "$is_local")
            print_node_hardware_info "$report_file" "$node_info" "  "
            
            node_idx=$((node_idx + 1))
            printf -- "\n" >> "$report_file"
        done
    else
        printf -- "Hostname: ${HOSTNAME:-N/A}\n" >> "$report_file"
        printf -- "\n" >> "$report_file"
        
        local cpu_arch=$(get_cpu_arch 2>/dev/null || echo "N/A")
        local machine_type=$(get_machine_type 2>/dev/null || echo "N/A")
        local os_info=$(get_os_info 2>/dev/null || echo "N/A")
        local kernel_version=$(get_kernel_version 2>/dev/null || echo "N/A")
        local uptime=$(get_uptime_info 2>/dev/null || echo "N/A")
        local cpu_model=$(get_cpu_model 2>/dev/null || echo "N/A")
        local cpu_physical_cores=$(get_cpu_physical_cores 2>/dev/null || echo "N/A")
        local cpu_logical_cores=$(get_cpu_logical_cores 2>/dev/null || echo "N/A")
        local cpu_freq=$(get_cpu_freq 2>/dev/null || echo "N/A")
        local cpu_l1d_cache=$(get_cpu_l1_cache 2>/dev/null || echo "N/A")
        local cpu_l2_cache=$(get_cpu_l2_cache 2>/dev/null || echo "N/A")
        local cpu_l3_cache=$(get_cpu_l3_cache 2>/dev/null || echo "N/A")
        local cpu_features=$(get_cpu_features 2>/dev/null || echo "N/A")
        local cpu_freq_min=$(get_cpu_freq_min 2>/dev/null || echo "N/A")
        local cpu_freq_max=$(get_cpu_freq_max 2>/dev/null || echo "N/A")
        local cpu_governor=$(get_cpu_governor 2>/dev/null || echo "N/A")
        local mem_total=$(get_memory_size_mb 2>/dev/null || echo "N/A")
        local mem_available=$(get_memory_available_mb 2>/dev/null || echo "N/A")
        local mem_type=$(get_memory_type 2>/dev/null || echo "N/A")
        local mem_freq=$(get_memory_freq 2>/dev/null || echo "N/A")
        local mem_channels=$(get_memory_channels 2>/dev/null || echo "N/A")
        local mem_slots_detail=$(get_memory_slots_detail 2>/dev/null)
        local numa_count=$(get_numa_node_count 2>/dev/null || echo "N/A")
        local numa_detail=$(get_numa_topology 2>/dev/null || echo "N/A")
        local mem_usage_rate=$(get_memory_usage_rate 2>/dev/null || echo "N/A")
        local thp_status=$(get_thp_status 2>/dev/null || echo "N/A")
        local hugepages=$(get_hugepages_count 2>/dev/null || echo "N/A")
        local net_bond=$(get_network_bond 2>/dev/null || echo "N/A")
        local net_count=$(get_network_interface_count 2>/dev/null || echo "N/A")
        local disk_queue=$(get_benchmark_disk_queue_depth 2>/dev/null || echo "N/A")
        local disk_ra=$(get_benchmark_disk_read_ahead 2>/dev/null || echo "N/A")
        local disk_trim_val=$(get_benchmark_disk_trim 2>/dev/null || echo "N/A")
        local disk_ms=$(get_benchmark_disk_max_sectors 2>/dev/null || echo "N/A")
        local mount_opts=$(get_benchmark_mount_options 2>/dev/null || echo "N/A")
        
        # Collect network basic lines
        local network_lines=()
        while IFS= read -r line; do
            if [ -n "$line" ]; then
                network_lines+=("$line")
            fi
        done < <(get_network_info 2>/dev/null | grep -v "^$")
        
        # Collect network advanced lines
        local net_adv_lines=()
        while IFS= read -r line; do
            [ -n "$line" ] && net_adv_lines+=("$line")
        done < <(get_network_advanced_info 2>/dev/null | grep -v "^$")
        
        # Build combined network lines
        local all_network_lines=()
        for nl in "${network_lines[@]}"; do
            all_network_lines+=("$nl")
        done
        for nal in "${net_adv_lines[@]}"; do
            all_network_lines+=("$nal")
        done

        print_system_info "$report_file" "" "$os_info" "$kernel_version" "$uptime"
        print_cpu_info "$report_file" "" \
            "$cpu_arch" "$machine_type" "$cpu_model" "$cpu_physical_cores" "$cpu_logical_cores" "$cpu_freq" \
            "$cpu_l1d_cache" "$cpu_l2_cache" "$cpu_l3_cache" "$cpu_features" "$cpu_freq_min" "$cpu_freq_max" "$cpu_governor"
        print_memory_info "$report_file" "" \
            "$mem_total" "$mem_available" "$mem_type" "$mem_freq" "$mem_channels" \
            "$mem_slots_detail" "$numa_count" "$numa_detail" \
            "$mem_usage_rate" "$thp_status" "$hugepages"
        
        local resolved_io_path="$IO_PATH"
        local disk_lines=()
        while IFS= read -r line; do
            disk_lines+=("$line")
        done < <(get_disk_info_detailed 2>/dev/null)
        print_disk_info_section "$report_file" "" "$resolved_io_path" "${disk_lines[@]}"
        
        local disk_usage_lines=()
        while IFS= read -r line; do
            disk_usage_lines+=("$line")
        done < <(get_disk_usage_info 2>/dev/null)
        print_disk_usage_section "$report_file" "" "$resolved_io_path" "${disk_usage_lines[@]}"
        
        local inode_lines=()
        while IFS= read -r line; do
            inode_lines+=("$line")
        done < <(get_inode_info 2>/dev/null)
        print_inode_section "$report_file" "" "$resolved_io_path" "${inode_lines[@]}"
        print_disk_io_settings "$report_file" "" "$disk_queue" "$disk_ra" "$disk_trim_val" "$disk_ms" "$mount_opts"
        print_network_info "$report_file" "" "$net_count" "$net_bond" "${all_network_lines[@]}"
    fi
    
    echo "$report_file"
}

