}

# Get CPU core count
get_cpu_cores() {
    nproc 2>/dev/null || grep -c ^processor /proc/cpuinfo 2>/dev/null || echo "unknown"
}

# Get memory size (MB)
get_memory_size_mb() {
    if [ -f /proc/meminfo ]; then
        awk '/MemTotal/ {printf "%.0f", $2/1024}' /proc/meminfo 2>/dev/null
    else
        echo "unknown"
    fi
}

# Get disk available space (KB)
get_disk_available_kb() {
    local path="${1:-$BASE_DIR}"
    df -P "$path" | awk 'NR==2 {print $4}'
}

# Get CPU model
get_cpu_model() {
    if [ -f /proc/cpuinfo ]; then
        grep -m 1 'model name' /proc/cpuinfo | sed 's/model name\s*: //' 2>/dev/null || echo "unknown"
    else
        echo "unknown"
    fi
}

# Get CPU physical cores count
get_cpu_physical_cores() {
    if [ -f /proc/cpuinfo ]; then
        local cores=$(grep -c 'physical id' /proc/cpuinfo 2>/dev/null)
        if [ -n "$cores" ] && [ "$cores" -gt 0 ] 2>/dev/null; then
            echo "$cores"
        else
            nproc 2>/dev/null || echo "unknown"
        fi
    else
        echo "unknown"
    fi
}

# Get CPU logical cores count
get_cpu_logical_cores() {
    nproc 2>/dev/null || grep -c ^processor /proc/cpuinfo 2>/dev/null || echo "unknown"
}

# Get CPU frequency (GHz)
get_cpu_freq() {
    if [ -f /proc/cpuinfo ]; then
        local freq=$(grep -m 1 'cpu MHz' /proc/cpuinfo | awk '{print $4}')
        if [ -n "$freq" ]; then
            awk "BEGIN {printf \"%.2f\", $freq / 1000}"
            return
        fi
    fi
    # Fallback to sysfs cpufreq (more reliable on aarch64)
    local freq=$(cat /sys/devices/system/cpu/cpu0/cpufreq/cpuinfo_max_freq 2>/dev/null)
    if [ -n "$freq" ] && [ "$freq" != "0" ]; then
        awk "BEGIN {printf \"%.2f\", $freq / 1000000}"
        return
    fi
    # Fallback to lscpu
    if command -v lscpu &>/dev/null; then
        freq=$(lscpu 2>/dev/null | grep -i 'CPU max MHz' | awk '{print $NF}')
        if [ -n "$freq" ] && [ "$freq" != "0" ]; then
            awk "BEGIN {printf \"%.2f\", $freq / 1000}"
            return
        fi
    fi
    # Last fallback: BogoMIPS (not reliable on aarch64)
    if [ -f /proc/cpuinfo ]; then
        freq=$(grep -m 1 'BogoMIPS' /proc/cpuinfo | awk '{print $3}')
        if [ -n "$freq" ]; then
            awk "BEGIN {printf \"%.2f\", $freq / 1000}"
            return
        fi
    fi
    echo "unknown"
}

# Get available memory (MB)
get_memory_available_mb() {
    if [ -f /proc/meminfo ]; then
        awk '/MemAvailable/ {printf "%.0f", $2/1024}' /proc/meminfo 2>/dev/null || echo "unknown"
    else
        echo "unknown"
    fi
}

# Get memory type (DDR4/DDR5 etc.)
get_memory_type() {
    local machine_type=$(get_machine_type 2>/dev/null)
    if echo "$machine_type" | grep -qi "virtual"; then
        echo "N/A (virtual machine)"
        return
    fi
    
    if command -v dmidecode &>/dev/null; then
        local mem_type=$(dmidecode -t memory 2>/dev/null | grep -m 1 'Type:' | sed 's/Type:\s*//' | sed 's/^[ \t]*//' | sed 's/[ \t]*$//' 2>/dev/null)
        if [ -n "$mem_type" ] && [ "$mem_type" != "Unknown" ] && [ "$mem_type" != "Error" ]; then
            echo "$mem_type"
            return
        fi
    fi
    
    local dmesg_type=$(dmesg 2>/dev/null | grep -i 'DDR' | head -1 | grep -o 'DDR[0-9]*' | head -1)
    if [ -n "$dmesg_type" ]; then
        echo "$dmesg_type"
        return
    fi
    
    local iomem_type=$(grep -i 'reserved' /proc/iomem 2>/dev/null | head -1)
    if [ -n "$iomem_type" ]; then
        echo "Detected"
        return
    fi
    echo "unknown (requires root for dmidecode)"
}

# Get memory channels count
get_memory_channels() {
    # Try dmidecode first (requires root)
    if command -v dmidecode &>/dev/null; then
        local channels=$(dmidecode -t memory 2>/dev/null | grep -c 'Channel' 2>/dev/null)
        if [ "$channels" -gt 0 ]; then
            echo "$channels"
            return
        fi
    fi
    # Try to detect from numactl (if available)
    if command -v numactl &>/dev/null; then
        local nodes=$(numactl --hardware 2>/dev/null | grep -c 'node ' | awk '{print $1}')
        if [ "$nodes" -gt 0 ]; then
            echo "$nodes"
            return
        fi
    fi
    # Fallback to checking memory nodes in sysfs
    if [ -d /sys/devices/system/node/ ]; then
        local node_count=$(ls /sys/devices/system/node/ | grep -c '^node[0-9]*$')
        if [ "$node_count" -gt 0 ]; then
            echo "$node_count"
            return
        fi
    fi
    echo "unknown (requires root for dmidecode)"
}

# Get memory slots detailed information
get_memory_slots_detail() {
    if ! command -v dmidecode &>/dev/null; then
        if [ -x "/usr/sbin/dmidecode" ]; then
            local slots_output=$(/usr/sbin/dmidecode -t memory 2>&1)
            if echo "$slots_output" | grep -qi "permission denied"; then
                echo "N/A (requires root privileges for dmidecode)"
                return
            fi
            echo "N/A (dmidecode execution failed)"
            return
        fi
        echo "N/A (dmidecode not installed)"
        return
    fi
    
    local slots_output=""
    local success=0
    
    if [ "$(whoami)" = "root" ]; then
        slots_output=$(/usr/sbin/dmidecode -t memory 2>&1)
        if echo "$slots_output" | grep -q "Memory Device\|Physical Memory Array"; then
            success=1
        fi
    fi
    
    if [ $success -eq 0 ] && command -v sudo &>/dev/null; then
        slots_output=$(sudo -n /usr/sbin/dmidecode -t memory 2>&1)
        if echo "$slots_output" | grep -q "Memory Device\|Physical Memory Array"; then
            success=1
        fi
    fi
    
    if [ $success -eq 0 ]; then
        if echo "$slots_output" | grep -qi "permission denied\|password is required"; then
            echo "N/A (permission denied, requires root)"
        else
            echo "N/A (dmidecode execution failed)"
        fi
        return
    fi
    
    local total_slots=$(echo "$slots_output" | grep -A10 'Physical Memory Array' | grep -i 'Number Of Devices' | awk '{print $NF}')
    if [ -z "$total_slots" ] || [ "$total_slots" = "0" ]; then
        total_slots=$(echo "$slots_output" | grep -c 'Memory Device')
    fi
    
    if [ -z "$total_slots" ] || [ "$total_slots" = "0" ]; then
        local machine_type=$(get_machine_type 2>/dev/null)
        if echo "$machine_type" | grep -qi "virtual"; then
            echo "N/A (virtual machine)"
        else
            echo "N/A (no memory slots detected)"
        fi
        return
    fi
    
    local slot_results=$(echo "$slots_output" | awk '
        BEGIN { slot_count=0; in_device=0 }
        /Memory Device/ { 
            if (in_device && size !~ /^(No Module Installed|Unknown)$/ && size != "" && size !~ /^0+\s*(MB|GB|bytes)$/) {
                print "Slot " slot_count ":"
                if (locator != "") print "  Locator: " locator
                print "  Size: " size
                if (mem_type != "") print "  Type: " mem_type
                if (speed != "" && speed != "Unknown") print "  Speed: " speed
                if (manufacturer != "" && manufacturer != "Unknown") print "  Manufacturer: " manufacturer
                if (part_num != "" && part_num != "Unknown") print "  Part Number: " part_num
            }
            slot_count++; 
            in_device=1; 
            size=""; locator=""; mem_type=""; speed=""; manufacturer=""; part_num=""
        }
        in_device && /Locator:/ { locator = substr($0, index($0, $2)); gsub(/^[ \t]+/, "", locator); gsub(/^Locator:\s*/, "", locator) }
        in_device && /Size:/ { size = substr($0, index($0, "Size:") + 5); gsub(/^[ \t]+/, "", size) }
        in_device && /Type:/ { mem_type = substr($0, index($0, $2)); gsub(/^[ \t]+/, "", mem_type) }
        in_device && /Speed:/ { speed = substr($0, index($0, $2)); gsub(/^[ \t]+/, "", speed); gsub(/^Memory Speed:\s*/, "", speed) }
        in_device && /Manufacturer:/ { manufacturer = substr($0, index($0, $2)); gsub(/^[ \t]+/, "", manufacturer) }
        in_device && /Part Number:/ { part_num = substr($0, index($0, $3)); gsub(/^[ \t]+/, "", part_num) }
        END { 
            if (in_device && size !~ /No Module Installed|0 MB|0 GB|0 bytes/ && size != "" && size != "No Module Installed" && size != "Unknown") {
                print "Slot " slot_count ":"
                if (locator != "") print "  Locator: " locator
                print "  Size: " size
                if (mem_type != "") print "  Type: " mem_type
                if (speed != "" && speed != "Unknown") print "  Speed: " speed
                if (manufacturer != "" && manufacturer != "Unknown") print "  Manufacturer: " manufacturer
                if (part_num != "" && part_num != "Unknown") print "  Part Number: " part_num
            }
        }
    ')
    
    local used_slots=$(echo "$slot_results" | grep -c '^Slot ')
    
    echo "Total Slots: $total_slots"
    echo "Used Slots: $used_slots"
    echo "$slot_results"
}

# Get operating system information
get_os_info() {
    if [ -f /etc/redhat-release ]; then
        cat /etc/redhat-release
        return
    fi
    
    if [ -f /etc/euleros-release ]; then
        echo "EulerOS $(cat /etc/euleros-release | awk '{print $3}')"
        return
    fi
    
    if [ -f /etc/openEuler-release ]; then
        cat /etc/openEuler-release | awk '{print $1, $3}'
        return
    fi
    
    if [ -f /etc/os-release ]; then
        local pretty_name=$(grep -oP 'PRETTY_NAME="?\K[^"]+' /etc/os-release 2>/dev/null)
        if [ -n "$pretty_name" ]; then
            echo "$pretty_name"
            return
        fi
    fi
    
    if [ -f /etc/lsb-release ]; then
        local os_name=$(grep -oP 'DISTRIB_ID=\K.*' /etc/lsb-release 2>/dev/null)
        local os_version=$(grep -oP 'DISTRIB_RELEASE=\K.*' /etc/lsb-release 2>/dev/null)
        echo "$os_name $os_version"
        return
    fi
    
    echo "Unknown"
}

# Get kernel version
get_kernel_version() {
    uname -r 2>/dev/null || echo "unknown"
}

