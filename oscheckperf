# Parse iperf3 result for matrix test
# Wait for iperf3 server to be ready by polling port listening status
# Parameters: server_ssh, port, [is_remote]
#   server_ssh: SSH command prefix to run on target host (empty for local)
#   port: port number to check
#   is_remote: "true" or empty/false
# Returns: 0 if port is ready within timeout, 1 if timeout
wait_for_iperf3_server() {
    local server_ssh="$1"
    local port="$2"
    local is_remote="${3:-}"
    
    local timeout="$4"
    local verbose="${5:-false}"
    local interval=1
    local waited=0
    
    debug_log "IPERF3_SERVER_WAIT_START" "port=$port" "timeout=${timeout}s" "is_remote=$is_remote"
    
    while [ $waited -lt $timeout ]; do
        if [ "$is_remote" = "true" ]; then
            if eval "$server_ssh 'netstat -tln 2>/dev/null | grep -q :$port || ss -tln 2>/dev/null | grep -q :$port'" > /dev/null; then
                debug_log "IPERF3_SERVER_READY" "port=$port" "waited=${waited}s"
                return 0
            fi
        else
            if netstat -tln 2>/dev/null | grep -q ":$port " || ss -tln 2>/dev/null | grep -q ":$port "; then
                debug_log "IPERF3_SERVER_READY" "port=$port" "waited=${waited}s"
                return 0
            fi
        fi
        sleep $interval
        waited=$((waited + interval))
        debug_log "IPERF3_SERVER_WAITING" "port=$port" "waited=${waited}s"
    done
    
    # Handle failure: print error and optional remote diagnostics
    if [ "$verbose" = "true" ] && [ "$is_remote" = "true" ]; then
        echo "    ✗ ERROR: Server $server_ssh:$port failed to start after ${timeout}s"
        # Print remote diagnostics for troubleshooting
        echo "    --- Remote diagnostics ---"
        local diag_cmd="echo '  iperf3 processes: '\$(ps aux 2>/dev/null | grep '[i]perf3' | wc -l); echo '  Port $port status: '\$(ss -tln 2>/dev/null | grep ':$port' || netstat -tln 2>/dev/null | grep ':$port' || echo '  not listening')"
        eval "$server_ssh '$diag_cmd'" | sed 's/^/    /'
        echo "    -----------------------------------"
    fi
    
    debug_log "IPERF3_SERVER_TIMEOUT" "port=$port" "timeout=${timeout}s" "is_remote=$is_remote"
    return 1
}

parse_iperf3_matrix_result() {
    local json_file="$1"
    
    if [ ! -f "$json_file" ]; then
        debug_log "PARSE_RESULT_FAIL" "file_not_found=$json_file"
        echo "0"
        return
    fi
    
    if ! jq_available; then
        debug_log "PARSE_RESULT_FAIL" "jq_not_available"
        echo "0"
        return
    fi
    
    # Extract JSON content by removing any leading non-JSON text
    local json_content=$(awk 'BEGIN{found=0} /^\{/{found=1} found{print} /^\}/{if(found) exit}' "$json_file" 2>/dev/null || cat "$json_file")
    
    # Extract metrics
    local bandwidth_bps=$(echo "$json_content" | jq -r '.end.sum_received.bits_per_second // 0' 2>/dev/null)
    debug_log "PARSE_RESULT_EXTRACT" "file=$json_file" "bps=$bandwidth_bps" "json_has_end=$(echo "$json_content" | jq -e '.end' >/dev/null 2>&1 && echo "yes" || echo "no")"
    
    # Convert bps to MB/s: 1 MB/s = 8,000,000 bps
    local bandwidth_mbs=$(awk "BEGIN {printf \"%.2f\", $bandwidth_bps / 8000000}" 2>/dev/null || echo "0")
    
    echo "$bandwidth_mbs"
}

