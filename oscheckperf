    local in_section=false
    local current_server_ip=""
    local current_events=""
    local current_time=""
    local current_eps=""
    local current_threads_avg_lat=""
    local current_threads_p95_lat=""
    local current_threads_min_lat=""
    local current_threads_max_lat=""
    local current_threads_sum_lat=""
    local current_threads_fairness=""
    local last_testing_ip=""
    
    while IFS= read -r line; do
        if [[ "$line" =~ "THREADS TEST RESULTS" ]]; then
            if [ "$in_section" = true ] && [ -n "$current_server_ip" ]; then
                current_eps=$(calc_eps "$current_events" "$current_time")
                printf "  %-18s %-15s %-18s %-18s %-14s %-14s %-18s\n" "$current_server_ip" "${current_eps:-N/A}" "${current_threads_avg_lat:-N/A}" "${current_threads_p95_lat:-N/A}" "${current_threads_min_lat:-N/A}" "${current_threads_max_lat:-N/A}" "${current_threads_sum_lat:-N/A}" >> "$output_file"
            fi
            in_section=true
            current_server_ip=$(echo "$line" | grep -oP 'Server: \K[0-9.]+' || echo "N/A")
            last_testing_ip="$current_server_ip"
            current_events=""
            current_time=""
            current_eps=""
            current_threads_avg_lat=""
            current_threads_p95_lat=""
            current_threads_min_lat=""
            current_threads_max_lat=""
            current_threads_sum_lat=""
            current_threads_fairness=""
        elif [[ "$line" =~ "Testing server" ]]; then
