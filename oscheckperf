        elif [ "$line" = "--- CPU Advanced Info ---" ]; then
            in_disk="false"; in_network="false"; in_slots="false"; in_inode="false"
            in_disk_usage="false"; in_cpu_advanced="true"; in_numa="false"
            in_memory_advanced="false"; in_io_advanced="false"; in_mount_options="false"
            in_network_advanced="false"
        elif [ "$line" = "--- NUMA Topology ---" ]; then
            in_disk="false"; in_network="false"; in_slots="false"; in_inode="false"
            in_disk_usage="false"; in_cpu_advanced="false"; in_numa="true"
            in_memory_advanced="false"; in_io_advanced="false"; in_mount_options="false"
            in_network_advanced="false"
        elif [ "$line" = "--- Memory Advanced Info ---" ]; then
            in_disk="false"; in_network="false"; in_slots="false"; in_inode="false"
            in_disk_usage="false"; in_cpu_advanced="false"; in_numa="false"
            in_memory_advanced="true"; in_io_advanced="false"; in_mount_options="false"
            in_network_advanced="false"
        elif [ "$line" = "--- IO Advanced Info (Benchmark Disk Only) ---" ]; then
            in_disk="false"; in_network="false"; in_slots="false"; in_inode="false"
            in_disk_usage="false"; in_cpu_advanced="false"; in_numa="false"
            in_memory_advanced="false"; in_io_advanced="true"; in_mount_options="false"
            in_network_advanced="false"
