            fi
        elif [ "$in_mount_options" = "true" ] && [ -n "$line" ]; then
            if [[ "$line" == MOUNT_OPTIONS:* ]]; then mount_options="${line#MOUNT_OPTIONS: }"
            fi
        elif [ "$in_network_advanced" = "true" ] && [ -n "$line" ]; then
            network_advanced_lines+=("$line")
        elif [[ "$line" == CPU_ARCH:* ]]; then
            cpu_arch="${line#CPU_ARCH: }"
        elif [[ "$line" == MACHINE_TYPE:* ]]; then
            machine_type="${line#MACHINE_TYPE: }"
        elif [[ "$line" == OS_INFO:* ]]; then
