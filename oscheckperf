# Threads test function
run_threads_test() {
    echo "=== Threads Performance Test ==="
    
    local temp_output_file="$TMP_DIR/vb_threads_${TIMESTAMP}.log"
    local threads="${THREADS_NUM:-0}"
    if [ "$threads" -eq 0 ]; then
        local cores=$(get_cpu_cores 2>/dev/null || echo "4")
        threads=$((cores * 4))
    fi
    local duration="$DURATION"
    
    # Only display test info in non-remote mode
    if [ "$REMOTE" != "true" ]; then
        echo "Starting threads test..."
        echo "  Threads: $threads, Duration: ${duration}s, yields: ${THREADS_YIELDS:-100}, locks: ${THREADS_LOCKS:-4}"
    fi
    
    run_command "sysbench threads \
        --threads=\"$threads\" \
        --thread-yields=\"${THREADS_YIELDS:-100}\" \
        --thread-locks=\"${THREADS_LOCKS:-4}\" \
        --time=\"${duration}\" \
        run" "$temp_output_file"
    
    # Parse result and display detailed output
    if [ "$DRY_RUN" != true ] && [ -f "$temp_output_file" ]; then
        # Display parsed output
        parse_threads_result "$temp_output_file"
        
        # Append to combined results file
        append_to_original "THREADS TEST RESULTS" "$temp_output_file"
    fi
    
    # Cleanup temp file
    rm -f "$temp_output_file"
    
    # Only display completion message in non-remote mode
    if [ "$REMOTE" != "true" ]; then
        echo "✓ Threads test completed"
    fi
}

# Parse threads result
parse_threads_result() {
    local result_file="$1"
    
    # Calculate events per second
    local total_events=$(grep "total number of events:" "$result_file" | awk '{print $NF}' || echo "0")
    local total_time=$(grep "total time:" "$result_file" | awk '{print $NF}' | tr -d 's' || echo "1")
    local events_per_sec=$(awk "BEGIN {printf \"%.2f\", $total_events / $total_time}" 2>/dev/null || echo "0")
    
    # Extract latency metrics
    local avg_latency=$(grep "avg:" "$result_file" | head -1 | awk '{print $NF}' | tr -d ',')
    local min_latency=$(grep -A5 "Latency (ms):" "$result_file" 2>/dev/null | grep "min:" | awk '{print $NF}' | tr -d ',' || echo "N/A")
    local max_latency=$(grep -A5 "Latency (ms):" "$result_file" 2>/dev/null | grep "max:" | awk '{print $NF}' | tr -d ',' || echo "N/A")
    local p95_latency=$(grep "95th percentile" "$result_file" | awk '{print $NF}')
    
    # Calculate Sum Latency: total_events * avg_latency
    local sum_latency=$(echo "$total_events" "$avg_latency" 2>/dev/null | awk '{if($2>0) printf "%.2f", $1 * $2; else print "N/A"}')
    
    # Extract threads fairness
    local threads_fairness_events=$(grep -A1 "Threads fairness:" "$result_file" | grep "events (avg/stddev):" | awk '{print $NF}')
    local threads_fairness_time=$(grep -A2 "Threads fairness:" "$result_file" | grep "execution time (avg/stddev):" | awk '{print $NF}')
    
    # Display detailed summary
    echo ""
    echo "Threads test summary:"
    echo "  total number of events: ${total_events}"
    echo "  total time: ${total_time}s"
    echo "  Events/sec: $events_per_sec"
    echo "  Avg Latency: ${avg_latency}ms"
    if [ -n "$min_latency" ] && [ "$min_latency" != "N/A" ]; then
        echo "  Min Latency: ${min_latency}ms"
    fi
    if [ -n "$max_latency" ] && [ "$max_latency" != "N/A" ]; then
        echo "  Max Latency: ${max_latency}ms"
    fi
    echo "  P95 Latency: ${p95_latency}ms"
    if [ -n "$sum_latency" ] && [ "$sum_latency" != "N/A" ]; then
        echo "  Sum Latency: ${sum_latency}ms"
    fi
    if [ -n "$threads_fairness_events" ] || [ -n "$threads_fairness_time" ]; then
        echo "  Threads fairness:"
        if [ -n "$threads_fairness_events" ]; then
            echo "    events (avg/stddev): $threads_fairness_events"
        fi
        if [ -n "$threads_fairness_time" ]; then
            echo "    execution time (avg/stddev): $threads_fairness_time"
        fi
    fi
}

