            export LD_LIBRARY_PATH="$BASE_DIR/lib:$LD_LIBRARY_PATH"
        fi
    fi
fi

# Set PATH to prioritize bundled tools (fio, sysbench, iperf3)
if [[ ":$PATH:" != *":$BASE_DIR/bin:"* ]]; then
    export PATH="$BASE_DIR/bin:$PATH"
fi

