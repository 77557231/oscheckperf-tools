# Note: set -e is intentionally not used to allow tests to continue even if some fail
# This ensures report generation happens regardless of individual test failures

# ================================================================================
# Global Configuration Variables - Centralized Management
# ================================================================================

# Base directory for all oscheckperf data - can be modified here for all paths
export BASE_DIR="${BASE_DIR:-$HOME/oscheckperf}"

# Temporary files directory (logs, intermediate data, network test results)
export TMP_DIR="$BASE_DIR/tmp"

# IO test data directory (sysbench/fio test files)
export IO_PATH="${IO_PATH:-$BASE_DIR/io_test}"

# Output directory for final reports and logs (original_data*, data*, report_benchmark*)
export OUTPUT_DIR="${OUTPUT_DIR:-./output}"

# System Configuration Constants
MIN_DISK_SPACE_GB=1                    # Minimum disk space required for IO tests (GB)
NETWORK_PORT="${NETWORK_PORT:-25201}"  # Network test port
SSH_PORT="${SSH_PORT:-22}"             # SSH port for remote server connections

# Default parameters
CONFIG_FILE=""
DRY_RUN=false
NO_CHECKS=false
DURATION="${DURATION:-60}"               # Unified test duration in seconds

# ================================================================================

# Set library search path to include bundled libs as fallback
# System libs take priority (put first); bundled libs are fallback for missing deps
if [ -d "$BASE_DIR/lib" ]; then
    export LD_LIBRARY_PATH="$LD_LIBRARY_PATH:$BASE_DIR/lib"
fi

# Get Linux distribution
get_linux_distro() {
    if [ -f /etc/kylin-release ]; then echo "kylin"; return; fi
    if [ -f /etc/neokylin-release ]; then echo "neokylin"; return; fi
    if [ -f /etc/uos-release ]; then echo "uos"; return; fi
    if [ -f /etc/deepin-release ]; then echo "deepin"; return; fi
    if [ -f /etc/startos-release ]; then echo "startos"; return; fi
    if [ -f /etc/euleros-release ]; then echo "euleros"; return; fi
    if [ -f /etc/openEuler-release ]; then echo "openeuler"; return; fi
    if [ -f /etc/redhat-release ]; then
        if grep -qi centos /etc/redhat-release; then echo "centos"; return; fi
        if grep -qi fedora /etc/redhat-release; then echo "fedora"; return; fi
        if grep -qi oracle /etc/redhat-release; then echo "oracle"; return; fi
        if grep -qi fangde /etc/redhat-release; then echo "fangde"; return; fi
        echo "redhat"; return;
    fi
    if [ -f /etc/debian_version ]; then echo "debian"; return; fi
    if [ -f /etc/lsb-release ]; then grep -oP "DISTRIB_ID=\K.*" /etc/lsb-release | tr "[:upper:]" "[:lower:]"; return; fi
    if [ -f /etc/os-release ]; then grep -oP "ID=\"?\K[^\"]+" /etc/os-release | tr "[:upper:]" "[:lower:]"; return; fi
    echo "unknown"
}

# ================================================================================
# Generic Result Parsing Framework
# ================================================================================

# Generic test result parser for report generation
# Usage: parse_test_results <input_file> <output_file> <test_type> <start_pattern> <end_patterns> <output_format> <headers> <field_specs>
# Field specs format: "field_name|pattern|extract_method|default_value[;field_name|pattern|extract_method|default_value...]"
# Extract methods: last_field, awk_1, awk_nf, grep_p, custom_awk:expression
parse_test_results() {
    local input_file="$1"
    local output_file="$2"
    local test_type="$3"
    local start_pattern="$4"
    local end_patterns="$5"
    local output_format="$6"
    local headers="$7"
    local field_specs="$8"
    
    if [ ! -f "$input_file" ]; then
        echo "  Test not executed" >> "$output_file"
        return
    fi
    
    if ! grep -qE "$start_pattern" "$input_file" 2>/dev/null; then
        echo "  Test not executed" >> "$output_file"
        return
    fi
    
    echo "  ${test_type} Test Results" >> "$output_file"
    echo "  ------------------------------------------------------------------------------------------" >> "$output_file"
    printf "  %s\n" "$headers" >> "$output_file"
    echo "  ------------------------------------------------------------------------------------------" >> "$output_file"
    
    local in_section=false
    local current_server_ip=""
    local last_testing_ip=""
    
    declare -A field_values
    
    IFS=';' read -ra fields <<< "$field_specs"
    for field in "${fields[@]}"; do
        IFS='|' read -r field_name pattern extract_method default_val <<< "$field"
        field_values["$field_name"]="$default_val"
    done
    
    while IFS= read -r line; do
        if [[ "$line" =~ "Testing server" ]]; then
            last_testing_ip=$(echo "$line" | grep -oP 'Testing server [0-9]+/[0-9]+: \K[0-9.]+' || echo "")
            if [ "$in_section" = true ] && [ -n "$current_server_ip" ]; then
                printf "  $output_format\n" "${field_values[@]}" >> "$output_file"
            fi
            in_section=false
            current_server_ip=""
            for field in "${fields[@]}"; do
                IFS='|' read -r field_name pattern extract_method default_val <<< "$field"
                field_values["$field_name"]="$default_val"
            done
        elif [[ "$line" =~ $start_pattern ]]; then
            if [ "$in_section" = true ] && [ -n "$current_server_ip" ]; then
                printf "  $output_format\n" "${field_values[@]}" >> "$output_file"
            fi
            in_section=true
            current_server_ip=$(echo "$line" | grep -oP 'Server: \K[0-9.]+' || echo "$last_testing_ip" || echo "N/A")
            field_values["server_ip"]="$current_server_ip"
            for field in "${fields[@]}"; do
                IFS='|' read -r field_name pattern extract_method default_val <<< "$field"
                if [ "$field_name" != "server_ip" ]; then
                    field_values["$field_name"]="$default_val"
                fi
            done
        elif [[ "$line" =~ ($end_patterns) ]]; then
            if [ "$in_section" = true ] && [ -n "$current_server_ip" ]; then
                printf "  $output_format\n" "${field_values[@]}" >> "$output_file"
            fi
            in_section=false
            current_server_ip=""
            for field in "${fields[@]}"; do
                IFS='|' read -r field_name pattern extract_method default_val <<< "$field"
                field_values["$field_name"]="$default_val"
            done
        elif [ "$in_section" = true ]; then
            for field in "${fields[@]}"; do
                IFS='|' read -r field_name pattern extract_method default_val <<< "$field"
                if [ "$field_name" = "server_ip" ]; then
                    continue
                fi
                if [[ "$line" =~ $pattern ]]; then
                    case "$extract_method" in
                        "last_field")
                            field_values["$field_name"]=$(echo "$line" | awk '{print $NF}' | tr -d ',')
                            ;;
                        "awk_1")
                            field_values["$field_name"]=$(echo "$line" | awk '{print $1}')
                            ;;
                        "awk_nf_minus_1")
                            field_values["$field_name"]=$(echo "$line" | awk '{print $(NF-1)}')
                            ;;
                        "grep_p")
                            field_values["$field_name"]=$(echo "$line" | grep -oP "$pattern" | awk '{print $NF}')
                            ;;
                        "custom_awk:events_per_sec")
                            field_values["$field_name"]=$(echo "$line" | awk -F'[()]' '{print $2}' | awk '{print $1}')
                            ;;
                        "custom_awk:total_operations")
                            field_values["$field_name"]=$(echo "$line" | awk '{print $NF}')
                            ;;
                        "custom_awk:total_time")
                            field_values["$field_name"]=$(echo "$line" | awk '{print $NF}' | tr -d 's')
                            ;;
                        "custom_awk:fairness")
                            field_values["$field_name"]=$(echo "$line" | awk '{print $NF}')
                            ;;
                        "custom_awk:fairness_threads")
                            field_values["$field_name"]=$(echo "$line" | awk '{print $3}')
                            ;;
                        *)
                            field_values["$field_name"]=$(echo "$line" | awk '{print $NF}' | tr -d ',')
                            ;;
                    esac
                fi
            done
        fi
    done < "$input_file"
    
    if [ "$in_section" = true ] && [ -n "$current_server_ip" ]; then
        printf "  $output_format\n" "${field_values[@]}" >> "$output_file"
    fi
}

# Calculate EPS (Events Per Second) from events and time
calc_eps() {
    local events="$1"
    local time="$2"
    if [ -n "$events" ] && [ -n "$time" ] && [ "$time" != "0" ]; then
        awk "BEGIN {printf \"%.2f\", $events / $time}" 2>/dev/null || echo "N/A"
    else
        echo "N/A"
    fi
}

