# Security validation functions (isolated module)
# ==============================================

# Validate path for security - check for dangerous characters
# Returns 0 if valid, 1 if invalid
# Prints error message with specific dangerous characters found
validate_path() {
    local path="$1"
    local param_name="$2"
    
    # List of dangerous characters that can be used for command injection
    local dangerous_chars=(";" "|" "&" "<" ">" "$" "\`" "\"" "'" "\\")
    local found_dangerous=""
    
    for char in "${dangerous_chars[@]}"; do
        if [[ "$path" == *"$char"* ]]; then
            # Escape special characters for display
            case "$char" in
                ";") found_dangerous="$found_dangerous ;" ;;
                "|") found_dangerous="$found_dangerous |" ;;
                "&") found_dangerous="$found_dangerous &" ;;
                "<") found_dangerous="$found_dangerous <" ;;
                ">") found_dangerous="$found_dangerous >" ;;
                "$") found_dangerous="$found_dangerous \$" ;;
                "\`") found_dangerous="$found_dangerous \`" ;;
                "\"") found_dangerous="$found_dangerous \"" ;;
                "'") found_dangerous="$found_dangerous '" ;;
                "\\") found_dangerous="$found_dangerous \\" ;;
            esac
        fi
    done
    
    if [ -n "$found_dangerous" ]; then
        echo "Error: Invalid $param_name path contains dangerous characters:$found_dangerous"
        echo "       Path: $path"
        return 1
    fi
    
    # Additional check: path traversal attack
    if [[ "$path" == *"../"* ]]; then
        echo "Error: Invalid $param_name path contains directory traversal (../)"
        echo "       Path: $path"
        return 1
    fi
    
    return 0
}

# Validate all path parameters
validate_all_paths() {
    local error_count=0
    
    # Validate IO_PATH
    if [ -n "${IO_PATH:-}" ]; then
        if ! validate_path "$IO_PATH" "IO_PATH"; then
            error_count=$((error_count + 1))
        fi
    fi
    
    # Validate OUTPUT_DIR
    if [ -n "${OUTPUT_DIR:-}" ]; then
        if ! validate_path "$OUTPUT_DIR" "OUTPUT_DIR"; then
            error_count=$((error_count + 1))
        fi
    fi
    
    # Validate TMP_DIR
    if [ -n "${TMP_DIR:-}" ]; then
        if ! validate_path "$TMP_DIR" "TMP_DIR"; then
            error_count=$((error_count + 1))
        fi
    fi
    
    if [ "$error_count" -gt 0 ]; then
        echo "Error: $error_count path validation error(s) found"
        exit 1
    fi
}

# Calculate statistics from bandwidth results
# Usage: calculate_stats "results_array"
# Returns: "total_bw|avg_bw|min_bw|max_bw|median_bw|count"
calculate_stats() {
    local results=("$@")
    
    local total_bw=0
    local count=0
    local min_bw=999999
    local max_bw=0
    local bw_values=()
    
    for result in "${results[@]}"; do
        IFS='|' read -r src dst r_bw <<< "$result"
        if [ "$r_bw" != "0" ] && [[ "$r_bw" =~ ^[0-9.]+$ ]]; then
            total_bw=$(echo "$total_bw + $r_bw" | bc)
            count=$((count + 1))
            bw_values+=("$r_bw")
            if (( $(echo "$r_bw < $min_bw" | bc -l) )); then
                min_bw="$r_bw"
            fi
            if (( $(echo "$r_bw > $max_bw" | bc -l) )); then
                max_bw="$r_bw"
            fi
        fi
    done
    
    local avg_bw="0"
    local median_bw="0"
    if [ $count -gt 0 ]; then
        avg_bw=$(echo "$total_bw / $count" | bc -l)
        IFS=$'\n' sorted_bw=($(sort -g <<< "${bw_values[*]}"))
        unset IFS
        local mid=$((count / 2))
        if [ $((count % 2)) -eq 0 ]; then
            median_bw=$(echo "(${sorted_bw[$mid-1]} + ${sorted_bw[$mid]}) / 2" | bc -l)
        else
            median_bw="${sorted_bw[$mid]}"
        fi
    fi
    
    echo "$total_bw|$avg_bw|$min_bw|$max_bw|$median_bw|$count"
}

# Execute command function (supports dry run mode)
run_command() {
    local cmd="$1"
    local output_file="$2"
    
    if [ "$DRY_RUN" = true ]; then
        echo "Dry run: $cmd"
        return 0
    fi
    
    if [ -n "$output_file" ]; then
        # Execute command and capture output (stdout to file, stderr to terminal)
        eval "$cmd" > "$output_file"
        local exit_code=$?
        
        return $exit_code
    else
        eval "$cmd"
        return $?
    fi
}

# Wait for command execution to complete (with timeout)
wait_with_timeout() {
    local pid="$1"
    local timeout="$2"
    local start_time=$(date +%s)
    
    while kill -0 "$pid" 2>/dev/null; do
        local current_time=$(date +%s)
        local elapsed=$((current_time - start_time))
        
        if [ "$elapsed" -ge "$timeout" ]; then
            kill -9 "$pid" 2>/dev/null
            return 1
        fi
        
        sleep 1
    done
    
    return 0
}

