# Get network interface information
get_network_info() {
    local result=""
    for iface in $(ls /sys/class/net/ 2>/dev/null | grep -v "^lo$"); do
        local mac=$(cat "/sys/class/net/$iface/address" 2>/dev/null || echo "N/A")
        local speed=$(cat "/sys/class/net/$iface/speed" 2>/dev/null || echo "N/A")
        local mtu=$(cat "/sys/class/net/$iface/mtu" 2>/dev/null || echo "N/A")
        local state=$(cat "/sys/class/net/$iface/operstate" 2>/dev/null || echo "N/A")
        local carrier=$(cat "/sys/class/net/$iface/carrier" 2>/dev/null || echo "N/A")
        local ip=$(ip addr show "$iface" 2>/dev/null | grep 'inet ' | awk '{print $2}' | cut -d'/' -f1 | head -1 || echo "N/A")
        local rx_bytes=$(cat "/sys/class/net/$iface/statistics/rx_bytes" 2>/dev/null || echo "N/A")
        local tx_bytes=$(cat "/sys/class/net/$iface/statistics/tx_bytes" 2>/dev/null || echo "N/A")
        
        local speed_str=""
        if [ "$speed" != "N/A" ] && [ "$speed" -gt 0 ] 2>/dev/null; then
            speed_str="${speed}Mbps"
        elif [ "$speed" = "N/A" ]; then
            speed_str="N/A"
        else
            speed_str="Unknown"
        fi
        
        result="${result}${iface}: IP=${ip}, MAC=${mac}, Speed=${speed_str}, MTU=${mtu}, State=${state}\n"
    done
    echo -e "$result"
}

# Get network advanced info (Speed, Duplex, Interrupt Coalescing, Offload, Driver)
get_network_advanced_info() {
    local has_output=false
    for iface in $(ls /sys/class/net/ 2>/dev/null | grep -v "^lo$"); do
        if command -v ethtool &>/dev/null; then
            local speed=$(ethtool "$iface" 2>/dev/null | grep 'Speed:' | awk '{print $2}')
            local duplex=$(ethtool "$iface" 2>/dev/null | grep 'Duplex:' | awk '{print $2}')
            local rx_usecs=$(ethtool -c "$iface" 2>/dev/null | grep 'rx-usecs:' | awk '{print $2}')
            local tx_usecs=$(ethtool -c "$iface" 2>/dev/null | grep 'tx-usecs:' | awk '{print $2}')
            local tso=$(ethtool -k "$iface" 2>/dev/null | grep 'tcp-segmentation-offload:' | awk '{print $2}')
            local gro=$(ethtool -k "$iface" 2>/dev/null | grep 'generic-receive-offload:' | awk '{print $2}')
            local driver=$(ethtool -i "$iface" 2>/dev/null | grep 'driver:' | awk '{print $2}')
            [ -z "$speed" ] && speed="N/A"
            [ -z "$duplex" ] && duplex="N/A"
            [ -z "$rx_usecs" ] && rx_usecs="N/A"
            [ -z "$tx_usecs" ] && tx_usecs="N/A"
            [ -z "$tso" ] && tso="N/A"
            [ -z "$gro" ] && gro="N/A"
            [ -z "$driver" ] && driver="N/A"
            echo "${iface}: Speed=${speed}, Duplex=${duplex}, rx-usecs=${rx_usecs}, tx-usecs=${tx_usecs}, TSO=${tso}, GRO=${gro}, Driver=${driver}"
            has_output=true
        fi
    done
    if [ "$has_output" = false ]; then
        echo "N/A"
    fi
}

# Get CPU architecture
