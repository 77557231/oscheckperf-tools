get_cpu_physical_cores() { if [ -f /proc/cpuinfo ]; then local cores=$(grep -c 'physical id' /proc/cpuinfo 2>/dev/null); if [ -n "$cores" ] && [ "$cores" -gt 0 ] 2>/dev/null; then echo "$cores"; else nproc 2>/dev/null || echo "N/A"; fi; else echo "N/A"; fi; }
get_cpu_logical_cores() { nproc 2>/dev/null || grep -c ^processor /proc/cpuinfo 2>/dev/null || echo "N/A"; }
get_cpu_freq() { if [ -f /proc/cpuinfo ]; then local freq=$(grep -m 1 'cpu MHz' /proc/cpuinfo | awk '{print $4}'); if [ -n "$freq" ]; then awk "BEGIN {printf \"%.2f\", $freq / 1000}"; return; fi; fi; freq=$(cat /sys/devices/system/cpu/cpu0/cpufreq/cpuinfo_max_freq 2>/dev/null); if [ -n "$freq" ] && [ "$freq" != "0" ]; then awk "BEGIN {printf \"%.2f\", $freq / 1000000}"; return; fi; if command -v lscpu &>/dev/null; then freq=$(lscpu 2>/dev/null | grep -i 'CPU max MHz' | awk '{print $NF}'); if [ -n "$freq" ] && [ "$freq" != "0" ]; then awk "BEGIN {printf \"%.2f\", $freq / 1000}"; return; fi; fi; if [ -f /proc/cpuinfo ]; then freq=$(grep -m 1 'BogoMIPS' /proc/cpuinfo | awk '{print $3}'); if [ -n "$freq" ]; then awk "BEGIN {printf \"%.2f\", $freq / 1000}"; return; fi; fi; echo "N/A"; }
get_memory_size_mb() { if [ -f /proc/meminfo ]; then awk '/MemTotal/ {printf "%.0f", $2/1024}' /proc/meminfo 2>/dev/null || echo "N/A"; else echo "N/A"; fi; }
get_memory_available_mb() { if [ -f /proc/meminfo ]; then awk '/MemAvailable/ {printf "%.0f", $2/1024}' /proc/meminfo 2>/dev/null || echo "N/A"; else echo "N/A"; fi; }
get_memory_type() { local machine_type=$(get_machine_type 2>/dev/null); if echo "$machine_type" | grep -qi "virtual"; then echo "N/A (virtual machine)"; return; fi; if command -v dmidecode &>/dev/null; then local mem_type=$(dmidecode -t memory 2>/dev/null | grep -m 1 'Type:' | sed 's/Type:\s*//' | sed 's/^[ \t]*//' | sed 's/[ \t]*$//' 2>/dev/null); if [ -n "$mem_type" ] && [ "$mem_type" != "Unknown" ] && [ "$mem_type" != "Error" ]; then echo "$mem_type"; return; fi; fi; local dmesg_type=$(dmesg 2>/dev/null | grep -i 'DDR' | head -1 | grep -o 'DDR[0-9]*' | head -1); if [ -n "$dmesg_type" ]; then echo "$dmesg_type"; return; fi; echo "unknown (requires root)"; }
get_memory_channels() { if command -v dmidecode &>/dev/null; then local channels=$(dmidecode -t memory 2>/dev/null | grep -c 'Channel' 2>/dev/null); if [ "$channels" -gt 0 ]; then echo "$channels"; return; fi; fi; if [ -d /sys/devices/system/node/ ]; then local node_count=$(ls /sys/devices/system/node/ | grep -c '^node[0-9]*$'); if [ "$node_count" -gt 0 ]; then echo "$node_count"; return; fi; fi; echo "unknown (requires root)"; }
get_memory_freq() { local machine_type=$(get_machine_type 2>/dev/null); if echo "$machine_type" | grep -qi "virtual"; then echo "N/A (virtual machine)"; return; fi; if command -v dmidecode &>/dev/null; then local freq=$(dmidecode -t memory 2>/dev/null | grep -m 1 'Configured Clock Speed' | awk '{print $4}' 2>/dev/null); if [ -n "$freq" ] && [ "$freq" -gt 0 ] 2>/dev/null; then echo "${freq} MHz"; return; fi; freq=$(dmidecode -t memory 2>/dev/null | grep -m 1 'Speed' | awk '{print $2}' 2>/dev/null); if [ -n "$freq" ] && [ "$freq" != "Unknown" ] && [ "$freq" -gt 0 ] 2>/dev/null; then echo "${freq} MHz"; return; fi; fi; echo "unknown (requires root)"; }
get_cpu_arch() { uname -m 2>/dev/null || echo "unknown"; }
get_kernel_version() { uname -r 2>/dev/null || echo "unknown"; }
get_network_bond() { if [ -d /proc/net/bonding/ ]; then local bonds=$(ls /proc/net/bonding/ 2>/dev/null | tr '\n' ', '); if [ -n "$bonds" ]; then echo "$bonds"; return; fi; fi; echo "None"; }
get_network_interface_count() { ls /sys/class/net/ 2>/dev/null | grep -v "^lo$" | wc -l 2>/dev/null || echo "0"; }
get_machine_type() { local machine_type="Physical Machine"; if command -v systemd-detect-virt &>/dev/null; then local virt_output=$(systemd-detect-virt 2>/dev/null); case "$virt_output" in "kvm") machine_type="Virtual Machine (KVM)";; "qemu") machine_type="Virtual Machine (QEMU)";; "vmware") machine_type="Virtual Machine (VMware)";; "virtualbox") machine_type="Virtual Machine (VirtualBox)";; "hyperv") machine_type="Virtual Machine (Hyper-V)";; "xen") machine_type="Virtual Machine (Xen)";; "none") machine_type="Physical Machine";; *) machine_type="Unknown";; esac; else if grep -qi 'kvm' /proc/cpuinfo 2>/dev/null || grep -qi 'qemu' /sys/devices/virtual/dmi/id/product_name 2>/dev/null; then machine_type="Virtual Machine (KVM/QEMU)"; elif grep -qi 'vmware' /sys/devices/virtual/dmi/id/product_name 2>/dev/null; then machine_type="Virtual Machine (VMware)"; elif grep -qi 'hypervisor' /proc/cpuinfo 2>/dev/null; then machine_type="Virtual Machine (Unknown)"; fi; fi; echo "$machine_type"; }
get_os_info() { if [ -f /etc/redhat-release ]; then cat /etc/redhat-release; return; fi; if [ -f /etc/euleros-release ]; then echo "EulerOS $(cat /etc/euleros-release | awk '{print $3}')"; return; fi; if [ -f /etc/openEuler-release ]; then cat /etc/openEuler-release | awk '{print $1, $3}'; return; fi; if [ -f /etc/os-release ]; then local pretty_name=$(grep -oP 'PRETTY_NAME="?\K[^"]+' /etc/os-release 2>/dev/null); if [ -n "$pretty_name" ]; then echo "$pretty_name"; return; fi; fi; if [ -f /etc/lsb-release ]; then local os_name=$(grep -oP 'DISTRIB_ID=\K.*' /etc/lsb-release 2>/dev/null); local os_version=$(grep -oP 'DISTRIB_RELEASE=\K.*' /etc/lsb-release 2>/dev/null); echo "$os_name $os_version"; return; fi; echo "Unknown"; }
get_disk_usage_info() { if command -v df &>/dev/null; then df -h 2>/dev/null | grep -v "^Filesystem" | while read -r line; do fs=$(echo "$line" | awk '{print $1}'); size=$(echo "$line" | awk '{print $2}'); used=$(echo "$line" | awk '{print $3}'); avail=$(echo "$line" | awk '{print $4}'); pct=$(echo "$line" | awk '{print $5}'); mount=$(echo "$line" | awk '{print $6}'); [ -z "$fs" ] && fs="-"; [ -z "$size" ] && size="-"; [ -z "$used" ] && used="-"; [ -z "$avail" ] && avail="-"; [ -z "$pct" ] && pct="-"; [ -z "$mount" ] && mount="-"; echo "$fs|$size|$used|$avail|$pct|$mount"; done; else echo "N/A"; fi; }
get_inode_info() { if command -v df &>/dev/null; then df -i 2>/dev/null | grep -v "^Filesystem" | while read -r line; do fs=$(echo "$line" | awk '{print $1}'); inodes=$(echo "$line" | awk '{print $2}'); used=$(echo "$line" | awk '{print $3}'); avail=$(echo "$line" | awk '{print $4}'); pct=$(echo "$line" | awk '{print $5}'); mount=$(echo "$line" | awk '{print $6}'); [ -z "$fs" ] && fs="-"; [ -z "$inodes" ] && inodes="-"; [ -z "$used" ] && used="-"; [ -z "$avail" ] && avail="-"; [ -z "$pct" ] && pct="-"; [ -z "$mount" ] && mount="-"; echo "$fs|$inodes|$used|$avail|$pct|$mount"; done; else echo "N/A"; fi; }
get_uptime_info() { if command -v uptime &>/dev/null; then uptime | sed -n 's/.* up \(.*\) load.*/\1/p' | sed 's/^[[:space:]]*//' | sed 's/[[:space:]]*$//' | sed 's/, *[0-9]* *user[s]*,* *$//'; else echo "N/A"; fi; }
get_network_info() { local result=""; for iface in $(ls /sys/class/net/ 2>/dev/null | grep -v "^lo$"); do local mac=$(cat "/sys/class/net/$iface/address" 2>/dev/null || echo "N/A"); local speed=$(cat "/sys/class/net/$iface/speed" 2>/dev/null || echo "N/A"); local mtu=$(cat "/sys/class/net/$iface/mtu" 2>/dev/null || echo "N/A"); local state=$(cat "/sys/class/net/$iface/operstate" 2>/dev/null || echo "N/A"); local ip=$(ip addr show "$iface" 2>/dev/null | grep 'inet ' | awk '{print $2}' | cut -d'/' -f1 | head -1 || echo "N/A"); local speed_str=""; if [ "$speed" != "N/A" ] && [ "$speed" -gt 0 ] 2>/dev/null; then speed_str="${speed}Mbps"; elif [ "$speed" = "N/A" ]; then speed_str="N/A"; else speed_str="Unknown"; fi; result="${result}${iface}: IP=${ip}, MAC=${mac}, Speed=${speed_str}, MTU=${mtu}, State=${state}\n"; done; echo -e "$result"; }
get_cpu_l1_cache() { if command -v lscpu &>/dev/null; then local v=$(lscpu -C 2>/dev/null | grep 'L1d' | head -1 | awk '{print $2}'); if [ -n "$v" ]; then echo "$v"; return; fi; v=$(lscpu 2>/dev/null | grep -i 'L1d cache' | awk -F: '{print $2}' | awk '{print $1}'); if [ -n "$v" ]; then echo "$v"; return; fi; if [ -f /sys/devices/system/cpu/cpu0/cache/index0/size ]; then cat /sys/devices/system/cpu/cpu0/cache/index0/size 2>/dev/null && return; fi; fi; echo "N/A"; }
get_cpu_l2_cache() { if command -v lscpu &>/dev/null; then local v=$(lscpu -C 2>/dev/null | grep 'L2' | head -1 | awk '{print $2}'); if [ -n "$v" ]; then echo "$v"; return; fi; v=$(lscpu 2>/dev/null | grep -i 'L2 cache' | awk -F: '{print $2}' | awk '{print $1}'); if [ -n "$v" ]; then echo "$v"; return; fi; fi; echo "N/A"; }
get_cpu_l3_cache() { if command -v lscpu &>/dev/null; then local v=$(lscpu -C 2>/dev/null | grep 'L3' | head -1 | awk '{print $2}'); if [ -n "$v" ]; then echo "$v"; return; fi; v=$(lscpu 2>/dev/null | grep -i 'L3 cache' | awk -F: '{print $2}' | awk '{print $1}'); if [ -n "$v" ]; then echo "$v"; return; fi; fi; echo "N/A"; }
get_cpu_features() { if [ -f /proc/cpuinfo ]; then grep -m 1 'flags' /proc/cpuinfo 2>/dev/null | sed 's/flags.*: //' || echo "N/A"; else echo "N/A"; fi; }
get_numa_node_count() { if command -v numactl &>/dev/null; then numactl --hardware 2>/dev/null | grep 'available' | awk '{print $2}' || echo "N/A"; else echo "N/A"; fi; }
get_numa_topology() { if command -v numactl &>/dev/null; then numactl --hardware 2>/dev/null || echo "N/A"; else echo "N/A"; fi; }
get_thp_status() { if [ -f /sys/kernel/mm/transparent_hugepage/enabled ]; then cat /sys/kernel/mm/transparent_hugepage/enabled 2>/dev/null || echo "N/A"; else echo "N/A"; fi; }
get_cpu_freq_min() { if [ -f /sys/devices/system/cpu/cpu0/cpufreq/scaling_min_freq ]; then local freq=$(cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_min_freq 2>/dev/null); if [ -n "$freq" ] && [ "$freq" != "0" ]; then awk "BEGIN {printf \"%.2f\", $freq / 1000}"; else echo "N/A"; fi; else echo "N/A"; fi; }
get_cpu_freq_max() { if [ -f /sys/devices/system/cpu/cpu0/cpufreq/scaling_max_freq ]; then local freq=$(cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_max_freq 2>/dev/null); if [ -n "$freq" ] && [ "$freq" != "0" ]; then awk "BEGIN {printf \"%.2f\", $freq / 1000}"; else echo "N/A"; fi; else echo "N/A"; fi; }
get_cpu_governor() { if [ -f /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor ]; then cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor 2>/dev/null || echo "N/A"; else echo "N/A"; fi; }
get_memory_usage_rate() { if command -v free &>/dev/null; then local mem_line=$(free | grep 'Mem:'); if [ -n "$mem_line" ]; then local total=$(echo "$mem_line" | awk '{print $2}'); local used=$(echo "$mem_line" | awk '{print $3}'); if [ "$total" -gt 0 ] 2>/dev/null; then awk "BEGIN {printf \"%.1f%%\", $used / $total * 100}"; else echo "N/A"; fi; else echo "N/A"; fi; else echo "N/A"; fi; }
get_hugepages_count() { if [ -f /proc/sys/vm/nr_hugepages ]; then cat /proc/sys/vm/nr_hugepages 2>/dev/null || echo "N/A"; else echo "N/A"; fi; }
get_benchmark_disk_device() { local io_path="${IO_PATH:-.}"; local device=$(df "$io_path" 2>/dev/null | tail -1 | awk '{print $1}'); if [ -n "$device" ]; then local basename_dev=$(basename "$device"); if [ -d "/sys/block/$basename_dev" ]; then echo "$basename_dev"; return; fi; if command -v lsblk &>/dev/null; then local disk=$(lsblk -ndo pkname "$device" 2>/dev/null | grep -v "^$" | head -1); if [ -n "$disk" ]; then echo "$disk"; return; fi; fi; for dm_dir in /sys/block/dm-*; do if [ -d "$dm_dir/slaves" ]; then local dev_name=$(cat "$dm_dir/dm/name" 2>/dev/null); if [ -n "$dev_name" ] && echo "$basename_dev" | grep -q "$dev_name"; then local slave=$(ls "$dm_dir/slaves/" 2>/dev/null | head -1); if [ -n "$slave" ]; then echo "$slave" | sed 's/[0-9]*$//; s/p[0-9]*$//'; return; fi; fi; fi; done; echo "$basename_dev" | sed 's/[0-9]*$//; s/p[0-9]*$//; s/-[0-9]*$//'; else echo ""; fi; }
get_benchmark_disk_queue_depth() { local disk=$(get_benchmark_disk_device); if [ -n "$disk" ] && [ -f "/sys/block/$disk/queue/nr_requests" ]; then cat "/sys/block/$disk/queue/nr_requests" 2>/dev/null || echo "N/A"; else echo "N/A"; fi; }
get_benchmark_disk_read_ahead() { local disk=$(get_benchmark_disk_device); if [ -n "$disk" ] && [ -f "/sys/block/$disk/queue/read_ahead_kb" ]; then cat "/sys/block/$disk/queue/read_ahead_kb" 2>/dev/null || echo "N/A"; else echo "N/A"; fi; }
get_benchmark_disk_trim() { local disk=$(get_benchmark_disk_device); if [ -n "$disk" ] && [ -f "/sys/block/$disk/queue/discard_max_bytes" ]; then cat "/sys/block/$disk/queue/discard_max_bytes" 2>/dev/null || echo "N/A"; else echo "N/A"; fi; }
get_benchmark_disk_max_sectors() { local disk=$(get_benchmark_disk_device); if [ -n "$disk" ] && [ -f "/sys/block/$disk/queue/max_sectors_kb" ]; then cat "/sys/block/$disk/queue/max_sectors_kb" 2>/dev/null || echo "N/A"; else echo "N/A"; fi; }
get_benchmark_mount_options() { local io_path="${IO_PATH:-.}"; if command -v findmnt &>/dev/null; then findmnt -T "$io_path" -o TARGET,FSTYPE,OPTIONS -n 2>/dev/null || echo "N/A"; else echo "N/A"; fi; }
get_network_advanced_info() { local has_output=false; for iface in $(ls /sys/class/net/ 2>/dev/null | grep -v "^lo$"); do if command -v ethtool &>/dev/null; then local speed=$(ethtool "$iface" 2>/dev/null | grep 'Speed:' | awk '{print $2}'); local duplex=$(ethtool "$iface" 2>/dev/null | grep 'Duplex:' | awk '{print $2}'); local rx_usecs=$(ethtool -c "$iface" 2>/dev/null | grep 'rx-usecs:' | awk '{print $2}'); local tx_usecs=$(ethtool -c "$iface" 2>/dev/null | grep 'tx-usecs:' | awk '{print $2}'); local tso=$(ethtool -k "$iface" 2>/dev/null | grep 'tcp-segmentation-offload:' | awk '{print $2}'); local gro=$(ethtool -k "$iface" 2>/dev/null | grep 'generic-receive-offload:' | awk '{print $2}'); local driver=$(ethtool -i "$iface" 2>/dev/null | grep 'driver:' | awk '{print $2}'); [ -z "$speed" ] && speed="N/A"; [ -z "$duplex" ] && duplex="N/A"; [ -z "$rx_usecs" ] && rx_usecs="N/A"; [ -z "$tx_usecs" ] && tx_usecs="N/A"; [ -z "$tso" ] && tso="N/A"; [ -z "$gro" ] && gro="N/A"; [ -z "$driver" ] && driver="N/A"; echo "${iface}: Speed=${speed}, Duplex=${duplex}, rx-usecs=${rx_usecs}, tx-usecs=${tx_usecs}, TSO=${tso}, GRO=${gro}, Driver=${driver}"; has_output=true; fi; done; if [ "$has_output" = false ]; then echo "N/A"; fi; }
get_memory_slots_detail() { if ! command -v dmidecode &>/dev/null; then if [ -x "/usr/sbin/dmidecode" ]; then local slots_output=$(/usr/sbin/dmidecode -t memory 2>&1); if echo "$slots_output" | grep -qi "permission denied"; then echo "N/A (permission denied, requires root)"; return; fi; echo "N/A (dmidecode execution failed)"; return; fi; echo "N/A (dmidecode not installed)"; return; fi; local slots_output=""; local success=0; if [ "$(whoami)" = "root" ]; then slots_output=$(/usr/sbin/dmidecode -t memory 2>&1); if echo "$slots_output" | grep -q "Memory Device\|Physical Memory Array"; then success=1; fi; fi; if [ $success -eq 0 ] && command -v sudo &>/dev/null; then slots_output=$(sudo -n /usr/sbin/dmidecode -t memory 2>&1); if echo "$slots_output" | grep -q "Memory Device\|Physical Memory Array"; then success=1; fi; fi; if [ $success -eq 0 ]; then if echo "$slots_output" | grep -qi "permission denied\|password is required"; then echo "N/A (permission denied, requires root)"; else echo "N/A (dmidecode execution failed)"; fi; return; fi; local total_slots=$(echo "$slots_output" | grep -A10 'Physical Memory Array' | grep -i 'Number Of Devices' | awk '{print $NF}'); if [ -z "$total_slots" ] || [ "$total_slots" = "0" ]; then total_slots=$(echo "$slots_output" | grep -c 'Memory Device'); fi; if [ -z "$total_slots" ] || [ "$total_slots" = "0" ]; then local machine_type=$(get_machine_type 2>/dev/null); if echo "$machine_type" | grep -qi "virtual"; then echo "N/A (virtual machine)"; else echo "N/A (no memory slots detected)"; fi; return; fi; local slot_results=$(echo "$slots_output" | awk 'BEGIN { slot_count=0; in_device=0 } /Memory Device/ { if (in_device && size !~ /^(No Module Installed|Unknown)$/ && size != "" && size !~ /^0+\s*(MB|GB|bytes)$/) { print "Slot " slot_count ":"; if (locator != "") print "  Locator: " locator; print "  Size: " size; if (mem_type != "") print "  Type: " mem_type; if (speed != "" && speed != "Unknown") print "  Speed: " speed; if (manufacturer != "" && manufacturer != "Unknown") print "  Manufacturer: " manufacturer; if (part_num != "" && part_num != "Unknown") print "  Part Number: " part_num; } slot_count++; in_device=1; size=""; locator=""; mem_type=""; speed=""; manufacturer=""; part_num="" } in_device && /Locator:/ { locator = substr($0, index($0, $2)); gsub(/^[ \t]+/, "", locator); gsub(/^Locator:\s*/, "", locator) } in_device && /Size:/ { size = substr($0, index($0, "Size:") + 5); gsub(/^[ \t]+/, "", size) } in_device && /Type:/ { mem_type = substr($0, index($0, $2)); gsub(/^[ \t]+/, "", mem_type) } in_device && /Speed:/ { speed = substr($0, index($0, $2)); gsub(/^[ \t]+/, "", speed); gsub(/^Memory Speed:\s*/, "", speed) } in_device && /Manufacturer:/ { manufacturer = substr($0, index($0, $2)); gsub(/^[ \t]+/, "", manufacturer) } in_device && /Part Number:/ { part_num = substr($0, index($0, $3)); gsub(/^[ \t]+/, "", part_num) } END { if (in_device && size !~ /^(No Module Installed|Unknown)$/ && size != "" && size !~ /^0+\s*(MB|GB|bytes)$/) { print "Slot " slot_count ":"; if (locator != "") print "  Locator: " locator; print "  Size: " size; if (mem_type != "") print "  Type: " mem_type; if (speed != "" && speed != "Unknown") print "  Speed: " speed; if (manufacturer != "" && manufacturer != "Unknown") print "  Manufacturer: " manufacturer; if (part_num != "" && part_num != "Unknown") print "  Part Number: " part_num; } }'); local used_slots=$(echo "$slot_results" | grep -c '^Slot '); echo "Total Slots: $total_slots"; echo "Used Slots: $used_slots"; echo "$slot_results"; }
REMOTE_EOF
}

