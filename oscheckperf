        threads=$(get_cpu_cores)
    fi
    local duration="$DURATION"
    
    local memory_oper_list="${MEMORY_OPER:-read write}"
    local IFS=' '
    read -ra oper_array <<< "$memory_oper_list"
    
    for oper in "${oper_array[@]}"; do
        local temp_output_file="$TMP_DIR/vb_memory_${oper}_${TIMESTAMP}.log"
        
        if [ "$REMOTE" != "true" ]; then
            echo "Starting memory ${oper} test..."
            echo "  Threads: $threads, Duration: ${duration}s, Block size: ${MEMORY_BLOCK_SIZE:-8K}"
        fi
        
        run_command "sysbench memory \
            --memory-block-size=\"${MEMORY_BLOCK_SIZE:-8K}\" \
            --memory-total-size=\"${MEMORY_TOTAL_SIZE:-20G}\" \
            --memory-oper=\"$oper\" \
            --threads=\"$threads\" \
            --time=\"${duration}\" \
            run" "$temp_output_file"
        
        if [ "$DRY_RUN" != true ] && [ -f "$temp_output_file" ]; then
            parse_memory_result "$temp_output_file" "$oper"
            append_to_original "MEMORY ${oper^^} TEST RESULTS" "$temp_output_file"
        fi
        
        rm -f "$temp_output_file"
        
        if [ "$REMOTE" != "true" ]; then
            echo "✓ Memory ${oper} test completed"
        fi
    done
}

