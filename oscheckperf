# Parse iperf3 result for matrix test
# Wait for iperf3 server to be ready by polling port listening status
# Parameters: server_ssh, port, [is_remote]
#   server_ssh: SSH command prefix to run on target host (empty for local)
#   port: port number to check
#   is_remote: "true" or empty/false
# Returns: 0 if port is ready within timeout, 1 if timeout
wait_for_iperf3_server() {
    local server_ssh="$1"
    local port="$2"
    local is_remote="${3:-}"
    
    local timeout="$4"
    local verbose="${5:-false}"
    local interval=1
    local waited=0
    
    while [ $waited -lt $timeout ]; do
        if [ "$is_remote" = "true" ]; then
            if eval "$server_ssh 'netstat -tln 2>/dev/null | grep -q :$port || ss -tln 2>/dev/null | grep -q :$port'" > /dev/null 2>&1; then
                return 0
            fi
        else
            if netstat -tln 2>/dev/null | grep -q ":$port " || ss -tln 2>/dev/null | grep -q ":$port "; then
                return 0
            fi
        fi
        sleep $interval
        waited=$((waited + interval))
    done
    
    # Handle failure: print error and optional remote diagnostics
    if [ "$verbose" = "true" ] && [ "$is_remote" = "true" ]; then
        echo "    ✗ ERROR: Server $server_ssh:$port failed to start after ${timeout}s"
        # Print remote diagnostics for troubleshooting
        echo "    --- Remote diagnostics ---"
        local diag_cmd="echo '  iperf3 processes: '\$(ps aux 2>/dev/null | grep '[i]perf3' | wc -l); echo '  Port $port status: '\$(ss -tln 2>/dev/null | grep ':$port' || netstat -tln 2>/dev/null | grep ':$port' || echo '  not listening')"
        eval "$server_ssh '$diag_cmd'" 2>/dev/null | sed 's/^/    /'
        echo "    -----------------------------------"
    fi
    
    return 1
}

