}

# Convert size string (e.g., 1G, 10GB, 512M) to GB
convert_to_gb() {
    local size="$1"
    local num=$(echo "$size" | sed 's/[^0-9.]//g')
    local unit=$(echo "$size" | sed 's/[0-9.]//g' | tr '[:lower:]' '[:upper:]')
    
    case "$unit" in
        "GB"|"G")
            echo "$num"
            ;;
        "MB"|"M")
            echo "scale=2; $num / 1024" | bc
            ;;
        "KB"|"K")
            echo "scale=4; $num / 1024 / 1024" | bc
            ;;
        *)
            echo "$num"
            ;;
    esac
}

# Check disk space
check_disk_space() {
    echo "  Checking disk space..."

    # Support new IO_PATH parameter with backward compatibility to IO_TEST_PATH
    local test_path="${IO_PATH:-${IO_TEST_PATH:-$IO_PATH_DEFAULT}}"
    local available_kb=$(get_disk_available_kb "$test_path")
    local available_gb=$((available_kb / 1024 / 1024))
    
    # Calculate required space based on mode and IO test configuration
    local required_gb=0
    
    # Base requirement based on mode
    case $MODE in
        quick)
            required_gb=2
            ;;
        production)
            required_gb=10
            ;;
        deep)
            required_gb=50
            ;;
        *)
            required_gb=0
            ;;
    esac
    
    # Additional space for IO tests
    if [ "$IO_ENABLED" = "true" ] && [ -n "${IO_TOTAL_SIZE:-}" ]; then
        local io_size_gb=$(convert_to_gb "$IO_TOTAL_SIZE")
        local server_count=1
        
        # Get number of servers (if using -f servers.txt)
        if [ ${#target_servers[@]} -gt 0 ]; then
            server_count=${#target_servers[@]}
        fi
        
        # Calculate IO space requirement (each server needs IO_TOTAL_SIZE)
        local io_required=$(echo "$io_size_gb * $server_count" | bc)
        
        # Convert to integer for comparison
        local io_required_int=$(echo "$io_required" | cut -d. -f1)
        if [ -z "$io_required_int" ] || [ "$io_required_int" = "0" ]; then
            io_required_int=$(echo "$io_size_gb * $server_count" | bc | cut -d. -f1)
        fi
        
        # Add IO requirement to base requirement
        required_gb=$((required_gb + io_required_int))
        
        echo "  IO test space requirement: ${IO_TOTAL_SIZE} x ${server_count} server(s) = ${io_required}GB"
    fi
    
    if [ "$available_gb" -lt "$required_gb" ]; then
        echo "Error: Insufficient disk space"
        echo "  Available: ${available_gb}GB"
        echo "  Required: ${required_gb}GB"
        return 1
    else
        echo "  ✓ Disk space: ${available_gb}GB available, ${required_gb}GB required"
    fi
}

