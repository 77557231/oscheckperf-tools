                            local fmt_min=$(if [ "$min_lat" != "N/A" ]; then awk "BEGIN {printf \"%.2f\", $min_lat}" 2>/dev/null || echo "$min_lat"; else echo "N/A"; fi)
                            local fmt_max=$(if [ "$max_lat" != "N/A" ]; then awk "BEGIN {printf \"%.2f\", $max_lat}" 2>/dev/null || echo "$max_lat"; else echo "N/A"; fi)
                            local fmt_fsync=$(if [ "$fsync_iops" != "N/A" ]; then awk "BEGIN {printf \"%.2f\", $fsync_iops}" 2>/dev/null || echo "$fsync_iops"; else echo "N/A"; fi)
                            
                            printf "  %-20s %-10s %-10s %-10s %-12s %-8s\n" "$server_ip" "$fmt_p95" "$fmt_min" "$fmt_max" "$fmt_fsync" "$io_mode" >> "$report_file"
                        done < <(sort -t'|' -k1,1 "$results_temp_file")
                    fi
                    
                    # If fio, add # FIO Extended Metrics module
                    if [ "$is_sysbench" = false ]; then
                        echo "" >> "$report_file"
                        echo "  # FIO Extended Metrics" >> "$report_file"
                        echo "  -----------------------------------------------------------------------------------------------------------------------------------------" >> "$report_file"
                        printf "  %-17s %-9s %-9s %-6s %-9s %-9s %-8s %-8s %-7s %-13s %-13s %-6s %-6s %-8s\n" "Server IP" "slat(us)" "clat(us)" "Depth" "CPU(usr)" "CPU(sys)" "bw_min" "bw_max" "ctx" "aggrios" "aggrticks" "util" "aggrutil" "Mode" >> "$report_file"
                        echo "  -----------------------------------------------------------------------------------------------------------------------------------------" >> "$report_file"
                        
                        # Print extended metrics from raw output
                        while IFS='|' read -r ext_ip ext_mode ext_p99 ext_disk ext_cpu_usr ext_cpu_sys ext_slat ext_clat ext_iodepth ext_ctx ext_aggrios ext_aggrticks ext_aggrinque ext_aggrutil; do
                            if ! [[ "$ext_ip" =~ ^[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}$ ]]; then
                                continue
                            fi
                            
                            local slat="$ext_slat"
                            local clat="$ext_clat"
                            local iodepth="${ext_iodepth:-N/A}"
                            local util="$ext_disk"
                            local cpu_usr="$ext_cpu_usr"
                            local cpu_sys="$ext_cpu_sys"
                            local ctx="${ext_ctx:-N/A}"
                            local aggrios="${ext_aggrios:-N/A}"
                            local aggrticks="${ext_aggrticks:-N/A}"
                            local aggrutil="${ext_aggrutil:-N/A}"
                            local b_min="${fio_bw_min[$ext_ip]:-N/A}"
                            local b_max="${fio_bw_max[$ext_ip]:-N/A}"
                            
                            # Convert _r/_w suffix to readable mode
                            local display_mode="$ext_mode"
                            if [[ "$ext_mode" == *"_r" ]]; then
                                display_mode="${ext_mode%_r} (r)"
                            elif [[ "$ext_mode" == *"_w" ]]; then
                                display_mode="${ext_mode%_w} (w)"
                            fi
                            
                            # Format all numeric values - integers remain as integers, decimals to 2 places
                            local fmt_slat=$(if [ "$slat" != "N/A" ]; then awk -v val="$slat" 'BEGIN {if (val == int(val)) printf "%d", val; else printf "%.2f", val}' 2>/dev/null || echo "$slat"; else echo "N/A"; fi)
                            local fmt_clat=$(if [ "$clat" != "N/A" ]; then awk "BEGIN {printf \"%.0f\", $clat}" 2>/dev/null || echo "$clat"; else echo "N/A"; fi)
                            local fmt_util=$(if [ "$util" != "N/A" ]; then awk -v val="$util" 'BEGIN {if (val == int(val)) printf "%d", val; else printf "%.2f", val}' 2>/dev/null || echo "$util"; else echo "N/A"; fi)
                            local fmt_cpu_usr=$(if [ "$cpu_usr" != "N/A" ]; then awk -v val="$cpu_usr" 'BEGIN {if (val == int(val)) printf "%d", val; else printf "%.2f", val}' 2>/dev/null || echo "$cpu_usr"; else echo "N/A"; fi)
                            local fmt_cpu_sys=$(if [ "$cpu_sys" != "N/A" ]; then awk -v val="$cpu_sys" 'BEGIN {if (val == int(val)) printf "%d", val; else printf "%.2f", val}' 2>/dev/null || echo "$cpu_sys"; else echo "N/A"; fi)
                            local fmt_b_min=$(if [ "$b_min" != "N/A" ]; then awk "BEGIN {printf \"%.0f\", $b_min}" 2>/dev/null || echo "$b_min"; else echo "N/A"; fi)
                            local fmt_b_max=$(if [ "$b_max" != "N/A" ]; then awk "BEGIN {printf \"%.0f\", $b_max}" 2>/dev/null || echo "$b_max"; else echo "N/A"; fi)
                            local fmt_aggrutil=$(if [ "$aggrutil" != "N/A" ]; then awk "BEGIN {printf \"%.2f\", $aggrutil}" 2>/dev/null || echo "$aggrutil"; else echo "N/A"; fi)
                            
                            printf "  %-17s %-9s %-9s %-6s %-9s %-9s %-8s %-8s %-7s %-13s %-13s %-6s %-6s %-8s\n" "$ext_ip" "$fmt_slat" "$fmt_clat" "$iodepth" "$fmt_cpu_usr" "$fmt_cpu_sys" "$fmt_b_min" "$fmt_b_max" "${ctx:-N/A}" "${aggrios:-N/A}" "${aggrticks:-N/A}" "$fmt_util" "$fmt_aggrutil" "$display_mode" >> "$report_file"
                        done < <(cat "$fio_extended_file" 2>/dev/null || true)
                    fi
                    
                    rm -f "$results_temp_file" "$fio_extended_file"
                fi
        else
            echo "  Test not executed" >> "$report_file"
        fi
    else
        echo "  Test not executed" >> "$report_file"
    fi

    cat >> "$report_file" << EOF

[Threads Test]
EOF

    parse_threads_report "$combined_file" "$report_file"

    cat >> "$report_file" << EOF

[Mutex Test]
EOF

    parse_mutex_report "$combined_file" "$report_file"

    cat >> "$report_file" << EOF

[Network Test]
EOF

    if [ -f "$combined_file" ]; then
        # Check if network test results exist
        if grep -q "NETWORK TEST RESULTS" "$combined_file" 2>/dev/null || grep -q "NETWORK MATRIX TEST RESULTS" "$combined_file" 2>/dev/null || grep -q "NETWORK PARALLEL TEST RESULTS" "$combined_file" 2>/dev/null; then
            # Extract all network test results
            local found_results=false

            # Get the output directory from the combined file path
            local output_dir=$(dirname "$combined_file")

            # Check for different types of network test files from current test only
            local network_files=()
            # Only read network test files that match the current timestamp pattern
            if ls "$TMP_DIR"/network_scenario_*_${TIMESTAMP}.json 1>/dev/null 2>&1; then
                network_files=($(ls "$TMP_DIR"/network_scenario_*_${TIMESTAMP}.json))
            fi
            # Also check for matrix and parallel test files from current test
            if ls "$TMP_DIR"/network_matrix_*_${TIMESTAMP}.json 1>/dev/null 2>&1; then
                network_files+=($(ls "$TMP_DIR"/network_matrix_*_${TIMESTAMP}.json))
            fi
            if ls "$TMP_DIR"/network_parallel_*_${TIMESTAMP}.json 1>/dev/null 2>&1; then
                network_files+=($(ls "$TMP_DIR"/network_parallel_*_${TIMESTAMP}.json))
            fi

            if [ ${#network_files[@]} -gt 0 ]; then
                # Multiple network tests - show comparison table
                echo "  Network Test Comparison (Multiple Servers)" >> "$report_file"
                echo "  -------------------------------------------------------------------------------------------------------------------" >> "$report_file"
                printf "  %-18s %-18s %-18s %-14s %-31s %-19s\n" "Client IP" "Server IP" "Bandwidth (MB/s)" "Retrans" "RTT(ms)" "CPU(%)" >> "$report_file"
                echo "  -------------------------------------------------------------------------------------------------------------------" >> "$report_file"
                
                # Collect all results for sorting and statistics
                local -a results_arr=()
                local -a display_arr=()
                
                # First pass: collect all results
                for json_file in "${network_files[@]}"; do
                    local net_bw="N/A"
                    local client_ip="N/A"
                    local server_ip="N/A"
                    local protocol="N/A"
                    local duration="N/A"
                    local parallel="N/A"
                    local retransmits="N/A"
                    local rtt_avg="N/A"
                    local rtt_min="N/A"
                    local rtt_max="N/A"
                    local cpu_sender="N/A"
                    local cpu_receiver="N/A"
                    local tcp_congestion="N/A"

                    if [ -f "$json_file" ]; then
                        if jq_available; then
                            # Extract JSON content by removing any leading non-JSON text
                            local json_content=$(awk 'BEGIN{found=0} /^\{/{found=1} found{print} /^\}/{if(found) exit}' "$json_file" 2>/dev/null || cat "$json_file")
                            
                            # Extract bandwidth from JSON content
                            local bandwidth_bps=$(echo "$json_content" | jq -r '.end.sum_received.bits_per_second // 0' 2>/dev/null)
                            # Convert bps to MB/s: 1 MB/s = 8,000,000 bps
                            net_bw=$(awk "BEGIN {printf \"%.2f\", $bandwidth_bps / 8000000}" 2>/dev/null || echo "N/A")
                            
                            # Extract client and server IPs from the JSON content
                            client_ip=$(echo "$json_content" | jq -r '.start.connected[0].local_host // "N/A"' 2>/dev/null)
                            server_ip=$(echo "$json_content" | jq -r '.start.connected[0].remote_host // "N/A"' 2>/dev/null)
                            
                            # Extract additional metrics
                            protocol=$(echo "$json_content" | jq -r '.start.test_start.protocol // "N/A"' 2>/dev/null)
                            local raw_duration=$(echo "$json_content" | jq -r '.end.sum_received.seconds // "N/A"' 2>/dev/null)
                            # Round duration to integer for cleaner display
                            if [ "$raw_duration" != "N/A" ] && [ "$raw_duration" != "null" ]; then
                                duration=$(awk "BEGIN {printf \"%.0f\", $raw_duration}" 2>/dev/null || echo "$raw_duration")
                            else
                                duration="N/A"
                            fi
                            parallel=$(echo "$json_content" | jq -r '.start.test_start.num_streams // "N/A"' 2>/dev/null)
                            retransmits=$(echo "$json_content" | jq -r '.end.sum_sent.retransmits // "N/A"' 2>/dev/null)
                            rtt_avg=$(echo "$json_content" | jq -r '.end.streams[0].sender.mean_rtt // "N/A"' 2>/dev/null)
                            rtt_min=$(echo "$json_content" | jq -r '.end.streams[0].sender.min_rtt // "N/A"' 2>/dev/null)
                            rtt_max=$(echo "$json_content" | jq -r '.end.streams[0].sender.max_rtt // "N/A"' 2>/dev/null)
                            cpu_sender=$(echo "$json_content" | jq -r '.end.cpu_utilization_percent.remote_total // "N/A"' 2>/dev/null)
                            cpu_receiver=$(echo "$json_content" | jq -r '.end.cpu_utilization_percent.host_total // "N/A"' 2>/dev/null)
                            tcp_congestion=$(echo "$json_content" | jq -r '.end.sender_tcp_congestion // "N/A"' 2>/dev/null)
                            
                            # Format CPU values to 2 decimal places
                            if [ "$cpu_sender" != "N/A" ] && [ "$cpu_sender" != "null" ]; then
                                cpu_sender=$(awk "BEGIN {printf \"%.2f\", $cpu_sender}" 2>/dev/null || echo "$cpu_sender")
                            else
                                cpu_sender="N/A"
                            fi
                            if [ "$cpu_receiver" != "N/A" ] && [ "$cpu_receiver" != "null" ]; then
                                cpu_receiver=$(awk "BEGIN {printf \"%.2f\", $cpu_receiver}" 2>/dev/null || echo "$cpu_receiver")
                            else
                                cpu_receiver="N/A"
                            fi
                            
                            # Convert RTT from microseconds to milliseconds if available
                            if [ "$rtt_avg" != "N/A" ] && [ "$rtt_avg" != "null" ]; then
                                rtt_avg=$(awk "BEGIN {printf \"%.3f\", $rtt_avg / 1000}" 2>/dev/null || echo "$rtt_avg")
                            else
                                rtt_avg="N/A"
                            fi
                            if [ "$rtt_min" != "N/A" ] && [ "$rtt_min" != "null" ]; then
                                rtt_min=$(awk "BEGIN {printf \"%.3f\", $rtt_min / 1000}" 2>/dev/null || echo "$rtt_min")
                            else
                                rtt_min="N/A"
                            fi
                            if [ "$rtt_max" != "N/A" ] && [ "$rtt_max" != "null" ]; then
                                rtt_max=$(awk "BEGIN {printf \"%.3f\", $rtt_max / 1000}" 2>/dev/null || echo "$rtt_max")
                            else
                                rtt_max="N/A"
                            fi
                            
                            if [ -z "$client_ip" ] || [ "$client_ip" = "null" ] || [ "$client_ip" = "N/A" ]; then
                                # Fallback: check if this is a matrix test file and try to get IP from results
                                local file_name=$(basename "$json_file")
                                if echo "$file_name" | grep -q "network_matrix"; then
                                    # For matrix tests, use placeholder indicating failed connection
                                    client_ip="Unknown"
                                elif echo "$file_name" | grep -q "network_parallel"; then
                                    # For parallel tests
                                    client_ip="Unknown"
                                elif echo "$file_name" | grep -q "network_scenario"; then
                                    # For scenario tests
                                    client_ip="Unknown"
                                else
                                    client_ip="Unknown"
                                fi
                            fi
                        fi
                    fi
                    
                    # Collect results for sorting and display
                    if [ "$server_ip" != "N/A" ] && [ "$server_ip" != "null" ]; then
                        local rtt_display="N/A"
                        if [ "$rtt_avg" != "N/A" ] && [ "$rtt_avg" != "null" ]; then
                            if [ "$rtt_min" != "N/A" ] && [ "$rtt_max" != "N/A" ]; then
                                rtt_display="${rtt_avg} (Min: ${rtt_min}, Max: ${rtt_max})"
                            else
                                rtt_display="$rtt_avg"
                            fi
                        fi
                        local cpu_display="N/A"
                        if ([ "$cpu_sender" != "N/A" ] && [ "$cpu_sender" != "null" ]) || ([ "$cpu_receiver" != "N/A" ] && [ "$cpu_receiver" != "null" ]); then
                            cpu_display="${cpu_sender:-N/A}/${cpu_receiver:-N/A}"
                        fi
                        
                        # Store result for sorting (bandwidth|client|server|retrans|rtt|cpu)
                        results_arr+=("$net_bw|$client_ip|$server_ip|${retransmits:-N/A}|$rtt_display|$cpu_display")
                        found_results=true
                    fi
                done
                
                # Calculate statistics and sort results
                if [ ${#results_arr[@]} -gt 0 ]; then
                    # Find max bandwidth
                    local max_bw=0
                    for result in "${results_arr[@]}"; do
                        local bw=$(echo "$result" | cut -d'|' -f1)
                        if [ "$bw" != "N/A" ] && (( $(echo "$bw > $max_bw" | bc -l) )); then
                            max_bw="$bw"
                        fi
                    done
                    
                    # Sort by bandwidth descending and display
                    local sorted_results=$(printf "%s\n" "${results_arr[@]}" | sort -t'|' -k1 -rn)
                    local rank=1
                    echo "$sorted_results" | while IFS='|' read -r bw client server retrans rtt cpu; do
                        printf "  %-18s %-18s %-18s %-14s %-31s %-19s" "$client" "$server" "$bw" "$retrans" "$rtt" "$cpu" >> "$report_file"
                        # Highlight poor performers (below 25% of max bandwidth)
                        if [ "$bw" != "N/A" ] && (( $(echo "$bw < $max_bw * 0.25" | bc -l) )); then
                            echo "  ⚠ POOR PERFORMANCE" >> "$report_file"
                        else
                            echo "" >> "$report_file"
                        fi
                        rank=$((rank + 1))
                    done
                fi
            else
                # No JSON files found, check combined file directly
                echo "  Test executed but no detailed results available" >> "$report_file"
                found_results=true
            fi
            
            if [ "$found_results" = false ]; then
                echo "  Test not executed or no results found" >> "$report_file"
            fi
        else
            echo "  Test not executed" >> "$report_file"
        fi
    else
        echo "  Test not executed" >> "$report_file"
    fi
    
    # Finalize report
    cat >> "$report_file" << EOF

================================================================================
                                End of Report
================================================================================
EOF
    

}

# Main function
main() {
    start_timer "main_total"
    
    # Capture full execution command
    local full_command="$0"
    for arg in "$@"; do
        if [[ "$arg" == *" "* ]]; then
            full_command="$full_command \"$arg\""
        else
            full_command="$full_command $arg"
        fi
    done
    export EXECUTION_COMMAND="$full_command"
    
    # Debug output before parse_args
    debug_log "Before parse_args" \
        "CPU_ENABLED=$CPU_ENABLED" \
        "MEMORY_ENABLED=$MEMORY_ENABLED" \
        "IO_ENABLED=$IO_ENABLED" \
        "NETWORK_ENABLED=$NETWORK_ENABLED" \
        "THREADS_ENABLED=$THREADS_ENABLED" \
        "MUTEX_ENABLED=$MUTEX_ENABLED"
    
    # Extract CONFIG_FILE before parse_args so we can load config first
    local early_config_file=""
    for arg in "$@"; do
        case "$arg" in
            -p=*|--config-file=*)
                early_config_file="${arg#*=}"
                ;;
            -p)
                # Next arg is the config file
                ;;
        esac
    done
    # Also handle -p value (space separated)
    local found_p=false
    for arg in "$@"; do
        if [ "$found_p" = true ]; then
            early_config_file="$arg"
            break
        fi
        if [ "$arg" = "-p" ]; then
            found_p=true
        fi
    done
    
    # Load configuration file first (before parse_args sets defaults)
    # This ensures config values take precedence over script defaults
    if [ -n "$early_config_file" ]; then
        load_config_file "$early_config_file"
    fi
    
    # Set default for DURATION if not set by config file
    DURATION="${DURATION:-60}"
    
    # Set defaults for global path/port parameters if not set by config file
    OUTPUT_DIR="${OUTPUT_DIR:-./output}"
    NETWORK_PORT="${NETWORK_PORT:-25201}"
    SSH_PORT="${SSH_PORT:-22}"
    IO_PATH="${IO_PATH:-$BASE_DIR/io_test}"
    
    # Save config file ENABLED flags BEFORE parse_args resets them
    local config_cpu_enabled="${CPU_ENABLED:-false}"
    local config_memory_enabled="${MEMORY_ENABLED:-false}"
    local config_io_enabled="${IO_ENABLED:-false}"
    local config_network_enabled="${NETWORK_ENABLED:-false}"
    local config_threads_enabled="${THREADS_ENABLED:-false}"
    local config_mutex_enabled="${MUTEX_ENABLED:-false}"
    
    # Parse command line arguments
    parse_args "$@"
    
    # If no subcommand was specified (all tests disabled after parse_args),
    # restore config file ENABLED settings
    if [ "$CPU_ENABLED" = "false" ] && [ "$MEMORY_ENABLED" = "false" ] && \
       [ "$IO_ENABLED" = "false" ] && [ "$NETWORK_ENABLED" = "false" ] && \
       [ "$THREADS_ENABLED" = "false" ] && [ "$MUTEX_ENABLED" = "false" ]; then
        export CPU_ENABLED="$config_cpu_enabled"
        export MEMORY_ENABLED="$config_memory_enabled"
        export IO_ENABLED="$config_io_enabled"
        export NETWORK_ENABLED="$config_network_enabled"
        export THREADS_ENABLED="$config_threads_enabled"
        export MUTEX_ENABLED="$config_mutex_enabled"
    fi
    
    # Validate all parameters first before doing anything else
    # Skip validation here if it's a check command - validation will be done in check_all()
    if [ "$CHECK_ENABLED" != "true" ]; then
        validate_all_parameters
    fi
    
    # Debug output after parse_args
    debug_log "After parse_args" \
        "CPU_ENABLED=$CPU_ENABLED" \
        "MEMORY_ENABLED=$MEMORY_ENABLED" \
        "IO_ENABLED=$IO_ENABLED" \
        "NETWORK_ENABLED=$NETWORK_ENABLED" \
        "THREADS_ENABLED=$THREADS_ENABLED" \
        "MUTEX_ENABLED=$MUTEX_ENABLED"
    
    # Set default values
    FORMAT="${FORMAT:-txt}"
    
    # Convert OUTPUT_DIR to absolute path to avoid issues when script changes directory
    case "$OUTPUT_DIR" in
        /*) ;;  # Already absolute path
        *) OUTPUT_DIR="$(cd "$(dirname "$OUTPUT_DIR")" && pwd)/$(basename "$OUTPUT_DIR")" ;;
    esac
    
    # Set timestamp
    if [ -z "$TIMESTAMP" ]; then
        TIMESTAMP=$(date '+%Y%m%d_%H%M%S')
    fi
    
    # Create all necessary directories
    mkdir -p "$OUTPUT_DIR"
    mkdir -p "$TMP_DIR"
    mkdir -p "$IO_PATH"
    
    # Second parse_args is no longer needed - ENABLED flags are handled above
    
    # Validate path parameters for security
    validate_all_paths
    
    # Process server list (supports file or direct IP list)
    target_servers=()
    local local_ip=$(get_machine_ip)
    local include_local=false
    
    # Clear credential arrays
    SERVER_USERNAMES=()
    SERVER_PASSWORDS=()
    
    if [ -n "$SERVERS_FILE" ]; then
        if [ -f "$SERVERS_FILE" ]; then
            # Read server IP list from file
            local servers=()
            mapfile -t servers < "$SERVERS_FILE"
            
            # Process each entry, supports: IP, IP username, IP username password (space-separated)
            local filtered_servers=()
            for entry in "${servers[@]}"; do
                entry=$(echo "$entry" | tr -d '\r' | xargs)
                if [ -n "$entry" ]; then
                    # Parse server entry to extract IP and credentials
                    parse_server_entry "$entry"
                    filtered_servers+=("$LAST_PARSED_IP")
                    if [ "$LAST_PARSED_IP" = "$local_ip" ]; then
                        include_local=true
                    fi
                fi
            done
            target_servers=(${filtered_servers[@]})
        else
            # Process SERVERS_FILE directly as IP list
            local ip_list=($SERVERS_FILE)
            local filtered_ips=()
            for entry in "${ip_list[@]}"; do
                entry=$(echo "$entry" | xargs)
                if [ -n "$entry" ]; then
                    # Parse server entry to extract IP and credentials
                    parse_server_entry "$entry"
                    filtered_ips+=("$LAST_PARSED_IP")
                    if [ "$LAST_PARSED_IP" = "$local_ip" ]; then
                        include_local=true
                    fi
                fi
            done
            target_servers=(${filtered_ips[@]})
        fi
        
        # Initialize tee logging BEFORE any output - all output goes to both terminal and data log file
        if [ "$REMOTE" != "true" ] && [ "$CHECK_ENABLED" != "true" ] && [ "$DRY_RUN" != true ]; then
            # Create OUTPUT_DIR if not exists
            mkdir -p "$OUTPUT_DIR"
            # Use exec tee to simultaneously output to terminal and log file
            exec > >(tee -a "$OUTPUT_DIR/data_${TIMESTAMP}_all_results.log") 2>&1
        fi
        
        if [ ${#target_servers[@]} -gt 0 ]; then
            # Local machine as iPerf3 server
            local server_ip=$(get_machine_ip)
            # All IPs as clients
            local client_ips=""
            for ip in "${target_servers[@]}"; do
                client_ips+="$ip "
            done
            client_ips=$(echo "$client_ips" | xargs)
            
            echo "Loading configuration from server list:"
            echo "  Server IP: $server_ip (local)"
            echo "  Client IPs: $client_ips"
            echo "  Local machine as iPerf3 server"
            
            # Set network test parameters
            export NETWORK_CLIENT_IP="$client_ips"
        fi
    fi
    
    # Install components if -i option is specified
    if [ -n "$INSTALL_TARGET" ]; then
        install_components "$INSTALL_TARGET"
        echo ""
        echo "=== Installation completed successfully! ==="
        exit 0
    fi
    
    # Handle check subcommand
    if [ "$CHECK_ENABLED" = "true" ]; then
        # Skip headers if running in remote mode
        if [ "$REMOTE" != "true" ]; then
            # Run checks for all servers
            echo "Running system checks for all servers..."
            echo "====================================="
            echo ""
            
            if [ ${#target_servers[@]} -gt 0 ]; then
                # Check each target server
                local server_idx=0
                for target_ip in "${target_servers[@]}"; do
                    server_idx=$((server_idx + 1))
                    echo "Checking server $server_idx/$(( ${#target_servers[@]} )): $target_ip"
                    echo "----------------------------------"
                    
                    if [ "$target_ip" = "$local_ip" ]; then
                        # Local machine check
                        check_all "$target_ip"
                    else
                        # Remote server check
                        echo "  Executing remote checks on $target_ip..."
                        set_ssh_password "$target_ip"
                        local check_ssh=$(get_ssh_command "$target_ip")
                        
                        # Ensure remote oscheckperf script is up-to-date before running check
                        local scp_cmd=$(get_scp_command "$target_ip")
                        eval "$scp_cmd -q '$0' '$target_ip:\$HOME/oscheckperf/'" > /dev/null 2>&1
                        eval "$check_ssh 'chmod +x \$HOME/oscheckperf/oscheckperf'" > /dev/null 2>&1
                        
                        eval "$check_ssh '\$HOME/oscheckperf/oscheckperf --remote check $target_ip'"
                    fi
                    echo ""
                done
            else
                # Single machine check
                check_all
            fi
        else
            # Remote mode: only run checks
            check_all "$CHECK_SERVER_IP"
        fi
        
        exit 0
    fi
    
    # Handle hardware subcommand
    if [ "$HARDWARE_ONLY" = "true" ]; then
        if ! command -v get_cpu_arch &> /dev/null; then
            echo "Error: hw_functions not found" >&2
            echo "Please ensure hw_functions is present in tools/ directory" >&2
            exit 1
        fi
        echo "Hardware Information Report"
        echo "=========================="
        echo ""
        
        local report_file="$OUTPUT_DIR/hardware_report_${TIMESTAMP}.log"
        
        if [ ${#target_servers[@]} -gt 0 ]; then
            generate_hardware_report_unified "$report_file" "${target_servers[@]}"
        else
            generate_hardware_report_unified "$report_file"
        fi
        
        cat "$report_file"
        
        echo ""
        echo "=== Hardware report generated successfully! ==="
        echo "Report: $report_file"
        exit 0
    fi
    
    # Run tests for all servers
    if [ "$REMOTE" != "true" ]; then
        echo "Running benchmark tests for all servers..."
        echo "======================================"
        echo ""
    fi
    
    # Run system checks before benchmark tests
    if [ "$REMOTE" != "true" ] && [ "$CHECK_ENABLED" != "true" ] && [ "$DRY_RUN" != "true" ]; then
        # Run system checks (skip in dry-run mode)
        check_all
    fi
    
    # Check if sysbench is installed before running tests
    if [ "$REMOTE" != "true" ] && [ "$CHECK_ENABLED" != "true" ]; then
        if ! command -v sysbench &> /dev/null; then
            echo "Error: sysbench is not installed."
            echo "Please run './oscheckperf -i' to install and distribute sysbench,"
            echo "or './oscheckperf check' to check dependencies."
            exit 1
        fi
    fi
    
    if [ ${#target_servers[@]} -gt 0 ]; then
        # Function to execute tests on a single server
        execute_server_tests() {
            local target_ip="$1"
            local server_idx="$2"
            
            echo ""
            echo "================================================================================"
            echo "Testing server $server_idx/$(( ${#target_servers[@]} )): $target_ip"
            echo "================================================================================"
            
            # Execute tests on the server
            if [ "$target_ip" = "$local_ip" ] || [ "$DRY_RUN" = true ]; then
                # Local machine test or dry-run mode (show commands for all servers)
                if [ "$target_ip" != "$local_ip" ]; then
                    echo "  [DRY RUN] Showing commands that would execute on remote server $target_ip:"
                fi
                run_all_selected_tests
            else
                # Remote server test (actual execution)
                echo "  Executing remote tests on $target_ip..."
                
                # Build the remote command with all enabled tests
                local remote_command="--remote"
                local has_non_network_tests=false
                
                # Add tests to remote command based on enabled flags
                if [ "$CPU_ENABLED" != "false" ]; then
                    remote_command="$remote_command cpu"
                    has_non_network_tests=true
                fi
                
                if [ "$MEMORY_ENABLED" != "false" ]; then
                    remote_command="$remote_command mem"
                    has_non_network_tests=true
                fi
                
                if [ "$IO_ENABLED" != "false" ]; then
                    remote_command="$remote_command io"
                    has_non_network_tests=true
                fi
                
                if [ "$THREADS_ENABLED" != "false" ]; then
                    remote_command="$remote_command threads"
                    has_non_network_tests=true
                fi
                
                if [ "$MUTEX_ENABLED" != "false" ]; then
                    remote_command="$remote_command mutex"
                    has_non_network_tests=true
                fi
                
                # If no tests specified, add all tests (same as local behavior)
                if [ "$has_non_network_tests" = "false" ]; then
                    # Check if only network test is requested
                    if [ "$NETWORK_ENABLED" = "true" ] && [ "$CPU_ENABLED" != "true" ] && [ "$MEMORY_ENABLED" != "true" ] && [ "$IO_ENABLED" != "true" ] && [ "$THREADS_ENABLED" != "true" ] && [ "$MUTEX_ENABLED" != "true" ]; then
                        # Only network test requested, skip remote tests
                        echo "  Skipping remote tests (only network test requested)"
                        return
                    else
                        # No tests specified, add all tests
                        remote_command="$remote_command all"
                        has_non_network_tests=true
                    fi
                fi
                
                # Only execute remote tests if there are non-network tests to run
                if [ "$has_non_network_tests" = true ]; then
                    # Add common parameters including TIMESTAMP
                    remote_command="$remote_command DURATION=\"$DURATION\" TIMESTAMP=\"$TIMESTAMP\""
                    
                    # Add test-specific parameters
                    # Support new SYSBENCH_PROFILES and IO_PATH parameters with backward compatibility
                    remote_command="$remote_command CPU_THREADS=\"$CPU_THREADS\" CPU_MAX_PRIME=\"$CPU_MAX_PRIME\""
                    remote_command="$remote_command MEMORY_THREADS=\"$MEMORY_THREADS\" MEMORY_BLOCK_SIZE=\"$MEMORY_BLOCK_SIZE\" MEMORY_TOTAL_SIZE=\"$MEMORY_TOTAL_SIZE\" MEMORY_OPER=\"$MEMORY_OPER\""
                    remote_command="$remote_command IO_TOOL=\"$IO_TOOL\" IO_TOTAL_SIZE=\"$IO_TOTAL_SIZE\" SYSBENCH_PROFILES=\"${SYSBENCH_PROFILES:-rndrw}\" SYSBENCH_FILE_NUM=\"$SYSBENCH_FILE_NUM\" SYSBENCH_DURATION=\"$SYSBENCH_DURATION\" IO_PATH=\"$IO_PATH\" FIO_DURATION=\"$FIO_DURATION\""
                    remote_command="$remote_command THREADS_NUM=\"$THREADS_NUM\" THREADS_YIELDS=\"$THREADS_YIELDS\" THREADS_LOCKS=\"$THREADS_LOCKS\""
                    remote_command="$remote_command MUTEX_THREADS=\"$MUTEX_THREADS\" MUTEX_NUM=\"$MUTEX_NUM\""
                    
                    # Execute the remote command and capture output to a temporary file
                    local temp_remote_file="$TMP_DIR/vb_remote_${target_ip//./_}_${TIMESTAMP}.log"
                    
                    # Always use remote oscheckperf for consistent execution
                    # Check if remote oscheckperf exists, if not, skip this server
                    set_ssh_password "$target_ip"
                    local ssh_cmd=$(get_ssh_command "$target_ip")
                    if eval "$ssh_cmd '[ -d ~/oscheckperf ]'" 2>/dev/null; then
                        # Use remote oscheckperf
                        # Build the remote command with only the requested tests
                        local remote_test_command=""
                        if [ "$CPU_ENABLED" = "true" ]; then
                            remote_test_command="cpu"
                        fi
                        if [ "$MEMORY_ENABLED" = "true" ]; then
                            remote_test_command="$remote_test_command mem"
                        fi
                        if [ "$IO_ENABLED" = "true" ]; then
                            remote_test_command="$remote_test_command io"
                        fi
                        if [ "$THREADS_ENABLED" = "true" ]; then
                            remote_test_command="$remote_test_command threads"
                        fi
                        if [ "$MUTEX_ENABLED" = "true" ]; then
                            remote_test_command="$remote_test_command mutex"
                        fi
                        
                        # Add duration parameter
                        if [ -n "$remote_test_command" ]; then
                            remote_test_command="$remote_test_command DURATION=$DURATION"
                            # Add IO test specific parameters
                            if [ "$IO_ENABLED" = "true" ]; then
                                remote_test_command="$remote_test_command IO_TOOL=$IO_TOOL"
                                if [ "$IO_TOOL" = "fio" ]; then
                                    remote_test_command="$remote_test_command FIO_DURATION=${FIO_DURATION:-$DURATION}"
                                    remote_test_command="$remote_test_command FIO_PROFILES=\"${FIO_PROFILES:-randrw}\""
                                    remote_test_command="$remote_test_command FIO_BS=${FIO_BS:-16K}"
                                    remote_test_command="$remote_test_command FIO_IODEPTH=${FIO_IODEPTH:-32}"
                                    remote_test_command="$remote_test_command FIO_NUMJOBS=${FIO_NUMJOBS:-4}"
                                    remote_test_command="$remote_test_command FIO_DIRECT=${FIO_DIRECT:-1}"
                                    remote_test_command="$remote_test_command FIO_IOENGINE=${FIO_IOENGINE:-libaio}"
                                    remote_test_command="$remote_test_command FIO_FILE_NUM=${FIO_FILE_NUM:-4}"
                                else
                                    remote_test_command="$remote_test_command SYSBENCH_PROFILES=\"${SYSBENCH_PROFILES:-rndrw}\""
                                    remote_test_command="$remote_test_command SYSBENCH_IO_MODE=\"${SYSBENCH_IO_MODE:-sync}\""
                                    remote_test_command="$remote_test_command SYSBENCH_EXTRA_FLAGS=\"${SYSBENCH_EXTRA_FLAGS:-direct}\""
                                    remote_test_command="$remote_test_command SYSBENCH_THREADS=\"${SYSBENCH_THREADS:-4}\""
                                    remote_test_command="$remote_test_command SYSBENCH_BLOCK_SIZE=\"${SYSBENCH_BLOCK_SIZE:-16K}\""
                                fi
                                # Support new IO_PATH parameter with backward compatibility
                                remote_test_command="$remote_test_command IO_TOTAL_SIZE=${IO_TOTAL_SIZE:-1G} SYSBENCH_FILE_NUM=${SYSBENCH_FILE_NUM:-4} SYSBENCH_DURATION=${SYSBENCH_DURATION:-$DURATION} IO_PATH=$IO_PATH"
                            fi
                        fi
                        
                        # Add NO_CHECKS parameter to skip checks during benchmark
                        # Pass --dry-run to remote so it also shows underlying commands
                        local dry_run_flag=""
                        if [ "$DRY_RUN" = true ]; then
                            dry_run_flag="--dry-run"
                        fi
                        
                        local full_remote_command="cd ~/oscheckperf && TIMESTAMP=$TIMESTAMP ./oscheckperf $dry_run_flag $remote_command $remote_test_command NO_CHECKS=true REMOTE=true"
                        set_ssh_password "$target_ip"
                        local ssh_cmd=$(get_ssh_command "$target_ip")
                        if [ "$DRY_RUN" = true ]; then
                            echo "[DRY RUN] Would execute remote command on $target_ip:"
                            echo "  $ssh_cmd '$full_remote_command'"
                        elif eval "$ssh_cmd '$full_remote_command'" 2>&1 > "$temp_remote_file"; then
                            # Display remote test output
                            cat "$temp_remote_file"
                            
                            # Fetch original sysbench output and fio JSON files from remote server
                            # Create a temporary directory to extract remote files
                            local temp_remote_dir="$TMP_DIR/vb_remote_${target_ip//./_}_${TIMESTAMP}"
                            mkdir -p "$temp_remote_dir"
                            # Extract remote files to temporary directory (original_data and fio JSON)
                            if ! eval "$ssh_cmd 'cd ~/oscheckperf && tar -czf - output/original_data_${TIMESTAMP}_* tmp/fio_*_result_${TIMESTAMP}.json 2>/dev/null || tar -czf - output/original_data_${TIMESTAMP}_*'" | tar -xzf - -C "$temp_remote_dir"; then
                                echo "  ⚠ Warning: Failed to fetch remote output files from $target_ip"
                            fi
                            
                            # Copy fio JSON files to local TMP_DIR with IP prefix
                            for json_file in "$temp_remote_dir/tmp/fio_"*"_result_${TIMESTAMP}.json"; do
                                if [ -f "$json_file" ]; then
                                    local base_name=$(basename "$json_file")
                                    cp "$json_file" "$TMP_DIR/${target_ip//./_}_${base_name}"
                                fi
                            done
                            
                            # Append remote original data to main file
                            local found_files=false
                            for file in "$temp_remote_dir/output/original_data_${TIMESTAMP}_"*; do
                                if [ -f "$file" ]; then
                                    found_files=true
                                    echo "" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                                    echo "================================================================================" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                                    echo "RESULTS FROM SERVER: $target_ip" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                                    echo "================================================================================" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                                    cat "$file" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                                fi
                            done
                            
                            # If no files found, record error
                            if [ "$found_files" = false ]; then
                                echo "" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                                echo "================================================================================" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                                echo "RESULTS FROM SERVER: $target_ip" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                                echo "================================================================================" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                                echo "Execution Command: $full_remote_command" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                                echo "" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                                echo "WARNING: No output files found from remote server" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                                echo "Checking remote server status:" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                                echo "- fio version: $(eval "$ssh_cmd 'fio --version 2>/dev/null || echo fio not found'")" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                                echo "- jq version: $(eval "$ssh_cmd 'jq --version 2>/dev/null || echo jq not found'")" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                                echo "- oscheckperf exists: $(eval "$ssh_cmd '[ -f ~/oscheckperf/oscheckperf ] && echo Yes || echo No'")" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                                echo "- Output dir exists: $(eval "$ssh_cmd '[ -d ~/oscheckperf/output ] && echo Yes || echo No'")" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                                echo "" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                                echo "Remote command output:" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                                cat "$temp_remote_file" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log" 2>/dev/null || echo "No output captured" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                            fi
                            
                            # Clean up temporary directory
                            rm -rf "$temp_remote_dir"
                        else
                            echo "  ✗ Remote test execution failed"
                            # Record failure in original data file for report generation
                            echo "" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                            echo "================================================================================" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                            echo "RESULTS FROM SERVER: $target_ip" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                            echo "================================================================================" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                            echo "Execution Command: $full_remote_command" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                            echo "" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                            echo "ERROR: Remote test execution failed" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                            echo "Output:" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                            cat "$temp_remote_file" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log" 2>/dev/null || echo "No output captured" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                        fi
                    else
                        echo "  ✗ Remote oscheckperf not found, skipping this server"
                        echo "  Hint: Use './oscheckperf -f all-servers -i' to distribute oscheckperf to all servers"
                    fi
                    
                    # Clean up
                    rm -f "$temp_remote_file"
                else
                    echo "  Skipping remote tests (only network test requested)"
                fi

            fi
        }
        
        # Determine execution mode: default to parallel (like gpcheckperf)
        local exec_mode="${EXEC_MODE:-parallel}"
        echo "Execution mode: $exec_mode"
        
        if [ "$exec_mode" = "parallel" ]; then
            # Parallel execution: run all servers simultaneously
            echo "Starting parallel tests on ${#target_servers[@]} servers..."
            local pids=()
            
            local server_idx=0
            for target_ip in "${target_servers[@]}"; do
                server_idx=$((server_idx + 1))
                # Run server tests in background
                execute_server_tests "$target_ip" "$server_idx" > "$TMP_DIR/vb_parallel_${target_ip//./_}_${TIMESTAMP}.log" 2>&1 &
                pids+=($!)
                echo "  Server $server_idx ($target_ip) started in background (PID: ${pids[-1]})"
            done
            
            # Wait for all background processes to complete
            echo "Waiting for all tests to complete..."
            for pid in "${pids[@]}"; do
                wait "$pid"
            done
            
            # Display output from all servers
            echo ""
            echo "=== Test Output Summary ==="
            for target_ip in "${target_servers[@]}"; do
                local log_file="$TMP_DIR/vb_parallel_${target_ip//./_}_${TIMESTAMP}.log"
                if [ -f "$log_file" ]; then
                    echo ""
                    echo "--- Output from $target_ip ---"
                    cat "$log_file"
                    rm -f "$log_file"
                fi
            done
        else
            # Serial execution: run servers one by one
            echo "Starting serial tests on ${#target_servers[@]} servers..."
            local server_idx=0
            for target_ip in "${target_servers[@]}"; do
                server_idx=$((server_idx + 1))
                execute_server_tests "$target_ip" "$server_idx"
            done
        fi
        
        # Execute network test (only once for the entire cluster)
        if [ "$NETWORK_ENABLED" != "false" ]; then
            run_network_test
        fi
    else
        # Single machine test mode
        run_all_selected_tests "true"
    fi
    
    # Only generate report in non-remote mode and non-dry-run mode
    if [ "$REMOTE" != "true" ] && [ "$DRY_RUN" != true ]; then
        # Generate report
        generate_report
        
        # End main timer before printing summary
        end_timer "main_total"
        
        # Print timer summary in debug mode
        print_timer_summary
        
        echo ""
        echo "=== Benchmark completed successfully! ==="
        echo "Report: $OUTPUT_DIR/report_benchmark_${TIMESTAMP}.log"
        echo "Detailed results: $OUTPUT_DIR/data_${TIMESTAMP}_all_results.log"
        echo "Original data: $OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
    elif [ "$DRY_RUN" = true ]; then
        end_timer "main_total"
        echo ""
        echo "[DRY RUN] Report generation skipped"
    else
        end_timer "main_total"
    fi
}

# Compile a package from source
# Arguments:
#   $1: package name (sysbench/sshpass)
#   $2: tarball path
#   $3: source directory name
#   $4: configure arguments
#   $5: autogen needed (true/false)
compile_package() {
    local package_name="$1"
    local tarball="$2"
    local src_dir="$3"
    local configure_args="$4"
    local need_autogen="$5"
    local install_dir="$BASE_DIR"
    local log_file="/tmp/compile_${package_name}_$$.log"
    
    echo "  Compiling $package_name..."
    
    # Skip actual compilation in dry run mode
    if [ "$DRY_RUN" = true ]; then
        echo "  Dry run: tar -zxf $tarball && cd $src_dir && ./configure $configure_args --prefix=$install_dir && make && make install"
        echo "  ✓ $package_name compilation skipped (dry run)"
        return 0
    fi
    
    # Create install directory if needed
    mkdir -p "$install_dir"
    
    # Extract source (silent)
    if ! tar -zxf "$tarball" > "$log_file" 2>&1; then
        echo "  ✗ Failed to extract $tarball"
        echo "    Error:"
        cat "$log_file"
        rm -f "$log_file"
        return 1
    fi
    
    # Try to find actual extracted directory (handle different naming patterns)
    local actual_src_dir=""
    if [ -d "$src_dir" ]; then
        actual_src_dir="$src_dir"
    elif [ -d "${package_name}-${src_dir}" ]; then
        actual_src_dir="${package_name}-${src_dir}"
    elif [ -d "${src_dir}-${package_name}" ]; then
        actual_src_dir="${src_dir}-${package_name}"
    else
        actual_src_dir=$(find . -maxdepth 1 -type d -name "*${src_dir}*" | head -1)
    fi
    
    if [ -z "$actual_src_dir" ] || [ ! -d "$actual_src_dir" ]; then
        echo "  ✗ Failed to find source directory for $package_name"
        find . -maxdepth 1 -type d -name "*${src_dir}*" -exec rm -rf {} \; 2>/dev/null || true
        rm -f "$log_file"
        return 1
    fi
    
    cd "$actual_src_dir" || { echo "  ✗ Failed to enter $actual_src_dir"; rm -f "$log_file"; return 1; }
    
    # Run autogen if needed (silent)
    if [ "$need_autogen" = "true" ]; then
        if [ -f "./autogen.sh" ]; then
            if ! ./autogen.sh > "$log_file" 2>&1; then
                echo "  ✗ autogen.sh failed"
                echo "    Error:"
                cat "$log_file"
                cd ..
                rm -f "$log_file"
                return 1
            fi
        elif [ -f "./configure.ac" ]; then
            if ! autoreconf -i > "$log_file" 2>&1; then
                echo "  ✗ autoreconf failed"
                echo "    Error:"
                cat "$log_file"
                cd ..
                rm -f "$log_file"
                return 1
            fi
        fi
    fi
    
    # Configure (silent)
    if ! ./configure $configure_args --prefix="$install_dir" > "$log_file" 2>&1; then
        echo "  ✗ configure failed"
        echo "    Error:"
        cat "$log_file"
        cd ..
        rm -f "$log_file"
        return 1
    fi
    
    # Make (silent)
    if ! make -j$(nproc) > "$log_file" 2>&1; then
        echo "  ✗ make failed"
        echo "    Error:"
        cat "$log_file"
        cd ..
        rm -f "$log_file"
        return 1
    fi
    
    # Install (silent)
    if ! make install > "$log_file" 2>&1; then
        echo "  ✗ make install failed"
        echo "    Error:"
        cat "$log_file"
        cd ..
        rm -f "$log_file"
        return 1
    fi
    
    # Cleanup
    cd ..
    rm -rf "$actual_src_dir"
    rm -f "$log_file"
    
    # Update PATH globally
    export PATH="$PATH:$install_dir/bin"
    
    # Verify installation
    if [ -x "$install_dir/bin/$package_name" ]; then
        echo "  ✓ $package_name compiled and installed successfully"
        return 0
    else
        echo "  ✗ $package_name compilation failed"
        return 1
    fi
}

# Copy runtime dependency libraries to lib/ directory for distribution
# Called after compiling packages that depend on system libraries
# that may not be present on all target machines
# Arguments:
#   $1: library pattern (e.g. "libmnl.so.*" or "libaio.so.*")
copy_dependency_libs() {
    local lib_pattern="$1"
    local install_dir="$BASE_DIR"
    local lib_dir="$install_dir/lib"
    local arch=$(uname -m)
    
    mkdir -p "$lib_dir"
    
    # Auto-detect library search paths based on architecture
    local search_dirs=(
        "/lib/${arch}-linux-gnu"
        "/lib64"
        "/usr/lib/${arch}-linux-gnu"
        "/usr/lib64"
        "/lib"
        "/usr/lib"
    )
    
    # Find the library file in system paths
    local lib_path=""
    local search_dir=""
    for search_dir in "${search_dirs[@]}"; do
        lib_path=$(ls "$search_dir"/$lib_pattern 2>/dev/null | head -1)
        if [ -n "$lib_path" ]; then
            break
        fi
    done
    
    if [ -z "$lib_path" ]; then
        echo "    Library $lib_pattern not found, skipping copy"
        return 0
    fi
    
    local lib_real_name=$(readlink -f "$lib_path" 2>/dev/null || echo "$(basename "$lib_path")")
    local lib_real_base=$(basename "$lib_real_name")
    local lib_copied_as=""
    
    # Skip if already copied
    if [ -f "$lib_dir/$lib_real_base" ] || [ -L "$lib_dir/$lib_real_base" ]; then
        echo "  ✓ $lib_real_base already in lib/ directory"
        lib_copied_as="$lib_real_base"
    else
        # Copy the real file with its actual name (not the symlink name)
        if [ -f "$lib_real_name" ]; then
            cp "$lib_real_name" "$lib_dir/" 2>/dev/null || true
            lib_copied_as="$lib_real_base"
        else
            # If can't get real name, just copy as is
            cp -L "$lib_path" "$lib_dir/" 2>/dev/null || true
            lib_copied_as=$(basename "$lib_path")
        fi
    fi
    
    # Copy all symlinks pointing to this library family
    local lib_base_name="${lib_real_base%%.*}"
    for candidate in $(ls "$search_dir"/${lib_base_name}.so.* 2>/dev/null); do
        local cname=$(basename "$candidate")
        if [ -L "$candidate" ]; then
            ln -sf "$lib_copied_as" "$lib_dir/$cname" 2>/dev/null || true
        fi
    done
    
    # Also create a libaio.so symlink for linking
    local short_name="${lib_base_name}.so"
    if [ ! -L "$lib_dir/$short_name" ] && [ ! -f "$lib_dir/$short_name" ]; then
        ln -sf "$lib_copied_as" "$lib_dir/$short_name" 2>/dev/null || true
    fi
    
    if [ -z "$lib_copied_as" ]; then
        lib_copied_as=$(basename "$lib_path")
    fi
    
    echo "  ✓ Copied $lib_copied_as to lib/ directory"
}

# Check if sudo is available (passwordless)
check_sudo_available() {
    if [ "$(whoami)" = "root" ]; then
        return 0
    fi
    sudo -n true 2>/dev/null
    return $?
}

# Check build dependencies
# Returns:
#   0: all dependencies are present
#   1: missing dependencies
check_build_dependencies() {
    local missing=()
    local is_ubuntu=0
    
    echo "  Checking build dependencies..."
    
    if command -v apt-get &> /dev/null; then
        is_ubuntu=1
    fi
    
    # Check common dependencies
    local dependencies=("automake" "autoconf" "libtool" "gcc" "make")
    for dep in "${dependencies[@]}"; do
        if ! command -v "$dep" &> /dev/null; then
            missing+=("$dep")
        fi
    done

    # Check libaio library (for fio libaio engine) using pkg-config or header check
    if ! pkg-config --exists libaio && [ ! -f /usr/include/libaio.h ]; then
        if [ $is_ubuntu -eq 1 ]; then
            missing+=("libaio-dev")
        else
            missing+=("libaio-devel")
        fi
    fi
    
    if [ ${#missing[@]} -gt 0 ]; then
        echo "  ✗ Error: Missing build dependencies: ${missing[*]}"
        echo "    Please install dependencies manually:"
        if command -v yum &> /dev/null; then
            echo "      sudo yum install -y automake autoconf libtool gcc make libaio-devel"
        elif command -v apt-get &> /dev/null; then
            echo "      sudo apt-get install -y automake autoconf libtool libtool-bin gcc make libaio-dev"
        else
            echo "      - CentOS/RHEL: sudo yum install -y automake autoconf libtool gcc make libaio-devel"
            echo "      - Ubuntu/Debian: sudo apt-get install -y automake autoconf libtool libtool-bin gcc make libaio-dev"
        fi
        return 1
    fi
    
    echo "  ✓ All build dependencies are present"
    return 0
}

