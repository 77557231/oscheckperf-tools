# Cleanup residual processes on all servers
# Parameter: $1 - if "network_only", only cleanup iperf3; otherwise cleanup all (fio, iperf3, sysbench, oscheckperf)
cleanup_residual_processes() {
    local mode="${1:-full}"
    echo "  Checking and cleaning up residual processes (fio, iperf3, sysbench)..."
    
    local local_ip=$(get_machine_ip)
    local port="$NETWORK_PORT"
    local total_cleaned=0
    local server_count=0
    local current_user=$(whoami)
    
    # Define process patterns to check (using exact patterns to avoid false positives)
    # iperf3: server mode (all ports, not just specific port)
    # fio: running fio tests (not just any fio process)
    # sysbench: running sysbench tests (not just any sysbench process)
    # oscheckperf: main benchmark script (for cleanup after Ctrl+C)
    local iperf3_pattern="iperf3 -s"
    local fio_pattern="fio.*--name="
    local sysbench_pattern="sysbench.*fileio"
    local oscheckperf_pattern="oscheckperf"
    
    # Function to cleanup processes on a specific host
    cleanup_host_processes() {
        local host="$1"
        local is_remote="$2"
        local host_cleaned=0
        local cleanup_details=""
        local current_user_local="$current_user"
        
        # Determine command prefix for remote execution
        local cmd_prefix=""
        if [ "$is_remote" = "true" ]; then
            local ssh_cmd=$(get_ssh_command "$host")
            cmd_prefix="timeout --signal=KILL 10 $ssh_cmd"
            # Get remote username from SSH config or use current user
            current_user_local=$(eval "$cmd_prefix whoami" 2>/dev/null || echo "$current_user")
        fi
        
        # Helper function to get PIDs for current user only
        get_user_pids() {
            local pattern="$1"
            if [ "$is_remote" = "true" ]; then
                eval "$cmd_prefix pgrep -u '$current_user_local' -f '$pattern'" 2>/dev/null || true
            else
                pgrep -u "$current_user_local" -f "$pattern" 2>/dev/null || true
            fi
        }
        
        # Helper function to kill PIDs with timeout
        kill_pids() {
            local pids="$1"
            local process_desc="$2"
            local pid_count=$(echo "$pids" | wc -l)
            cleanup_details="${cleanup_details}    - $process_desc: $pid_count process(es)\n"
            if [ "$is_remote" = "true" ]; then
                eval "$cmd_prefix sh -c 'echo $pids | xargs kill -9 2>/dev/null || true'" 2>/dev/null
            else
                timeout --signal=KILL 5 sh -c "echo '$pids' | xargs kill -9 2>/dev/null || true" 2>/dev/null
            fi
            host_cleaned=$((host_cleaned + pid_count))
        }
        
        # Check and cleanup iperf3 server processes (current user only)
        local iperf3_pids=$(get_user_pids "$iperf3_pattern")
        iperf3_pids=$(echo "$iperf3_pids" | grep -E '^[0-9]+$' || true)
        if [ -n "$iperf3_pids" ]; then
            kill_pids "$iperf3_pids" "iperf3 server"
        fi
        
        # In network_only mode, only cleanup iperf3
        if [ "$mode" = "network_only" ]; then
            # Skip fio, sysbench, and oscheckperf cleanup
            :
        else
            # Check and cleanup fio test processes (current user only)
            local fio_pids=$(get_user_pids "$fio_pattern")
            fio_pids=$(echo "$fio_pids" | grep -E '^[0-9]+$' || true)
            if [ -n "$fio_pids" ]; then
                kill_pids "$fio_pids" "fio test"
            fi
            
            # Check and cleanup sysbench test processes (current user only)
            local sysbench_pids=$(get_user_pids "$sysbench_pattern")
            sysbench_pids=$(echo "$sysbench_pids" | grep -E '^[0-9]+$' || true)
            if [ -n "$sysbench_pids" ]; then
                kill_pids "$sysbench_pids" "sysbench test"
            fi
            
            # Check and cleanup oscheckperf processes (cleanup after Ctrl+C) - current user only
            local oscheckperf_pids=$(get_user_pids "$oscheckperf_pattern")
            # Exclude current process and all its children
            oscheckperf_pids=$(echo "$oscheckperf_pids" | grep -v $$ | grep -v -f <(pgrep -P $$ 2>/dev/null || true) | grep -E '^[0-9]+$' || true)
            if [ -n "$oscheckperf_pids" ]; then
                kill_pids "$oscheckperf_pids" "oscheckperf"
            fi
        fi
        
        # Print cleanup details if any processes were cleaned
        if [ $host_cleaned -gt 0 ]; then
            if [ "$is_remote" = "true" ]; then
                echo "  Cleaning up residual processes on $host:"
            else
                echo "  Cleaning up residual processes on local machine:"
            fi
            echo -e "$cleanup_details"
            total_cleaned=$((total_cleaned + host_cleaned))
            server_count=$((server_count + 1))
        fi
    }
    
    # Cleanup local machine
    cleanup_host_processes "localhost" "false"
    
    # Cleanup remote servers if configured
    if [ ${#target_servers[@]} -gt 0 ]; then
        for ip in "${target_servers[@]}"; do
            # Skip local machine
            if [ "$ip" = "$local_ip" ]; then
                continue
            fi
            
            # Cleanup remote host
            cleanup_host_processes "$ip" "true"
        done
    fi
    
    # Print summary
    if [ $total_cleaned -gt 0 ]; then
        echo "  ✓ Cleaned up $total_cleaned residual process(es) on $server_count server(s)"
    else
        echo "  ✓ No residual fio/iperf3/sysbench processes found"
    fi
}

# Parse CPU result
parse_cpu_result() {
    local result_file="$1"
    
    local events_per_sec=$(grep "events per second" "$result_file" 2>/dev/null | awk -F: '{print $2}' | tr -d ' ' || echo "0")
    local avg_latency=$(grep "avg:" "$result_file" 2>/dev/null | head -1 | awk '{print $NF}' | tr -d ',' || echo "0")
    local min_latency=$(grep -A5 "Latency (ms):" "$result_file" 2>/dev/null | grep "min:" | awk '{print $NF}' | tr -d ',' || echo "N/A")
    local p95_latency=$(grep "95th percentile" "$result_file" 2>/dev/null | awk '{print $NF}' | head -1 | tr -d ',' || echo "0")
    local p99_latency=$(grep "99th percentile" "$result_file" 2>/dev/null | awk '{print $NF}' | head -1 | tr -d ',' || echo "0")
    local max_latency=$(grep -A5 "Latency (ms):" "$result_file" 2>/dev/null | grep "max:" | awk '{print $NF}' | tr -d ',' || echo "N/A")
    
    # Calculate Sum Latency: events_per_sec * duration * avg_latency (approximation)
    local cpu_duration="$DURATION"
    local sum_latency="N/A"
    if [ -n "$events_per_sec" ] && [ "$events_per_sec" != "0" ] && [ -n "$avg_latency" ] && [ "$avg_latency" != "0" ]; then
        sum_latency=$(awk -v eps="$events_per_sec" -v dur="$cpu_duration" -v avg="$avg_latency" 'BEGIN {printf "%.2f", eps * dur * avg}')
    fi
    
    # Extract Threads fairness metrics
    local threads_fairness_events=$(grep -A2 "Threads fairness:" "$result_file" 2>/dev/null | grep "events" | head -1)
    local threads_fairness_time=$(grep -A2 "Threads fairness:" "$result_file" 2>/dev/null | grep "execution time" | head -1)
    
    # Display detailed summary
    echo ""
    echo "CPU test summary:"
    echo "  CPU speed:"
    echo "    events per second: $events_per_sec"
    echo "  Avg Latency: ${avg_latency}ms"
    if [ -n "$min_latency" ] && [ "$min_latency" != "N/A" ]; then
        echo "  Min Latency: ${min_latency}ms"
    fi
    echo "  P95 Latency: ${p95_latency}ms"
    if [ -n "$p99_latency" ] && [ "$p99_latency" != "0" ]; then
        echo "  P99 Latency: ${p99_latency}ms"
    fi
    if [ -n "$max_latency" ] && [ "$max_latency" != "N/A" ]; then
        echo "  Max Latency: ${max_latency}ms"
    fi
    if [ -n "$sum_latency" ] && [ "$sum_latency" != "N/A" ]; then
        echo "  Sum Latency: ${sum_latency}ms"
    fi
    echo "  Threads fairness:"
    if [ -n "$threads_fairness_events" ]; then
        echo "    $threads_fairness_events"
    fi
    if [ -n "$threads_fairness_time" ]; then
        echo "    $threads_fairness_time"
    fi
}

# Parse memory result
parse_memory_result() {
    local result_file="$1"
    
    # Extract Total operations and operations per second
    local total_ops_line=$(grep "Total operations:" "$result_file" 2>/dev/null)
    local total_ops=$(echo "$total_ops_line" | awk '{print $3}' || echo "0")
    local ops_per_sec=$(echo "$total_ops_line" | awk -F'[()]' '{print $2}' | awk '{print $1}' || echo "0")
    
    # Extract transferred data and MiB/sec
    local transferred_line=$(grep "MiB transferred" "$result_file" 2>/dev/null)
    local transferred=$(echo "$transferred_line" | awk '{print $1}' || echo "0")
    local mib_per_sec=$(echo "$transferred_line" | awk -F'[()]' '{print $2}' | awk '{print $1}' || echo "0")
    
    local avg_latency=$(grep "avg:" "$result_file" 2>/dev/null | head -1 | awk '{print $NF}' | tr -d ',' || echo "0")
    local min_latency=$(grep -A5 "Latency (ms):" "$result_file" 2>/dev/null | grep "min:" | awk '{print $NF}' | tr -d ',' || echo "N/A")
    local max_latency=$(grep -A5 "Latency (ms):" "$result_file" 2>/dev/null | grep "max:" | awk '{print $NF}' | tr -d ',' || echo "N/A")
    
    # Extract p95 latency
    local p95_latency=$(grep "95th percentile" "$result_file" 2>/dev/null | awk '{print $NF}' | head -1 | tr -d ',' || echo "0")
    
    # Calculate Sum Latency: total_ops * avg_latency
    local sum_latency=$(echo "$total_ops" "$avg_latency" 2>/dev/null | awk '{if($2>0) printf "%.2f", $1 * $2; else print "N/A"}')
    
    # Display detailed summary
    echo ""
    echo "Memory test summary:"
    echo "  Total operations: ${total_ops} (${ops_per_sec} per second)"
    echo "  Transferred: ${transferred} MiB (${mib_per_sec} MiB/sec)"
    echo "  Avg Latency: ${avg_latency}ms"
    if [ -n "$min_latency" ] && [ "$min_latency" != "N/A" ]; then
        echo "  Min Latency: ${min_latency}ms"
    fi
    if [ -n "$max_latency" ] && [ "$max_latency" != "N/A" ]; then
        echo "  Max Latency: ${max_latency}ms"
    fi
    echo "  P95 Latency: ${p95_latency:-0}ms"
    if [ -n "$sum_latency" ] && [ "$sum_latency" != "N/A" ]; then
        echo "  Sum Latency: ${sum_latency}ms"
    fi
}

# Append result to original data file (raw sysbench output for traceability)
append_to_original() {
    local section_title="$1"
    local result_file="$2"
    local original_file="$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
    
    # Get local machine IP
    local local_ip=$(get_machine_ip)
    
    # Append execution command to the beginning of the file if it's the first write
    if [ ! -f "$original_file" ] || [ ! -s "$original_file" ]; then
        echo "Execution Command: $EXECUTION_COMMAND" >> "$original_file"
        echo "" >> "$original_file"
    fi
    
    # Append to original data file for traceability (only raw test output)
    echo "" >> "$original_file"
    echo "================================================================================" >> "$original_file"
    echo "$section_title (Server: $local_ip) (ORIGINAL OUTPUT)" >> "$original_file"
    echo "================================================================================" >> "$original_file"
    if [ -f "$result_file" ]; then
        # For sysbench and fio tests, extract only the raw test output
        if echo "$section_title" | grep -E "CPU|MEMORY|IO|THREADS|MUTEX|FIO" > /dev/null; then
            # For both local and remote tests, just append the whole file to original data
            # This ensures we capture all raw sysbench/fio output
            cat "$result_file" >> "$original_file"
        # For network tests
        elif echo "$section_title" | grep -E "NETWORK" > /dev/null; then
            # Extract network test raw output
            cat "$result_file" >> "$original_file"
        else
            # For other tests, just append the whole file
            cat "$result_file" >> "$original_file"
        fi
    fi
    echo "" >> "$original_file"
}

