# Get CPU instruction set features
get_cpu_features() {
    if [ -f /proc/cpuinfo ]; then
        grep -m 1 'flags' /proc/cpuinfo 2>/dev/null | sed 's/flags.*: //' || echo "N/A"
    else
        echo "N/A"
    fi
