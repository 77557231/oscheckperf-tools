install_jq() {
    local install_dir="$HOME/oscheckperf"
    
    if [ -d "$install_dir/bin" ] && [ -x "$install_dir/bin/jq" ]; then
        echo "  ✓ jq already installed at $install_dir"
        export PATH="$PATH:$install_dir/bin"
        return 0
    fi
    
    echo "[Step 1/2] Compiling jq..."
    
    echo "  Checking build dependencies..."
    if ! command -v gcc &> /dev/null || ! command -v make &> /dev/null || ! command -v automake &> /dev/null || ! command -v autoconf &> /dev/null || ! command -v libtool &> /dev/null; then
        install_build_dependencies "automake autoconf libtool gcc make" "automake autoconf libtool gcc make" "jq"
    else
        echo "  Build dependencies already installed"
    fi
    
    compile_package "jq" "tools/jq-1.8.1.tar.gz" "jq-1.8.1" "--with-oniguruma=builtin" "false"
    local compile_result=$?
    
    if ! grep -q "oscheckperf/bin" ~/.bashrc; then
        run_command "echo 'export PATH=\$PATH:$install_dir/bin' >> ~/.bashrc" "/dev/null"
    fi
    
    if command -v jq &> /dev/null; then
        echo "  ✓ jq version: $(jq --version)"
    fi
    
    return $compile_result
}

# Copy oscheckperf script to install directory
install_oscheckperf_script() {
    local install_dir="$HOME/oscheckperf"
    local benchmark_dir=$(realpath "$(dirname "$0")")
    
    mkdir -p "$install_dir"
    
    if [ -f "$benchmark_dir/oscheckperf" ]; then
        cp "$benchmark_dir/oscheckperf" "$install_dir/"
        chmod +x "$install_dir/oscheckperf"
        echo "  ✓ Copied oscheckperf script to $install_dir/"
        return 0
    else
        echo "  ✗ oscheckperf script not found"
        return 1
    fi
}

# Main installation function
install_components() {
    local target="$1"
    local local_ip=$(get_machine_ip)
    local install_dir="$HOME/oscheckperf"
    local error_count=0
    
    echo "=== Oscheckperf Installation and Distribution ==="
    
    # Determine what to install
    local install_sysbench=false
    local install_sshpass=false
    local install_fio=false
    local install_iperf3=false
    local install_numactl=false
    local install_ethtool=false
    local install_jq=false
    local install_script=false
    
    case "$target" in
        sysbench)
            install_sysbench=true
            ;;
        sshpass)
            install_sshpass=true
            ;;
        fio)
            install_fio=true
            ;;
        iperf3)
            install_iperf3=true
            ;;
        numactl)
            install_numactl=true
            ;;
        ethtool)
            install_ethtool=true
            ;;
        jq)
            install_jq=true
            ;;
        oscheckperf)
            install_script=true
            ;;
        all)
            install_sysbench=true
            install_sshpass=true
            install_fio=true
            install_iperf3=true
            install_numactl=true
            install_ethtool=true
            install_jq=true
            install_script=true
            ;;
        *)
            echo "Error: Invalid installation target '$target'"
            echo "Valid targets: sysbench, sshpass, fio, iperf3, numactl, ethtool, jq, oscheckperf, all"
            exit 1
            ;;
    esac
    
    # Local installation
    if [ "$install_sysbench" = "true" ]; then
        install_sysbench || error_count=$((error_count + 1))
    fi
    
    if [ "$install_sshpass" = "true" ]; then
        install_sshpass || error_count=$((error_count + 1))
    fi
    
    if [ "$install_fio" = "true" ]; then
        install_fio || error_count=$((error_count + 1))
    fi
    
    if [ "$install_iperf3" = "true" ]; then
        install_iperf3 || error_count=$((error_count + 1))
    fi
    
    if [ "$install_numactl" = "true" ]; then
        install_numactl || error_count=$((error_count + 1))
    fi
    
    if [ "$install_ethtool" = "true" ]; then
        install_ethtool || error_count=$((error_count + 1))
    fi
    
    if [ "$install_jq" = "true" ]; then
        install_jq || error_count=$((error_count + 1))
    fi
    
    if [ "$install_script" = "true" ]; then
        install_oscheckperf_script || error_count=$((error_count + 1))
    fi
    
    export INSTALL_ERROR_COUNT=$error_count
    
    # Distribute to remote servers
    if [ ${#target_servers[@]} -gt 0 ]; then
        echo "[Step 2/2] Distributing to target servers..."
        echo "  Server list: ${target_servers[*]}"
        
        # Arrays to track skipped servers
        local -a skipped_arch=()
        local -a skipped_os=()
        local -a skipped_distro=()
        local -a failed=()
        
        for ip in "${target_servers[@]}"; do
            distribute_to_server "$ip" "$local_ip" "$target"
            local ret=$?
            case $ret in
                2)
                    skipped_arch+=("$ip")
                    ;;
                3)
                    skipped_os+=("$ip")
                    ;;
                4)
                    skipped_distro+=("$ip")
                    ;;
                1)
                    failed+=("$ip")
                    ;;
            esac
        done
        
        # Display skipped servers summary
        if [ ${#skipped_arch[@]} -gt 0 ] || [ ${#skipped_os[@]} -gt 0 ] || [ ${#skipped_distro[@]} -gt 0 ] || [ ${#failed[@]} -gt 0 ]; then
            echo ""
            echo "=== Skipped/Failed Servers ==="
            if [ ${#skipped_arch[@]} -gt 0 ]; then
                echo "  Architecture mismatch (skipped):"
                for ip in "${skipped_arch[@]}"; do
                    echo "    - $ip"
                done
            fi
            if [ ${#skipped_os[@]} -gt 0 ]; then
                echo "  OS mismatch (skipped):"
                for ip in "${skipped_os[@]}"; do
                    echo "    - $ip"
                done
            fi
            if [ ${#skipped_distro[@]} -gt 0 ]; then
                echo "  Distribution mismatch (requires remote compilation):"
                for ip in "${skipped_distro[@]}"; do
                    echo "    - $ip"
                done
                echo "  Note: Servers with distribution mismatch will need manual remote compilation"
            fi
            if [ ${#failed[@]} -gt 0 ]; then
                echo "  Distribution failed:"
                for ip in "${failed[@]}"; do
                    echo "    - $ip"
                done
            fi
        fi
    fi
    
    echo ""
    echo "=== Distribution Summary ==="
    echo "  Installation directory: $install_dir"
    if [ "$install_sysbench" = "true" ] && command -v sysbench &> /dev/null; then
        echo "  - sysbench: installed ($(sysbench --version))"
    fi
    if [ "$install_sshpass" = "true" ] && command -v sshpass &> /dev/null; then
        echo "  - sshpass: installed ($(sshpass -V 2>&1 | head -1))"
    fi
    if [ "$install_fio" = "true" ] && command -v fio &> /dev/null; then
        echo "  - fio: installed ($(fio --version | head -1))"
    fi
    if [ "$install_iperf3" = "true" ] && command -v iperf3 &> /dev/null; then
        echo "  - iperf3: installed ($(iperf3 --version | head -1))"
    fi
    if [ "$install_numactl" = "true" ] && command -v numactl &> /dev/null; then
        echo "  - numactl: installed ($(numactl --version 2>&1 | head -1))"
    fi
    if [ "$install_ethtool" = "true" ] && command -v ethtool &> /dev/null; then
        echo "  - ethtool: installed ($(ethtool --version 2>&1 | head -1))"
    fi
    if [ "$install_jq" = "true" ] && command -v jq &> /dev/null; then
        echo "  - jq: installed ($(jq --version))"
    fi
    if [ "$install_script" = "true" ]; then
        echo "  - oscheckperf: installed"
    fi
}

