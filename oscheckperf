                        elif [[ "$line" =~ "95th percentile" ]]; then
                            current_threads_p95_lat=$(echo "$line" | awk '{print $NF}')
                        fi
                    fi
                done < "$combined_file"
                
                if [ "$in_threads_section" = true ] && [ -n "$current_server_ip" ]; then
                    if [ -n "$current_events" ] && [ -n "$current_time" ]; then
                        current_eps=$(awk "BEGIN {printf \"%.2f\", $current_events / $current_time}")
                    fi
                    printf "  %-20s %-15s %-15s %-15s\n" "$current_server_ip" "${current_eps:-N/A}" "${current_threads_avg_lat:-N/A}" "${current_threads_p95_lat:-N/A}" >> "$report_file"
                fi
            else
                # Single server - show results directly
                local threads_events=$(grep -A30 "THREADS TEST RESULTS" "$combined_file" 2>/dev/null | grep "total number of events:" | awk '{print $NF}')
                local threads_time=$(grep -A30 "THREADS TEST RESULTS" "$combined_file" 2>/dev/null | grep "total time:" | awk '{print $NF}' | tr -d 's')
                local threads_avg_lat=$(grep -A30 "THREADS TEST RESULTS" "$combined_file" 2>/dev/null | grep -A5 "Latency (ms):" | grep "avg:" | awk '{print $NF}')
                local threads_p95_lat=$(grep -A30 "THREADS TEST RESULTS" "$combined_file" 2>/dev/null | grep "95th percentile" | awk '{print $NF}')

                if [ -n "$threads_events" ]; then
                    local threads_eps=$(awk "BEGIN {printf \"%.2f\", $threads_events / ${threads_time:-1}}")

                    cat >> "$report_file" << EOF
  Events/sec:     ${threads_eps}
  Avg Latency:    ${threads_avg_lat:-0} ms
  P95 Latency:    ${threads_p95_lat:-0} ms
EOF
                else
                    echo "  Test not executed" >> "$report_file"
                fi
            fi
        else
            echo "  Test not executed" >> "$report_file"
        fi
    else
        echo "  Test not executed" >> "$report_file"
    fi

    cat >> "$report_file" << EOF

[Mutex Test]
EOF

    if [ -f "$combined_file" ]; then
        # Check if Mutex test results exist (both local and remote formats)
        if grep -q "Mutex test summary:\|MUTEX TEST RESULTS" "$combined_file" 2>/dev/null; then
            # Count Mutex test sections (one per server)
            local mutex_section_count=$(($(grep -c "Mutex test summary:" "$combined_file" 2>/dev/null) + $(grep -c "MUTEX TEST RESULTS" "$combined_file" 2>/dev/null)))
            
            if [ "$mutex_section_count" -gt 1 ]; then
                # Multiple servers - show comparison table
                echo "  Mutex Test Comparison (Multiple Servers)" >> "$report_file"
                echo "  =========================================" >> "$report_file"
                printf "  %-20s %-15s %-15s %-15s\n" "Server IP" "Transactions" "TPS" "Avg Latency (ms)" >> "$report_file"
                echo "  -----------------------------------------" >> "$report_file"
                
                local server_idx=0
                local in_mutex_section=false
                local current_server_ip=""
                local current_events=""
                local current_time=""
                local current_tps=""
                local current_mutex_avg_lat=""
                local last_testing_ip=""
                
                while IFS= read -r line; do
                    if [[ "$line" =~ "Testing server" ]]; then
                        last_testing_ip=$(echo "$line" | grep -oP 'Testing server [0-9]+/[0-9]+: \K[0-9.]+' || echo "")
                        if [ "$in_mutex_section" = true ] && [ -n "$current_server_ip" ]; then
                            if [ -n "$current_events" ] && [ -n "$current_time" ] && [ "$current_time" != "0" ]; then
                                current_tps=$(awk "BEGIN {printf \"%.2f\", $current_events / $current_time}" 2>/dev/null || echo "N/A")
                            else
                                current_tps="N/A"
                            fi
                            printf "  %-20s %-15s %-15s %-15s\n" "$current_server_ip" "${current_events:-N/A}" "${current_tps:-N/A}" "${current_mutex_avg_lat:-N/A}" >> "$report_file"
                        fi
                        in_mutex_section=false
                        current_server_ip=""
                    elif [[ "$line" =~ "MUTEX TEST RESULTS" ]]; then
                        if [ "$in_mutex_section" = true ] && [ -n "$current_server_ip" ]; then
                            if [ -n "$current_events" ] && [ -n "$current_time" ] && [ "$current_time" != "0" ]; then
                                current_tps=$(awk "BEGIN {printf \"%.2f\", $current_events / $current_time}" 2>/dev/null || echo "N/A")
                            else
                                current_tps="N/A"
                            fi
                            printf "  %-20s %-15s %-15s %-15s\n" "$current_server_ip" "${current_events:-N/A}" "${current_tps:-N/A}" "${current_mutex_avg_lat:-N/A}" >> "$report_file"
                        fi
                        in_mutex_section=true
                        current_server_ip=$(echo "$line" | grep -oP 'Server: \K[0-9.]+' || echo "N/A")
                        server_idx=$((server_idx + 1))
                        current_events=""
                        current_time=""
                        current_tps=""
                        current_mutex_avg_lat=""
                    elif [[ "$line" =~ "Mutex test summary:" ]]; then
                        in_mutex_section=true
                        current_server_ip="${last_testing_ip:-N/A}"
                        current_events=""
                        current_time=""
                        current_tps=""
                        current_mutex_avg_lat=""
                    elif [ "$in_mutex_section" = true ] && [[ "$line" =~ "TEST RESULTS" ]] && [[ ! "$line" =~ "MUTEX TEST RESULTS" ]] && [[ ! "$line" =~ "Mutex test summary:" ]]; then
                        if [ -n "$current_server_ip" ]; then
                            if [ -n "$current_events" ] && [ -n "$current_time" ] && [ "$current_time" != "0" ]; then
                                current_tps=$(awk "BEGIN {printf \"%.2f\", $current_events / $current_time}" 2>/dev/null || echo "N/A")
                            else
                                current_tps="N/A"
                            fi
                            printf "  %-20s %-15s %-15s %-15s\n" "$current_server_ip" "${current_events:-N/A}" "${current_tps:-N/A}" "${current_mutex_avg_lat:-N/A}" >> "$report_file"
                        fi
                        in_mutex_section=false
                        current_server_ip=""
                    elif [ "$in_mutex_section" = true ]; then
                        if [[ "$line" =~ "total number of events:" ]]; then
                            current_events=$(echo "$line" | awk '{print $NF}')
                        elif [[ "$line" =~ "total time:" ]]; then
                            current_time=$(echo "$line" | awk '{print $NF}' | tr -d 's')
                        elif [[ "$line" =~ "avg:" ]]; then
                            current_mutex_avg_lat=$(echo "$line" | awk '{print $NF}' | tr -d ',')
                        fi
                    fi
                done < "$combined_file"
                
                if [ "$in_mutex_section" = true ] && [ -n "$current_server_ip" ]; then
                    if [ -n "$current_events" ] && [ -n "$current_time" ]; then
                        current_tps=$(awk "BEGIN {printf \"%.2f\", $current_events / $current_time}")
                    fi
                    printf "  %-20s %-15s %-15s %-15s\n" "$current_server_ip" "${current_events:-N/A}" "${current_tps:-N/A}" "${current_mutex_avg_lat:-N/A}" >> "$report_file"
                fi
            else
                # Single server - show results directly
                local mutex_events=$(grep -A30 "MUTEX TEST RESULTS" "$combined_file" 2>/dev/null | grep "total number of events:" | awk '{print $NF}')
                local mutex_time=$(grep -A30 "MUTEX TEST RESULTS" "$combined_file" 2>/dev/null | grep "total time:" | awk '{print $NF}' | tr -d 's')
                local mutex_avg_lat=$(grep -A30 "MUTEX TEST RESULTS" "$combined_file" 2>/dev/null | grep -A5 "Latency (ms):" | grep "avg:" | awk '{print $NF}')
                local mutex_p95_lat=$(grep -A30 "MUTEX TEST RESULTS" "$combined_file" 2>/dev/null | grep "95th percentile" | awk '{print $NF}')

                if [ -n "$mutex_events" ]; then
                    local mutex_tps=$(awk "BEGIN {printf \"%.2f\", $mutex_events / ${mutex_time:-1}}")

                    cat >> "$report_file" << EOF
  Transactions:   ${mutex_events}
  TPS:            ${mutex_tps}
  Avg Latency:    ${mutex_avg_lat:-0} ms
  P95 Latency:    ${mutex_p95_lat:-0} ms
EOF
                else
                    echo "  Test not executed" >> "$report_file"
                fi
            fi
        else
            echo "  Test not executed" >> "$report_file"
        fi
    else
        echo "  Test not executed" >> "$report_file"
    fi

    cat >> "$report_file" << EOF

[Network Test]
EOF

    if [ -f "$combined_file" ]; then
        # Check if network test results exist
        if grep -q "NETWORK TEST RESULTS" "$combined_file" 2>/dev/null || grep -q "NETWORK MATRIX TEST RESULTS" "$combined_file" 2>/dev/null || grep -q "NETWORK PARALLEL TEST RESULTS" "$combined_file" 2>/dev/null; then
            # Extract all network test results
            local found_results=false

            # Get the output directory from the combined file path
            local output_dir=$(dirname "$combined_file")

            # Check for different types of network test files from current test only
            local network_files=()
            # Only read network test files that match the current timestamp pattern
            if ls "$TMP_DIR"/network_scenario_*_${TIMESTAMP}.json 1>/dev/null 2>&1; then
                network_files=($(ls "$TMP_DIR"/network_scenario_*_${TIMESTAMP}.json))
            fi
            # Also check for matrix and parallel test files from current test
            if ls "$TMP_DIR"/network_matrix_*_${TIMESTAMP}.json 1>/dev/null 2>&1; then
                network_files+=($(ls "$TMP_DIR"/network_matrix_*_${TIMESTAMP}.json))
            fi
            if ls "$TMP_DIR"/network_parallel_*_${TIMESTAMP}.json 1>/dev/null 2>&1; then
                network_files+=($(ls "$TMP_DIR"/network_parallel_*_${TIMESTAMP}.json))
            fi

            if [ ${#network_files[@]} -gt 0 ]; then
                # Multiple network tests - show comparison table
                echo "  Network Test Comparison (Multiple Servers)" >> "$report_file"
                echo "  ===============================================================" >> "$report_file"
                printf "  %-20s %-20s %-15s %-10s %-10s %-10s\n" "Client IP" "Server IP" "Bandwidth (MB/s)" "Protocol" "Duration" "Parallel" >> "$report_file"
                echo "  ---------------------------------------------------------------" >> "$report_file"
                
                # Process each network test file
                for json_file in "${network_files[@]}"; do
                    local net_bw="0"
                    local client_ip="N/A"
                    local server_ip="N/A"
                    local protocol="N/A"
                    local duration="N/A"
                    local parallel="N/A"

                    if [ -f "$json_file" ]; then
                        # Check if jq is installed
                        if command -v jq &> /dev/null; then
                            # Extract JSON content by removing any leading non-JSON text
                            local json_content=$(awk 'BEGIN{found=0} /^\{/{found=1} found{print} /^\}/{if(found) exit}' "$json_file" 2>/dev/null || cat "$json_file")
                            
                            # Extract bandwidth from JSON content
                            local bandwidth_bps=$(echo "$json_content" | jq -r '.end.sum_received.bits_per_second // 0' 2>/dev/null)
                            # Convert bps to MB/s: 1 MB/s = 8,000,000 bps
                            net_bw=$(awk "BEGIN {printf \"%.2f\", $bandwidth_bps / 8000000}" 2>/dev/null || echo "0")
                            
                            # Extract client and server IPs from the JSON content
                            client_ip=$(echo "$json_content" | jq -r '.start.connected[0].local_host // "N/A"' 2>/dev/null)
                            server_ip=$(echo "$json_content" | jq -r '.start.connected[0].remote_host // "N/A"' 2>/dev/null)
                            
                            # Extract additional metrics
                            protocol=$(echo "$json_content" | jq -r '.start.test_start.protocol // "N/A"' 2>/dev/null)
                            local raw_duration=$(echo "$json_content" | jq -r '.end.sum_received.seconds // "N/A"' 2>/dev/null)
                            # Round duration to integer for cleaner display
                            if [ "$raw_duration" != "N/A" ] && [ "$raw_duration" != "null" ]; then
                                duration=$(awk "BEGIN {printf \"%.0f\", $raw_duration}" 2>/dev/null || echo "$raw_duration")
                            else
                                duration="N/A"
                            fi
                            parallel=$(echo "$json_content" | jq -r '.start.test_start.num_streams // "N/A"' 2>/dev/null)
                            
                            if [ -z "$client_ip" ] || [ "$client_ip" = "null" ] || [ "$client_ip" = "N/A" ]; then
                                # Fallback: get client IP from filename
                                local file_name=$(basename "$json_file")
                                client_ip=$(echo "$file_name" | grep -oP 'network_\w+_\K[0-9]+' | head -1)
                                if [ -z "$client_ip" ]; then
                                    client_ip="Client"
                                else
                                    client_ip="Client $client_ip"
                                fi
                            fi
                        fi
                    fi
                    
                    # Display the result
                    if [ "$server_ip" != "N/A" ] && [ "$server_ip" != "null" ]; then
                        echo "  $client_ip -> $server_ip: ${net_bw} MB/s (Protocol: $protocol, Duration: ${duration}s, Parallel: $parallel)"
                        printf "  %-20s %-20s %-15s %-10s %-10s %-10s\n" "$client_ip" "$server_ip" "${net_bw}" "$protocol" "${duration}s" "$parallel" >> "$report_file"
                    else
                        echo "  $client_ip: ${net_bw} MB/s"
                        printf "  %-20s %-20s %-15s %-10s %-10s %-10s\n" "$client_ip" "N/A" "${net_bw}" "$protocol" "${duration}s" "$parallel" >> "$report_file"
                    fi
                    found_results=true
                done
            else
                # No JSON files found, check combined file directly
                echo "  Test executed but no detailed results available" >> "$report_file"
                found_results=true
            fi
            
            if [ "$found_results" = false ]; then
                echo "  Test not executed or no results found" >> "$report_file"
            fi
        else
            echo "  Test not executed" >> "$report_file"
        fi
    else
        echo "  Test not executed" >> "$report_file"
    fi
    
    # Add pgbench results if available
    cat >> "$report_file" << EOF

[pgbench Test]
EOF
    
    if [ -f "$combined_file" ]; then
        if grep -q "PGBENCH TEST RESULTS" "$combined_file" 2>/dev/null; then
            local pgbench_results=$(grep -A20 "PGBENCH TEST RESULTS" "$combined_file" 2>/dev/null)
            if [ -n "$pgbench_results" ]; then
                echo "$pgbench_results" >> "$report_file"
            else
                echo "  Test not executed" >> "$report_file"
            fi
        else
            echo "  Test not executed" >> "$report_file"
        fi
    else
        echo "  Test not executed" >> "$report_file"
    fi
    
    # Finalize report
    cat >> "$report_file" << EOF

================================================================================
                                End of Report
================================================================================
EOF
    

}

# Main function
main() {
    # Capture full execution command
    local full_command="$0"
    for arg in "$@"; do
        if [[ "$arg" == *" "* ]]; then
            full_command="$full_command \"$arg\""
        else
            full_command="$full_command $arg"
        fi
    done
    export EXECUTION_COMMAND="$full_command"
    
    # Debug output before parse_args
    debug_log "Before parse_args" \
        "CPU_ENABLED=$CPU_ENABLED" \
        "MEMORY_ENABLED=$MEMORY_ENABLED" \
        "IO_ENABLED=$IO_ENABLED" \
        "NETWORK_ENABLED=$NETWORK_ENABLED" \
        "THREADS_ENABLED=$THREADS_ENABLED" \
        "MUTEX_ENABLED=$MUTEX_ENABLED"
    
    # Parse command line arguments
    parse_args "$@"
    
    # Validate all parameters first before doing anything else
    # Skip validation here if it's a check command - validation will be done in check_all()
    if [ "$CHECK_ENABLED" != "true" ]; then
        validate_all_parameters
    fi
    
    # Debug output after parse_args
    debug_log "After parse_args" \
        "CPU_ENABLED=$CPU_ENABLED" \
        "MEMORY_ENABLED=$MEMORY_ENABLED" \
        "IO_ENABLED=$IO_ENABLED" \
        "NETWORK_ENABLED=$NETWORK_ENABLED" \
        "THREADS_ENABLED=$THREADS_ENABLED" \
        "MUTEX_ENABLED=$MUTEX_ENABLED"
    
    # Set default values
    OUTPUT_DIR="${OUTPUT_DIR:-$OUTPUT_DIR_DEFAULT}"
    FORMAT="${FORMAT:-txt}"
    CLEANUP="${CLEANUP:-true}"
    
    # Convert OUTPUT_DIR to absolute path to avoid issues when script changes directory
    case "$OUTPUT_DIR" in
        /*) ;;  # Already absolute path
        *) OUTPUT_DIR="$(cd "$(dirname "$OUTPUT_DIR")" && pwd)/$(basename "$OUTPUT_DIR")" ;;
    esac
    
    # Set timestamp
    if [ -z "$TIMESTAMP" ]; then
        TIMESTAMP=$(date '+%Y%m%d_%H%M%S')
    fi
    
    # Create all necessary directories
    mkdir -p "$OUTPUT_DIR"
    mkdir -p "$TMP_DIR"
    mkdir -p "$IO_PATH_DEFAULT"
    
    # Save subcommand enable flags
    local saved_cpu_enabled="$CPU_ENABLED"
    local saved_memory_enabled="$MEMORY_ENABLED"
    local saved_io_enabled="$IO_ENABLED"
    local saved_network_enabled="$NETWORK_ENABLED"
    local saved_threads_enabled="$THREADS_ENABLED"
    local saved_mutex_enabled="$MUTEX_ENABLED"
    local saved_pgbench_enabled="$PGBENCH_ENABLED"
    
    # Debug output after saving flags
    debug_log "Saved flags" \
        "saved_cpu_enabled=$saved_cpu_enabled" \
        "saved_memory_enabled=$saved_memory_enabled" \
        "saved_io_enabled=$saved_io_enabled" \
        "saved_network_enabled=$saved_network_enabled" \
        "saved_threads_enabled=$saved_threads_enabled" \
        "saved_mutex_enabled=$saved_mutex_enabled"
    

    
    # Restore subcommand enable flags
    export CPU_ENABLED="$saved_cpu_enabled"
    export MEMORY_ENABLED="$saved_memory_enabled"
    export IO_ENABLED="$saved_io_enabled"
    export NETWORK_ENABLED="$saved_network_enabled"
    export THREADS_ENABLED="$saved_threads_enabled"
    export MUTEX_ENABLED="$saved_mutex_enabled"
    export PGBENCH_ENABLED="$saved_pgbench_enabled"
    
    # Process command line arguments again to ensure they override config file values
    parse_args "$@"
    
    # Validate path parameters for security
    validate_all_paths
    
    # Process server list (supports file or direct IP list)
    target_servers=()
    local local_ip=$(get_machine_ip)
    local include_local=false
    if [ -n "$SERVERS_FILE" ]; then
        if [ -f "$SERVERS_FILE" ]; then
            # Read server IP list from file
            local servers=()
            mapfile -t servers < "$SERVERS_FILE"
            
            # Process each IP, remove whitespace and newlines
            local filtered_servers=()
            for ip in "${servers[@]}"; do
                ip=$(echo "$ip" | tr -d '\r' | xargs)
                if [ -n "$ip" ]; then
                    filtered_servers+=("$ip")
                    if [ "$ip" = "$local_ip" ]; then
                        include_local=true
                    fi
                fi
            done
            target_servers=(${filtered_servers[@]})
        else
            # Process SERVERS_FILE directly as IP list
            local ip_list=($SERVERS_FILE)
            local filtered_ips=()
            for ip in "${ip_list[@]}"; do
                ip=$(echo "$ip" | xargs)
                if [ -n "$ip" ]; then
                    filtered_ips+=("$ip")
                    if [ "$ip" = "$local_ip" ]; then
                        include_local=true
                    fi
                fi
            done
            target_servers=(${filtered_ips[@]})
        fi
        
        # Initialize tee logging BEFORE any output - all output goes to both terminal and data log file
        if [ "$REMOTE" != "true" ] && [ "$CHECK_ENABLED" != "true" ] && [ "$DRY_RUN" != true ]; then
            # Create OUTPUT_DIR if not exists
            mkdir -p "$OUTPUT_DIR"
            # Use exec tee to simultaneously output to terminal and log file
            exec > >(tee -a "$OUTPUT_DIR/data_${TIMESTAMP}_all_results.log") 2>&1
        fi
        
        if [ ${#target_servers[@]} -gt 0 ]; then
            # Local machine as iPerf3 server
            local server_ip=$(get_machine_ip)
            # All IPs as clients
            local client_ips=""
            for ip in "${target_servers[@]}"; do
                client_ips+="$ip "
            done
            client_ips=$(echo "$client_ips" | xargs)
            
            echo "Loading configuration from server list:"
            echo "  Server IP: $server_ip (local)"
            echo "  Client IPs: $client_ips"
            echo "  Local machine as iPerf3 server"
            
            # Set network test parameters
            export NETWORK_SERVER_IP="$server_ip"
            export NETWORK_CLIENT_IP="$client_ips"
        fi
    fi
    
    # Install and distribute sysbench if -i option is specified
    if [ "${SYSBENCH_INSTALL:-false}" = "true" ]; then
        install_and_distribute_sysbench
        echo ""
        echo "=== Sysbench installation completed successfully! ==="
        exit 0
    fi
    
    # Handle check subcommand
    if [ "$CHECK_ENABLED" = "true" ]; then
        # Skip headers if running in remote mode
        if [ "$REMOTE" != "true" ]; then
            # Run checks for all servers
            echo "Running system checks for all servers..."
            echo "====================================="
            echo ""
            
            if [ ${#target_servers[@]} -gt 0 ]; then
                # Check each target server
                local server_idx=0
                for target_ip in "${target_servers[@]}"; do
                    server_idx=$((server_idx + 1))
                    echo "Checking server $server_idx/$(( ${#target_servers[@]} )): $target_ip"
                    echo "----------------------------------"
                    
                    if [ "$target_ip" = "$local_ip" ]; then
                        # Local machine check
                        check_all
                    else
                        # Remote server check
                        echo "  Executing remote checks on $target_ip..."
                        ssh "$target_ip" "\$HOME/oscheckperf/oscheckperf --remote check"
                    fi
                    echo ""
                done
            else
                # Single machine check
                check_all
            fi
        else
            # Remote mode: only run checks
            check_all
        fi
        
        exit 0
    fi
    

    
    # Run tests for all servers
    if [ "$REMOTE" != "true" ]; then
        echo "Running benchmark tests for all servers..."
        echo "======================================"
        echo ""
    fi
    
    # Run system checks before benchmark tests
    if [ "$REMOTE" != "true" ] && [ "$CHECK_ENABLED" != "true" ]; then
        # Run system checks
        check_all
    fi
    
    # Check if sysbench is installed before running tests
    if [ "$REMOTE" != "true" ] && [ "$CHECK_ENABLED" != "true" ]; then
        if ! command -v sysbench &> /dev/null; then
            echo "Error: sysbench is not installed."
            echo "Please run './oscheckperf -i' to install and distribute sysbench,"
            echo "or './oscheckperf check' to check dependencies."
            exit 1
        fi
    fi
    
    if [ ${#target_servers[@]} -gt 0 ]; then
        # Function to execute tests on a single server
        execute_server_tests() {
            local target_ip="$1"
            local server_idx="$2"
            
            echo ""
            echo "================================================================================"
            echo "Testing server $server_idx/$(( ${#target_servers[@]} )): $target_ip"
            echo "================================================================================"
            
            # Execute tests on the server
            if [ "$target_ip" = "$local_ip" ]; then
                # Local machine test
                if [ "$CPU_ENABLED" != "false" ]; then
                    run_cpu_test
                fi
                
                if [ "$MEMORY_ENABLED" != "false" ]; then
                    run_memory_test
                fi
                
                if [ "$IO_ENABLED" != "false" ]; then
                    run_io_test
                fi
                
                if [ "$THREADS_ENABLED" != "false" ]; then
                    run_threads_test
                fi
                
                if [ "$MUTEX_ENABLED" != "false" ]; then
                    run_mutex_test
                fi
                
                if [ "$PGBENCH_ENABLED" = "true" ]; then
                    run_pgbench_test
                fi
            else
                # Remote server test
                echo "  Executing remote tests on $target_ip..."
                
                # Build the remote command with all enabled tests
                local remote_command="\$HOME/oscheckperf/oscheckperf --remote"
                local has_non_network_tests=false
                
                # Add tests to remote command based on enabled flags
                if [ "$CPU_ENABLED" != "false" ]; then
                    remote_command="$remote_command cpu"
                    has_non_network_tests=true
                fi
                
                if [ "$MEMORY_ENABLED" != "false" ]; then
                    remote_command="$remote_command mem"
                    has_non_network_tests=true
                fi
                
                if [ "$IO_ENABLED" != "false" ]; then
                    remote_command="$remote_command io"
                    has_non_network_tests=true
                fi
                
                if [ "$THREADS_ENABLED" != "false" ]; then
                    remote_command="$remote_command threads"
                    has_non_network_tests=true
                fi
                
                if [ "$MUTEX_ENABLED" != "false" ]; then
                    remote_command="$remote_command mutex"
                    has_non_network_tests=true
                fi
                
                # If no tests specified, add all tests (same as local behavior)
                if [ "$has_non_network_tests" = "false" ]; then
                    # Check if only network test is requested
                    if [ "$NETWORK_ENABLED" = "true" ] && [ "$CPU_ENABLED" != "true" ] && [ "$MEMORY_ENABLED" != "true" ] && [ "$IO_ENABLED" != "true" ] && [ "$THREADS_ENABLED" != "true" ] && [ "$MUTEX_ENABLED" != "true" ]; then
                        # Only network test requested, skip remote tests
                        echo "  Skipping remote tests (only network test requested)"
                        return
                    else
                        # No tests specified, add all tests
                        remote_command="$remote_command all"
                        has_non_network_tests=true
                    fi
                fi
                
                # Only execute remote tests if there are non-network tests to run
                if [ "$has_non_network_tests" = true ]; then
                    # Add common parameters including TIMESTAMP
                    remote_command="$remote_command DURATION=\"$DURATION\" TIMESTAMP=\"$TIMESTAMP\""
                    
                    # Add test-specific parameters
                    # Support new SYSBENCH_PROFILES and IO_PATH parameters with backward compatibility
                    remote_command="$remote_command CPU_THREADS=\"$CPU_THREADS\" CPU_MAX_PRIME=\"$CPU_MAX_PRIME\""
                    remote_command="$remote_command MEMORY_THREADS=\"$MEMORY_THREADS\" MEMORY_BLOCK_SIZE=\"$MEMORY_BLOCK_SIZE\" MEMORY_TOTAL_SIZE=\"$MEMORY_TOTAL_SIZE\" MEMORY_OPER=\"$MEMORY_OPER\""
                    remote_command="$remote_command IO_TOOL=\"$IO_TOOL\" IO_TOTAL_SIZE=\"$IO_TOTAL_SIZE\" SYSBENCH_PROFILES=\"${SYSBENCH_PROFILES:-rndrw}\" SYSBENCH_FILE_NUM=\"$SYSBENCH_FILE_NUM\" SYSBENCH_DURATION=\"$SYSBENCH_DURATION\" IO_PATH=\"${IO_PATH:-${IO_TEST_PATH:-$HOME/oscheckperf/io_test}}\" FIO_DURATION=\"$FIO_DURATION\""
                    remote_command="$remote_command THREADS_THREADS=\"$THREADS_THREADS\" THREADS_YIELDS=\"$THREADS_YIELDS\" THREADS_LOCKS=\"$THREADS_LOCKS\""
                    remote_command="$remote_command MUTEX_THREADS=\"$MUTEX_THREADS\" MUTEX_NUM=\"$MUTEX_NUM\""
                    remote_command="$remote_command PGBENCH_DURATION=\"$PGBENCH_DURATION\" PGBENCH_CLIENTS=\"$PGBENCH_CLIENTS\" PGBENCH_THREADS=\"$PGBENCH_THREADS\" PGBENCH_SCALE=\"$PGBENCH_SCALE\" PGBENCH_DB=\"$PGBENCH_DB\""
                    
                    # Execute the remote command and capture output to a temporary file
                    local temp_remote_file="$TMP_DIR/vb_remote_${target_ip//./_}_${TIMESTAMP}.txt"
                    
                    # Always use remote oscheckperf for consistent execution
                    # Check if remote oscheckperf exists, if not, skip this server
                    if ssh "$target_ip" "[ -d ~/oscheckperf ]" 2>/dev/null; then
                        # Use remote oscheckperf
                        # Build the remote command with only the requested tests
                        local remote_test_command=""
                        if [ "$CPU_ENABLED" = "true" ]; then
                            remote_test_command="cpu"
                        fi
                        if [ "$MEMORY_ENABLED" = "true" ]; then
                            remote_test_command="$remote_test_command mem"
                        fi
                        if [ "$IO_ENABLED" = "true" ]; then
                            remote_test_command="$remote_test_command io"
                        fi
                        if [ "$THREADS_ENABLED" = "true" ]; then
                            remote_test_command="$remote_test_command threads"
                        fi
                        if [ "$MUTEX_ENABLED" = "true" ]; then
                            remote_test_command="$remote_test_command mutex"
                        fi
                        
                        # Add duration parameter
                        if [ -n "$remote_test_command" ]; then
                            remote_test_command="$remote_test_command DURATION=$DURATION"
                            # Add IO test specific parameters
                            if [ "$IO_ENABLED" = "true" ]; then
                                remote_test_command="$remote_test_command IO_TOOL=$IO_TOOL"
                                if [ "$IO_TOOL" = "fio" ]; then
                                    remote_test_command="$remote_test_command FIO_DURATION=${FIO_DURATION:-$DURATION}"
                                    remote_test_command="$remote_test_command FIO_PROFILES=\"${FIO_PROFILES:-randrw}\""
                                    remote_test_command="$remote_test_command FIO_BS=${FIO_BS:-8K}"
                                    remote_test_command="$remote_test_command FIO_IODEPTH=${FIO_IODEPTH:-64}"
                                    remote_test_command="$remote_test_command FIO_NUMJOBS=${FIO_NUMJOBS:-4}"
                                    remote_test_command="$remote_test_command FIO_DIRECT=${FIO_DIRECT:-1}"
                                else
                                    remote_test_command="$remote_test_command SYSBENCH_PROFILES=\"${SYSBENCH_PROFILES:-rndrw}\""
                                fi
                                # Support new IO_PATH parameter with backward compatibility
                                remote_test_command="$remote_test_command IO_TOTAL_SIZE=${IO_TOTAL_SIZE:-1G} SYSBENCH_FILE_NUM=${SYSBENCH_FILE_NUM:-1} SYSBENCH_DURATION=${SYSBENCH_DURATION:-$DURATION} IO_PATH=${IO_PATH:-${IO_TEST_PATH:-$HOME/oscheckperf/io_test}}"
                            fi
                        fi
                        
                        # Add NO_CHECKS parameter to skip checks during benchmark
                        local full_remote_command="cd ~/oscheckperf && TIMESTAMP=$TIMESTAMP ./oscheckperf $remote_command $remote_test_command NO_CHECKS=true REMOTE=true"
                        if [ "$DRY_RUN" = true ]; then
                            echo "[DRY RUN] Would execute remote command on $target_ip:"
                            echo "  ssh $target_ip '$full_remote_command'"
                        elif ssh "$target_ip" "$full_remote_command" 2>&1 > "$temp_remote_file"; then
                            # Display remote test output
                            cat "$temp_remote_file"
                            
                            # Fetch original sysbench output from remote server
                            # Create a temporary directory to extract remote files
                            local temp_remote_dir="$TMP_DIR/vb_remote_${target_ip//./_}_${TIMESTAMP}"
                            mkdir -p "$temp_remote_dir"
                            # Extract remote files to temporary directory
                            if ! ssh "$target_ip" "cd ~/oscheckperf && tar -czf - output/original_data_${TIMESTAMP}_*" | tar -xzf - -C "$temp_remote_dir"; then
                                echo "  ⚠ Warning: Failed to fetch remote output files from $target_ip"
                            fi
                            
                            # Append remote original data to main file
                            local found_files=false
                            for file in "$temp_remote_dir/output/original_data_${TIMESTAMP}_"*; do
                                if [ -f "$file" ]; then
                                    found_files=true
                                    echo "" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                                    echo "================================================================================" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                                    echo "RESULTS FROM SERVER: $target_ip" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                                    echo "================================================================================" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                                    cat "$file" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                                fi
                            done
                            
                            # If no files found, record error
                            if [ "$found_files" = false ]; then
                                echo "" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                                echo "================================================================================" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                                echo "RESULTS FROM SERVER: $target_ip" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                                echo "================================================================================" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                                echo "Execution Command: $full_remote_command" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                                echo "" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                                echo "WARNING: No output files found from remote server" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                                echo "Checking remote server status:" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                                echo "- fio version: $(ssh "$target_ip" "fio --version 2>/dev/null || echo 'fio not found'")" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                                echo "- jq version: $(ssh "$target_ip" "jq --version 2>/dev/null || echo 'jq not found'")" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                                echo "- oscheckperf exists: $(ssh "$target_ip" "[ -f ~/oscheckperf/oscheckperf ] && echo 'Yes' || echo 'No'")" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                                echo "- Output dir exists: $(ssh "$target_ip" "[ -d ~/oscheckperf/output ] && echo 'Yes' || echo 'No'")" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                                echo "" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                                echo "Remote command output:" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                                cat "$temp_remote_file" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log" 2>/dev/null || echo "No output captured" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                            fi
                            
                            # Clean up temporary directory
                            rm -rf "$temp_remote_dir"
                        else
                            echo "  ✗ Remote test execution failed"
                            # Record failure in original data file for report generation
                            echo "" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                            echo "================================================================================" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                            echo "RESULTS FROM SERVER: $target_ip" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                            echo "================================================================================" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                            echo "Execution Command: $full_remote_command" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                            echo "" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                            echo "ERROR: Remote test execution failed" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                            echo "Output:" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                            cat "$temp_remote_file" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log" 2>/dev/null || echo "No output captured" >> "$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
                        fi
                    else
                        echo "  ✗ Remote oscheckperf not found, skipping this server"
                        echo "  Hint: Use './oscheckperf -f servers.txt -i' to distribute oscheckperf to all servers"
                    fi
                    
                    # Clean up
                    rm -f "$temp_remote_file"
                else
                    echo "  Skipping remote tests (only network test requested)"
                fi

            fi
        }
        
        # Determine execution mode: default to parallel (like gpcheckperf)
        local exec_mode="${EXEC_MODE:-parallel}"
        echo "Execution mode: $exec_mode"
        
        if [ "$exec_mode" = "parallel" ]; then
            # Parallel execution: run all servers simultaneously
            echo "Starting parallel tests on ${#target_servers[@]} servers..."
            local pids=()
            
            local server_idx=0
            for target_ip in "${target_servers[@]}"; do
                server_idx=$((server_idx + 1))
                # Run server tests in background
                execute_server_tests "$target_ip" "$server_idx" > "$TMP_DIR/vb_parallel_${target_ip//./_}_${TIMESTAMP}.log" 2>&1 &
                pids+=($!)
                echo "  Server $server_idx ($target_ip) started in background (PID: ${pids[-1]})"
            done
            
            # Wait for all background processes to complete
            echo "Waiting for all tests to complete..."
            for pid in "${pids[@]}"; do
                wait "$pid"
            done
            
            # Display output from all servers
            echo ""
            echo "=== Test Output Summary ==="
            for target_ip in "${target_servers[@]}"; do
                local log_file="$TMP_DIR/vb_parallel_${target_ip//./_}_${TIMESTAMP}.log"
                if [ -f "$log_file" ]; then
                    echo ""
                    echo "--- Output from $target_ip ---"
                    cat "$log_file"
                    rm -f "$log_file"
                fi
            done
        else
            # Serial execution: run servers one by one
            echo "Starting serial tests on ${#target_servers[@]} servers..."
            local server_idx=0
            for target_ip in "${target_servers[@]}"; do
                server_idx=$((server_idx + 1))
                execute_server_tests "$target_ip" "$server_idx"
            done
        fi
        
        # Execute network test (only once for the entire cluster)
        if [ "$NETWORK_ENABLED" != "false" ]; then
            run_network_test
        fi
    else
        # Single machine test mode
        if [ "$CPU_ENABLED" != "false" ]; then
            run_cpu_test
        fi
        
        if [ "$MEMORY_ENABLED" != "false" ]; then
            run_memory_test
        fi
        
        if [ "$IO_ENABLED" != "false" ]; then
            run_io_test
        fi
        
        if [ "$NETWORK_ENABLED" != "false" ]; then
            run_network_test
        fi
        
        if [ "$THREADS_ENABLED" != "false" ]; then
            run_threads_test
        fi
        
        if [ "$MUTEX_ENABLED" != "false" ]; then
            run_mutex_test
        fi
        
        if [ "$PGBENCH_ENABLED" = "true" ]; then
            run_pgbench_test
        fi
    fi
    
    # Only generate report in non-remote mode and non-dry-run mode
    if [ "$REMOTE" != "true" ] && [ "$DRY_RUN" != true ]; then
        # Generate report
        generate_report
        
        echo ""
        echo "=== Benchmark completed successfully! ==="
        echo "Report: $OUTPUT_DIR/report_benchmark_${TIMESTAMP}.log"
        echo "Detailed results: $OUTPUT_DIR/data_${TIMESTAMP}_all_results.log"
        echo "Original data: $OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
    elif [ "$DRY_RUN" = true ]; then
        echo ""
        echo "[DRY RUN] Report generation skipped"
    fi
}

# Install and distribute oscheckperf to target servers
install_and_distribute_sysbench() {
    local local_ip=$(get_machine_ip)
    local sysbench_dir="$HOME/oscheckperf"
    local benchmark_dir=$(realpath "$(dirname "$0")")
    local need_compile=false
    
    echo "=== Oscheckperf Installation and Distribution ==="
    
    # Check if local machine is in server list and needs compilation
    if [ ${#target_servers[@]} -gt 0 ]; then
        # Multi-server mode: check if local machine is in server list
        local is_local_in_list=false
        for ip in "${target_servers[@]}"; do
            if [ "$ip" = "$local_ip" ]; then
                is_local_in_list=true
                break
            fi
        done
        
        # If local machine is in list and no oscheckperf directory, need to compile
        if [ "$is_local_in_list" = "true" ] && [ ! -d "$sysbench_dir" ]; then
            need_compile=true
        fi
        
        # Compile sysbench if needed
        if [ "$need_compile" = "true" ]; then
            echo "[Step 1/4] Installing dependencies and compiling sysbench on local machine..."
            echo "  Local IP: $local_ip"
            echo "  Sysbench directory: $sysbench_dir"
            
            # Create oscheckperf directory first
            echo "  Creating oscheckperf directory: $sysbench_dir"
            mkdir -p "$sysbench_dir"
            
            # Check if dependencies are already installed
            echo "  Checking build dependencies..."
            if ! command -v gcc &> /dev/null || ! command -v make &> /dev/null || ! command -v automake &> /dev/null; then
                echo "  Installing build dependencies..."
                run_command "sudo yum install -y automake autoconf libtool gcc gcc-c++ make" "/dev/null"
            else
                echo "  Build dependencies already installed, skipping"
            fi
            
            # Compile sysbench
            echo "  Compiling sysbench..."
            run_command "tar -zxf tools/sysbench-1.0.20.tar.gz && cd sysbench-1.0.20 && ./autogen.sh && ./configure --without-mysql --prefix=\$HOME/oscheckperf && make && make install" "/dev/null"
            
            # Configure environment
            echo "  Configuring environment variables..."
            # Add to bashrc only if not already present
            if ! grep -q "oscheckperf/bin" ~/.bashrc; then
                run_command "echo 'export PATH=\$PATH:\$HOME/oscheckperf/bin' >> ~/.bashrc" "/dev/null"
            else
                echo "  PATH already configured in bashrc, skipping"
            fi
            # Also update current session PATH
            export PATH="$PATH:$HOME/oscheckperf/bin"
            echo "  ✓ Updated PATH in current session: $PATH"
            
            # Cleanup source directory
            run_command "rm -rf sysbench-1.0.20" "/dev/null"
            
            # Verify installation
            if [ -d "$sysbench_dir" ]; then
                echo "  ✓ sysbench compiled and installed successfully"
            else
                echo "  ✗ sysbench compilation failed"
                return 1
            fi
        else
            if [ -d "$sysbench_dir" ]; then
                echo "[Step 1/4] oscheckperf directory exists on local machine, skipping compilation"
                echo "  Local IP: $local_ip"
                echo "  Sysbench directory: $sysbench_dir"
            else
                echo "[Step 1/4] Skipping compilation: local machine not in server list"
            fi
        fi
        
        # Copy oscheckperf script to oscheckperf directory (main script first)
        echo "[Step 2/4] Copying oscheckperf script..."
        if [ -f "$benchmark_dir/oscheckperf" ]; then
            if cp "$benchmark_dir/oscheckperf" "$sysbench_dir/" 2>/dev/null; then
                chmod +x "$sysbench_dir/oscheckperf"
                echo "  ✓ Copied oscheckperf to $sysbench_dir/"
            else
                echo "  ⚠️  Failed to copy oscheckperf to $sysbench_dir/, continuing anyway"
            fi
        else
            echo "  ✗ oscheckperf script not found at $benchmark_dir/oscheckperf"
            return 1
        fi
        
        # Distribute to other servers if oscheckperf directory exists
        if [ -d "$sysbench_dir" ]; then
            echo "[Step 3/4] Distributing to target servers..."
            echo "  Server list: ${target_servers[*]}"
            
            # SCP to each server except local machine
            local distribute_success=true
            for ip in "${target_servers[@]}"; do
                if [ "$ip" != "$local_ip" ]; then
                    echo "  Distributing to $ip..."
                    # Check if remote oscheckperf directory exists
                    if run_command "ssh $ip 'test -d \$HOME/oscheckperf'" "/dev/null"; then
                        # oscheckperf directory exists, only distribute main script
                        echo "  oscheckperf directory exists on $ip, only distributing main script"
                        if run_command "scp -q $sysbench_dir/oscheckperf $ip:\$HOME/oscheckperf/" "/dev/null"; then
                            # Set executable permission
                            if run_command "ssh $ip 'chmod +x \$HOME/oscheckperf/oscheckperf'" "/dev/null"; then
                                echo "  ✓ Successfully distributed oscheckperf script to $ip"
                            else
                                echo "  ✗ Failed to set permissions on $ip"
                                distribute_success=false
                            fi
                        else
                            echo "  ✗ Failed to distribute oscheckperf script to $ip"
                            distribute_success=false
                        fi
                    else
                        # oscheckperf directory doesn't exist, distribute entire directory
                        echo "  oscheckperf directory doesn't exist on $ip, distributing entire directory"
                        # Create tar package
                        local tar_file="$HOME/oscheckperf.tar.gz"
                        if run_command "tar -czf $tar_file -C $HOME oscheckperf" "/dev/null"; then
                            if run_command "scp -q $tar_file $ip:$HOME/" "/dev/null"; then
                                # Create a temporary file to capture SSH output
                                local ssh_output=$(mktemp)
                                if run_command "ssh $ip 'rm -rf \$HOME/oscheckperf && mkdir -p \$HOME/oscheckperf && tar -xzf \$HOME/oscheckperf.tar.gz -C \$HOME && rm -f \$HOME/oscheckperf.tar.gz && chmod +x \$HOME/oscheckperf/oscheckperf && if ! grep -q \"oscheckperf/bin\" ~/.bashrc; then echo '\''export PATH=\$PATH:\$HOME/oscheckperf/bin'\'' >> ~/.bashrc; fi && source ~/.bashrc && sysbench --version'" "$ssh_output"; then
                                    echo "  ✓ Successfully distributed to $ip"
                                else
                                    echo "  ✗ Failed to distribute to $ip: SSH command failed"
                                    echo "  SSH output:"
                                    cat "$ssh_output"
                                    distribute_success=false
                                fi
                                # Cleanup temporary file
                                rm -f "$ssh_output"
                            else
                                echo "  ✗ Failed to distribute to $ip: SCP failed"
                                distribute_success=false
                            fi
                            # Cleanup tar file
                            run_command "rm -f $tar_file" "/dev/null"
                        else
                            echo "  ✗ Failed to create tar package, skipping distribution to $ip"
                            distribute_success=false
                        fi
                    fi
                fi
            done
            
            if [ "$distribute_success" = "true" ]; then
                echo "  ✓ All files distributed to all target servers"
            else
                echo "  ✗ Some distributions failed"
            fi
        fi
        
        echo "[Step 4/4] Installation and distribution completed"
        echo ""
        echo "=== Distribution Summary ==="
        echo "  Oscheckperf installed at: $sysbench_dir"
        echo "  Scripts and tools copied:"
        echo "    - $sysbench_dir/oscheckperf"
        echo "  Target servers:"
        for ip in "${target_servers[@]}"; do
            echo "    - $ip"
        done
    else
        # Single machine mode
        if [ ! -d "$sysbench_dir" ]; then
            echo "[Step 1/3] Installing dependencies and compiling sysbench..."
            echo "  Sysbench directory: $sysbench_dir"
            
            # Check if dependencies are already installed
            echo "  Checking build dependencies..."
            if ! command -v gcc &> /dev/null || ! command -v make &> /dev/null || ! command -v automake &> /dev/null; then
                echo "  Installing build dependencies..."
                run_command "sudo yum install -y automake autoconf libtool gcc gcc-c++ make" "/dev/null"
            else
                echo "  Build dependencies already installed, skipping"
            fi
            
            # Compile sysbench
            echo "  Compiling sysbench..."
            run_command "tar -zxf tools/sysbench-1.0.20.tar.gz && cd sysbench-1.0.20 && ./autogen.sh && ./configure --without-mysql --prefix=\$HOME/oscheckperf && make && make install" "/dev/null"
            
            # Configure environment
            echo "  Configuring environment variables..."
            # Add to bashrc only if not already present
            if ! grep -q "oscheckperf/bin" ~/.bashrc; then
                run_command "echo 'export PATH=\$PATH:\$HOME/oscheckperf/bin' >> ~/.bashrc" "/dev/null"
            else
                echo "  PATH already configured in bashrc, skipping"
            fi
            # Also update current session PATH
            export PATH="$PATH:$HOME/oscheckperf/bin"
            echo "  ✓ Updated PATH in current session: $PATH"
            
            # Cleanup source directory
            run_command "rm -rf sysbench-1.0.20" "/dev/null"
            
            # Verify installation
            if [ -d "$sysbench_dir" ]; then
                echo "  ✓ sysbench compiled and installed successfully"
            else
                echo "  ✗ sysbench compilation failed"
                return 1
            fi
        else
            echo "  ✓ oscheckperf directory already exists: $sysbench_dir"
        fi
    fi
}

# Validate all parameters before test execution
validate_all_parameters() {
    local no_exit="${1:-false}"
    local error_count=0
    local output=""
    
    # Validate SYSBENCH_PROFILES
    if [ -n "$SYSBENCH_PROFILES" ]; then
        local valid_sysbench_modes="seqwr seqrewr seqrd rndrd rndwr rndrw"
        for mode in $SYSBENCH_PROFILES; do
            if [[ ! " $valid_sysbench_modes " =~ " $mode " ]]; then
                output="${output}ERROR: Invalid SYSBENCH_PROFILES mode: $mode\n"
                output="${output}  Valid modes: $valid_sysbench_modes\n"
                error_count=$((error_count + 1))
            fi
        done
    fi

    # Validate FIO_PROFILES
    if [ -n "$FIO_PROFILES" ]; then
        local valid_fio_modes="read write randread randwrite rw randrw trim randtrim trimwrite"
        for mode in $FIO_PROFILES; do
            if [[ ! " $valid_fio_modes " =~ " $mode " ]]; then
                output="${output}ERROR: Invalid FIO_PROFILES mode: $mode\n"
                output="${output}  Valid modes: $valid_fio_modes\n"
                error_count=$((error_count + 1))
            fi
        done
    fi

    # Validate IO_TOOL
    if [ -n "$IO_TOOL" ]; then
        local valid_io_tools="sysbench fio"
        if [[ ! " $valid_io_tools " =~ " $IO_TOOL " ]]; then
            output="${output}ERROR: Invalid IO_TOOL: $IO_TOOL\n"
            output="${output}  Valid values: $valid_io_tools\n"
            error_count=$((error_count + 1))
        fi
    fi

    # Validate FIO_DIRECT
    if [ -n "$FIO_DIRECT" ]; then
        local valid_fio_direct="0 1"
        if [[ ! " $valid_fio_direct " =~ " $FIO_DIRECT " ]]; then
            output="${output}ERROR: Invalid FIO_DIRECT: $FIO_DIRECT\n"
            output="${output}  Valid values: $valid_fio_direct\n"
            error_count=$((error_count + 1))
        fi
    fi

    # Validate NETWORK_MODE
    if [ -n "$NETWORK_MODE" ]; then
        local valid_network_modes="serial parallel matrix"
        if [[ ! " $valid_network_modes " =~ " $NETWORK_MODE " ]]; then
            output="${output}ERROR: Invalid NETWORK_MODE: $NETWORK_MODE\n"
            output="${output}  Valid values: $valid_network_modes\n"
            error_count=$((error_count + 1))
        fi
    fi

    # Validate MEMORY_OPER
    if [ -n "$MEMORY_OPER" ]; then
        local valid_memory_oper="read write"
        if [[ ! " $valid_memory_oper " =~ " $MEMORY_OPER " ]]; then
            output="${output}ERROR: Invalid MEMORY_OPER: $MEMORY_OPER\n"
            output="${output}  Valid values: $valid_memory_oper\n"
            error_count=$((error_count + 1))
        fi
    fi

    # Validate BOOLEAN type parameters
    for bool_param in "CLEANUP" "NO_CHECKS"; do
        local param_val=$(eval echo \${$bool_param:-})
        if [ -n "$param_val" ]; then
            local valid_booleans="true false"
            if [[ ! " $valid_booleans " =~ " $param_val " ]]; then
                output="${output}ERROR: Invalid $bool_param: $param_val\n"
                output="${output}  Valid values: $valid_booleans\n"
                error_count=$((error_count + 1))
            fi
        fi
    done

    # Validate numeric parameters
    for num_param in "DURATION" "CPU_THREADS" "CPU_MAX_PRIME" "MEMORY_THREADS" \
        "SYSBENCH_FILE_NUM" "SYSBENCH_DURATION" "FIO_DURATION" "FIO_IODEPTH" \
        "FIO_NUMJOBS" "THREADS_NUM" "THREADS_YIELDS" "THREADS_LOCKS" \
        "MUTEX_THREADS" "MUTEX_NUM" "NETWORK_PARALLEL"; do
        local param_val=$(eval echo \${$num_param:-})
        if [ -n "$param_val" ]; then
            if [[ ! "$param_val" =~ ^[0-9]+$ ]]; then
                output="${output}ERROR: Invalid $num_param: $param_val\n"
                output="${output}  Must be a positive integer\n"
                error_count=$((error_count + 1))
            fi
        fi
    done

    # Output results
    if [ "$error_count" -gt 0 ]; then
        echo -e "$output\c"
        echo "Total parameter validation errors: $error_count"
        if [ "$no_exit" != "true" ]; then
            exit 1
        else
            return 1
        fi
    else
        echo "Parameter validation passed."
        return 0
    fi
}

# 执行主函数
main "$@"