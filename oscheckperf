            cpu_model="${line#CPU_MODEL: }"
        elif [[ "$line" == CPU_PHYSICAL_CORES:* ]]; then
            cpu_physical_cores="${line#CPU_PHYSICAL_CORES: }"
        elif [[ "$line" == CPU_LOGICAL_CORES:* ]]; then
            cpu_logical_cores="${line#CPU_LOGICAL_CORES: }"
        elif [[ "$line" == CPU_FREQ:* ]]; then
            cpu_freq="${line#CPU_FREQ: }"
        elif [[ "$line" == MEM_TOTAL:* ]]; then
