# Get CPU L1 data cache size (with fallback for VMs where lscpu -C is empty)
get_cpu_l1_cache() {
    if command -v lscpu &>/dev/null; then
        local cache_val=$(lscpu -C 2>/dev/null | grep 'L1d' | head -1 | awk '{print $2}')
        if [ -n "$cache_val" ]; then
            echo "$cache_val"
            return
        fi
        # Fallback: try lscpu summary mode
        cache_val=$(lscpu 2>/dev/null | grep -i 'L1d cache' | awk -F: '{print $2}' | awk '{print $1}')
        if [ -n "$cache_val" ]; then
            echo "$cache_val"
            return
        fi
        # Fallback: try sysfs
        if [ -f /sys/devices/system/cpu/cpu0/cache/index0/size ]; then
            cat /sys/devices/system/cpu/cpu0/cache/index0/size 2>/dev/null && return
        fi
    fi
    echo "N/A"
}

