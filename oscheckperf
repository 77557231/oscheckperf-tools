# Check if command exists
check_command() {
    local cmd="$1"
    local install_hint="$2"
    
    if command -v "$cmd" &> /dev/null; then
        return 0
    else
        if [ -n "$install_hint" ]; then
            echo "Warning: Command '$cmd' is not installed. $install_hint"
        else
            echo "Warning: Command '$cmd' is not installed"
        fi
        return 1
    fi
}

# Get CPU core count
get_cpu_cores() {
    nproc 2>/dev/null || grep -c ^processor /proc/cpuinfo 2>/dev/null || echo "unknown"
}

# Get memory size (MB)
get_memory_size_mb() {
    if [ -f /proc/meminfo ]; then
        awk '/MemTotal/ {printf "%.0f", $2/1024}' /proc/meminfo 2>/dev/null
    else
        echo "unknown"
    fi
}

# Get disk available space (KB)
get_disk_available_kb() {
    local path="${1:-$BASE_DIR}"
    df -P "$path" | awk 'NR==2 {print $4}'
}

# Log output functions
log_info() {
    echo "[INFO] $(date '+%Y-%m-%d %H:%M:%S') - $1"
}

log_error() {
    echo "[ERROR] $(date '+%Y-%m-%d %H:%M:%S') - $1" >&2
}

log_warn() {
    echo "[WARN] $(date '+%Y-%m-%d %H:%M:%S') - $1"
}

# Debug log function - only outputs when DEBUG is enabled
# Usage: debug_log "message" [var1=value1] [var2=value2] ...
debug_log() {
    if [ "$DEBUG" != "true" ]; then
        return
    fi
    
    local message="$1"
    shift
    
    echo "[DEBUG] $(date '+%Y-%m-%d %H:%M:%S') - $message"
    
    # Print additional variable values if provided
    for arg in "$@"; do
        echo "        $arg"
    done
}

# ==============================================
# Security validation functions (isolated module)
# ==============================================

# Validate path for security - check for dangerous characters
# Returns 0 if valid, 1 if invalid
# Prints error message with specific dangerous characters found
validate_path() {
    local path="$1"
    local param_name="$2"
    
    # List of dangerous characters that can be used for command injection
    local dangerous_chars=(";" "|" "&" "<" ">" "$" "\`" "\"" "'" "\\")
    local found_dangerous=""
    
    for char in "${dangerous_chars[@]}"; do
        if [[ "$path" == *"$char"* ]]; then
            # Escape special characters for display
            case "$char" in
                ";") found_dangerous="$found_dangerous ;" ;;
                "|") found_dangerous="$found_dangerous |" ;;
                "&") found_dangerous="$found_dangerous &" ;;
                "<") found_dangerous="$found_dangerous <" ;;
                ">") found_dangerous="$found_dangerous >" ;;
                "$") found_dangerous="$found_dangerous \$" ;;
                "\`") found_dangerous="$found_dangerous \`" ;;
                "\"") found_dangerous="$found_dangerous \"" ;;
                "'") found_dangerous="$found_dangerous '" ;;
                "\\") found_dangerous="$found_dangerous \\" ;;
            esac
        fi
    done
    
    if [ -n "$found_dangerous" ]; then
        echo "Error: Invalid $param_name path contains dangerous characters:$found_dangerous"
        echo "       Path: $path"
        return 1
    fi
    
    # Additional check: path traversal attack
    if [[ "$path" == *"../"* ]]; then
        echo "Error: Invalid $param_name path contains directory traversal (../)"
        echo "       Path: $path"
        return 1
    fi
    
    return 0
}

# Validate all path parameters
validate_all_paths() {
    local error_count=0
    
    # Validate IO_PATH
    if [ -n "${IO_PATH:-}" ]; then
        if ! validate_path "$IO_PATH" "IO_PATH"; then
            error_count=$((error_count + 1))
        fi
    fi
    
    # Validate OUTPUT_DIR
    if [ -n "${OUTPUT_DIR:-}" ]; then
        if ! validate_path "$OUTPUT_DIR" "OUTPUT_DIR"; then
            error_count=$((error_count + 1))
        fi
    fi
    
    # Validate TMP_DIR
    if [ -n "${TMP_DIR:-}" ]; then
        if ! validate_path "$TMP_DIR" "TMP_DIR"; then
            error_count=$((error_count + 1))
        fi
    fi
    
    # Validate IO_TEST_PATH (backward compatibility)
    if [ -n "${IO_TEST_PATH:-}" ]; then
        if ! validate_path "$IO_TEST_PATH" "IO_TEST_PATH"; then
            error_count=$((error_count + 1))
        fi
    fi
    
    if [ "$error_count" -gt 0 ]; then
        echo "Error: $error_count path validation error(s) found"
        exit 1
    fi
}

# Cleanup test file
cleanup_file() {
    local file="$1"
    if [ -f "$file" ]; then
        rm -f "$file"
    fi
}

# Cleanup test directory
cleanup_dir() {
    local dir="$1"
    if [ -d "$dir" ]; then
        rm -rf "$dir"
    fi
}

# Execute command function (supports dry run mode)
run_command() {
    local cmd="$1"
    local output_file="$2"
    
    if [ "$DRY_RUN" = true ]; then
        echo "Dry run: $cmd"
        return 0
    fi
    
    if [ -n "$output_file" ]; then
        # Execute command and capture output
        eval "$cmd" > "$output_file" 2>&1
        local exit_code=$?
        
        return $exit_code
    else
        eval "$cmd"
        return $?
    fi
}

# Wait for command execution to complete (with timeout)
wait_with_timeout() {
    local pid="$1"
    local timeout="$2"
    local start_time=$(date +%s)
    
    while kill -0 "$pid" 2>/dev/null; do
        local current_time=$(date +%s)
        local elapsed=$((current_time - start_time))
        
        if [ "$elapsed" -ge "$timeout" ]; then
            kill -9 "$pid" 2>/dev/null
            return 1
        fi
        
        sleep 1
    done
    
    return 0
}

# Load configuration file


# Parse multi-server configuration
# Format: IP:ROLE:description, multiple servers separated by commas
parse_servers() {
    local servers_str="${SERVERS:-}"
    if [ -z "$servers_str" ]; then
        echo ""
        return
    fi
    
    local IFS=','
    for server in $servers_str; do
        local ip=$(echo "$server" | cut -d: -f1)
        local role=$(echo "$server" | cut -d: -f2)
        local desc=$(echo "$server" | cut -d: -f3)
        echo "$ip|$role|$desc"
    done
}

# Parse test scenarios configuration
# Format: CLIENT_IP:SERVER_IP:Duration (Duration is optional)
parse_test_scenarios() {
    local scenarios_str="${TEST_SCENARIOS:-}"
    if [ -z "$scenarios_str" ]; then
        echo ""
        return
    fi
    
    local IFS=','
    for scenario in $scenarios_str; do
        local client_ip=$(echo "$scenario" | cut -d: -f1)
        local server_ip=$(echo "$scenario" | cut -d: -f2)
        local duration=$(echo "$scenario" | cut -d: -f3)
        echo "$client_ip|$server_ip|$duration"
    done
}

# Check all dependencies
check_all() {
    if [ "$NO_CHECKS" = "true" ]; then
        return
    fi
    
    echo "Checking system prerequisites..."
    echo "--------------------------------"
    
    # Validate parameters first - as the first check item
    echo "  Checking parameters..."
    # Use temporary file to capture output and exit code
    local temp_output=$(mktemp)
    validate_all_parameters true >"$temp_output" 2>&1
    local validation_exit_code=$?
    # Indent the output
    sed 's/^/  /' "$temp_output"
    rm -f "$temp_output"
    if [ $validation_exit_code -eq 0 ]; then
        echo "  ✓ Parameters check passed"
    else
        echo "  ✗ Parameters check failed"
        exit 1
    fi
    echo ""
    
    # Check dependencies
    check_dependencies
    
    # Check permissions
    check_permissions
    
    # Check disk space
    check_disk_space
    
    # Check network connectivity
    check_network
    
    # Check SSH passwordless login for remote servers
    debug_log "Starting check_ssh"
    check_ssh
    
    # Cleanup residual processes on all servers (before test execution)
    # Skip cleanup if SKIP_CLEANUP is set to true
    debug_log "Starting cleanup_residual_processes"
    if [ "${SKIP_CLEANUP:-false}" != "true" ]; then
        # Use timeout to prevent cleanup from hanging
        timeout --signal=KILL 30 cleanup_residual_processes 2>/dev/null || true
    fi
    debug_log "cleanup_residual_processes completed"
    
    echo ""
    echo "Prerequisites check completed successfully!"
    echo "----------------------------------------"
    echo ""
}

# Check dependencies
check_dependencies() {
    local has_error=false
    
    echo "  Checking dependencies..."
    
    # sysbench is required
    if check_command "sysbench" "sysbench will be automatically distributed to remote servers"; then
        echo "  ✓ sysbench: Installed (required for all tests)"
    else
        echo "  ⚠ sysbench: Not installed (will be automatically distributed)"
    fi
    
    # Additional tools (optional, based on test types)
    if check_command "fio" "Please run: sudo yum install -y fio"; then
        echo "  ✓ fio: Installed (required for IO tests)"
    else
        echo "  ⚠ fio: Not installed (required for IO tests)"
    fi
    
    if check_command "iperf3" "Please run: sudo yum install -y iperf3"; then
        echo "  ✓ iperf3: Installed (required for network tests)"
    else
        echo "  ⚠ iperf3: Not installed (required for network tests)"
    fi
    
    if check_command "jq" "Please run: sudo yum install -y jq"; then
        echo "  ✓ jq: Installed (required for parsing fio JSON output)"
    else
        echo "  ⚠ jq: Not installed (required for parsing fio JSON output)"
    fi
    
    echo "  Note: Install optional dependencies based on your testing needs"
    
    return 0
}

# Check permissions
check_permissions() {
    echo "  Checking permissions..."
    
    # Check test directory write permission
    # Support new IO_PATH parameter with backward compatibility to IO_TEST_PATH
    local test_path="${IO_PATH:-${IO_TEST_PATH:-$IO_PATH_DEFAULT}}"
    if [ -w "$test_path" ]; then
