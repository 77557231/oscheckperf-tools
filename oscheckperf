# Calculate statistics from bandwidth results
# Usage: calculate_stats "results_array"
# Returns: "total_bw|avg_bw|min_bw|max_bw|median_bw|count"
calculate_stats() {
    local results=("$@")
    
    local total_bw=0
    local count=0
    local min_bw=999999
    local max_bw=0
    local bw_values=()
    
    for result in "${results[@]}"; do
        IFS='|' read -r src dst r_bw <<< "$result"
        if [ "$r_bw" != "0" ] && [[ "$r_bw" =~ ^[0-9.]+$ ]]; then
            total_bw=$(echo "$total_bw + $r_bw" | bc)
            count=$((count + 1))
            bw_values+=("$r_bw")
            if (( $(echo "$r_bw < $min_bw" | bc -l) )); then
                min_bw="$r_bw"
            fi
            if (( $(echo "$r_bw > $max_bw" | bc -l) )); then
                max_bw="$r_bw"
            fi
        fi
    done
    
    local avg_bw="0"
    local median_bw="0"
    if [ $count -gt 0 ]; then
        avg_bw=$(echo "$total_bw / $count" | bc -l)
        IFS=$'\n' sorted_bw=($(sort -g <<< "${bw_values[*]}"))
        unset IFS
        local mid=$((count / 2))
        if [ $((count % 2)) -eq 0 ]; then
            median_bw=$(echo "(${sorted_bw[$mid-1]} + ${sorted_bw[$mid]}) / 2" | bc -l)
        else
            median_bw="${sorted_bw[$mid]}"
        fi
    fi
    
    echo "$total_bw|$avg_bw|$min_bw|$max_bw|$median_bw|$count"
}

# Execute command function (supports dry run mode)
run_command() {
    local cmd="$1"
    local output_file="$2"
    
    if [ "$DRY_RUN" = true ]; then
        echo "Dry run: $cmd"
        return 0
    fi
    
    if [ -n "$output_file" ]; then
        # Execute command and capture output
        eval "$cmd" > "$output_file" 2>&1
        local exit_code=$?
        
        return $exit_code
    else
        eval "$cmd"
        return $?
    fi
}

# Wait for command execution to complete (with timeout)
wait_with_timeout() {
    local pid="$1"
    local timeout="$2"
    local start_time=$(date +%s)
    
    while kill -0 "$pid" 2>/dev/null; do
        local current_time=$(date +%s)
        local elapsed=$((current_time - start_time))
        
        if [ "$elapsed" -ge "$timeout" ]; then
            kill -9 "$pid" 2>/dev/null
            return 1
        fi
        
        sleep 1
    done
    
    return 0
}

