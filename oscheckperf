# Parse sysbench fileio result
parse_sysbench_fileio_result() {
    local result_file="$1"
    
    # Extract metrics
    local read_iops=$(grep "reads/s:" "$result_file" 2>/dev/null | awk '{print $NF}' || echo "0")
    local write_iops=$(grep "writes/s:" "$result_file" 2>/dev/null | awk '{print $NF}' || echo "0")
    local fsync_iops=$(grep "fsyncs/s:" "$result_file" 2>/dev/null | awk '{print $NF}' || echo "N/A")
    local total_iops=$(awk "BEGIN {printf \"%.2f\", $read_iops + $write_iops}" 2>/dev/null || echo "0")
    local read_bw=$(grep "read, MiB/s:" "$result_file" 2>/dev/null | awk '{print $NF}' || echo "0")
    local write_bw=$(grep "written, MiB/s:" "$result_file" 2>/dev/null | awk '{print $NF}' || echo "0")
    local total_bw=$(awk "BEGIN {printf \"%.2f\", $read_bw + $write_bw}" 2>/dev/null || echo "0")
    local avg_latency=$(grep "avg:" "$result_file" 2>/dev/null | head -1 | awk '{print $NF}' | tr -d ',' || echo "0")
    local min_latency=$(grep -A10 "Latency (ms):" "$result_file" 2>/dev/null | grep "min:" | awk '{print $NF}' | tr -d ',' || echo "N/A")
    local max_latency=$(grep -A10 "Latency (ms):" "$result_file" 2>/dev/null | grep "max:" | awk '{print $NF}' | tr -d ',' || echo "N/A")
    local p95_latency=$(grep "95th percentile" "$result_file" 2>/dev/null | awk '{print $NF}' || echo "N/A")
    local events_fair=$(grep -A10 "Threads fairness:" "$result_file" 2>/dev/null | grep "events (avg/stddev):" | head -1)
    local execution_fair=$(grep -A10 "Threads fairness:" "$result_file" 2>/dev/null | grep "execution time (avg/stddev):" | head -1)
    
    # Display summary
    echo ""
    echo "IO test results:"
    echo "  Read IOPS: $read_iops"
    echo "  Write IOPS: $write_iops"
    if [ "$fsync_iops" != "N/A" ]; then
        echo "  Fsyncs/s: $fsync_iops"
    fi
    echo "  Total IOPS: $total_iops"
    echo "  Read BW: ${read_bw}MB/s"
    echo "  Write BW: ${write_bw}MB/s"
    echo "  Total BW: ${total_bw}MB/s"
    echo "  Avg Latency: ${avg_latency}ms"
    if [ "$min_latency" != "N/A" ]; then
        echo "  Min Latency: ${min_latency}ms"
    fi
    if [ "$max_latency" != "N/A" ]; then
        echo "  Max Latency: ${max_latency}ms"
    fi
    if [ "$p95_latency" != "N/A" ]; then
        echo "  P95 Latency: ${p95_latency}ms"
    fi
    if [ -n "$events_fair" ] || [ -n "$execution_fair" ]; then
        echo "  Threads fairness:"
        if [ -n "$events_fair" ]; then
            echo "    $events_fair"
        fi
        if [ -n "$execution_fair" ]; then
            echo "    $execution_fair"
        fi
    fi
}



# Get machine's real IP address
get_machine_ip() {
    # Try hostname -I first (returns all IPs), take the first one
    local ip=$(hostname -I 2>/dev/null | awk '{print $1}')
    if [ -n "$ip" ]; then
        echo "$ip"
        return 0
    fi
    
    # Fallback: try ip route
    ip=$(ip route get 8.8.8.8 2>/dev/null | grep -oP 'src \K\S+')
    if [ -n "$ip" ]; then
        echo "$ip"
        return 0
    fi
    
    # Last fallback
    echo "127.0.0.1"
}

# Display per-second throughput
display_per_second_throughput() {
    local text_file="$1"
    local server_ip="$2"
    
    if [ ! -f "$text_file" ]; then
        return
    fi
    
    echo ""
    echo "Per-second throughput for $server_ip:"
    # Extract interval lines showing per-second data (format: [  5] 0.00-1.00 sec XXX MBytes X.XX Gbits/sec)
    # Support both Mbits/sec and Gbits/sec
    local lines=$(grep "sec" "$text_file" | grep "MBytes" | grep -E "(M|G)bits/sec" | grep -v "sender\|receiver")
    if [ -n "$lines" ]; then
        echo "$lines" | sed 's/^/  /'
    else
        echo "  No per-second data available"
    fi
}

# Network test function
run_network_test() {
    local network_tool="${NETWORK_TOOL:-iperf3}"
    local network_mode="${NETWORK_MODE:-matrix}"
    local network_enabled="${NETWORK_ENABLED:-true}"
    local network_client_ip="${NETWORK_CLIENT_IP:-}"
    
    # Check if network test is enabled
    if [ "$network_enabled" != "true" ]; then
        echo "Network test disabled"
        return 0
    fi
    
    # Automatically use target_servers if NETWORK_CLIENT_IP is not set
    if [ -z "$network_client_ip" ] && [ ${#target_servers[@]} -gt 0 ]; then
        network_client_ip="${target_servers[*]}"
    fi
    
    # Skip network test if no client IPs are configured (single machine test has no meaning)
    if [ -z "$network_client_ip" ]; then
        echo "=== Network Performance Test ==="
        echo "Skipping network test: No client IPs configured (single machine test has no meaning)"
        return 0
    fi
    
    echo "=== Network Performance Test ==="
    
    
    # Check if iperf3 is installed
    if ! command -v iperf3 &> /dev/null; then
        echo "Error: iperf3 not installed, please run: sudo yum install -y iperf3"
        return 1
    fi

    # Clean up residual iperf3 processes before starting network tests
    echo "  Cleaning up residual iperf3 server processes before network test..."
    cleanup_residual_processes "network_only"
    
    if [ "$network_mode" = "matrix" ]; then
        run_matrix_network_test
    else
        run_serial_network_test
    fi
}

# Serial network test (sequential testing)
# Supports both local and remote server: uses first host as server
run_serial_network_test() {
    start_timer "network_test_serial"
    local port="$NETWORK_PORT"
    local duration="$DURATION"
    local parallel="${NETWORK_PARALLEL:-1}"
    
    # Create temp directory if it doesn't exist
    local output_dir="$TMP_DIR"
    mkdir -p "$output_dir"
    
    # Get all host IPs from server list or NETWORK_CLIENT_IP
    local host_ips=()
    if [ ${#target_servers[@]} -gt 0 ]; then
        host_ips=(${target_servers[@]})
    else
        local client_ip="${NETWORK_CLIENT_IP:-}"
        if [ -z "$client_ip" ]; then
            echo "Skipping serial network test: No client IPs configured"
            return 0
        fi
        host_ips=($client_ip)
    fi
    
    local num_hosts=${#host_ips[@]}
    
    if [ $num_hosts -lt 2 ]; then
        echo "Skipping serial network test: At least 2 hosts required"
        return 0
    fi
    
    # Use the first host as server
    local server_ip="${host_ips[0]}"
    local local_ip=$(get_machine_ip)
    local is_local_server="false"
    
    # Check if server is local machine
    if [ "$server_ip" = "$local_ip" ] || [ "$server_ip" = "localhost" ] || [ "$server_ip" = "127.0.0.1" ]; then
        is_local_server="true"
    fi
    
    # Build client list (all hosts except the server)
    local client_ips=()
    for ((i=1; i<num_hosts; i++)); do
        client_ips+=("${host_ips[$i]}")
    done
    local num_clients=${#client_ips[@]}
    
    echo "Starting iperf3 serial test..."
    echo "  Server: $server_ip:$port ${is_local_server:+(local)}"
    echo "  Client(s): ${client_ips[*]}"
    echo "  Duration: ${duration}s, Parallel connections: $parallel"
    echo "  Total test scenarios: $num_clients"
    
    # Start iperf3 server
    echo "  Starting iperf3 server on $server_ip..."
    # Calculate timeout parameters:
    # --idle-timeout: 600 seconds (10 minutes) for automatic cleanup
    # --rcv-timeout: (duration + 30) * 1000 milliseconds to support long tests
    local server_idle_timeout=600
    local server_rcv_timeout=$(( (duration + 30) * 1000 ))
    
    if [ "$DRY_RUN" = true ]; then
        if [ "$is_local_server" = "true" ]; then
            echo "[DRY RUN] iperf3 -s -p \"$port\" -D --idle-timeout $server_idle_timeout --rcv-timeout $server_rcv_timeout"
        else
            local server_ssh=$(get_ssh_command "$server_ip")
            echo "[DRY RUN] $server_ssh 'iperf3 -s -p $port -D --idle-timeout $server_idle_timeout --rcv-timeout $server_rcv_timeout'"
        fi
    else
        if [ "$is_local_server" = "true" ]; then
            # Local server: direct execution for better performance
            run_command "iperf3 -s -p \"$port\" -D --idle-timeout $server_idle_timeout --rcv-timeout $server_rcv_timeout" "/dev/null"
            if ! wait_for_iperf3_server "" "$port" "" 10; then
                echo "  ✗ Local server $port startup timeout after 10s"
                return 1
            fi
        else
            # Remote server: use SSH
            set_ssh_password "$server_ip"
            local server_ssh=$(get_ssh_command "$server_ip")
            eval "$server_ssh 'iperf3 -s -p $port -D --idle-timeout $server_idle_timeout --rcv-timeout $server_rcv_timeout'"
            sleep 3
        fi
    fi
    
    # Execute tests for each client IP sequentially
    local results=()
    local client_idx=0
    for client in "${client_ips[@]}"; do
        client_idx=$((client_idx + 1))
        
        if [ $num_clients -gt 1 ]; then
            echo ""
            echo "  [Test $client_idx/$num_clients] Testing from client: $client"
        fi
        
        # Skip test if client and server are the same IP (loopback test)
        if [ "$client" = "$server_ip" ]; then
            echo "  ⚠ Skipping loopback test (client and server are the same IP)"
            echo "  Loopback tests do not represent real network performance"
            continue
        fi
        
        # Calculate timeout: duration + 30s buffer for each client (increased from 15s)
        local client_timeout=$((duration + 30))
        local client_output_file="$TMP_DIR/network_scenario_${client_idx}_${TIMESTAMP}.json"
        local client_text_output="$TMP_DIR/network_scenario_${client_idx}_${TIMESTAMP}_text.log"
        
        # Run iperf3 client with timeout and capture both JSON and text output
        if [ "$DRY_RUN" = true ]; then
            set_ssh_password "$client"
            local client_ssh=$(get_ssh_command "$client")
            echo "[DRY RUN] $client_ssh 'iperf3 -c $server_ip -p $port -t $duration -P $parallel --connect-timeout 3000 -J'"
            echo "[DRY RUN] $client_ssh 'iperf3 -c $server_ip -p $port -t $duration -P $parallel --connect-timeout 3000 2>&1 | grep -v ^$'"
            results+=("$client|$server_ip|0")
            echo "  [DRY RUN] Test would complete: $client -> $server_ip"
        else
            # Actual run: execute the client test
            # Check if client is reachable first
            if ! ping -c 1 -W 2 "$client" > /dev/null 2>&1; then
                echo "  ⚠ Client $client is unreachable"
                continue
            fi
            
            # Check if iperf3 is installed on client
            set_ssh_password "$client"
            local client_ssh=$(get_ssh_command "$client")
            if ! eval "$client_ssh 'command -v iperf3 > /dev/null 2>&1'" > /dev/null 2>&1; then
                echo "  ⚠ iperf3 not installed on client $client"
                echo "  Please install iperf3 on $client manually"
                continue
            fi
            
            echo "  Running test: $client -> $server_ip"
            
            # Check if iperf3 server is reachable from client
            if ! eval "$client_ssh 'nc -z -w 2 $server_ip $port'" > /dev/null 2>&1; then
                echo "  ⚠ Server $server_ip:$port is not reachable from client $client"
                echo "  Possible issues: firewall blocking port $port, or iperf3 server not running"
                continue
            fi
            
            # Run iperf3 client with timeout
            local exit_status=0
            eval "timeout --signal=KILL $client_timeout $client_ssh 'iperf3 -c $server_ip -p $port -t $duration -P $parallel --connect-timeout 3000 -J'" > "$client_output_file" 2>&1
            exit_status=$?
            
            if [ $exit_status -eq 0 ]; then
                # Parse result
                if [ -f "$client_output_file" ]; then
                    # Generate text-like output from JSON
                    generate_iperf3_text_from_json "$client_output_file" "$client_text_output"
                    
                    # Parse and display result
                    local bandwidth=$(parse_iperf3_matrix_result "$client_output_file")
                    parse_iperf3_result "$client_output_file"
                    
                    # Add result to results array
                    results+=("$client|$server_ip|$bandwidth")
                    
                    # Display per-second throughput
                    display_per_second_throughput "$client_text_output" "$server_ip (from $client)"
                    
                    # Append to combined results file
                    append_to_original "NETWORK TEST RESULTS ($server_ip from $client)" "$client_text_output"
                    
                    echo "  ✓ Test completed: $client -> $server_ip = ${bandwidth} MB/s"
                else
                    results+=("$client|$server_ip|0")
                    echo "  ⚠ Test failed: $client -> $server_ip (no output file)"
                fi
            else
                results+=("$client|$server_ip|0")
                echo "  ⚠ Test failed: $client -> $server_ip (timeout or error)"
            fi
        fi
    done
    
    # Stop iperf3 server
    echo "  Stopping iperf3 server..."
    if [ "$DRY_RUN" = true ]; then
        if [ "$is_local_server" = "true" ]; then
            echo "[DRY RUN] pkill -f \"iperf3 -s -p $port\""
        else
            local server_ssh=$(get_ssh_command "$server_ip")
            echo "[DRY RUN] $server_ssh 'pkill -f \"iperf3 -s -p $port\"'"
        fi
    else
        if [ "$is_local_server" = "true" ]; then
            pkill -f "iperf3 -s -p $port" 2>/dev/null || true
        else
            set_ssh_password "$server_ip"
            local server_ssh=$(get_ssh_command "$server_ip")
            eval "$server_ssh 'killall iperf3 2>/dev/null || true'" > /dev/null 2>&1
        fi
        sleep 1
    fi
    
    # Output summary of results to terminal
    if [ ${#results[@]} -gt 0 ]; then
        echo ""
        for result in "${results[@]}"; do
            IFS='|' read -r src dst bw <<< "$result"
            echo "- $src -> $dst = ${bw} MB/s"
        done
    fi
    
    echo ""
    echo "✓ Serial network test completed"
    
    end_timer "network_test_serial"
    return 0
}


# Partition all host pairs into batches with no shared nodes within each batch
# Uses circle method for even N, modified circle method for odd N
# Output: one batch per line, pairs separated by commas, each pair as "src|dst"
partition_pairs_into_batches() {
    local num_hosts=$1
    shift
    local host_ips=("$@")
    
    # For even N: use circle method (N-1 rounds, each with N/2 pairs)
    # For odd N: use modified circle method (N rounds, each with (N-1)/2 pairs, one host rests per round)
    
    if [ $((num_hosts % 2)) -eq 0 ]; then
        # Even N: standard circle method
        # Algorithm: fix host 0, rotate remaining hosts in a circle
        local m=$((num_hosts - 1))
        for ((round=0; round<m; round++)); do
            local arranged=()
            arranged[0]=0
            for ((pos=1; pos<=m; pos++)); do
                arranged[$pos]=$(( (pos + round - 1) % m + 1 ))
            done
            
            # Pair: (arr[0],arr[1]), (arr[2],arr[m]), (arr[3],arr[m-1]), ...
            local batch_pairs=()
            batch_pairs+=("${host_ips[${arranged[0]}]}|${host_ips[${arranged[1]}]}")
            
            local left=2
            local right=$m
            while [ $left -lt $right ]; do
                local idx1=${arranged[$left]}
                local idx2=${arranged[$right]}
                if [ "$idx1" -lt "$idx2" ]; then
                    batch_pairs+=("${host_ips[$idx1]}|${host_ips[$idx2]}")
                else
                    batch_pairs+=("${host_ips[$idx2]}|${host_ips[$idx1]}")
                fi
                left=$((left + 1))
                right=$((right - 1))
            done
            
            echo "$(IFS=,; echo "${batch_pairs[*]}")"
        done
    else
        # Odd N: use dummy host + circle method
        # Add a dummy host to make N+1 (even), use circle method, skip pairs with dummy
        local even_n=$((num_hosts + 1))
        local m=$((even_n - 1))
        
        for ((round=0; round<m; round++)); do
            # Build arrangement for this round
            local arranged=()
            arranged[0]=0
            for ((pos=1; pos<=m; pos++)); do
                arranged[$pos]=$(( (pos + round - 1) % m + 1 ))
            done
            
            # Pair hosts, skip any pair involving the dummy (index = num_hosts)
            local batch_pairs=()
            
            # First pair
            if [ "${arranged[0]}" -lt "$num_hosts" ] && [ "${arranged[1]}" -lt "$num_hosts" ]; then
                local idx1=${arranged[0]}
                local idx2=${arranged[1]}
                if [ "$idx1" -lt "$idx2" ]; then
                    batch_pairs+=("${host_ips[$idx1]}|${host_ips[$idx2]}")
                else
                    batch_pairs+=("${host_ips[$idx2]}|${host_ips[$idx1]}")
                fi
            fi
            
            # Remaining pairs
            local left=2
            local right=$m
            while [ $left -lt $right ]; do
                local idx1=${arranged[$left]}
                local idx2=${arranged[$right]}
                
                # Only include if both are real hosts (not dummy)
                if [ "$idx1" -lt "$num_hosts" ] && [ "$idx2" -lt "$num_hosts" ]; then
                    if [ "$idx1" -lt "$idx2" ]; then
                        batch_pairs+=("${host_ips[$idx1]}|${host_ips[$idx2]}")
                    else
                        batch_pairs+=("${host_ips[$idx2]}|${host_ips[$idx1]}")
                    fi
                fi
                
                left=$((left + 1))
                right=$((right - 1))
            done
            
            if [ ${#batch_pairs[@]} -gt 0 ]; then
                echo "$(IFS=,; echo "${batch_pairs[*]}")"
            fi
        done
    fi
}


# Run a single matrix test pair (server start -> client test -> server stop)
run_single_matrix_pair() {
    local src="$1"
    local dst="$2"
    local port="$3"
    local duration="$4"
    local parallel="$5"
    local LOCAL_IP="$6"
    local pair_idx="$7"
    
    local client_output_file="$TMP_DIR/network_matrix_${pair_idx}_${TIMESTAMP}.json"
    local client_text_output="$TMP_DIR/network_matrix_${pair_idx}_${TIMESTAMP}_text.log"
    local client_timeout=$((duration + 15))
    local result="0"
    
    # Start iperf3 server on destination
    set_ssh_password "$dst"
    local dst_ssh=$(get_ssh_command "$dst")
    
    if [ "$DRY_RUN" = true ]; then
        echo "[DRY RUN] $dst_ssh 'iperf3 -s -p $port -D'"
    else
        eval "$dst_ssh 'iperf3 -s -p $port -D'"
        
        # Wait for remote server port to be ready
        if ! wait_for_iperf3_server "$dst_ssh" "$port" "true" 15 "true"; then
            echo "  ⚠ Server $dst:$port startup timeout after 15s"
        fi
    fi
    
    # Run iperf3 client from source
    if [ "$DRY_RUN" = true ]; then
        if [ "$src" = "$LOCAL_IP" ]; then
            echo "[DRY RUN] timeout --signal=KILL $client_timeout iperf3 -c \"$dst\" -p \"$port\" -t \"$duration\" -P \"$parallel\" -J"
        else
            local src_ssh=$(get_ssh_command "$src")
            echo "[DRY RUN] timeout --signal=KILL $client_timeout $src_ssh 'iperf3 -c \"$dst\" -p \"$port\" -t \"$duration\" -P \"$parallel\" -J'"
        fi
    else
        if [ "$src" = "$LOCAL_IP" ]; then
            # Run locally
            if timeout --signal=KILL $client_timeout iperf3 -c "$dst" -p "$port" -t "$duration" -P "$parallel" -J > "$client_output_file" 2>&1; then
                generate_iperf3_text_from_json "$client_output_file" "$client_text_output"
            else
                echo "  ⚠ Test failed: $src -> $dst"
                eval "$dst_ssh 'killall iperf3 2>/dev/null || true'" > /dev/null 2>&1
                echo "$src|$dst|0"
                return
            fi
        else
            # Run via SSH
            set_ssh_password "$src"
            local src_ssh=$(get_ssh_command "$src")
            if eval "timeout --signal=KILL $client_timeout $src_ssh 'iperf3 -c \"$dst\" -p \"$port\" -t \"$duration\" -P \"$parallel\" -J'" > "$client_output_file" 2>&1; then
                generate_iperf3_text_from_json "$client_output_file" "$client_text_output"
            else
                echo "  ⚠ Test failed: $src -> $dst"
                eval "$dst_ssh 'killall iperf3 2>/dev/null || true'" > /dev/null 2>&1
                echo "$src|$dst|0"
                return
            fi
        fi
        
        # Parse result
        if [ -f "$client_output_file" ]; then
            local bandwidth=$(parse_iperf3_matrix_result "$client_output_file")
            result="$bandwidth"
            
            # Display per-second throughput
            display_per_second_throughput "$client_text_output" "$dst (from $src)"
            
            # Append to combined results file
            append_to_original "NETWORK MATRIX TEST RESULTS ($src -> $dst)" "$client_text_output"
            
            echo "  ✓ Test completed: $src -> $dst = ${bandwidth} MB/s"
        else
            echo "  ⚠ Test failed: $src -> $dst (no output file)"
        fi
    fi
    
    # Stop iperf3 server on destination
    if [ "$DRY_RUN" = true ]; then
        echo "[DRY RUN] Would stop iperf3 server on $dst"
        echo "[DRY RUN] $dst_ssh 'pkill -f \"iperf3 -s -p $port\"'"
    else
        eval "$dst_ssh 'killall iperf3 2>/dev/null || true'" > /dev/null 2>&1
        sleep 1
    fi
    
    echo "$src|$dst|$result"
}


# Run a batch of matrix test pairs in parallel
run_matrix_batch() {
    local batch_idx="$1"
    local base_port="$2"
    local duration="$3"
    local parallel="$4"
    local LOCAL_IP="$5"
    shift 5
    local pairs=("$@")
    
    local batch_size=${#pairs[@]}
    echo ""
    echo "  [Batch $batch_idx] Running $batch_size pairs in parallel..."
    
    # Start all batch servers in parallel
    local server_ports=()
    local server_dsts=()
    local pair_idx=0
    
    # Calculate timeout parameters for server:
    # --idle-timeout: 600 seconds (10 minutes) for automatic cleanup
    # --rcv-timeout: (duration + 30) * 1000 milliseconds to support long tests
    local server_idle_timeout=600
    local server_rcv_timeout=$(( (duration + 30) * 1000 ))
    
    debug_log "MATRIX_BATCH_START" "batch=$batch_idx" "base_port=$base_port" "duration=$duration" "parallel=$parallel" "pairs=${#pairs[@]}"
    
    for pair in "${pairs[@]}"; do
        IFS='|' read -r src dst <<< "$pair"
        local port=$((base_port + pair_idx))
        
        echo "    Starting server on $dst with port $port..."
        set_ssh_password "$dst"
        local dst_ssh=$(get_ssh_command "$dst")
        
        if [ "$DRY_RUN" = true ]; then
            echo "    [DRY RUN] $dst_ssh 'iperf3 -s -p $port -D --idle-timeout $server_idle_timeout --rcv-timeout $server_rcv_timeout'"
        else
            # iperf3 -D daemonizes itself, so no & needed; SSH session returns immediately
            if [ "$DEBUG" = "true" ]; then
                # Capture output for diagnostic when debug mode is enabled
                local server_output
                server_output=$(eval "$dst_ssh 'iperf3 -s -p $port -D --idle-timeout $server_idle_timeout --rcv-timeout $server_rcv_timeout'" 2>&1)
                local server_exit=$?
                debug_log "SERVER_START_RESULT" "pair=$src|$dst" "port=$port" "exit_code=$server_exit" "output=$server_output"
            else
                eval "$dst_ssh 'iperf3 -s -p $port -D --idle-timeout $server_idle_timeout --rcv-timeout $server_rcv_timeout'"
            fi
            server_ports+=("$port")
            server_dsts+=("$dst")
        fi
        
        pair_idx=$((pair_idx + 1))
    done
    
    # Wait for all batch servers to be ready (polls every 1s internally)
    # Retry mechanism: if server startup fails, kill all iperf3 processes and retry up to 2 times
    if [ "$DRY_RUN" != true ]; then
        local server_ready=true
        local max_retries=2
        local retry=0

        while [ $retry -lt $max_retries ]; do
            if [ $retry -gt 0 ]; then
                echo "    Retrying server startup (attempt $((retry + 1))/$max_retries)..."
                # Clean up all iperf3 processes on destination hosts before retry
                local retry_pair=0
                for pair in "${pairs[@]}"; do
                    IFS='|' read -r src dst <<< "$pair"
                    set_ssh_password "$dst"
                    local dst_ssh=$(get_ssh_command "$dst")
                    eval "$dst_ssh 'killall iperf3 2>/dev/null || true'" > /dev/null 2>&1
                    retry_pair=$((retry_pair + 1))
                done
                sleep 1
                # Restart servers
                pair_idx=0
                for pair in "${pairs[@]}"; do
                    IFS='|' read -r src dst <<< "$pair"
                    local port=$((base_port + pair_idx))
                    set_ssh_password "$dst"
                    local dst_ssh=$(get_ssh_command "$dst")
                    eval "$dst_ssh 'iperf3 -s -p $port -D --idle-timeout $server_idle_timeout --rcv-timeout $server_rcv_timeout'"
                    pair_idx=$((pair_idx + 1))
                done
                sleep 2
            fi

            server_ready=true
            local pair_check=0
            for pair in "${pairs[@]}"; do
                IFS='|' read -r src dst <<< "$pair"
                local port=$((base_port + pair_check))

                set_ssh_password "$dst"
                local dst_ssh=$(get_ssh_command "$dst")

                # wait_for_iperf3_server internally polls every 1s up to timeout seconds
                debug_log "SERVER_CHECK_START" "pair=$src|$dst" "port=$port" "timeout=15"
                if wait_for_iperf3_server "$dst_ssh" "$port" "true" 15 "true"; then
                    echo "    ✓ Server $dst:$port ready"
                    debug_log "SERVER_CHECK_OK" "pair=$src|$dst" "port=$port"
                else
                    echo "    ✗ Server $dst:$port not ready"
                    debug_log "SERVER_CHECK_FAIL" "pair=$src|$dst" "port=$port" "retry=$retry"
                    server_ready=false
                fi

                pair_check=$((pair_check + 1))
            done

            if [ "$server_ready" = true ]; then
                break
            fi

            retry=$((retry + 1))
        done

        if [ "$server_ready" = false ]; then
            echo "    ✗ ERROR: Server startup failed after $max_retries retries"
            # Still return results for all pairs with 0 bandwidth
            for pair in "${pairs[@]}"; do
                IFS='|' read -r src dst <<< "$pair"
                echo "RESULT:$src|$dst|0"
            done
            return 0
        fi
    fi
    
    # Run all clients in parallel
    local client_pids=()
    local client_output_files=()
    local client_results=()
    pair_idx=0
    
    debug_log "CLIENT_EXECUTION_START" "batch=$batch_idx" "client_count=${#pairs[@]}"
    
    for pair in "${pairs[@]}"; do
        IFS='|' read -r src dst <<< "$pair"
        local port=$((base_port + pair_idx))
        local client_output_file="$TMP_DIR/network_matrix_${batch_idx}_${pair_idx}_${TIMESTAMP}.json"
        local client_text_output="$TMP_DIR/network_matrix_${batch_idx}_${pair_idx}_${TIMESTAMP}_text.log"
        local client_timeout=$((duration + 30))  # Increased from 15s to 30s buffer
        
        echo "    Running client: $src -> $dst (port $port)..."
        
        if [ "$DRY_RUN" = true ]; then
            if [ "$src" = "$LOCAL_IP" ]; then
                echo "    [DRY RUN] timeout --signal=KILL $client_timeout iperf3 -c \"$dst\" -p \"$port\" -t \"$duration\" -P \"$parallel\" --connect-timeout 3000 -J"
            else
                local src_ssh=$(get_ssh_command "$src")
                echo "    [DRY RUN] timeout --signal=KILL $client_timeout $src_ssh 'iperf3 -c \"$dst\" -p \"$port\" -t \"$duration\" -P \"$parallel\" --connect-timeout 3000 -J'"
            fi
            client_results+=("$src|$dst|0")
        else
            if [ "$src" = "$LOCAL_IP" ]; then
                debug_log "CLIENT_LAUNCH_LOCAL" "pair=$src|$dst" "port=$port" "timeout=$client_timeout" "output=$client_output_file"
                timeout --signal=KILL $client_timeout iperf3 -c "$dst" -p "$port" -t "$duration" -P "$parallel" --connect-timeout 3000 -J > "$client_output_file" 2>&1 &
                client_pids+=($!)
            else
                set_ssh_password "$src"
                local src_ssh=$(get_ssh_command "$src")
                local ssh_cmd="timeout --signal=KILL $client_timeout $src_ssh 'iperf3 -c \"$dst\" -p \"$port\" -t \"$duration\" -P \"$parallel\" --connect-timeout 3000 -J'"
                debug_log "CLIENT_LAUNCH_SSH" "pair=$src|$dst" "port=$port" "timeout=$client_timeout" "output=$client_output_file" "cmd=$ssh_cmd"
                eval "$ssh_cmd" > "$client_output_file" 2>&1 &
                client_pids+=($!)
            fi
            client_output_files+=("$client_output_file|$client_text_output|$src|$dst")
        fi
        
        pair_idx=$((pair_idx + 1))
    done
    
    # Wait for all clients to complete
    if [ "$DRY_RUN" != true ]; then
        local wait_idx=0
        debug_log "CLIENT_WAIT_START" "waiting_for=${#client_pids[@]} clients"
        for pid in "${client_pids[@]}"; do
            wait $pid 2>/dev/null
            local exit_code=$?
            debug_log "CLIENT_WAIT_RESULT" "pid=$pid" "idx=$wait_idx" "exit_code=$exit_code"
            wait_idx=$((wait_idx + 1))
        done
        
        # Parse results for all pairs
        pair_idx=0
        for output_info in "${client_output_files[@]}"; do
            IFS='|' read -r client_output_file client_text_output src dst <<< "$output_info"
            IFS='|' read -r pair_src pair_dst <<< "${pairs[$pair_idx]}"
            
            debug_log "RESULT_PARSE_START" "pair=$pair_src->$pair_dst" "json_file=$client_output_file"
            
            if [ -f "$client_output_file" ]; then
                local file_size
                file_size=$(wc -c < "$client_output_file" 2>/dev/null || echo "unknown")
                debug_log "RESULT_FILE_INFO" "pair=$pair_src->$pair_dst" "size=${file_size}bytes" "first_200=$(head -c 200 "$client_output_file" 2>/dev/null | tr '\n' ' ')"
                
                generate_iperf3_text_from_json "$client_output_file" "$client_text_output"
                local bandwidth=$(parse_iperf3_matrix_result "$client_output_file")
                debug_log "RESULT_BANDWIDTH" "pair=$pair_src->$pair_dst" "bandwidth=$bandwidth"
                
                display_per_second_throughput "$client_text_output" "$pair_dst (from $pair_src)"
                append_to_original "NETWORK MATRIX TEST RESULTS ($pair_src -> $pair_dst)" "$client_text_output"
                
                # Check for zero bandwidth - indicates connection failure
                if [ "$bandwidth" = "0" ] || [ "$bandwidth" = "0.00" ]; then
                    echo "    ✗ ERROR: Zero bandwidth for $pair_src -> $pair_dst (server may not have started properly)"
                    debug_log "RESULT_ZERO_BW" "pair=$pair_src->$pair_dst" "json_file=$client_output_file" "full_content=$(cat "$client_output_file" 2>/dev/null | tr '\n' ' ')"
                    client_results+=("$pair_src|$pair_dst|0")
                else
                    echo "    ✓ Test completed: $pair_src -> $pair_dst = ${bandwidth} MB/s"
                    client_results+=("$pair_src|$pair_dst|$bandwidth")
                fi
            else
                echo "    ⚠ Test failed: $pair_src -> $pair_dst (timeout or error)"
                debug_log "RESULT_FILE_MISSING" "pair=$pair_src->$pair_dst" "expected_file=$client_output_file"
                client_results+=("$pair_src|$pair_dst|0")
            fi
            
            pair_idx=$((pair_idx + 1))
        done
    fi
    
    # Stop all servers
    if [ "$DRY_RUN" = true ]; then
        pair_idx=0
        for pair in "${pairs[@]}"; do
            IFS='|' read -r src dst <<< "$pair"
            local port=$((base_port + pair_idx))
            set_ssh_password "$dst"
            local dst_ssh=$(get_ssh_command "$dst")
            echo "    [DRY RUN] $dst_ssh 'pkill -f \"iperf3 -s -p $port\"'"
            pair_idx=$((pair_idx + 1))
        done
    else
        debug_log "SERVER_CLEANUP_START" "batch=$batch_idx" "server_count=${#server_dsts[@]}"
        pair_idx=0
        for dst in "${server_dsts[@]}"; do
            local port=${server_ports[$pair_idx]}
            set_ssh_password "$dst"
            local dst_ssh=$(get_ssh_command "$dst")
            if [ "$DEBUG" = "true" ]; then
                local cleanup_output
                cleanup_output=$(eval "$dst_ssh 'killall iperf3 2>/dev/null || true'" 2>&1)
                debug_log "SERVER_CLEANUP_RESULT" "dst=$dst" "port=$port" "output=$cleanup_output"
            else
                eval "$dst_ssh 'killall iperf3 2>/dev/null || true'" > /dev/null 2>&1
            fi
            pair_idx=$((pair_idx + 1))
        done
        debug_log "SERVER_CLEANUP_WAIT" "wait=2s"
        sleep 2
    fi
    
    debug_log "MATRIX_BATCH_END" "batch=$batch_idx" "results=${#client_results[@]}"
    
    # Return results
    for result in "${client_results[@]}"; do
        echo "RESULT:$result"
    done
}



# Matrix network test (all-to-all cross testing)
# Supports batch parallel execution when num_hosts > 3
run_matrix_network_test() {
    start_timer "network_test_matrix"
    echo "=== Matrix Network Performance Test (All-to-All) ==="
    debug_log "MATRIX_NETWORK_TEST_START"
    
    # Get local IP address
    local LOCAL_IP=$(hostname -I | awk '{print $1}')
    debug_log "LOCAL_IP" "ip=$LOCAL_IP"
    
    local port="$NETWORK_PORT"
    local duration="$DURATION"
    local parallel="${NETWORK_PARALLEL:-1}"
    
    # Create output directory if it doesn't exist
    local output_dir="$OUTPUT_DIR"
    mkdir -p "$output_dir"
    
    # Get all host IPs from server list or NETWORK_CLIENT_IP
    local host_ips=()
    if [ ${#target_servers[@]} -gt 0 ]; then
        host_ips=(${target_servers[@]})
    else
        # Use NETWORK_CLIENT_IP if server list not provided
        local client_ip="${NETWORK_CLIENT_IP:-}"
        if [ -z "$client_ip" ]; then
            echo "Skipping matrix network test: No client IPs configured"
            return 0
        fi
        host_ips=($client_ip)
    fi
    
    local num_hosts=${#host_ips[@]}
    
    if [ $num_hosts -lt 2 ]; then
        echo "Skipping matrix network test: At least 2 hosts required for matrix testing"
        return 0
    fi
    
    echo "Starting matrix network test..."
    echo "  Hosts: ${host_ips[*]}"
    echo "  Test duration: ${duration}s per pair"
    echo "  Parallel connections: $parallel"
    local total_pairs=$((num_hosts * (num_hosts - 1) / 2))
    echo "  Total test pairs: $total_pairs"
    
    # Clean up any residual iperf3 processes on all hosts before starting
    echo "  Cleaning up residual iperf3 processes..."
    for host in "${host_ips[@]}"; do
        set_ssh_password "$host"
        local host_ssh=$(get_ssh_command "$host")
        eval "$host_ssh 'killall iperf3 2>/dev/null || true'" > /dev/null 2>&1
    done
    
    # Determine execution mode: serial vs batch parallel
    local use_batch_parallel=false
    local batch_size=1
    
    if [ $num_hosts -gt 3 ]; then
        batch_size=$((num_hosts / 2))
        use_batch_parallel=true
        echo "  Execution mode: Batch parallel (batch_size=$batch_size)"
        debug_log "EXECUTION_MODE" "mode=batch_parallel" "batch_size=$batch_size" "num_hosts=$num_hosts"
    else
        echo "  Execution mode: Serial (num_hosts <= 3, cannot batch)"
        debug_log "EXECUTION_MODE" "mode=serial" "num_hosts=$num_hosts"
    fi
    
    # Create results array
    local results=()
    
    if [ "$use_batch_parallel" = true ]; then
        # Batch parallel execution mode
        # Generate all batches at once using greedy partitioning
        local all_batches=()
        debug_log "BATCH_PARTITION_START"
        while IFS= read -r batch_line; do
            [ -n "$batch_line" ] && all_batches+=("$batch_line")
        done < <(partition_pairs_into_batches $num_hosts "${host_ips[@]}")
        debug_log "BATCH_PARTITION_RESULT" "total_batches=${#all_batches[@]}" "batches=$(IFS=';'; echo "${all_batches[*]}")"
        
        local num_batches=${#all_batches[@]}
        echo "  Total batches: $num_batches"
        
        for ((batch_idx=0; batch_idx<num_batches; batch_idx++)); do
            local batch_line="${all_batches[$batch_idx]}"
            local batch_pairs=()
            IFS=',' read -ra batch_pairs <<< "$batch_line"
            
            local batch_count=${#batch_pairs[@]}
            echo ""
            echo "  === Batch $((batch_idx + 1))/$num_batches ==="
            echo "  Pairs in this batch: $batch_count"
            for pair in "${batch_pairs[@]}"; do
                echo "    $pair"
            done
            
            # Run batch in parallel and collect results
            if [ "$DRY_RUN" = true ]; then
                run_matrix_batch $((batch_idx + 1)) "$port" "$duration" "$parallel" "$LOCAL_IP" "${batch_pairs[@]}"
                for pair in "${batch_pairs[@]}"; do
                    IFS='|' read -r src dst <<< "$pair"
                    results+=("$src|$dst|0")
                done
            else
                while IFS= read -r line; do
                    if [[ "$line" == RESULT:* ]]; then
                        results+=("${line#RESULT:}")
                    fi
                done < <(run_matrix_batch $((batch_idx + 1)) "$port" "$duration" "$parallel" "$LOCAL_IP" "${batch_pairs[@]}")
            fi

            # Add sleep between batches to ensure old processes are fully cleaned up
            # and ports are released before starting next batch
            if [ $((batch_idx + 1)) -lt $num_batches ] && [ "$DRY_RUN" != true ]; then
                echo "  Waiting for batch cleanup (2s)..."
                debug_log "BATCH_CLEANUP_WAIT" "after_batch=$((batch_idx + 1))" "wait=2s"
                sleep 2
            fi
        done
        
        debug_log "ALL_BATCHES_COMPLETED" "results_count=${#results[@]}"
    else
        # Original serial execution mode
        # Generate host pairs (A→B only, no B→A duplicates)
        local test_pairs=()
        for ((i=0; i<num_hosts; i++)); do
            for ((j=i+1; j<num_hosts; j++)); do
                test_pairs+=("${host_ips[i]}|${host_ips[j]}")
            done
        done
        
        local num_pairs=${#test_pairs[@]}
        echo "  Total test scenarios: $num_pairs"
        echo "  Test pairs: ${test_pairs[*]}"
        
        # Execute tests for each pair serially
        local pair_idx=0
        for pair in "${test_pairs[@]}"; do
            pair_idx=$((pair_idx + 1))
            IFS='|' read -r src dst <<< "$pair"
            
            echo ""
            echo "  [Test $pair_idx/$num_pairs] Testing: $src -> $dst"
            
            # Start iperf3 server on destination
            echo "  Starting iperf3 server on $dst..."
            set_ssh_password "$dst"
            local dst_ssh=$(get_ssh_command "$dst")
            
            # Calculate timeout parameters for server:
            # --idle-timeout: 600 seconds (10 minutes) for automatic cleanup
            # --rcv-timeout: (duration + 30) * 1000 milliseconds to support long tests
            local server_idle_timeout=600
            local server_rcv_timeout=$(( (duration + 30) * 1000 ))
            
            if [ "$DRY_RUN" = true ]; then
                echo "[DRY RUN] $dst_ssh 'iperf3 -s -p $port -D --idle-timeout $server_idle_timeout --rcv-timeout $server_rcv_timeout'"
            else
                eval "$dst_ssh 'iperf3 -s -p $port -D --idle-timeout $server_idle_timeout --rcv-timeout $server_rcv_timeout'"
                
                # Wait for remote server port to be ready
                if ! wait_for_iperf3_server "$dst_ssh" "$port" "true" 15 "true"; then
                    echo "  ⚠ Server $dst:$port startup timeout after 15s"
                fi
            fi
            
            # Run iperf3 client from source
            local client_output_file="$TMP_DIR/network_matrix_${pair_idx}_${TIMESTAMP}.json"
            local client_text_output="$TMP_DIR/network_matrix_${pair_idx}_${TIMESTAMP}_text.log"
            
            echo "  Running iperf3 client from $src to $dst..."
            
            # Calculate timeout: duration + 30s buffer
            local client_timeout=$((duration + 30))
            
            # Check if source is local machine
            if [ "$DRY_RUN" = true ]; then
                echo "[DRY RUN] Would run iperf3 client from $src to $dst"
                if [ "$src" = "$LOCAL_IP" ]; then
                    echo "[DRY RUN] timeout --signal=KILL $client_timeout iperf3 -c \"$dst\" -p \"$port\" -t \"$duration\" -P \"$parallel\" --connect-timeout 3000 -J"
                else
                    local src_ssh=$(get_ssh_command "$src")
                    echo "[DRY RUN] timeout --signal=KILL $client_timeout $src_ssh 'iperf3 -c \"$dst\" -p \"$port\" -t \"$duration\" -P \"$parallel\" --connect-timeout 3000 -J'"
                fi
            else
                if [ "$src" = "$LOCAL_IP" ]; then
                    # Run locally
                    if timeout --signal=KILL $client_timeout iperf3 -c "$dst" -p "$port" -t "$duration" -P "$parallel" --connect-timeout 3000 -J > "$client_output_file" 2>&1; then
                        # Generate text format from JSON
                        generate_iperf3_text_from_json "$client_output_file" "$client_text_output"
                    else
                        results+=("$src|$dst|0")
                        echo "  ⚠ Test failed: $src -> $dst"
                        # Stop iperf3 server on destination
                        eval "$dst_ssh 'killall iperf3 2>/dev/null || true'" > /dev/null 2>&1
                        continue
                    fi
                else
                    # Run via SSH
                    set_ssh_password "$src"
                    local src_ssh=$(get_ssh_command "$src")
                    if eval "timeout --signal=KILL $client_timeout $src_ssh 'iperf3 -c \"$dst\" -p \"$port\" -t \"$duration\" -P \"$parallel\" --connect-timeout 3000 -J'" > "$client_output_file" 2>&1; then
                        # Generate text format from JSON
                        generate_iperf3_text_from_json "$client_output_file" "$client_text_output"
                    else
                        results+=("$src|$dst|0")
                        echo "  ⚠ Test failed: $src -> $dst"
                        # Stop iperf3 server on destination
                        eval "$dst_ssh 'killall iperf3 2>/dev/null || true'" > /dev/null 2>&1
                        continue
                    fi
                fi
            fi
            
            # Parse result
            if [ "$DRY_RUN" != true ] && [ -f "$client_output_file" ]; then
                local bandwidth=$(parse_iperf3_matrix_result "$client_output_file")
                results+=("$src|$dst|$bandwidth")
                
                # Display per-second throughput
                display_per_second_throughput "$client_text_output" "$dst (from $src)"
                
                # Append to combined results file
                append_to_original "NETWORK MATRIX TEST RESULTS ($src -> $dst)" "$client_text_output"
                
                echo "  ✓ Test completed: $src -> $dst = ${bandwidth} MB/s"
            else
                if [ "$DRY_RUN" = true ]; then
                    results+=("$src|$dst|0")
                    echo "  [DRY RUN] Test would complete: $src -> $dst"
                else
                    results+=("$src|$dst|0")
                    echo "  ⚠ Test failed: $src -> $dst"
                fi
            fi
            
            # Stop iperf3 server on destination
            if [ "$DRY_RUN" = true ]; then
                echo "[DRY RUN] Would stop iperf3 server on $dst"
                echo "[DRY RUN] $dst_ssh 'pkill -f \"iperf3 -s -p $port\"'"
            else
                eval "$dst_ssh 'killall iperf3 2>/dev/null || true'" > /dev/null 2>&1
                sleep 1
            fi
        done
    fi
    
    # Final cleanup: Ensure all iperf3 processes are stopped on all hosts
    echo "  Performing final cleanup of iperf3 processes..."
    for host in "${host_ips[@]}"; do
        set_ssh_password "$host"
        local host_ssh=$(get_ssh_command "$host")
        eval "$host_ssh 'killall iperf3 2>/dev/null || true'" > /dev/null 2>&1
    done
    
    # Generate matrix report
    generate_matrix_report results host_ips
    
    # Output summary of results to terminal
    if [ ${#results[@]} -gt 0 ]; then
        echo ""
        for result in "${results[@]}"; do
            IFS='|' read -r src dst bw <<< "$result"
            echo "- $src -> $dst = ${bw} MB/s"
        done
    fi
    
    echo ""
    echo "✓ Matrix network test completed"
    
    end_timer "network_test_matrix"
}

# Parallel network test (concurrent testing)
