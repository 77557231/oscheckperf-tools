                current_threads_avg_lat=$(echo "$line" | awk '{print $NF}' | tr -d ',')
            elif [[ "$line" =~ "min:" ]] && [[ ! "$line" =~ "execution time" ]]; then
                current_threads_min_lat=$(echo "$line" | awk '{print $NF}' | tr -d ',')
            elif [[ "$line" =~ "max:" ]] && [[ ! "$line" =~ "execution time" ]]; then
                current_threads_max_lat=$(echo "$line" | awk '{print $NF}' | tr -d ',')
            elif [[ "$line" =~ "95th percentile" ]]; then
