            fi
            in_section=true
            current_server_ip=$(echo "$line" | grep -oP 'Server: \K[0-9.]+' || echo "N/A")
            current_eps=""
            current_avg_lat=""
            current_p95_lat=""
            current_max_lat=""
            current_min_lat=""
            current_sum_lat=""
            current_fairness=""
        elif [[ "$line" =~ "MEMORY TEST RESULTS" || "$line" =~ "SYSBENCH FILEIO TEST RESULTS" || "$line" =~ "THREADS TEST RESULTS" || "$line" =~ "MUTEX TEST RESULTS" || "$line" =~ "NETWORK TEST RESULTS" ]]; then
