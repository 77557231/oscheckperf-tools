# Parse mutex result
parse_mutex_result() {
    local result_file="$1"
    
    # Extract metrics (sysbench 1.0.20 format)
    local transactions=$(grep "total number of events:" "$result_file" 2>/dev/null | awk '{print $NF}' || echo "0")
    local total_time=$(grep "total time:" "$result_file" 2>/dev/null | awk '{print $NF}' | tr -d 's' || echo "1")
    local tps=$(awk "BEGIN {printf \"%.2f\", $transactions / $total_time}" 2>/dev/null || echo "0")
    local avg_latency=$(grep "avg:" "$result_file" 2>/dev/null | head -1 | awk '{print $NF}' | tr -d ',' || echo "0")
    local min_latency=$(grep -A5 "Latency (ms):" "$result_file" 2>/dev/null | grep "min:" | awk '{print $NF}' | tr -d ',' || echo "N/A")
    local max_latency=$(grep -A5 "Latency (ms):" "$result_file" 2>/dev/null | grep "max:" | awk '{print $NF}' | tr -d ',' || echo "N/A")
    local p95_latency=$(grep "95th percentile" "$result_file" 2>/dev/null | awk '{print $NF}' || echo "0")
    
    # Calculate Sum Latency: transactions * avg_latency
    local sum_latency=$(echo "$transactions" "$avg_latency" 2>/dev/null | awk '{if($2>0) printf "%.2f", $1 * $2; else print "N/A"}')
    
    # Display detailed summary
    echo ""
    echo "Mutex test summary:"
    echo "  total number of events: $transactions"
    echo "  total time: ${total_time}s"
    echo "  Transactions: $transactions"
    echo "  TPS: $tps"
    echo "  Avg Latency: ${avg_latency}ms"
    if [ -n "$min_latency" ] && [ "$min_latency" != "N/A" ]; then
        echo "  Min Latency: ${min_latency}ms"
    fi
    if [ -n "$max_latency" ] && [ "$max_latency" != "N/A" ]; then
        echo "  Max Latency: ${max_latency}ms"
    fi
    echo "  P95 Latency: ${p95_latency}ms"
    if [ -n "$sum_latency" ] && [ "$sum_latency" != "N/A" ]; then
        echo "  Sum Latency: ${sum_latency}ms"
    fi
}

