# pgbench test function
run_pgbench_test() {
    echo "=== PostgreSQL Benchmark Test ==="
    
    local temp_output_file="$TMP_DIR/vb_pgbench_${TIMESTAMP}.txt"
    local db_name="${PGBENCH_DB:-pgbench_db}"
    local duration="${PGBENCH_DURATION:-300}"
    local threads="${PGBENCH_THREADS:-0}"
    
    if [ "$threads" -eq 0 ]; then
        threads=$(get_cpu_cores)
        echo "Auto-detected CPU cores: $threads"
    fi
    
    # Only display test info in non-remote mode
    if [ "$REMOTE" != "true" ]; then
        echo "Starting pgbench test..."
        echo "  Database: $db_name, Threads: $threads, Duration: ${duration}s"
        
        # Create database if it doesn't exist
        echo "  Creating database $db_name if it doesn't exist..."
        run_command "psql -c \"CREATE DATABASE $db_name\" 2>/dev/null || true" "/dev/null"
        
        # Initialize pgbench schema
        echo "  Initializing pgbench schema..."
        run_command "pgbench -i -s 1 $db_name" "/dev/null"
        
        # Run pgbench test
        echo "  Running pgbench benchmark..."
    else
        # In remote mode, run commands without output
        run_command "psql -c \"CREATE DATABASE $db_name\" 2>/dev/null || true" "/dev/null"
        run_command "pgbench -i -s 1 $db_name" "/dev/null"
    fi
    run_command "pgbench -c $threads -j $threads -T $duration -r $db_name" "$temp_output_file"
    
    # Display result
    if [ "$DRY_RUN" != true ] && [ -f "$temp_output_file" ]; then
        # Only display output in non-remote mode
        if [ "$REMOTE" != "true" ]; then
            echo ""
            echo "pgbench test results:"
            cat "$temp_output_file"
        fi
        
        # Append to combined results file
        append_to_original "PGBENCH TEST RESULTS" "$temp_output_file"
    fi
    
    # Cleanup temp file
    rm -f "$temp_output_file"
    
    # Only display completion message in non-remote mode
    if [ "$REMOTE" != "true" ]; then
        echo "✓ pgbench test completed"
    fi
}

# Generate report
generate_report() {
    local report_file="$OUTPUT_DIR/report_benchmark_${TIMESTAMP}.log"
    local combined_file="$OUTPUT_DIR/original_data_${TIMESTAMP}_all_results.log"
    
    # Fallback to data file if original doesn't exist
    if [ ! -f "$combined_file" ]; then
        combined_file="$OUTPUT_DIR/data_${TIMESTAMP}_all_results.log"
    fi

    # Get system info
    local cpu_cores=$(get_cpu_cores 2>/dev/null || echo "N/A")
    local memory_mb=$(get_memory_size_mb 2>/dev/null || echo "N/A")

    # Unified duration
    local unified_duration="${DURATION:-60}"

    # Get server list and their info
    local server_info=""
    if [ ${#target_servers[@]} -gt 0 ]; then
        server_info="Server List:"
        for ip in "${target_servers[@]}"; do
            if [ "$ip" = "$(get_machine_ip)" ]; then
                # Local server
                local local_cpu=$(get_cpu_cores 2>/dev/null || echo "N/A")
                local local_mem=$(get_memory_size_mb 2>/dev/null || echo "N/A")
                server_info="${server_info}\n  - $ip (local): CPU Cores: ${local_cpu}, Memory Size: ${local_mem} MB"
            else
                # Remote server
                local remote_cpu=$(ssh "$ip" "nproc 2>/dev/null || grep -c ^processor /proc/cpuinfo 2>/dev/null || echo 'N/A'" 2>/dev/null || echo "N/A")
                local remote_mem=$(ssh "$ip" "awk '/MemTotal/ {printf \"%.0f\", \$2/1024}' /proc/meminfo 2>/dev/null || echo 'N/A'" 2>/dev/null || echo "N/A")
                server_info="${server_info}\n  - $ip: CPU Cores: ${remote_cpu}, Memory Size: ${remote_mem} MB"
            fi
        done
    fi

    # Generate report
    printf -- "================================================================================\n" > "$report_file"
    printf -- "                    Database System Benchmark Report\n" >> "$report_file"
    printf -- "================================================================================\n" >> "$report_file"
    printf -- "\n" >> "$report_file"
    printf -- "Basic Information\n" >> "$report_file"
    printf -- "-----------------\n" >> "$report_file"
    printf -- "Test Time: $(date '+%Y-%m-%d %H:%M:%S')\n" >> "$report_file"
    printf -- "Hostname: ${HOSTNAME:-N/A}\n" >> "$report_file"
    printf -- "CPU Cores: ${cpu_cores}\n" >> "$report_file"
    printf -- "Memory Size: ${memory_mb} MB\n" >> "$report_file"
    printf -- "Unified Duration: ${unified_duration}s\n" >> "$report_file"
    if [ -n "$server_info" ]; then
        echo -e "$server_info" >> "$report_file"
    fi
    printf -- "\n" >> "$report_file"
    printf -- "================================================================================\n" >> "$report_file"
    printf -- "                           Test Configuration\n" >> "$report_file"
    printf -- "================================================================================\n" >> "$report_file"
    printf -- "\n" >> "$report_file"
    printf -- "[CPU Test]\n" >> "$report_file"
    printf -- "  Enabled: ${CPU_ENABLED:-true}\n" >> "$report_file"
    printf -- "  Threads: $(if [ "${CPU_THREADS:-0}" = "0" ]; then echo "auto ($cpu_cores)"; else echo "${CPU_THREADS}"; fi)\n" >> "$report_file"
    printf -- "  Duration: ${unified_duration}s\n" >> "$report_file"
    printf -- "  Max Prime: ${CPU_MAX_PRIME:-20000}\n" >> "$report_file"
    printf -- "\n" >> "$report_file"
    printf -- "[Memory Test]\n" >> "$report_file"
    printf -- "  Enabled: ${MEMORY_ENABLED:-true}\n" >> "$report_file"
    printf -- "  Block Size: ${MEMORY_BLOCK_SIZE:-8K}\n" >> "$report_file"
    printf -- "  Total Size: ${MEMORY_TOTAL_SIZE:-20G}\n" >> "$report_file"
    printf -- "  Operation: ${MEMORY_OPER:-read}\n" >> "$report_file"
    printf -- "  Duration: ${unified_duration}s\n" >> "$report_file"
    printf -- "\n" >> "$report_file"
    printf -- "[IO Test]\n" >> "$report_file"
    printf -- "  Enabled: ${IO_ENABLED:-true}\n" >> "$report_file"
    printf -- "  Tool: ${IO_TOOL:-sysbench}\n" >> "$report_file"
    printf -- "  File Size: ${IO_TOTAL_SIZE:-1G}\n" >> "$report_file"
    if [ "${IO_TOOL:-sysbench}" = "fio" ]; then
        printf -- "  Test Profiles: ${FIO_PROFILES:-randrw}\n" >> "$report_file"
        # Show individual profile configurations
        local profiles="${FIO_PROFILES:-randrw}"
        for profile in $profiles; do
            local rw_type="${profile}"
            local bs="${FIO_BS:-8K}"
            local iodepth="${FIO_IODEPTH:-64}"
            local numjobs="${FIO_NUMJOBS:-4}"
            printf -- "  Profile %s: rw=%s, bs=%s, iodepth=%s, numjobs=%s\n" "$profile" "$rw_type" "$bs" "$iodepth" "$numjobs" >> "$report_file"
        done
    else
        printf -- "  Test Mode: ${SYSBENCH_PROFILES:-rndrw}\n" >> "$report_file"
    fi
    # Support new IO_PATH parameter with backward compatibility to IO_TEST_PATH
    printf -- "  Test Path: ${IO_PATH:-${IO_TEST_PATH:-$HOME/oscheckperf/io_test}}\n" >> "$report_file"
    printf -- "  Duration: $(if [ "${IO_TOOL:-sysbench}" = "fio" ]; then echo "${FIO_DURATION:-$unified_duration}s"; else echo "${SYSBENCH_DURATION:-$unified_duration}s"; fi)\n" >> "$report_file"
    printf -- "\n" >> "$report_file"
    printf -- "[Network Test]\n" >> "$report_file"
    printf -- "  Enabled: ${NETWORK_ENABLED:-true}\n" >> "$report_file"
    printf -- "  Tool: ${NETWORK_TOOL:-iperf3}\n" >> "$report_file"
    printf -- "  Server: ${NETWORK_SERVER_IP:-auto}\n" >> "$report_file"
    printf -- "  Port: ${NETWORK_PORT:-25201}\n" >> "$report_file"
    printf -- "  Duration: ${unified_duration}s\n" >> "$report_file"
    printf -- "  Parallel: ${NETWORK_PARALLEL:-1}\n" >> "$report_file"
    printf -- "\n" >> "$report_file"
    printf -- "[Threads Test]\n" >> "$report_file"
    printf -- "  Enabled: ${THREADS_ENABLED:-true}\n" >> "$report_file"
    printf -- "  Threads: ${THREADS_NUM:-100}\n" >> "$report_file"
    printf -- "  Duration: ${unified_duration}s\n" >> "$report_file"
    printf -- "  Yields: ${THREADS_YIELDS:-100}\n" >> "$report_file"
    printf -- "  Locks: ${THREADS_LOCKS:-4}\n" >> "$report_file"
    printf -- "\n" >> "$report_file"
    printf -- "[Mutex Test]\n" >> "$report_file"
    printf -- "  Enabled: ${MUTEX_ENABLED:-true}\n" >> "$report_file"
    printf -- "  Threads: $(if [ "${MUTEX_THREADS:-0}" = "0" ]; then echo "auto ($cpu_cores)"; else echo "${MUTEX_THREADS}"; fi)\n" >> "$report_file"
    printf -- "  Duration: ${unified_duration}s\n" >> "$report_file"
    printf -- "  Mutex Num: ${MUTEX_NUM:-1024}\n" >> "$report_file"
    printf -- "\n" >> "$report_file"
    printf -- "[pgbench Test]\n" >> "$report_file"
    printf -- "  Enabled: ${PGBENCH_ENABLED:-false}\n" >> "$report_file"
    printf -- "  Database: ${PGBENCH_DB:-pgbench_db}\n" >> "$report_file"
    printf -- "  Duration: ${PGBENCH_DURATION:-300}s\n" >> "$report_file"
    printf -- "  Threads: $(if [ "${PGBENCH_THREADS:-0}" = "0" ]; then echo "auto ($cpu_cores)"; else echo "${PGBENCH_THREADS}"; fi)\n" >> "$report_file"
    printf -- "\n" >> "$report_file"
    printf -- "================================================================================\n" >> "$report_file"
    printf -- "                           Test Results Summary\n" >> "$report_file"
    printf -- "================================================================================\n" >> "$report_file"
    printf -- "\n" >> "$report_file"
    printf -- "[CPU Test]\n" >> "$report_file"

    # Parse CPU results from combined file
    if [ -f "$combined_file" ]; then
        # Check if CPU test results exist
        if grep -q "CPU TEST RESULTS" "$combined_file" 2>/dev/null; then
            # Count CPU test sections (one per server)
            local cpu_section_count=$(grep -c "CPU TEST RESULTS" "$combined_file" 2>/dev/null)
            
            if [ "$cpu_section_count" -gt 1 ]; then
                # Multiple servers - show comparison table
                echo "  CPU Test Comparison (Multiple Servers)" >> "$report_file"
                echo "  ======================================" >> "$report_file"
                printf "  %-20s %-15s %-15s %-15s\n" "Server IP" "Events/sec" "Avg Latency (ms)" "P95 Latency (ms)" >> "$report_file"
                echo "  --------------------------------------" >> "$report_file"
                
                local in_cpu_section=false
                local current_server_ip=""
                local current_eps=""
                local current_avg_lat=""
                local current_p95_lat=""
                
                while IFS= read -r line; do
                    if [[ "$line" =~ "CPU TEST RESULTS" ]]; then
                        if [ "$in_cpu_section" = true ] && [ -n "$current_server_ip" ]; then
                            printf "  %-20s %-15s %-15s %-15s\n" "$current_server_ip" "${current_eps:-N/A}" "${current_avg_lat:-N/A}" "${current_p95_lat:-N/A}" >> "$report_file"
                        fi
                        in_cpu_section=true
                        current_server_ip=$(echo "$line" | grep -oP 'Server: \K[0-9.]+' || echo "N/A")
                        current_eps=""
                        current_avg_lat=""
                        current_p95_lat=""
                    elif [[ "$line" =~ "MEMORY TEST RESULTS" || "$line" =~ "SYSBENCH FILEIO TEST RESULTS" || "$line" =~ "THREADS TEST RESULTS" || "$line" =~ "MUTEX TEST RESULTS" || "$line" =~ "NETWORK TEST RESULTS" ]]; then
                        # End of CPU section when encountering next test type
                        if [ "$in_cpu_section" = true ] && [ -n "$current_server_ip" ]; then
                            printf "  %-20s %-15s %-15s %-15s\n" "$current_server_ip" "${current_eps:-N/A}" "${current_avg_lat:-N/A}" "${current_p95_lat:-N/A}" >> "$report_file"
                        fi
                        in_cpu_section=false
                    elif [ "$in_cpu_section" = true ]; then
                        if [[ "$line" =~ "events per second:" ]]; then
                            current_eps=$(echo "$line" | awk '{print $NF}')
                        elif [[ "$line" =~ "avg:" ]] && [[ "$line" =~ [0-9] ]] && [[ ! "$line" =~ "events (avg/stddev):" ]] && [[ ! "$line" =~ "execution time" ]]; then
                            current_avg_lat=$(echo "$line" | awk '{print $NF}')
                        elif [[ "$line" =~ "95th percentile:" ]]; then
                            current_p95_lat=$(echo "$line" | awk '{print $NF}')
                        fi
                    fi
                done < "$combined_file"
                
                if [ "$in_cpu_section" = true ] && [ -n "$current_server_ip" ]; then
                    printf "  %-20s %-15s %-15s %-15s\n" "$current_server_ip" "${current_eps:-N/A}" "${current_avg_lat:-N/A}" "${current_p95_lat:-N/A}" >> "$report_file"
                fi
            else
                # Single server - show results directly
                local cpu_events=$(grep -A3 "CPU test summary:" "$combined_file" 2>/dev/null | grep "events per second:" | awk '{print $NF}')
                local cpu_avg_lat=$(grep -A5 "CPU test summary:" "$combined_file" 2>/dev/null | grep "Avg Latency:" | awk '{print $NF}' | sed 's/ms//')
                local cpu_p95_lat=$(grep -A6 "CPU test summary:" "$combined_file" 2>/dev/null | grep "P95 Latency:" | awk '{print $NF}' | sed 's/ms//')
                local cpu_threads_fairness_events=$(grep -A10 "CPU test summary:" "$combined_file" 2>/dev/null | grep "events (avg/stddev):" | head -1)
                local cpu_threads_fairness_time=$(grep -A12 "CPU test summary:" "$combined_file" 2>/dev/null | grep "execution time (avg/stddev):" | head -1)

                if [ -n "$cpu_events" ]; then
                    cat >> "$report_file" << EOF
  CPU speed:
    events per second: ${cpu_events}
  Avg Latency:   ${cpu_avg_lat:-0} ms
  P95 Latency:   ${cpu_p95_lat:-0} ms
EOF
                    if [ -n "$cpu_threads_fairness_events" ] || [ -n "$cpu_threads_fairness_time" ]; then
                        echo "  Threads fairness:" >> "$report_file"
                        if [ -n "$cpu_threads_fairness_events" ]; then
                            echo "    ${cpu_threads_fairness_events}" >> "$report_file"
                        fi
                        if [ -n "$cpu_threads_fairness_time" ]; then
                            echo "    ${cpu_threads_fairness_time}" >> "$report_file"
                        fi
                    fi
                else
                    echo "  Test not executed" >> "$report_file"
                fi
            fi
        else
            echo "  Test not executed" >> "$report_file"
        fi
    else
        echo "  Test not executed" >> "$report_file"
    fi

    cat >> "$report_file" << EOF

[Memory Test]
EOF

    if [ -f "$combined_file" ]; then
        if grep -q "MEMORY TEST RESULTS" "$combined_file" 2>/dev/null; then
            local mem_section_count=$(grep -c "MEMORY TEST RESULTS" "$combined_file" 2>/dev/null)
            
            if [ "$mem_section_count" -gt 1 ]; then
                echo "  Memory Test Comparison (Multiple Servers)" >> "$report_file"
                echo "  =========================================" >> "$report_file"
                printf "  %-20s %-15s %-15s %-15s\n" "Server IP" "Ops/sec" "MiB/sec" "Avg Latency (ms)" >> "$report_file"
                echo "  ----------------------------------------" >> "$report_file"
                
                local in_mem_section=false
                local current_server_ip=""
                local current_ops_sec=""
                local current_mib_sec=""
                local current_mem_avg_lat=""
                
                while IFS= read -r line; do
                    if [[ "$line" =~ "MEMORY TEST RESULTS" ]]; then
                        if [ "$in_mem_section" = true ] && [ -n "$current_server_ip" ]; then
                            printf "  %-20s %-15s %-15s %-15s\n" "$current_server_ip" "${current_ops_sec:-N/A}" "${current_mib_sec:-N/A}" "${current_mem_avg_lat:-N/A}" >> "$report_file"
                        fi
                        in_mem_section=true
                        current_server_ip=$(echo "$line" | grep -oP 'Server: \K[0-9.]+' || echo "N/A")
                        current_ops_sec=""
                        current_mib_sec=""
                        current_mem_avg_lat=""
                    elif [[ "$line" =~ "SYSBENCH FILEIO TEST RESULTS" || "$line" =~ "THREADS TEST RESULTS" || "$line" =~ "MUTEX TEST RESULTS" || "$line" =~ "NETWORK TEST RESULTS" ]]; then
                        # End of Memory section when encountering next test type
                        if [ "$in_mem_section" = true ] && [ -n "$current_server_ip" ]; then
                            printf "  %-20s %-15s %-15s %-15s\n" "$current_server_ip" "${current_ops_sec:-N/A}" "${current_mib_sec:-N/A}" "${current_mem_avg_lat:-N/A}" >> "$report_file"
                        fi
                        in_mem_section=false
                    elif [ "$in_mem_section" = true ]; then
                        if [[ "$line" =~ "Total operations:" ]]; then
                            current_ops_sec=$(echo "$line" | awk -F'[()]' '{print $2}' | awk '{print $1}')
                        elif [[ "$line" =~ "MiB transferred" ]]; then
                            current_mib_sec=$(echo "$line" | awk -F'[()]' '{print $2}' | awk '{print $1}')
                        elif [[ "$line" =~ "avg:" ]]; then
                            current_mem_avg_lat=$(echo "$line" | awk '{print $NF}' | tr -d ',')
                        fi
                    fi
                done < "$combined_file"
                
                if [ "$in_mem_section" = true ] && [ -n "$current_server_ip" ]; then
                    printf "  %-20s %-15s %-15s %-15s\n" "$current_server_ip" "${current_ops_sec:-N/A}" "${current_mib_sec:-N/A}" "${current_mem_avg_lat:-N/A}" >> "$report_file"
