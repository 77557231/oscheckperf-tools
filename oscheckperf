        fi
    fi
    
    # Add statistics to report
    cat >> "$report_file" << EOF

================================================================================
                                Statistics
================================================================================
Total bandwidth: $(printf "%.2f" $total_bw) MB/s
Average bandwidth: $(printf "%.2f" $avg_bw) MB/s
Minimum bandwidth: $(printf "%.2f" $min_bw) MB/s
Maximum bandwidth: $(printf "%.2f" $max_bw) MB/s
Median bandwidth: $(printf "%.2f" $median_bw) MB/s
Total test clients: $count

================================================================================
EOF
    
    echo "  ✓ Parallel report generated: $report_file"
    
    # Append report to combined results
    append_to_original "PARALLEL NETWORK TEST REPORT" "$report_file"
}

# Parse iperf3 result for matrix test
parse_iperf3_matrix_result() {
    local json_file="$1"
    
    # Check if jq is installed
    if ! command -v jq &> /dev/null; then
        echo "0"
        return
    fi
    
    if [ ! -f "$json_file" ]; then
        echo "0"
        return
    fi
    
    # Extract JSON content by removing any leading non-JSON text
    local json_content=$(awk 'BEGIN{found=0} /^\{/{found=1} found{print} /^\}/{if(found) exit}' "$json_file" 2>/dev/null || cat "$json_file")
    
    # Extract metrics
    local bandwidth_bps=$(echo "$json_content" | jq -r '.end.sum_received.bits_per_second // 0' 2>/dev/null)
    # Convert bps to MB/s: 1 MB/s = 8,000,000 bps
    local bandwidth_mbs=$(awk "BEGIN {printf \"%.2f\", $bandwidth_bps / 8000000}" 2>/dev/null || echo "0")
    
    echo "$bandwidth_mbs"
}

