# Returns 0 if command is available (either in oscheckperf/bin or system PATH)
# Returns 1 if command is not found anywhere
# Side effect: sets CHECK_CMD_SOURCE to "local", "system", or "not_found"
check_command() {
    local cmd="$1"
    local install_hint="$2"
    local local_bin="$BASE_DIR/bin/$cmd"
    
    # Check if command exists in oscheckperf bin directory
    if [ -x "$local_bin" ]; then
        CHECK_CMD_SOURCE="local"
        return 0
    fi
    
    # Check system PATH
    if command -v "$cmd" &> /dev/null; then
        CHECK_CMD_SOURCE="system"
        return 0
    fi
    
    # Command not found anywhere
    CHECK_CMD_SOURCE="not_found"
    if [ -n "$install_hint" ]; then
        echo "Warning: Command '$cmd' is not installed. $install_hint"
    else
        echo "Warning: Command '$cmd' is not installed"
    fi
    return 1
}

# Require command to exist (exits if not found)
require_command() {
    local cmd="$1"
    local install_hint="$2"
    
    if ! command -v "$cmd" &> /dev/null; then
        echo "Error: Command '$cmd' is required but not installed."
        if [ -n "$install_hint" ]; then
            echo "  Please install it: $install_hint"
        fi
        return 1
    fi
    return 0
}

# Check if jq is available
