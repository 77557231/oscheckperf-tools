# Server credentials storage (associative arrays)
declare -A SERVER_USERNAMES
declare -A SERVER_PASSWORDS

# Check if sshpass is available
check_sshpass() {
    if ! command -v sshpass &> /dev/null; then
        return 1
    fi
    return 0
}

# Parse server entry to extract IP, username, and password
# Format: IP[:username[:password]]
# Sets: LAST_PARSED_IP global variable with the IP
# Side effect: populates SERVER_USERNAMES and SERVER_PASSWORDS arrays
parse_server_entry() {
    local entry="$1"
    local ip=""
    local username=""
    local password=""
    
    # Count colons to determine format
    local colon_count=$(echo "$entry" | grep -o ":" | wc -l)
    
    if [ "$colon_count" -eq 2 ]; then
        # Format: IP:username:password
        ip=$(echo "$entry" | cut -d: -f1)
        username=$(echo "$entry" | cut -d: -f2)
        password=$(echo "$entry" | cut -d: -f3-)
        SERVER_USERNAMES["$ip"]="$username"
        SERVER_PASSWORDS["$ip"]="$password"
    elif [ "$colon_count" -eq 1 ]; then
        # Format: IP:username (no password - treat as password auth with empty password)
        ip=$(echo "$entry" | cut -d: -f1)
        username=$(echo "$entry" | cut -d: -f2)
        SERVER_USERNAMES["$ip"]="$username"
        SERVER_PASSWORDS["$ip"]=""
    else
        # Format: IP only (passwordless)
        ip="$entry"
    fi
    
    LAST_PARSED_IP="$ip"
}

# Check if server uses password authentication
is_password_auth() {
    local ip="$1"
    if [ -n "${SERVER_USERNAMES[$ip]}" ]; then
        return 0
    fi
    return 1
}

# Set SSHPASS environment variable for a server
# Parameters: ip
# Side effect: exports SSHPASS environment variable
set_ssh_password() {
    local ip="$1"
    if is_password_auth "$ip"; then
        local password="${SERVER_PASSWORDS[$ip]}"
        if [ -n "$password" ]; then
            printf -v SSHPASS '%s' "$password"
            export SSHPASS
        fi
    fi
}

# Build authentication prefix for SSH/SCP commands
# Parameters: ip, cmd_type (ssh/scp)
# Returns: Command prefix with proper authentication
build_auth_prefix() {
    local ip="$1"
    local cmd_type="$2"
    local ssh_port=$(get_ssh_port)
    local pass_arg=""
    local host_arg=""
    local port_opt=""
    
    if is_password_auth "$ip"; then
        local username="${SERVER_USERNAMES[$ip]}"
        local password="${SERVER_PASSWORDS[$ip]}"
        
        if [ -n "$password" ]; then
            if ! check_sshpass; then
                echo "Error: sshpass is not installed but password authentication is required for server $ip"
                echo "Please install sshpass first:"
                echo "  CentOS/RHEL: sudo yum install -y sshpass"
                echo "  Ubuntu/Debian: sudo apt-get install -y sshpass"
                exit 1
            fi
            pass_arg="sshpass -p $(printf '%q' "$password") "
        elif [ -z "$password" ]; then
            echo "Error: Password not provided for server $ip with username '$username'"
            exit 1
        fi
        
        host_arg="$username@$ip"
        port_opt="-o PreferredAuthentications=password -o PubkeyAuthentication=no"
    else
        host_arg="$ip"
        port_opt=""
    fi
    
    if [ "$cmd_type" = "ssh" ]; then
        echo "${pass_arg}ssh -p $ssh_port -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR $port_opt $host_arg"
    else
        echo "${pass_arg}scp -P $ssh_port -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR $port_opt"
    fi
}

# Get SSH command prefix for a server
# Returns: SSH command prefix (with or without sshpass)
# Side effect: sets SSHPASS environment variable if password auth is used
get_ssh_command() {
    set_ssh_password "$1"
    build_auth_prefix "$1" "ssh"
}

# Get SCP command prefix for a server
# Returns: SCP command prefix (with or without sshpass)
# Side effect: sets SSHPASS environment variable if password auth is used
get_scp_command() {
    set_ssh_password "$1"
    build_auth_prefix "$1" "scp"
}

# Load configuration from file
load_config_file() {
    local config_file="$1"
    
    if [ ! -f "$config_file" ]; then
        echo "Error: Config file '$config_file' not found"
        exit 1
    fi
    
    echo "Loading configuration from $config_file..."
    
    while IFS='=' read -r key value; do
        # Skip comments and empty lines
        if [[ "$key" =~ ^# || -z "$key" ]]; then
            continue
        fi
        
        # Trim whitespace
        key=$(echo "$key" | xargs)
        value=$(echo "$value" | xargs)
        
        # Only set if not already set (command line has higher priority)
        if [ -z "${!key:-}" ]; then
            export "$key"="$value"
            debug_log "Config loaded" "$key=$value"
        fi
    done < "$config_file"
}

# Execute SSH command with optional timeout
# Usage: exec_ssh_cmd <server_ip> <command> [timeout_seconds] [extra_options]
exec_ssh_cmd() {
    local server="$1"
    local cmd="$2"
    local timeout="${3:-}"
    local extra_opts="${4:-}"
    
    local ssh_cmd=$(get_ssh_command "$server")
    if [ -n "$extra_opts" ]; then
        ssh_cmd=$(echo "$ssh_cmd" | sed "s/ssh /ssh $extra_opts /")
    fi
    
    if [ "$DRY_RUN" = "true" ]; then
        if [ -n "$timeout" ]; then
            echo "[DRY RUN] timeout --signal=KILL $timeout $ssh_cmd '$cmd'"
        else
            echo "[DRY RUN] $ssh_cmd '$cmd'"
        fi
        return 0
    fi
    
    if [ -n "$timeout" ]; then
        eval "timeout --signal=KILL $timeout $ssh_cmd '$cmd'"
    else
        eval "$ssh_cmd '$cmd'"
    fi
}

# Execute SSH command with proper authentication (backward compatible)
# Usage: exec_ssh <server_ip> <command> [extra_ssh_options]
exec_ssh() {
    exec_ssh_cmd "$1" "$2" "" "$3"
}

# Execute SSH command with timeout (backward compatible)
# Usage: exec_ssh_with_timeout <server_ip> <timeout_seconds> <command> [extra_ssh_options]
exec_ssh_with_timeout() {
    exec_ssh_cmd "$1" "$3" "$2" "$4"
}

# Trap Ctrl+C (SIGINT) to clean up processes
trap cleanup SIGINT

# Cleanup function to handle Ctrl+C and exit
cleanup() {
    echo ""
    echo "=== Cleaning up processes ==="
    
    # Kill iperf3 servers
    pkill -f "iperf3 -s" 2>/dev/null || true
    
    # Kill any running sysbench processes
    pkill -f "sysbench" 2>/dev/null || true
    
    # Kill any running fio processes
    pkill -f "fio" 2>/dev/null || true
    
    echo "✓ Cleanup completed"
    exit 1
}

# Export immediately for library functions
export OUTPUT_DIR

# Parse command line arguments
parse_args() {
    local remaining_args=()
    local found_subcommand=false
    
    # Initialize all tests as disabled
    export CPU_ENABLED=false
    export MEMORY_ENABLED=false
    export IO_ENABLED=false
    export NETWORK_ENABLED=false
    export THREADS_ENABLED=false
    export MUTEX_ENABLED=false
    
    # Iterate through all arguments
    local i=1
    while [ $i -le $# ]; do
        case "${!i}" in
            --)
                # End of options
                i=$((i + 1))
                break
                ;;
            --help)
                show_help
                exit 0
                ;;
            --version)
                echo "Version: 1.0.1"
                exit 0
                ;;
            --dry-run)
                DRY_RUN=true
                i=$((i + 1))
                ;;
            --debug)  
                DEBUG=true  
                i=$((i + 1))  
                ;;
            --parallel)
                export EXEC_MODE="parallel"
                i=$((i + 1))
                ;;
            --serial)
                export EXEC_MODE="serial"
                i=$((i + 1))
                ;;
            --remote)
                export REMOTE=true
                i=$((i + 1))
                ;;
            -h)
                show_help
                exit 0
                ;;
            -i)
                local next_idx=$((i + 1))
                INSTALL_TARGET="${!next_idx:-all}"
                i=$((i + 2))
                ;;
            -p)
                local next_idx=$((i + 1))
                CONFIG_FILE="${!next_idx}"
                i=$((i + 2))
                ;;
            -o)
                local next_idx=$((i + 1))
                OUTPUT_DIR="${!next_idx}"
                i=$((i + 2))
                ;;
            -f)
                local next_idx=$((i + 1))
                SERVERS_FILE="${!next_idx}"
                i=$((i + 2))
                ;;
            -[^-]*)
                # Unknown option starting with single dash
                echo "Unknown option: ${!i}"
                show_help
                exit 1
                ;;
            cpu|mem|io|network|thread|threads|mutex|all|check|hardware)
                # Subcommand
                local cmd="${!i}"
                found_subcommand=true
                
                # Enable the corresponding test
                case "$cmd" in
                    cpu)
                        export CPU_ENABLED=true
                        ;;
                    mem)
                        export MEMORY_ENABLED=true
                        ;;
                    io)
                        export IO_ENABLED=true
                        ;;
                    network)
                        export NETWORK_ENABLED=true
                        ;;
                    thread|threads)
                        export THREADS_ENABLED=true
                        ;;
                    mutex)
                        export MUTEX_ENABLED=true
                        ;;
                    all)
                        # Enable all tests
                        export CPU_ENABLED=true
                        export MEMORY_ENABLED=true
                        export IO_ENABLED=true
                        export NETWORK_ENABLED=true
                        export THREADS_ENABLED=true
                        export MUTEX_ENABLED=true
                        ;;
                    check)
                        # Only run checks
                        export CHECK_ENABLED=true
                        # Check if next argument is an IP address (for remote mode)
                        local next_idx=$((i + 1))
                        if [ $next_idx -le $# ] && [[ "${!next_idx}" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
                            export CHECK_SERVER_IP="${!next_idx}"
                            i=$((i + 1))
                        fi
                        ;;
                    hardware)
                        # Only show hardware info
                        export HARDWARE_ONLY=true
                        ;;
                esac
                
                i=$((i + 1))
                ;;
            *)
                # Check if this looks like a command (doesn't contain =)
                local arg="${!i}"
                if [[ "$arg" != *"="* ]]; then
                    # This looks like a command, check if it's valid
                    case "$arg" in
                        cpu|mem|io|network|thread|threads|mutex|all|check|hardware)
                            # Already handled above, should not reach here
                            remaining_args+=("$arg")
                            ;;
                        fio|sysbench)
                            # Common mistakes - provide helpful error message
                            echo "Error: '$arg' is not a valid command. Please use 'io' with IO_TOOL=$arg instead."
                            echo "Example: ./oscheckperf io -f all-servers IO_TOOL=$arg"
                            show_help
                            exit 1
                            ;;
                        *)
                            # Unknown command
                            echo "Error: Unknown command '$arg'"
                            echo "Valid commands: cpu, mem, io, network, thread, mutex, all, check, hardware"
                            show_help
                            exit 1
                            ;;
                    esac
                else
                    # KEY=VALUE parameter
                    remaining_args+=("$arg")
                fi
                i=$((i + 1))
                ;;
        esac
    done
    
    # If no subcommand specified, enable all tests
    # Only set default if not already set by config file or command line
    if [ "$found_subcommand" = "false" ]; then
        export CPU_ENABLED="${CPU_ENABLED:-true}"
        export MEMORY_ENABLED="${MEMORY_ENABLED:-true}"
        export IO_ENABLED="${IO_ENABLED:-true}"
        export NETWORK_ENABLED="${NETWORK_ENABLED:-true}"
        export THREADS_ENABLED="${THREADS_ENABLED:-true}"
        export MUTEX_ENABLED="${MUTEX_ENABLED:-true}"
    fi
    # Set default for hardware info in report
    export REPORT_HARDWARE_INFO="${REPORT_HARDWARE_INFO:-true}"
    
    # Debug output
    debug_log "parse_args completed" \
        "CPU_ENABLED=$CPU_ENABLED" \
        "MEMORY_ENABLED=$MEMORY_ENABLED" \
        "IO_ENABLED=$IO_ENABLED" \
        "NETWORK_ENABLED=$NETWORK_ENABLED" \
        "THREADS_ENABLED=$THREADS_ENABLED" \
        "MUTEX_ENABLED=$MUTEX_ENABLED" \
        "REPORT_HARDWARE_INFO=$REPORT_HARDWARE_INFO" \
        "SERVERS_FILE=$SERVERS_FILE" \
        "OUTPUT_DIR=$OUTPUT_DIR" \
        "DURATION=$DURATION" \
        "IO_TOOL=$IO_TOOL"
    
    # Process remaining arguments as KEY=VALUE pairs
    for arg in "${remaining_args[@]}"; do
        if [[ "$arg" =~ ^([A-Z_]+)=(.*)$ ]]; then
            local key="${BASH_REMATCH[1]}"
            local value="${BASH_REMATCH[2]}"
            export "$key"="$value"
        elif [ "$arg" = "NO_CHECKS=true" ]; then
            NO_CHECKS=true
        fi
    done
}

