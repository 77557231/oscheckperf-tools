# Convert size string (e.g., 1G, 10GB, 512M) to GB
convert_to_gb() {
    local size="$1"
    local num=$(echo "$size" | sed 's/[^0-9.]//g')
    local unit=$(echo "$size" | sed 's/[0-9.]//g' | tr '[:lower:]' '[:upper:]')
    
    case "$unit" in
        "GB"|"G")
            echo "$num"
            ;;
        "MB"|"M")
            echo "scale=2; $num / 1024" | bc
            ;;
        "KB"|"K")
            echo "scale=4; $num / 1024 / 1024" | bc
            ;;
        *)
            echo "$num"
            ;;
    esac
}

# Check disk space
check_disk_space() {
    echo "  Checking disk space..."

    local test_path="$IO_PATH"
    local available_kb=$(get_disk_available_kb "$test_path")
    local available_gb=$((available_kb / 1024 / 1024))
    
    # Calculate required space based on IO test configuration
    local required_gb=${MIN_DISK_SPACE_GB:-1}
    
    # Space requirement is mainly determined by IO test size
    # Note: This check is for local machine only. Remote servers will check their own disk space separately.
    if [ "$IO_ENABLED" = "true" ] && [ -n "${IO_TOTAL_SIZE:-}" ]; then
        local io_size_gb=$(convert_to_gb "$IO_TOTAL_SIZE")
        local io_required_int=$(echo "$io_size_gb" | cut -d. -f1)
        if [ -z "$io_required_int" ] || [ "$io_required_int" = "0" ]; then
            io_required_int=$(echo "$io_size_gb" | bc | cut -d. -f1)
        fi
        
        required_gb=$((io_required_int))
        
        if [ ${#target_servers[@]} -eq 0 ]; then
            echo "  IO test space requirement: ${IO_TOTAL_SIZE}"
        else
            echo "  IO test space requirement: ${IO_TOTAL_SIZE} per server"
            echo "  Note: This requirement applies to all ${#target_servers[@]} servers"
        fi
    fi
    
    if [ "$available_gb" -lt "$required_gb" ]; then
        echo "Error: Insufficient disk space"
        echo "  Available: ${available_gb}GB"
        echo "  Required: ${required_gb}GB"
        return 1
    else
        echo "  ✓ Disk space: ${available_gb}GB available, ${required_gb}GB required"
    fi
}

