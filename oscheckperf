# Print memory information section (merged basic + slots + NUMA + THP/hugepages at end)
print_memory_info() {
    local report_file="$1"
    local prefix="$2"
    local mem_total="$3"
    local mem_available="$4"
    local mem_type="$5"
    local mem_freq="$6"
    local mem_channels="$7"
    local mem_slots_detail="$8"
    local numa_node_count="$9"
    local numa_detail_lines="${10}"
    local usage_rate="${11}"
    local thp_status="${12}"
    local hugepages_count="${13}"

    printf -- "%s[Memory Information]\n" "$prefix" >> "$report_file"
    printf -- "%s--------------------------------------------------------------------------------\n" "$prefix" >> "$report_file"
    printf -- "%s%-20s %s MB\n" "$prefix" "Total:" "$mem_total" >> "$report_file"
    printf -- "%s%-20s %s MB\n" "$prefix" "Available:" "$mem_available" >> "$report_file"
    printf -- "%s%-20s %s\n" "$prefix" "Type:" "$mem_type" >> "$report_file"
    printf -- "%s%-20s %s\n" "$prefix" "Frequency:" "$mem_freq" >> "$report_file"
    printf -- "%s%-20s %s\n" "$prefix" "Channels:" "$mem_channels" >> "$report_file"
    if [ -n "$usage_rate" ] && [ "$usage_rate" != "N/A" ]; then
        printf -- "%s%-20s %s\n" "$prefix" "Usage Rate:" "$usage_rate" >> "$report_file"
    fi
    # Memory settings at end of Memory Information
    if [ -n "$thp_status" ] && [ "$thp_status" != "N/A" ]; then
        printf -- "%s%-20s %s\n" "$prefix" "THP Status:" "$thp_status" >> "$report_file"
    fi
    if [ -n "$hugepages_count" ] && [ "$hugepages_count" != "N/A" ]; then
        printf -- "%s%-20s %s\n" "$prefix" "Hugepages:" "$hugepages_count" >> "$report_file"
    fi
    printf -- "\n" >> "$report_file"

    # Memory slots detail
    if [ -n "$mem_slots_detail" ]; then
        printf -- "%s[Memory Slots Detail]\n" "$prefix" >> "$report_file"
        printf -- "%s--------------------------------------------------------------------------------\n" "$prefix" >> "$report_file"
        printf -- "%s" "$mem_slots_detail" >> "$report_file"
        printf -- "\n" >> "$report_file"
    fi

    # NUMA topology
    if [ "$numa_node_count" != "N/A" ] || [ -n "$numa_detail_lines" ]; then
        printf -- "%s[NUMA Topology]\n" "$prefix" >> "$report_file"
        printf -- "%s--------------------------------------------------------------------------------\n" "$prefix" >> "$report_file"
        printf -- "%s%-20s %s\n" "$prefix" "Node Count:" "$numa_node_count" >> "$report_file"
        if [ -n "$numa_detail_lines" ]; then
            printf -- "%s%-20s\n" "$prefix" "Topology Detail:" >> "$report_file"
            while IFS= read -r line; do
                [ -n "$line" ] && printf -- "%s  %s\n" "$prefix" "$line" >> "$report_file"
            done <<< "$numa_detail_lines"
        fi
        printf -- "\n" >> "$report_file"
    fi
}

# Print disk IO settings (for benchmark disk only)
print_disk_io_settings() {
    local report_file="$1"
    local prefix="$2"
    local queue_depth="$3"
    local read_ahead="$4"
    local trim="$5"
    local max_sectors="$6"
    local mount_opts="$7"
    
    if [ -n "$mount_opts" ] && [ "$mount_opts" != "N/A" ]; then
        printf -- "%s[Mount Options (Benchmark FS Only)]\n" "$prefix" >> "$report_file"
        printf -- "%s--------------------------------------------------------------------------------\n" "$prefix" >> "$report_file"
        printf -- "%s%s\n" "$prefix" "$mount_opts" >> "$report_file"
        printf -- "%s\n" "$prefix" >> "$report_file"
    fi
    
    if [ "$queue_depth" != "N/A" ] || [ "$read_ahead" != "N/A" ] || [ "$trim" != "N/A" ] || [ "$max_sectors" != "N/A" ]; then
        printf -- "%s[Disk IO Settings (Benchmark Disk Only)]\n" "$prefix" >> "$report_file"
        printf -- "%s--------------------------------------------------------------------------------\n" "$prefix" >> "$report_file"
        if [ "$queue_depth" != "N/A" ]; then
            printf -- "%s%-20s %s\n" "$prefix" "Queue Depth:" "$queue_depth" >> "$report_file"
        fi
        if [ "$read_ahead" != "N/A" ]; then
            printf -- "%s%-20s %s\n" "$prefix" "Read Ahead (KB):" "$read_ahead" >> "$report_file"
        fi
        if [ "$trim" != "N/A" ]; then
            printf -- "%s%-20s %s\n" "$prefix" "TRIM Max Bytes:" "$trim" >> "$report_file"
        fi
        if [ "$max_sectors" != "N/A" ]; then
            printf -- "%s%-20s %s\n" "$prefix" "Max Sectors (KB):" "$max_sectors" >> "$report_file"
        fi
        printf -- "\n" >> "$report_file"
    fi
}

# Print network information section (merged basic + advanced)
print_network_info() {
    local report_file="$1"
    local prefix="$2"
    local net_count="$3"
    local net_bond="$4"
    shift 4
    local network_lines=("$@")
    
    if [ ${#network_lines[@]} -gt 0 ] || [ "$net_count" != "N/A" ] || [ "$net_bond" != "N/A" ]; then
        printf -- "%s[Network Information]\n" "$prefix" >> "$report_file"
        printf -- "%s--------------------------------------------------------------------------------\n" "$prefix" >> "$report_file"
        printf -- "%s%-20s %s\n" "$prefix" "Interface Count:" "$net_count" >> "$report_file"
        printf -- "%s%-20s %s\n" "$prefix" "Bond Interfaces:" "$net_bond" >> "$report_file"
        printf -- "%s%-20s\n" "$prefix" "Interfaces:" >> "$report_file"
        for iface_line in "${network_lines[@]}"; do
            if [ -n "$iface_line" ]; then
                printf -- "%s  %s\n" "$prefix" "$iface_line" >> "$report_file"
            fi
        done
        printf -- "\n" >> "$report_file"
    fi
}

# Parse and print single node hardware information
print_node_hardware_info() {
