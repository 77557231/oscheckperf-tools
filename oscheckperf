# Check SSH passwordless login for remote servers
check_ssh() {
    local local_ip=$(get_machine_ip)
    
    if [ ${#target_servers[@]} -gt 0 ]; then
        echo "  Checking SSH connectivity..."
        local ssh_failed=()
        local has_password_auth=false
        local has_passwordless_auth=false
        
        for ip in "${target_servers[@]}"; do
            # Skip local machine
            if [ "$ip" = "$local_ip" ]; then
                continue
            fi
            
            # Check if this server uses password authentication
            if is_password_auth "$ip"; then
                has_password_auth=true
                echo "  - $ip: using password authentication (skip passwordless check)"
            else
                has_passwordless_auth=true
                local ssh_port=$(get_ssh_port)
                # Test SSH connection with BatchMode=yes to avoid password prompt
                if ! ssh -p "$ssh_port" -o BatchMode=yes -o ConnectTimeout=5 -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR "$ip" "echo 2>/dev/null" > /dev/null 2>&1; then
                    ssh_failed+=($ip)
                fi
            fi
        done
        
        # Only check passwordless login for servers that don't use password auth
        if [ "$has_passwordless_auth" = "true" ] && [ ${#ssh_failed[@]} -gt 0 ]; then
            echo "Error: SSH passwordless login not configured for the following servers:"
            for ip in "${ssh_failed[@]}"; do
                echo "  - $ip"
            done
            echo ""
            echo "Please configure SSH passwordless login for these servers before running the test."
            echo "You can use: ssh-copy-id $USER@<server_ip>"
            exit 1
        elif [ "$has_passwordless_auth" = "true" ]; then
            echo "  ✓ SSH passwordless login: OK"
        fi
        
        if [ "$has_password_auth" = "true" ]; then
            echo "  ✓ Password authentication configured for some servers"
            # Check if sshpass is installed when password authentication is used
            echo "  Checking sshpass availability..."
            if check_sshpass; then
                echo "  ✓ sshpass is installed"
            else
                echo "Error: sshpass is required for password authentication but not installed"
                echo ""
                echo "Please install sshpass before running tests with password authentication:"
                echo ""
                echo "Option 1: Install via package manager:"
                echo "  CentOS/RHEL: sudo yum install -y sshpass"
                echo "  Ubuntu/Debian: sudo apt-get install -y sshpass"
                echo ""
                echo "Option 2: Compile from source (no root required):"
                echo "  ./oscheckperf -i sshpass"
                echo ""
                exit 1
            fi
        fi
    fi
}

