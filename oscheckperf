            fi
            in_section=false
        elif [ "$in_section" = true ]; then
            if [[ "$line" =~ "events per second:" ]]; then
                current_eps=$(echo "$line" | awk '{print $NF}')
            elif [[ "$line" =~ "avg:" ]] && [[ "$line" =~ [0-9] ]] && [[ ! "$line" =~ "events \(avg/stddev\):" ]] && [[ ! "$line" =~ "execution time" ]]; then
                current_avg_lat=$(echo "$line" | awk '{print $NF}')
            elif [[ "$line" =~ "95th percentile:" ]]; then
                current_p95_lat=$(echo "$line" | awk '{print $NF}')
            elif [[ "$line" =~ "min:" ]] && [[ "$line" =~ [0-9] ]] && [[ ! "$line" =~ "execution time" ]]; then
                current_min_lat=$(echo "$line" | awk '{print $NF}' | tr -d ',')
            elif [[ "$line" =~ "max:" ]] && [[ "$line" =~ [0-9] ]] && [[ ! "$line" =~ "execution time" ]]; then
                current_max_lat=$(echo "$line" | awk '{print $NF}' | tr -d ',')
            elif [[ "$line" =~ "sum:" ]]; then
                current_sum_lat=$(echo "$line" | awk '{print $NF}' | tr -d ',')
            elif echo "$line" | grep -q "events.*avg/stddev"; then
                current_fairness=$(echo "$line" | awk '{print $NF}')
            fi
        fi
    done < "$input_file"
    
    if [ "$in_section" = true ] && [ -n "$current_server_ip" ]; then
        printf "  %-16s %-12s %-14s %-14s %-14s %-18s %-18s\n" "$current_server_ip" "${current_eps:-N/A}" "${current_avg_lat:-N/A}" "${current_p95_lat:-N/A}" "${current_max_lat:-N/A}" "${current_min_lat:-N/A}" "${current_sum_lat:-N/A}" >> "$output_file"
    fi
}

