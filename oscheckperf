    local current_events=""
    local current_time=""
    local current_tps=""
    local current_mutex_avg_lat=""
    local current_mutex_min_lat=""
    local current_mutex_max_lat=""
    local current_mutex_p95_lat=""
    local current_mutex_sum_lat=""
    local current_mutex_fairness=""
    local last_testing_ip=""
    
    while IFS= read -r line; do
        if [[ "$line" =~ "Testing server" ]]; then
            last_testing_ip=$(echo "$line" | grep -oP 'Testing server [0-9]+/[0-9]+: \K[0-9.]+' || echo "")
            if [ "$in_section" = true ] && [ -n "$current_server_ip" ]; then
                current_tps=$(calc_eps "$current_events" "$current_time")
                printf "  %-18s %-15s %-15s %-18s %-14s %-14s %-14s %-18s\n" "$current_server_ip" "${current_events:-N/A}" "${current_tps:-N/A}" "${current_mutex_avg_lat:-N/A}" "${current_mutex_min_lat:-N/A}" "${current_mutex_max_lat:-N/A}" "${current_mutex_p95_lat:-N/A}" "${current_mutex_sum_lat:-N/A}" >> "$output_file"
            fi
            in_section=false
            current_server_ip=""
        elif [[ "$line" =~ "MUTEX TEST RESULTS" ]]; then
            if [ "$in_section" = true ] && [ -n "$current_server_ip" ]; then
                current_tps=$(calc_eps "$current_events" "$current_time")
                printf "  %-18s %-15s %-15s %-18s %-14s %-14s %-14s %-18s\n" "$current_server_ip" "${current_events:-N/A}" "${current_tps:-N/A}" "${current_mutex_avg_lat:-N/A}" "${current_mutex_min_lat:-N/A}" "${current_mutex_max_lat:-N/A}" "${current_mutex_p95_lat:-N/A}" "${current_mutex_sum_lat:-N/A}" >> "$output_file"
            fi
            in_section=true
            current_server_ip=$(echo "$line" | grep -oP 'Server: \K[0-9.]+' || echo "N/A")
            current_events=""
            current_time=""
            current_tps=""
            current_mutex_avg_lat=""
            current_mutex_min_lat=""
            current_mutex_max_lat=""
            current_mutex_p95_lat=""
            current_mutex_sum_lat=""
            current_mutex_fairness=""
        elif [[ "$line" =~ "Mutex test summary:" ]]; then
            in_section=true
            current_server_ip="${last_testing_ip:-N/A}"
            current_events=""
            current_time=""
            current_tps=""
            current_mutex_avg_lat=""
            current_mutex_min_lat=""
            current_mutex_max_lat=""
            current_mutex_p95_lat=""
            current_mutex_sum_lat=""
            current_mutex_fairness=""
        elif [ "$in_section" = true ] && [[ "$line" =~ "TEST RESULTS" ]] && [[ ! "$line" =~ "MUTEX TEST RESULTS" ]] && [[ ! "$line" =~ "Mutex test summary:" ]]; then
            if [ -n "$current_server_ip" ]; then
                current_tps=$(calc_eps "$current_events" "$current_time")
                printf "  %-18s %-15s %-15s %-18s %-14s %-14s %-14s %-18s\n" "$current_server_ip" "${current_events:-N/A}" "${current_tps:-N/A}" "${current_mutex_avg_lat:-N/A}" "${current_mutex_min_lat:-N/A}" "${current_mutex_max_lat:-N/A}" "${current_mutex_p95_lat:-N/A}" "${current_mutex_sum_lat:-N/A}" >> "$output_file"
            fi
            in_section=false
        elif [ "$in_section" = true ]; then
            if [[ "$line" =~ "total number of events:" ]]; then
                current_events=$(echo "$line" | awk '{print $NF}')
            elif [[ "$line" =~ "total time:" ]]; then
                current_time=$(echo "$line" | awk '{print $NF}' | tr -d 's')
            elif [[ "$line" =~ "avg:" ]] && [[ ! "$line" =~ "events" ]]; then
                current_mutex_avg_lat=$(echo "$line" | awk '{print $NF}' | tr -d ',')
            elif [[ "$line" =~ "min:" ]] && [[ ! "$line" =~ "execution time" ]]; then
                current_mutex_min_lat=$(echo "$line" | awk '{print $NF}' | tr -d ',')
            elif [[ "$line" =~ "max:" ]] && [[ ! "$line" =~ "execution time" ]]; then
                current_mutex_max_lat=$(echo "$line" | awk '{print $NF}' | tr -d ',')
            elif [[ "$line" =~ "95th percentile" ]]; then
                current_mutex_p95_lat=$(echo "$line" | awk '{print $NF}')
            elif [[ "$line" =~ "sum:" ]]; then
                current_mutex_sum_lat=$(echo "$line" | awk '{print $NF}' | tr -d ',')
            elif echo "$line" | grep -q "events.*avg/stddev"; then
                current_mutex_fairness=$(echo "$line" | awk '{print $3}')
            fi
        fi
    done < "$input_file"
    
    if [ "$in_section" = true ] && [ -n "$current_server_ip" ]; then
        current_tps=$(calc_eps "$current_events" "$current_time")
        printf "  %-18s %-15s %-15s %-18s %-14s %-14s %-14s %-18s\n" "$current_server_ip" "${current_events:-N/A}" "${current_tps:-N/A}" "${current_mutex_avg_lat:-N/A}" "${current_mutex_min_lat:-N/A}" "${current_mutex_max_lat:-N/A}" "${current_mutex_p95_lat:-N/A}" "${current_mutex_sum_lat:-N/A}" >> "$output_file"
    fi
}

# Get SSH port with validation
# Returns: Valid SSH port number (1-65535)
get_ssh_port() {
    local port="$SSH_PORT"
    
    # Validate port is a number between 1 and 65535
    if ! [[ "$port" =~ ^[1-9][0-9]{0,4}$ ]] || [ "$port" -lt 1 ] || [ "$port" -gt 65535 ]; then
        echo "Error: Invalid SSH port '$port'. Port must be between 1 and 65535" >&2
        exit 1
    fi
    
    echo "$port"
}
