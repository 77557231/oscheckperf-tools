    write_clat_p95=$((write_clat_p95 / 1000))
    write_clat_p99=$((write_clat_p99 / 1000))
    
    # Convert bw from KB/s to MB/s using awk to handle large numbers
    local read_bw_mb=$(awk "BEGIN {printf \"%.2f\", $read_bw_kb / 1024}" 2>/dev/null || echo "0")
    local write_bw_mb=$(awk "BEGIN {printf \"%.2f\", $write_bw_kb / 1024}" 2>/dev/null || echo "0")
    
