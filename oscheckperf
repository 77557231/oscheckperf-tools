            current_server_ip=""
            current_events=""
            current_time=""
            current_eps=""
            current_threads_avg_lat=""
            current_threads_p95_lat=""
            current_threads_min_lat=""
            current_threads_max_lat=""
            current_threads_sum_lat=""
            current_threads_fairness=""
        elif [[ "$line" =~ "Threads test summary:" ]]; then
            in_section=true
            current_server_ip="${last_testing_ip:-N/A}"
            current_events=""
            current_time=""
            current_eps=""
            current_threads_avg_lat=""
            current_threads_p95_lat=""
            current_threads_min_lat=""
            current_threads_max_lat=""
            current_threads_sum_lat=""
            current_threads_fairness=""
        elif [ "$in_section" = true ] && [[ "$line" =~ "TEST RESULTS" ]] && [[ ! "$line" =~ "THREADS TEST RESULTS" ]] && [[ ! "$line" =~ "Threads test summary:" ]]; then
            if [ -n "$current_server_ip" ]; then
                current_eps=$(calc_eps "$current_events" "$current_time")
                printf "  %-18s %-15s %-18s %-18s %-14s %-14s %-18s\n" "$current_server_ip" "${current_eps:-N/A}" "${current_threads_avg_lat:-N/A}" "${current_threads_p95_lat:-N/A}" "${current_threads_min_lat:-N/A}" "${current_threads_max_lat:-N/A}" "${current_threads_sum_lat:-N/A}" >> "$output_file"
            fi
            in_section=false
            current_server_ip=""
        elif [ "$in_section" = true ]; then
            if [[ "$line" =~ "total number of events:" ]]; then
                current_events=$(echo "$line" | awk '{print $NF}')
            elif [[ "$line" =~ "total time:" ]]; then
                current_time=$(echo "$line" | awk '{print $NF}' | tr -d 's')
            elif [[ "$line" =~ "avg:" ]] && [[ ! "$line" =~ "events" ]]; then
                current_threads_avg_lat=$(echo "$line" | awk '{print $NF}' | tr -d ',')
