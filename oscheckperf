        printf -- "%s%-20s %s\n" "$prefix" "L2 Cache:" "$l2" >> "$report_file"
    fi
    if [ -n "$l3" ] && [ "$l3" != "N/A" ]; then
        printf -- "%s%-20s %s\n" "$prefix" "L3 Cache:" "$l3" >> "$report_file"
    fi
    if [ -n "$features" ] && [ "$features" != "N/A" ]; then
        printf -- "%s%-20s %s\n" "$prefix" "Features:" "$features" >> "$report_file"
    fi
    if [ "$freq_min" != "N/A" ] || [ "$freq_max" != "N/A" ]; then
