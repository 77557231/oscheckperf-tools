            if (( $(echo "$r_bw < $min_bw" | bc -l) )); then
                min_bw="$r_bw"
            fi
            if (( $(echo "$r_bw > $max_bw" | bc -l) )); then
                max_bw="$r_bw"
            fi
        fi
    done
    
    # Calculate average and median
    local avg_bw="0"
    local median_bw="0"
    if [ $count -gt 0 ]; then
        avg_bw=$(echo "$total_bw / $count" | bc -l)
        # Sort bandwidth values for median
        IFS=$'\n' sorted_bw=($(sort -g <<< "${bw_values[*]}"))
        unset IFS
        local mid=$((count / 2))
        if [ $((count % 2)) -eq 0 ]; then
            median_bw=$(echo "(${sorted_bw[$mid-1]} + ${sorted_bw[$mid]}) / 2" | bc -l)
        else
