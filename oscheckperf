# Note: set -e is intentionally not used to allow tests to continue even if some fail
# This ensures report generation happens regardless of individual test failures

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# ================================================================================
# Path Constants - Centralized path management
# All paths are derived from BASE_DIR for easy modification
# ================================================================================
# Base directory for all oscheckperf data - can be modified here for all paths
export BASE_DIR="${BASE_DIR:-$HOME/oscheckperf}"

# Temporary files directory (logs, intermediate data, network test results)
export TMP_DIR="$BASE_DIR/tmp"

# IO test data directory (sysbench/fio test files)
export IO_PATH_DEFAULT="$BASE_DIR/io_test"

# Output directory for final reports and logs (original_data*, data*, report_benchmark*)
export OUTPUT_DIR_DEFAULT="./output"

# ================================================================================

# Default parameters
CONFIG_FILE=""
OUTPUT_DIR="$OUTPUT_DIR_DEFAULT"
DRY_RUN=false
NO_CHECKS=false

# Trap Ctrl+C (SIGINT) to clean up processes
trap cleanup SIGINT

# Cleanup function to handle Ctrl+C and exit
cleanup() {
    echo ""
    echo "=== Cleaning up processes ==="
    
    # Kill iperf3 servers
    pkill -f "iperf3 -s" 2>/dev/null || true
    
    # Kill any running sysbench processes
    pkill -f "sysbench" 2>/dev/null || true
    
    # Kill any running fio processes
    pkill -f "fio" 2>/dev/null || true
    
    echo "✓ Cleanup completed"
    exit 1
}

# Export immediately for library functions
export OUTPUT_DIR

# Parse command line arguments
parse_args() {
    local remaining_args=()
    local found_subcommand=false
    
    # Initialize all tests as disabled
    export CPU_ENABLED=false
    export MEMORY_ENABLED=false
    export IO_ENABLED=false
    export NETWORK_ENABLED=false
    export THREADS_ENABLED=false
    export MUTEX_ENABLED=false
    export PGBENCH_ENABLED=false
    
    # Iterate through all arguments
    local i=1
    while [ $i -le $# ]; do
        case "${!i}" in
            --)
                # End of options
                i=$((i + 1))
                break
                ;;
            --help)
                show_help
                exit 0
                ;;
            --version)
                echo "Version: 0.6.5"
                exit 0
                ;;
            --dry-run)
                DRY_RUN=true
                i=$((i + 1))
                ;;
            --debug)  
                DEBUG=true  
                i=$((i + 1))  
                ;;
            --parallel)
                export EXEC_MODE="parallel"
                i=$((i + 1))
                ;;
            --serial)
                export EXEC_MODE="serial"
                i=$((i + 1))
                ;;
            --remote)
                export REMOTE=true
                i=$((i + 1))
                ;;
            -h)
                show_help
                exit 0
                ;;
            -i)
                SYSBENCH_INSTALL=true
                i=$((i + 1))
                ;;
            -o)
                local next_idx=$((i + 1))
                OUTPUT_DIR="${!next_idx}"
                i=$((i + 2))
                ;;
            -f)
                local next_idx=$((i + 1))
                SERVERS_FILE="${!next_idx}"
                i=$((i + 2))
                ;;
            -[^-]*)
                # Unknown option starting with single dash
                echo "Unknown option: ${!i}"
                show_help
                exit 1
                ;;
            cpu|mem|io|network|thread|threads|mutex|all|check)
                # Subcommand
                local cmd="${!i}"
                found_subcommand=true
                
                # Enable the corresponding test
                case "$cmd" in
                    cpu)
                        export CPU_ENABLED=true
                        ;;
                    mem)
                        export MEMORY_ENABLED=true
                        ;;
                    io)
                        export IO_ENABLED=true
                        ;;
                    network)
                        export NETWORK_ENABLED=true
                        ;;
                    thread|threads)
                        export THREADS_ENABLED=true
                        ;;
                    mutex)
                        export MUTEX_ENABLED=true
                        ;;
                    all)
                        # Enable all tests
                        export CPU_ENABLED=true
                        export MEMORY_ENABLED=true
                        export IO_ENABLED=true
                        export NETWORK_ENABLED=true
                        export THREADS_ENABLED=true
                        export MUTEX_ENABLED=true
                        export PGBENCH_ENABLED=false
                        ;;
                    check)
                        # Only run checks
                        export CHECK_ENABLED=true
                        ;;
                esac
                
                i=$((i + 1))
                ;;
            *)
                remaining_args+=("${!i}")
                i=$((i + 1))
                ;;
        esac
    done
    
    # If no subcommand specified, enable all tests
    if [ "$found_subcommand" = "false" ]; then
        export CPU_ENABLED=true
        export MEMORY_ENABLED=true
        export IO_ENABLED=true
        export NETWORK_ENABLED=true
        export THREADS_ENABLED=true
        export MUTEX_ENABLED=true
        export PGBENCH_ENABLED=false
    fi
    
    # Debug output
    debug_log "parse_args completed" \
        "CPU_ENABLED=$CPU_ENABLED" \
        "MEMORY_ENABLED=$MEMORY_ENABLED" \
        "IO_ENABLED=$IO_ENABLED" \
        "NETWORK_ENABLED=$NETWORK_ENABLED" \
        "THREADS_ENABLED=$THREADS_ENABLED" \
        "MUTEX_ENABLED=$MUTEX_ENABLED" \
        "SERVERS_FILE=$SERVERS_FILE" \
        "OUTPUT_DIR=$OUTPUT_DIR" \
        "DURATION=$DURATION" \
        "IO_TOOL=$IO_TOOL"
    
    # Process remaining arguments as KEY=VALUE pairs
    for arg in "${remaining_args[@]}"; do
        if [[ "$arg" =~ ^([A-Z_]+)=(.*)$ ]]; then
            local key="${BASH_REMATCH[1]}"
            local value="${BASH_REMATCH[2]}"
            export "$key"="$value"
        elif [ "$arg" = "NO_CHECKS=true" ]; then
            NO_CHECKS=true
        fi
    done
}

