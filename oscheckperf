parse_cpu_report() {
    local input_file="$1"
    local output_file="$2"
    
    if [ ! -f "$input_file" ]; then
        echo "  Test not executed" >> "$output_file"
        return
    fi
    
    if ! grep -q "CPU TEST RESULTS" "$input_file" 2>/dev/null; then
        echo "  Test not executed" >> "$output_file"
        return
    fi
    
    echo "  CPU Test Results" >> "$output_file"
    echo "  ---------------------------------------------------------------------------------------------------------------" >> "$output_file"
    printf "  %-18s %-12s %-12s %-12s %-12s %-12s %-14s %-10s\n" "Server IP" "Events/sec" "Avg Lat(ms)" "P95 Lat(ms)" "Max Lat(ms)" "Min Lat(ms)" "Sum Lat(ms)" "Fairness(avg)" >> "$output_file"
    echo "  ---------------------------------------------------------------------------------------------------------------" >> "$output_file"
    
    local in_section=false
    local current_server_ip=""
    local current_eps=""
    local current_avg_lat=""
    local current_p95_lat=""
    local current_max_lat=""
    local current_min_lat=""
    local current_sum_lat=""
    local current_fairness=""
    
    while IFS= read -r line; do
        if [[ "$line" =~ "CPU TEST RESULTS" ]]; then
            if [ "$in_section" = true ] && [ -n "$current_server_ip" ]; then
                printf "  %-18s %-12s %-12s %-12s %-12s %-12s %-14s %-10s\n" "$current_server_ip" "${current_eps:-N/A}" "${current_avg_lat:-N/A}" "${current_p95_lat:-N/A}" "${current_max_lat:-N/A}" "${current_min_lat:-N/A}" "${current_sum_lat:-N/A}" "${current_fairness:-N/A}" >> "$output_file"
            fi
            in_section=true
            current_server_ip=$(echo "$line" | grep -oP 'Server: \K[0-9.]+' || echo "N/A")
            current_eps=""
            current_avg_lat=""
            current_p95_lat=""
            current_max_lat=""
            current_min_lat=""
            current_sum_lat=""
            current_fairness=""
        elif [[ "$line" =~ MEMORY.*TEST.*RESULTS || "$line" =~ "SYSBENCH FILEIO TEST RESULTS" || "$line" =~ "THREADS TEST RESULTS" || "$line" =~ "MUTEX TEST RESULTS" || "$line" =~ "NETWORK TEST RESULTS" ]]; then
            if [ "$in_section" = true ] && [ -n "$current_server_ip" ]; then
                printf "  %-18s %-12s %-12s %-12s %-12s %-12s %-14s %-10s\n" "$current_server_ip" "${current_eps:-N/A}" "${current_avg_lat:-N/A}" "${current_p95_lat:-N/A}" "${current_max_lat:-N/A}" "${current_min_lat:-N/A}" "${current_sum_lat:-N/A}" "${current_fairness:-N/A}" >> "$output_file"
            fi
            in_section=false
            current_server_ip=""
            current_eps=""
            current_avg_lat=""
            current_p95_lat=""
            current_max_lat=""
            current_min_lat=""
            current_sum_lat=""
            current_fairness=""
        elif [ "$in_section" = true ]; then
            if [[ "$line" =~ "events per second:" ]]; then
                current_eps=$(echo "$line" | awk '{print $NF}')
            elif [[ "$line" =~ "avg:" ]] && [[ "$line" =~ [0-9] ]] && [[ ! "$line" =~ "events \(avg/stddev\):" ]] && [[ ! "$line" =~ "execution time" ]]; then
                current_avg_lat=$(echo "$line" | awk '{print $NF}')
            elif [[ "$line" =~ "95th percentile:" ]]; then
                current_p95_lat=$(echo "$line" | awk '{print $NF}')
            elif [[ "$line" =~ "min:" ]] && [[ "$line" =~ [0-9] ]] && [[ ! "$line" =~ "execution time" ]]; then
                current_min_lat=$(echo "$line" | awk '{print $NF}' | tr -d ',')
            elif [[ "$line" =~ "max:" ]] && [[ "$line" =~ [0-9] ]] && [[ ! "$line" =~ "execution time" ]]; then
                current_max_lat=$(echo "$line" | awk '{print $NF}' | tr -d ',')
            elif [[ "$line" =~ "sum:" ]]; then
                current_sum_lat=$(echo "$line" | awk '{print $NF}' | tr -d ',')
            elif echo "$line" | grep -q "events.*avg/stddev"; then
                current_fairness=$(echo "$line" | awk '{print $NF}')
            fi
        fi
    done < "$input_file"
    
    if [ "$in_section" = true ] && [ -n "$current_server_ip" ]; then
        printf "  %-18s %-12s %-12s %-12s %-12s %-12s %-14s %-10s\n" "$current_server_ip" "${current_eps:-N/A}" "${current_avg_lat:-N/A}" "${current_p95_lat:-N/A}" "${current_max_lat:-N/A}" "${current_min_lat:-N/A}" "${current_sum_lat:-N/A}" "${current_fairness:-N/A}" >> "$output_file"
    fi
}

