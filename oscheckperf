# Print disk information section (filtered: only swap and IO_PATH related device)
print_disk_info_section() {
    local report_file="$1"
    local prefix="$2"
    local io_path="$3"
    shift 3
    local disk_lines=("$@")
    
    # Get IO_PATH device name and mount point for filtering
    local io_device=""
    local io_mount=""
    if [ -n "$io_path" ] && command -v df &>/dev/null; then
        io_device=$(df "$io_path" 2>/dev/null | tail -1 | awk '{print $1}' | sed 's|/dev/||; s|^mapper/||')
        io_mount=$(df "$io_path" 2>/dev/null | tail -1 | awk '{print $6}')
    fi
    
    # Fallback: if IO_PATH doesn't exist, use root directory
    if [ -z "$io_device" ] && command -v df &>/dev/null; then
        io_device=$(df / 2>/dev/null | tail -1 | awk '{print $1}' | sed 's|/dev/||; s|^mapper/||')
        io_mount="/"
    fi
    
    # Filter relevant lines
    local filtered_lines=()
    for disk_line in "${disk_lines[@]}"; do
        if [ -n "$disk_line" ] && [ "$disk_line" != "N/A" ]; then
            IFS='|' read -r name size type fstype mountpoint disk_type vendor model scheduler wcache <<< "$disk_line"
            # Clean up name (remove tree characters and leading spaces)
            local clean_name=$(echo "$name" | sed 's/^[├└─ ]*//; s/^[│ ]*//')
            local show=false
            # Show disk and rom types directly
            if [ "$type" = "disk" ] || [ "$type" = "rom" ]; then
                show=true
            fi
            # Show all partition and LVM devices
            if [ "$type" = "part" ] || [ "$type" = "lvm" ]; then
                show=true
            fi
            if $show; then
                filtered_lines+=("$disk_line")
            fi
        fi
    done
    
    if [ ${#filtered_lines[@]} -gt 0 ]; then
        printf -- "%s[Disk Information]\n" "$prefix" >> "$report_file"
        printf -- "%s------------------------------------------------------------------------------------------------------\n" "$prefix" >> "$report_file"
        printf -- "%s%-28s %-12s %-6s %-8s %-14s %-5s %-8s %-12s %-8s %-8s\n" "$prefix" "NAME" "SIZE" "TYPE" "FS" "MOUNTPOINT" "TYPE" "VENDOR" "MODEL" "SCHEDULER" "WCACHE" >> "$report_file"
        printf -- "%s------------------------------------------------------------------------------------------------------\n" "$prefix" >> "$report_file"
        for disk_line in "${filtered_lines[@]}"; do
            IFS='|' read -r name size type fstype mountpoint disk_type vendor model scheduler wcache <<< "$disk_line"
            # Clean up name for display
            local display_name=$(echo "$name" | sed 's/^[├└─ ]*//; s/^[│ ]*//')
            [ "$disk_type" = "Unknown" ] && disk_type="-"
            printf -- "%s%-28s %-12s %-6s %-8s %-14s %-5s %-8s %-12s %-8s %-8s\n" "$prefix" "$display_name" "$size" "$type" "$fstype" "$mountpoint" "$disk_type" "$vendor" "$model" "$scheduler" "$wcache" >> "$report_file"
        done
        printf -- "\n" >> "$report_file"
    fi
}

