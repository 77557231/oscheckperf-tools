# Parse iperf3 JSON result
parse_iperf3_result() {
    local json_file="$1"
    
    if [ ! -f "$json_file" ]; then
        echo "⚠ Result file not found: $json_file"
        return
    fi
    
    if ! jq_available; then
        echo "⚠ jq not installed, skipping detailed parsing"
        return
    fi
    
    # Extract JSON content by removing any leading non-JSON text
    local json_content=$(awk 'BEGIN{found=0} /^\{/{found=1} found{print} /^\}/{if(found) exit}' "$json_file" 2>/dev/null || cat "$json_file")
    
    # Extract metrics
    local bandwidth_bps=$(echo "$json_content" | jq -r '.end.sum_received.bits_per_second // 0' 2>/dev/null)
    # Convert bps to MB/s: 1 MB/s = 8,000,000 bps
    local bandwidth_mbs=$(awk "BEGIN {printf \"%.2f\", $bandwidth_bps / 8000000}" 2>/dev/null || echo "0")
    
    # Extract extended metrics
    local retransmits=$(echo "$json_content" | jq -r '.end.sum_received.retransmits // "N/A"' 2>/dev/null)
    local rtt_avg=$(echo "$json_content" | jq -r '.end.streams[0].sender.mean_rtt // "N/A"' 2>/dev/null)
    local rtt_min=$(echo "$json_content" | jq -r '.end.streams[0].sender.min_rtt // "N/A"' 2>/dev/null)
    local rtt_max=$(echo "$json_content" | jq -r '.end.streams[0].sender.max_rtt // "N/A"' 2>/dev/null)
    local cpu_sender=$(echo "$json_content" | jq -r '.end.cpu_utilization_percent.sender // "N/A"' 2>/dev/null)
    local cpu_receiver=$(echo "$json_content" | jq -r '.end.cpu_utilization_percent.receiver // "N/A"' 2>/dev/null)
    
    # Convert RTT from microseconds to milliseconds if available
    if [ "$rtt_avg" != "N/A" ] && [ "$rtt_avg" != "null" ]; then
        rtt_avg=$(awk "BEGIN {printf \"%.3f\", $rtt_avg / 1000}" 2>/dev/null || echo "$rtt_avg")
    fi
    if [ "$rtt_min" != "N/A" ] && [ "$rtt_min" != "null" ]; then
        rtt_min=$(awk "BEGIN {printf \"%.3f\", $rtt_min / 1000}" 2>/dev/null || echo "$rtt_min")
    fi
    if [ "$rtt_max" != "N/A" ] && [ "$rtt_max" != "null" ]; then
        rtt_max=$(awk "BEGIN {printf \"%.3f\", $rtt_max / 1000}" 2>/dev/null || echo "$rtt_max")
    fi
    
    # Display summary
    echo ""
    echo "Network test results:"
    echo "  Dynamic Average Bandwidth: ${bandwidth_mbs} MB/s"
    
    # Display extended metrics
    if [ "$retransmits" != "N/A" ] && [ "$retransmits" != "null" ]; then
        echo "  Retransmits: ${retransmits}"
    fi
    if [ "$rtt_avg" != "N/A" ] && [ "$rtt_avg" != "null" ]; then
        echo "  RTT (ms): ${rtt_avg} (Min: ${rtt_min}, Max: ${rtt_max})"
    fi
    if [ "$cpu_sender" != "N/A" ] && [ "$cpu_sender" != "null" ]; then
        echo "  CPU: Sender ${cpu_sender}%, Receiver ${cpu_receiver}%"
    fi
    
    # Only show jitter and packet loss for UDP tests (not applicable for TCP)
    if [ "${NETWORK_PROTOCOL:-tcp}" = "udp" ]; then
        local jitter_ms=$(jq -r '.end.sum_received.jitter_ms // 0' "$json_file" 2>/dev/null)
        local lost_packets=$(jq -r '.end.sum_received.lost_packets // 0' "$json_file" 2>/dev/null)
        local total_packets=$(jq -r '.end.sum_received.packets // 0' "$json_file" 2>/dev/null)
        
        # Calculate packet loss rate
        local packet_loss="0"
        if [ "$total_packets" -gt 0 ] 2>/dev/null; then
            packet_loss=$(awk "BEGIN {printf \"%.2f\", $lost_packets * 100 / $total_packets}" 2>/dev/null || echo "0")
        fi
        
        echo "  Jitter: ${jitter_ms} ms"
        echo "  Lost Packets: ${lost_packets}"
        echo "  Packet Loss: ${packet_loss}%"
    fi
}

# Generate text format output from iperf3 JSON output
generate_iperf3_text_from_json() {
    local json_file="$1"
    local output_file="$2"
    
    if [ ! -f "$json_file" ]; then
        touch "$output_file"
        return
    fi
    
    if ! jq_available; then
        touch "$output_file"
        return
    fi
    
    # Extract JSON content
    local json_content=$(awk 'BEGIN{found=0} /^\{/{found=1} found{print} /^\}/{if(found) exit}' "$json_file" 2>/dev/null || cat "$json_file")
    
    # Generate text-like output from JSON
    {
        echo "iperf3 text output (generated from JSON)"
        echo "========================================="
        
        # Extract interval data
        local intervals=$(echo "$json_content" | jq -r '.intervals[]' 2>/dev/null)
        
        if [ -n "$intervals" ]; then
            local interval_idx=0
            echo "$intervals" | while read -r interval; do
                interval_idx=$((interval_idx + 1))
                
                # Extract timestamp and duration
                local start=$(echo "$interval" | jq -r '.streams[0].start // 0' 2>/dev/null)
                local end=$(awk "BEGIN {printf \"%.2f\", $start + 1}" 2>/dev/null)
                
                # Extract received data
                local bytes=$(echo "$interval" | jq -r '.streams[0].sum.bytes // 0' 2>/dev/null)
                local bits_per_second=$(echo "$interval" | jq -r '.streams[0].sum.bits_per_second // 0' 2>/dev/null)
                
                # Convert bytes to MBytes
                local mbytes=$(awk "BEGIN {printf \"%.2f\", $bytes / 1048576}" 2>/dev/null || echo "0")
                
                # Convert bps to Mbits/sec or Gbits/sec
                local bitrate=""
                if [ "$bits_per_second" -gt 1000000000 ] 2>/dev/null; then
                    bitrate=$(awk "BEGIN {printf \"%.2f Gbits/sec\", $bits_per_second / 1000000000}" 2>/dev/null)
                else
                    bitrate=$(awk "BEGIN {printf \"%.2f Mbits/sec\", $bits_per_second / 1000000}" 2>/dev/null)
                fi
                
                if [ -n "$start" ] && [ "$start" != "null" ]; then
                    printf "[%3d] %6.2f-%6.2f sec  %6.2f MBytes  %s\n" "$interval_idx" "$start" "$end" "$mbytes" "$bitrate"
                fi
            done
        fi
        
        # Add summary
        echo ""
        echo "- - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"
        
        local total_bytes=$(echo "$json_content" | jq -r '.end.sum_received.bytes // 0' 2>/dev/null)
        local total_bits_per_second=$(echo "$json_content" | jq -r '.end.sum_received.bits_per_second // 0' 2>/dev/null)
        
        local total_mbytes=$(awk "BEGIN {printf \"%.2f\", $total_bytes / 1048576}" 2>/dev/null || echo "0")
        
        local total_bitrate=""
        if [ "$total_bits_per_second" -gt 1000000000 ] 2>/dev/null; then
            total_bitrate=$(awk "BEGIN {printf \"%.2f Gbits/sec\", $total_bits_per_second / 1000000000}" 2>/dev/null)
        else
            total_bitrate=$(awk "BEGIN {printf \"%.2f Mbits/sec\", $total_bits_per_second / 1000000}" 2>/dev/null)
        fi
        
        printf "[SUM] %6.2f-%6.2f sec  %6.2f MBytes  %s  sender\n" "0.00" "$(echo "$json_content" | jq -r '.end.sum_received.seconds // 0' 2>/dev/null)" "$total_mbytes" "$total_bitrate"
        printf "[SUM] %6.2f-%6.2f sec  %6.2f MBytes  %s  receiver\n" "0.00" "$(echo "$json_content" | jq -r '.end.sum_received.seconds // 0' 2>/dev/null)" "$total_mbytes" "$total_bitrate"
        
    } > "$output_file"
}

# Parse iperf3 JSON to metrics (extended indicators)
parse_iperf3_json_to_metrics() {
    local json_file="$1"
    
    if [ ! -f "$json_file" ] || ! jq_available; then
        echo "retransmits=N/A|rtt_min=N/A|rtt_max=N/A|rtt_avg=N/A|cpu_host=N/A|cpu_remote=N/A|tcp_congestion=N/A"
        return
    fi
    
    # Extract metrics from JSON
    local retransmits=$(jq -r '.end.sum_received.retransmits // 0' "$json_file" 2>/dev/null || echo "N/A")
    
    # Extract RTT metrics
    local rtt_min=$(jq -r '.end.streams[0].sender.min_rtt // 0' "$json_file" 2>/dev/null || echo "N/A")
    local rtt_max=$(jq -r '.end.streams[0].sender.max_rtt // 0' "$json_file" 2>/dev/null || echo "N/A")
    local rtt_avg=$(jq -r '.end.streams[0].sender.mean_rtt // 0' "$json_file" 2>/dev/null || echo "N/A")
    
    # Extract CPU metrics
    local cpu_host=$(jq -r '.end.cpu_utilization_percent.host_total // 0' "$json_file" 2>/dev/null || echo "N/A")
    local cpu_remote=$(jq -r '.end.cpu_utilization_percent.remote_total // 0' "$json_file" 2>/dev/null || echo "N/A")
    
    # Extract TCP congestion control algorithm
    local tcp_congestion=$(jq -r '.start.stored_tcp_congestion // "N/A"' "$json_file" 2>/dev/null || echo "N/A")
    
    # Format RTT to milliseconds (convert from microseconds if needed)
    if [[ "$rtt_min" != "N/A" ]] && [[ "$rtt_min" =~ [0-9] ]]; then
        rtt_min=$(awk "BEGIN {printf \"%.2f\", $rtt_min / 1000}" 2>/dev/null || echo "$rtt_min")
    fi
    if [[ "$rtt_max" != "N/A" ]] && [[ "$rtt_max" =~ [0-9] ]]; then
        rtt_max=$(awk "BEGIN {printf \"%.2f\", $rtt_max / 1000}" 2>/dev/null || echo "$rtt_max")
    fi
    if [[ "$rtt_avg" != "N/A" ]] && [[ "$rtt_avg" =~ [0-9] ]]; then
        rtt_avg=$(awk "BEGIN {printf \"%.2f\", $rtt_avg / 1000}" 2>/dev/null || echo "$rtt_avg")
    fi
    
    # Return all metrics as pipe-separated string
    echo "retransmits=${retransmits}|rtt_min=${rtt_min}|rtt_max=${rtt_max}|rtt_avg=${rtt_avg}|cpu_host=${cpu_host}|cpu_remote=${cpu_remote}|tcp_congestion=${tcp_congestion}"
}

# Parse fio JSON to metrics (extended indicators)
parse_fio_json_to_metrics() {
    local json_file="$1"
    local normal_output_file="$2"
    
    if [ ! -f "$json_file" ] || ! jq_available; then
        echo "lat_p99=N/A|lat_max=N/A|disk_util=N/A|cpu_usr=N/A|cpu_sys=N/A|bw_min=N/A|bw_max=N/A|slat=N/A|clat=N/A|ctx=N/A|majf=N/A|minf=N/A|iodepth=N/A"
        return
    fi
    
    # Extract metrics from JSON
    local lat_p99_read=$(jq -r '.jobs[0].read.clat_ns.percentile."99.000000" // 0' "$json_file" 2>/dev/null || echo "0")
    local lat_p99_write=$(jq -r '.jobs[0].write.clat_ns.percentile."99.000000" // 0' "$json_file" 2>/dev/null || echo "0")
    
    local lat_max_read=$(jq -r '.jobs[0].read.clat_ns.max // 0' "$json_file" 2>/dev/null || echo "0")
    local lat_max_write=$(jq -r '.jobs[0].write.clat_ns.max // 0' "$json_file" 2>/dev/null || echo "0")
    
    local disk_util="N/A"
    if [ -f "$normal_output_file" ]; then
        disk_util=$(grep -oP 'util=\K[0-9.]+' "$normal_output_file" | head -n1 | awk '{printf "%.2f", $1}' 2>/dev/null || echo "N/A")
    fi
    local cpu_usr=$(jq -r '.jobs[0].usr_cpu // 0' "$json_file" 2>/dev/null || echo "N/A")
    local cpu_sys=$(jq -r '.jobs[0].sys_cpu // 0' "$json_file" 2>/dev/null || echo "N/A")
    
    local bw_min_read=$(jq -r '.jobs[0].read.bw_min // 0' "$json_file" 2>/dev/null || echo "0")
    local bw_max_read=$(jq -r '.jobs[0].read.bw_max // 0' "$json_file" 2>/dev/null || echo "0")
    local bw_min_write=$(jq -r '.jobs[0].write.bw_min // 0' "$json_file" 2>/dev/null || echo "0")
    local bw_max_write=$(jq -r '.jobs[0].write.bw_max // 0' "$json_file" 2>/dev/null || echo "0")
    
    local slat_avg_read=$(jq -r '.jobs[0].read.slat_ns.mean // 0' "$json_file" 2>/dev/null || echo "0")
    local clat_avg_read=$(jq -r '.jobs[0].read.clat_ns.mean // 0' "$json_file" 2>/dev/null || echo "0")
    local slat_avg_write=$(jq -r '.jobs[0].write.slat_ns.mean // 0' "$json_file" 2>/dev/null || echo "0")
    local clat_avg_write=$(jq -r '.jobs[0].write.clat_ns.mean // 0' "$json_file" 2>/dev/null || echo "0")
    
    local ctx=$(jq -r '.jobs[0].ctx // 0' "$json_file" 2>/dev/null || echo "N/A")
    local majf=$(jq -r '.jobs[0].majf // 0' "$json_file" 2>/dev/null || echo "N/A")
    local minf=$(jq -r '.jobs[0].minf // 0' "$json_file" 2>/dev/null || echo "N/A")
    
    local iodepth_level=$(jq -r '.jobs[0].read.io_depth_level // "N/A"' "$json_file" 2>/dev/null || echo "N/A")
    
    # Convert nanoseconds to milliseconds
    lat_p99_read=$(awk "BEGIN {printf \"%.6f\", $lat_p99_read / 1000000}" 2>/dev/null || echo "$lat_p99_read")
    lat_p99_write=$(awk "BEGIN {printf \"%.6f\", $lat_p99_write / 1000000}" 2>/dev/null || echo "$lat_p99_write")
    lat_max_read=$(awk "BEGIN {printf \"%.6f\", $lat_max_read / 1000000}" 2>/dev/null || echo "$lat_max_read")
    lat_max_write=$(awk "BEGIN {printf \"%.6f\", $lat_max_write / 1000000}" 2>/dev/null || echo "$lat_max_write")
    
    slat_avg_read=$(awk "BEGIN {printf \"%.6f\", $slat_avg_read / 1000000}" 2>/dev/null || echo "$slat_avg_read")
    clat_avg_read=$(awk "BEGIN {printf \"%.6f\", $clat_avg_read / 1000000}" 2>/dev/null || echo "$clat_avg_read")
    slat_avg_write=$(awk "BEGIN {printf \"%.6f\", $slat_avg_write / 1000000}" 2>/dev/null || echo "$slat_avg_write")
    clat_avg_write=$(awk "BEGIN {printf \"%.6f\", $clat_avg_write / 1000000}" 2>/dev/null || echo "$clat_avg_write")
    
    # Calculate averages
    local lat_p99=$(awk "BEGIN {printf \"%.6f\", ($lat_p99_read + $lat_p99_write) / 2}" 2>/dev/null || echo "$lat_p99_read")
    local lat_max=$(awk "BEGIN {printf \"%.6f\", ($lat_max_read > $lat_max_write) ? $lat_max_read : $lat_max_write}" 2>/dev/null || echo "$lat_max_read")
    local bw_min=$(awk "BEGIN {printf \"%.2f\", ($bw_min_read < $bw_min_write) ? $bw_min_read : $bw_min_write}" 2>/dev/null || echo "$bw_min_read")
    local bw_max=$(awk "BEGIN {printf \"%.2f\", ($bw_max_read > $bw_max_write) ? $bw_max_read : $bw_max_write}" 2>/dev/null || echo "$bw_max_read")
    
    # Calculate slat and clat averages
    local slat=$(awk "BEGIN {printf \"%.6f\", ($slat_avg_read + $slat_avg_write) / 2}" 2>/dev/null || echo "$slat_avg_read")
    local clat=$(awk "BEGIN {printf \"%.6f\", ($clat_avg_read + $clat_avg_write) / 2}" 2>/dev/null || echo "$clat_avg_read")
    
    # Return all metrics as pipe-separated string
    echo "lat_p99=${lat_p99}|lat_max=${lat_max}|disk_util=${disk_util}|cpu_usr=${cpu_usr}|cpu_sys=${cpu_sys}|bw_min=${bw_min}|bw_max=${bw_max}|slat=${slat}|clat=${clat}|ctx=${ctx}|majf=${majf}|minf=${minf}|iodepth=${iodepth_level}"
}

# Threads test function
run_threads_test() {
    echo "=== Threads Performance Test ==="
    
    local temp_output_file="$TMP_DIR/vb_threads_${TIMESTAMP}.log"
    local threads="${THREADS_NUM:-0}"
    if [ "$threads" -eq 0 ]; then
        local cores=$(get_cpu_cores 2>/dev/null || echo "4")
        threads=$((cores * 4))
    fi
    local duration="$DURATION"
    
    # Only display test info in non-remote mode
    if [ "$REMOTE" != "true" ]; then
        echo "Starting threads test..."
        echo "  Threads: $threads, Duration: ${duration}s, yields: ${THREADS_YIELDS:-100}, locks: ${THREADS_LOCKS:-4}"
    fi
    
    run_command "sysbench threads \
        --threads=\"$threads\" \
        --thread-yields=\"${THREADS_YIELDS:-100}\" \
        --thread-locks=\"${THREADS_LOCKS:-4}\" \
        --time=\"${duration}\" \
        run" "$temp_output_file"
    
    # Parse result and display detailed output
    if [ "$DRY_RUN" != true ] && [ -f "$temp_output_file" ]; then
        # Display parsed output
        parse_threads_result "$temp_output_file"
        
        # Append to combined results file
        append_to_original "THREADS TEST RESULTS" "$temp_output_file"
    fi
    
    # Cleanup temp file
    rm -f "$temp_output_file"
    
    # Only display completion message in non-remote mode
    if [ "$REMOTE" != "true" ]; then
        echo "✓ Threads test completed"
    fi
}

# Parse threads result
parse_threads_result() {
    local result_file="$1"
    
    # Calculate events per second
    local total_events=$(grep "total number of events:" "$result_file" | awk '{print $NF}' || echo "0")
    local total_time=$(grep "total time:" "$result_file" | awk '{print $NF}' | tr -d 's' || echo "1")
    local events_per_sec=$(awk "BEGIN {printf \"%.2f\", $total_events / $total_time}" 2>/dev/null || echo "0")
    
    # Extract latency metrics
    local avg_latency=$(grep "avg:" "$result_file" | head -1 | awk '{print $NF}' | tr -d ',')
    local min_latency=$(grep -A5 "Latency (ms):" "$result_file" 2>/dev/null | grep "min:" | awk '{print $NF}' | tr -d ',' || echo "N/A")
    local max_latency=$(grep -A5 "Latency (ms):" "$result_file" 2>/dev/null | grep "max:" | awk '{print $NF}' | tr -d ',' || echo "N/A")
    local p95_latency=$(grep "95th percentile" "$result_file" | awk '{print $NF}')
    
    # Calculate Sum Latency: total_events * avg_latency
    local sum_latency=$(echo "$total_events" "$avg_latency" 2>/dev/null | awk '{if($2>0) printf "%.2f", $1 * $2; else print "N/A"}')
    
    # Extract threads fairness
    local threads_fairness_events=$(grep -A1 "Threads fairness:" "$result_file" | grep "events (avg/stddev):" | awk '{print $NF}')
    local threads_fairness_time=$(grep -A2 "Threads fairness:" "$result_file" | grep "execution time (avg/stddev):" | awk '{print $NF}')
    
    # Display detailed summary
    echo ""
    echo "Threads test summary:"
    echo "  total number of events: ${total_events}"
    echo "  total time: ${total_time}s"
    echo "  Events/sec: $events_per_sec"
    echo "  Avg Latency: ${avg_latency}ms"
    if [ -n "$min_latency" ] && [ "$min_latency" != "N/A" ]; then
        echo "  Min Latency: ${min_latency}ms"
    fi
    if [ -n "$max_latency" ] && [ "$max_latency" != "N/A" ]; then
        echo "  Max Latency: ${max_latency}ms"
    fi
    echo "  P95 Latency: ${p95_latency}ms"
    if [ -n "$sum_latency" ] && [ "$sum_latency" != "N/A" ]; then
        echo "  Sum Latency: ${sum_latency}ms"
    fi
    if [ -n "$threads_fairness_events" ] || [ -n "$threads_fairness_time" ]; then
        echo "  Threads fairness:"
        if [ -n "$threads_fairness_events" ]; then
            echo "    events (avg/stddev): $threads_fairness_events"
        fi
        if [ -n "$threads_fairness_time" ]; then
            echo "    execution time (avg/stddev): $threads_fairness_time"
        fi
    fi
}

