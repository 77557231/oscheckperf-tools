            elif [[ "$line" =~ "sum:" ]]; then
                current_threads_sum_lat=$(echo "$line" | awk '{print $NF}' | tr -d ',')
            elif echo "$line" | grep -q "events.*avg/stddev"; then
                current_threads_fairness=$(echo "$line" | awk '{print $3}')
            fi
        fi
    done < "$input_file"
    
    if [ "$in_section" = true ] && [ -n "$current_server_ip" ]; then
        current_eps=$(calc_eps "$current_events" "$current_time")
        printf "  %-18s %-12s %-12s %-12s %-14s %-14s %-16s %-14s\n" "$current_server_ip" "${current_eps:-N/A}" "${current_threads_avg_lat:-N/A}" "${current_threads_p95_lat:-N/A}" "${current_threads_min_lat:-N/A}" "${current_threads_max_lat:-N/A}" "${current_threads_sum_lat:-N/A}" "${current_threads_fairness:-N/A}" >> "$output_file"
    fi
}

